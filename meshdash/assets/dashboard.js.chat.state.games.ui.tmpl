    function normalizeActiveGameId(value) {{
      const token = String(value || "").trim().toLowerCase();
      if (token === "checkers") return "checkers";
      if (token === "chess") return "chess";
      if (token === "poker") return "poker";
      return "reversi";
    }}

    function syncGamesActivePanels() {{
      activeGameId = normalizeActiveGameId(activeGameId);
      const gameIds = ["reversi", "checkers", "chess", "poker"];
      for (const gameId of gameIds) {{
        const isActive = activeGameId === gameId;
        const selectBtn = document.getElementById(`games-select-${{gameId}}-btn`);
        if (selectBtn instanceof HTMLButtonElement) {{
          selectBtn.classList.toggle("is-active", isActive);
          selectBtn.setAttribute("aria-pressed", isActive ? "true" : "false");
        }}
        const sidePanel = document.getElementById(`games-side-${{gameId}}`);
        if (sidePanel instanceof HTMLElement) {{
          sidePanel.hidden = !isActive;
          sidePanel.classList.toggle("is-active", isActive);
        }}
        const mainPanel = document.getElementById(`games-main-${{gameId}}`);
        if (mainPanel instanceof HTMLElement) {{
          mainPanel.hidden = !isActive;
          mainPanel.classList.toggle("is-active", isActive);
        }}
      }}
    }}

    function renderGamesView(_state = latestState) {{
      syncReversiNetworkState(_state);
      syncBoardGameNetworkState("checkers", _state);
      syncBoardGameNetworkState("chess", _state);
      syncGamesActivePanels();
      if (activeGameId === "reversi") {{
        renderReversiLinkUi(_state);
        renderReversiBoard();
        renderReversiStatus();
        return;
      }}
      if (activeGameId === "checkers") {{
        renderBoardGameLinkUi("checkers", _state);
        refreshCheckersGame();
        renderCheckersBoard();
        renderCheckersStatus();
        return;
      }}
      if (activeGameId === "poker") {{
        renderPokerStatus();
        renderPokerTable();
        return;
      }}
      renderBoardGameLinkUi("chess", _state);
      refreshChessGame();
      renderChessBoard();
      renderChessStatus();
    }}

    function bindGamesControls() {{
      const reversiBtn = document.getElementById("games-select-reversi-btn");
      if (reversiBtn instanceof HTMLButtonElement && reversiBtn.dataset.bound !== "1") {{
        reversiBtn.dataset.bound = "1";
        reversiBtn.addEventListener("click", () => {{
          activeGameId = "reversi";
          if (activeLayoutView === "games") {{
            renderGamesView(latestState);
          }}
        }});
      }}
      const checkersBtn = document.getElementById("games-select-checkers-btn");
      if (checkersBtn instanceof HTMLButtonElement && checkersBtn.dataset.bound !== "1") {{
        checkersBtn.dataset.bound = "1";
        checkersBtn.addEventListener("click", () => {{
          activeGameId = "checkers";
          if (activeLayoutView === "games") {{
            renderGamesView(latestState);
          }}
        }});
      }}
      const chessBtn = document.getElementById("games-select-chess-btn");
      if (chessBtn instanceof HTMLButtonElement && chessBtn.dataset.bound !== "1") {{
        chessBtn.dataset.bound = "1";
        chessBtn.addEventListener("click", () => {{
          activeGameId = "chess";
          if (activeLayoutView === "games") {{
            renderGamesView(latestState);
          }}
        }});
      }}
      const pokerBtn = document.getElementById("games-select-poker-btn");
      if (pokerBtn instanceof HTMLButtonElement && pokerBtn.dataset.bound !== "1") {{
        pokerBtn.dataset.bound = "1";
        pokerBtn.addEventListener("click", () => {{
          activeGameId = "poker";
          if (activeLayoutView === "games") {{
            renderGamesView(latestState);
          }}
        }});
      }}
      const peerSelect = document.getElementById("reversi-peer-select");
      if (peerSelect instanceof HTMLSelectElement && peerSelect.dataset.bound !== "1") {{
        peerSelect.dataset.bound = "1";
        peerSelect.addEventListener("change", () => {{
          reversiPeerId = normalizeNodeId(peerSelect.value || "");
          if (activeLayoutView === "games") renderGamesView(latestState);
        }});
      }}
      const hostColorSelect = document.getElementById("reversi-host-color-select");
      if (hostColorSelect instanceof HTMLSelectElement && hostColorSelect.dataset.bound !== "1") {{
        hostColorSelect.dataset.bound = "1";
        hostColorSelect.addEventListener("change", () => {{
          reversiHostColorPreference = parseReversiColor(hostColorSelect.value, reversiPiece.black);
          if (activeLayoutView === "games") renderGamesView(latestState);
        }});
      }}
      const hostBtn = document.getElementById("reversi-host-btn");
      if (hostBtn instanceof HTMLButtonElement && hostBtn.dataset.bound !== "1") {{
        hostBtn.dataset.bound = "1";
        hostBtn.addEventListener("click", () => {{
          void hostReversiMatch();
        }});
      }}
      const acceptBtn = document.getElementById("reversi-accept-btn");
      if (acceptBtn instanceof HTMLButtonElement && acceptBtn.dataset.bound !== "1") {{
        acceptBtn.dataset.bound = "1";
        acceptBtn.addEventListener("click", () => {{
          void acceptReversiInvite();
        }});
      }}
      const declineBtn = document.getElementById("reversi-decline-btn");
      if (declineBtn instanceof HTMLButtonElement && declineBtn.dataset.bound !== "1") {{
        declineBtn.dataset.bound = "1";
        declineBtn.addEventListener("click", () => {{
          declineReversiInvite();
        }});
      }}
      const disconnectBtn = document.getElementById("reversi-disconnect-btn");
      if (disconnectBtn instanceof HTMLButtonElement && disconnectBtn.dataset.bound !== "1") {{
        disconnectBtn.dataset.bound = "1";
        disconnectBtn.addEventListener("click", () => {{
          void disconnectReversiMatch();
        }});
      }}
      for (const gameId of ["checkers", "chess"]) {{
        const refs = boardGameRefs(gameId);
        const peerSelectEl = document.getElementById(`${{refs.id}}-peer-select`);
        if (peerSelectEl instanceof HTMLSelectElement && peerSelectEl.dataset.bound !== "1") {{
          peerSelectEl.dataset.bound = "1";
          peerSelectEl.addEventListener("change", () => {{
            refs.setPeerId(normalizeNodeId(peerSelectEl.value || ""));
            if (activeLayoutView === "games") renderGamesView(latestState);
          }});
        }}
        const colorSelectEl = document.getElementById(`${{refs.id}}-host-color-select`);
        if (colorSelectEl instanceof HTMLSelectElement && colorSelectEl.dataset.bound !== "1") {{
          colorSelectEl.dataset.bound = "1";
          colorSelectEl.addEventListener("change", () => {{
            refs.setHostColorPreference(colorSelectEl.value || "");
            if (activeLayoutView === "games") renderGamesView(latestState);
          }});
        }}
        const hostBtnEl = document.getElementById(`${{refs.id}}-host-btn`);
        if (hostBtnEl instanceof HTMLButtonElement && hostBtnEl.dataset.bound !== "1") {{
          hostBtnEl.dataset.bound = "1";
          hostBtnEl.addEventListener("click", () => {{
            void hostBoardGameMatch(gameId);
          }});
        }}
        const acceptBtnEl = document.getElementById(`${{refs.id}}-accept-btn`);
        if (acceptBtnEl instanceof HTMLButtonElement && acceptBtnEl.dataset.bound !== "1") {{
          acceptBtnEl.dataset.bound = "1";
          acceptBtnEl.addEventListener("click", () => {{
            void acceptBoardGameInvite(gameId);
          }});
        }}
        const declineBtnEl = document.getElementById(`${{refs.id}}-decline-btn`);
        if (declineBtnEl instanceof HTMLButtonElement && declineBtnEl.dataset.bound !== "1") {{
          declineBtnEl.dataset.bound = "1";
          declineBtnEl.addEventListener("click", () => {{
            declineBoardGameInvite(gameId);
          }});
        }}
        const disconnectBtnEl = document.getElementById(`${{refs.id}}-disconnect-btn`);
        if (disconnectBtnEl instanceof HTMLButtonElement && disconnectBtnEl.dataset.bound !== "1") {{
          disconnectBtnEl.dataset.bound = "1";
          disconnectBtnEl.addEventListener("click", () => {{
            void disconnectBoardGameMatch(gameId);
          }});
        }}
        const inviteList = document.getElementById(`${{refs.id}}-invite-list`);
        if (inviteList instanceof HTMLElement && inviteList.dataset.bound !== "1") {{
          inviteList.dataset.bound = "1";
          inviteList.addEventListener("click", (event) => {{
            const target = event.target;
            if (!(target instanceof Element)) return;
            const row = target.closest("button.reversi-invite-item");
            if (!(row instanceof HTMLButtonElement)) return;
            const fromId = normalizeNodeId(row.dataset.fromId || "");
            const sessionId = String(row.dataset.sessionId || "").trim().toLowerCase();
            if (!isCanonicalNodeId(fromId) || !sessionId) return;
            refs.setPeerId(fromId);
            refs.setSelectedInviteKey(boardGameInviteKey(fromId, sessionId));
            if (activeLayoutView === "games") {{
              renderGamesView(latestState);
            }}
          }});
        }}
      }}
      const newGameBtn = document.getElementById("reversi-new-game-btn");
      if (newGameBtn instanceof HTMLButtonElement && newGameBtn.dataset.bound !== "1") {{
        newGameBtn.dataset.bound = "1";
        newGameBtn.addEventListener("click", () => {{
          startNewReversiGame();
        }});
      }}
      const checkersNewGameBtn = document.getElementById("checkers-new-game-btn");
      if (checkersNewGameBtn instanceof HTMLButtonElement && checkersNewGameBtn.dataset.bound !== "1") {{
        checkersNewGameBtn.dataset.bound = "1";
        checkersNewGameBtn.addEventListener("click", () => {{
          startNewCheckersGame();
        }});
      }}
      const chessNewGameBtn = document.getElementById("chess-new-game-btn");
      if (chessNewGameBtn instanceof HTMLButtonElement && chessNewGameBtn.dataset.bound !== "1") {{
        chessNewGameBtn.dataset.bound = "1";
        chessNewGameBtn.addEventListener("click", () => {{
          startNewChessGame();
        }});
      }}
      const restartPokerFromControls = () => {{
        const playerCount = getPokerPlayerCountFromControl();
        const rules = getPokerRulesFromControls();
        startNewPokerGame({{
          player_count: playerCount,
          starting_stack: rules.starting_stack,
          ante: rules.ante,
          small_blind: rules.small_blind,
          big_blind: rules.big_blind,
          auto_deal: true,
        }});
      }};
      const pokerPlayerCountSelect = document.getElementById("poker-player-count-select");
      if (pokerPlayerCountSelect instanceof HTMLSelectElement && pokerPlayerCountSelect.dataset.bound !== "1") {{
        pokerPlayerCountSelect.dataset.bound = "1";
        pokerPlayerCountSelect.addEventListener("change", () => {{
          restartPokerFromControls();
        }});
      }}
      for (const inputId of ["poker-starting-stack-input", "poker-ante-input", "poker-small-blind-input", "poker-big-blind-input"]) {{
        const inputEl = document.getElementById(inputId);
        if (inputEl instanceof HTMLInputElement && inputEl.dataset.bound !== "1") {{
          inputEl.dataset.bound = "1";
          inputEl.addEventListener("change", () => {{
            restartPokerFromControls();
          }});
        }}
      }}
      const pokerNewTableBtn = document.getElementById("poker-new-table-btn");
      if (pokerNewTableBtn instanceof HTMLButtonElement && pokerNewTableBtn.dataset.bound !== "1") {{
        pokerNewTableBtn.dataset.bound = "1";
        pokerNewTableBtn.addEventListener("click", () => {{
          restartPokerFromControls();
        }});
      }}
      const pokerNextPhaseBtn = document.getElementById("poker-next-phase-btn");
      if (pokerNextPhaseBtn instanceof HTMLButtonElement && pokerNextPhaseBtn.dataset.bound !== "1") {{
        pokerNextPhaseBtn.dataset.bound = "1";
        pokerNextPhaseBtn.addEventListener("click", () => {{
          advancePokerPhase();
        }});
      }}
      const pokerCheckCallBtn = document.getElementById("poker-check-call-btn");
      if (pokerCheckCallBtn instanceof HTMLButtonElement && pokerCheckCallBtn.dataset.bound !== "1") {{
        pokerCheckCallBtn.dataset.bound = "1";
        pokerCheckCallBtn.addEventListener("click", () => {{
          const state = ensurePokerState();
          const seat = pokerCurrentSeat();
          const callAmount = seat ? pokerCurrentCallAmount(state, seat) : 0;
          applyPokerBettingAction(callAmount > 0 ? "call" : "check");
        }});
      }}
      const pokerBetRaiseBtn = document.getElementById("poker-bet-raise-btn");
      if (pokerBetRaiseBtn instanceof HTMLButtonElement && pokerBetRaiseBtn.dataset.bound !== "1") {{
        pokerBetRaiseBtn.dataset.bound = "1";
        pokerBetRaiseBtn.addEventListener("click", () => {{
          const state = ensurePokerState();
          const action = normalizePokerChipAmount(state.current_bet, 0, 0, Number.MAX_SAFE_INTEGER) > 0 ? "raise" : "bet";
          applyPokerBettingAction(action, getPokerBetAmountFromControl(Math.max(1, normalizePokerChipAmount(state.big_blind, 1, 1, Number.MAX_SAFE_INTEGER))));
        }});
      }}
      const pokerFoldBtn = document.getElementById("poker-fold-btn");
      if (pokerFoldBtn instanceof HTMLButtonElement && pokerFoldBtn.dataset.bound !== "1") {{
        pokerFoldBtn.dataset.bound = "1";
        pokerFoldBtn.addEventListener("click", () => {{
          applyPokerBettingAction("fold");
        }});
      }}
      const pokerBetAmountInput = document.getElementById("poker-bet-amount-input");
      if (pokerBetAmountInput instanceof HTMLInputElement && pokerBetAmountInput.dataset.bound !== "1") {{
        pokerBetAmountInput.dataset.bound = "1";
        pokerBetAmountInput.addEventListener("keydown", (event) => {{
          if (event.key !== "Enter") return;
          event.preventDefault();
          const state = ensurePokerState();
          const action = normalizePokerChipAmount(state.current_bet, 0, 0, Number.MAX_SAFE_INTEGER) > 0 ? "raise" : "bet";
          applyPokerBettingAction(action, getPokerBetAmountFromControl(Math.max(1, normalizePokerChipAmount(state.big_blind, 1, 1, Number.MAX_SAFE_INTEGER))));
        }});
      }}
      const boardEl = document.getElementById("reversi-board");
      if (boardEl instanceof HTMLElement && boardEl.dataset.bound !== "1") {{
        boardEl.dataset.bound = "1";
        boardEl.addEventListener("click", (event) => {{
          const target = event.target;
          if (!(target instanceof Element)) return;
          const button = target.closest("button.reversi-cell");
          if (!(button instanceof HTMLButtonElement)) return;
          const row = Math.trunc(Number(button.dataset.row) || 0);
          const col = Math.trunc(Number(button.dataset.col) || 0);
          applyReversiMove(row, col);
        }});
      }}
      const checkersBoardEl = document.getElementById("checkers-board");
      if (checkersBoardEl instanceof HTMLElement && checkersBoardEl.dataset.bound !== "1") {{
        checkersBoardEl.dataset.bound = "1";
        checkersBoardEl.addEventListener("click", (event) => {{
          const target = event.target;
          if (!(target instanceof Element)) return;
          const button = target.closest("button.checkers-cell");
          if (!(button instanceof HTMLButtonElement)) return;
          const row = Math.trunc(Number(button.dataset.row) || 0);
          const col = Math.trunc(Number(button.dataset.col) || 0);
          handleCheckersBoardClick(row, col);
        }});
      }}
      const chessBoardEl = document.getElementById("chess-board");
      if (chessBoardEl instanceof HTMLElement && chessBoardEl.dataset.bound !== "1") {{
        chessBoardEl.dataset.bound = "1";
        chessBoardEl.addEventListener("click", (event) => {{
          const target = event.target;
          if (!(target instanceof Element)) return;
          const button = target.closest("button.chess-cell");
          if (!(button instanceof HTMLButtonElement)) return;
          const row = Math.trunc(Number(button.dataset.row) || 0);
          const col = Math.trunc(Number(button.dataset.col) || 0);
          handleChessBoardClick(row, col);
        }});
      }}
      const pokerTableEl = document.getElementById("poker-table");
      if (pokerTableEl instanceof HTMLElement && pokerTableEl.dataset.bound !== "1") {{
        pokerTableEl.dataset.bound = "1";
        pokerTableEl.addEventListener("click", (event) => {{
          const target = event.target;
          if (!(target instanceof Element)) return;
          const button = target.closest("button.poker-card");
          if (!(button instanceof HTMLButtonElement)) return;
          const seat = normalizePokerIndex(button.dataset.seat, -1);
          const card = normalizePokerIndex(button.dataset.card, -1);
          togglePokerDiscard(seat, card);
        }});
      }}
      const inviteListEl = document.getElementById("reversi-invite-list");
      if (inviteListEl instanceof HTMLElement && inviteListEl.dataset.bound !== "1") {{
        inviteListEl.dataset.bound = "1";
        inviteListEl.addEventListener("click", (event) => {{
          const target = event.target;
          if (!(target instanceof Element)) return;
          const row = target.closest("button.reversi-invite-item");
          if (!(row instanceof HTMLButtonElement)) return;
          const fromId = normalizeNodeId(row.dataset.fromId || "");
          const sessionId = String(row.dataset.sessionId || "").trim().toLowerCase();
          if (!isCanonicalNodeId(fromId) || !sessionId) return;
          reversiPeerId = fromId;
          reversiSelectedInviteKey = reversiInviteKey(fromId, sessionId);
          if (activeLayoutView === "games") {{
            renderGamesView(latestState);
          }}
        }});
      }}
    }}

