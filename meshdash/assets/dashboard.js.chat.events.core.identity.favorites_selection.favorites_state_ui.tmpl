          const entries = Array.isArray(parsed)
            ? parsed
            : (parsed && typeof parsed === "object" ? Object.entries(parsed) : []);
          for (const entry of entries) {{
            if (!Array.isArray(entry) || entry.length < 2) continue;
            const nodeId = normalizeNodeId(entry[0]);
            const presetId = normalizeNodeTagPresetId(entry[1], "");
            if (!isSelectableNodeId(nodeId)) continue;
            if (!presetId || !nodeTagPresetsById.has(presetId)) continue;
            nodeTagByNodeId.set(nodeId, presetId);
