    function loadFavoriteNodes() {{
      favoriteNodeIds.clear();
      try {{
        const raw = window.localStorage.getItem(favoritesStorageKey);
        if (!raw) return;
        const parsed = JSON.parse(raw);
        if (!Array.isArray(parsed)) return;
        for (const entry of parsed) {{
          const nodeId = normalizeNodeId(entry);
          if (isSelectableNodeId(nodeId)) {{
            favoriteNodeIds.add(nodeId);
          }}
        }}
      }} catch (_err) {{
      }}
    }}

    function persistFavoriteNodes() {{
      try {{
        const ids = Array.from(favoriteNodeIds).slice(0, 2000);
        window.localStorage.setItem(favoritesStorageKey, JSON.stringify(ids));
      }} catch (_err) {{
      }}
    }}

    function loadMutedNodes() {{
      mutedNodeIds.clear();
      try {{
        const raw = window.localStorage.getItem(mutedNodesStorageKey);
        if (!raw) return;
        const parsed = JSON.parse(raw);
        if (!Array.isArray(parsed)) return;
        for (const entry of parsed) {{
          const nodeId = normalizeNodeId(entry);
          if (isSelectableNodeId(nodeId) && !isSelfNodeId(nodeId)) {{
            mutedNodeIds.add(nodeId);
          }}
        }}
      }} catch (_err) {{
      }}
    }}

    function persistMutedNodes() {{
      try {{
        const ids = Array.from(mutedNodeIds).slice(0, 2000);
        window.localStorage.setItem(mutedNodesStorageKey, JSON.stringify(ids));
      }} catch (_err) {{
      }}
    }}

    function normalizeNodeNoteText(rawValue, maxChars = 1200) {{
      let text = String(rawValue == null ? "" : rawValue)
        .replace(/\r\n?/g, "\n")
        .replace(/\u0000/g, "");
      const cap = Math.max(80, Math.trunc(Number(maxChars) || 1200));
      if (text.length > cap) {{
        text = text.slice(0, cap);
      }}
      if (!text.trim()) {{
        return "";
      }}
      return text.trim();
    }}

    function loadNodeNotes() {{
      nodeNotesById.clear();
      try {{
        const raw = window.localStorage.getItem(nodeNotesStorageKey);
        if (!raw) return;
        const parsed = JSON.parse(raw);
        const entries = Array.isArray(parsed)
          ? parsed
          : (parsed && typeof parsed === "object" ? Object.entries(parsed) : []);
        for (const item of entries) {{
          let rawNodeId = "";
          let rawEntry = null;
          if (Array.isArray(item)) {{
            rawNodeId = String(item[0] || "");
            rawEntry = item[1];
          }} else {{
            continue;
          }}
          const nodeId = normalizeNodeId(rawNodeId);
          if (!isSelectableNodeId(nodeId)) continue;
          const rawNote = (
            typeof rawEntry === "string"
              ? rawEntry
              : (rawEntry && (rawEntry.note ?? rawEntry.text))
          );
          const note = normalizeNodeNoteText(rawNote);
          if (!note) continue;
          const updatedRaw = Number(rawEntry && (rawEntry.updated_unix ?? rawEntry.updatedUnix));
          const updatedUnix = Number.isFinite(updatedRaw) && updatedRaw > 0
            ? Math.trunc(updatedRaw)
            : 0;
          nodeNotesById.set(nodeId, {{
            note,
            updatedUnix,
          }});
        }}
      }} catch (_err) {{
      }}
    }}

    function persistNodeNotes() {{
      try {{
        const payload = {{}};
        let count = 0;
        for (const [nodeId, rawEntry] of nodeNotesById.entries()) {{
          if (count >= 4000) break;
          const cleanNodeId = normalizeNodeId(nodeId);
          if (!isSelectableNodeId(cleanNodeId)) continue;
          const note = normalizeNodeNoteText(rawEntry && rawEntry.note);
          if (!note) continue;
          const updatedRaw = Number(rawEntry && rawEntry.updatedUnix);
          const updatedUnix = Number.isFinite(updatedRaw) && updatedRaw > 0
            ? Math.trunc(updatedRaw)
            : Math.floor(Date.now() / 1000);
          payload[cleanNodeId] = {{
            note,
            updated_unix: updatedUnix,
          }};
          count += 1;
        }}
        window.localStorage.setItem(nodeNotesStorageKey, JSON.stringify(payload));
      }} catch (_err) {{
      }}
    }}

    function nodeNoteEntry(nodeId) {{
      const normalized = normalizeNodeId(nodeId);
      if (!isSelectableNodeId(normalized)) return null;
      const rawEntry = nodeNotesById.get(normalized);
      if (!rawEntry || typeof rawEntry !== "object") return null;
      const note = normalizeNodeNoteText(rawEntry.note);
      if (!note) return null;
      const updatedRaw = Number(rawEntry.updatedUnix);
      const updatedUnix = Number.isFinite(updatedRaw) && updatedRaw > 0
        ? Math.trunc(updatedRaw)
        : 0;
      return {{
        nodeId: normalized,
        note,
        updatedUnix,
      }};
    }}

    function saveNodeNote(nodeId, rawNote) {{
      const normalized = normalizeNodeId(nodeId);
      if (!isSelectableNodeId(normalized)) {{
        return {{ ok: false, nodeId: normalized, note: "", updatedUnix: 0, cleared: false }};
      }}
      const note = normalizeNodeNoteText(rawNote);
      if (!note) {{
        nodeNotesById.delete(normalized);
        persistNodeNotes();
        return {{ ok: true, nodeId: normalized, note: "", updatedUnix: 0, cleared: true }};
      }}
      const updatedUnix = Math.floor(Date.now() / 1000);
      nodeNotesById.set(normalized, {{
        note,
        updatedUnix,
      }});
      persistNodeNotes();
      return {{ ok: true, nodeId: normalized, note, updatedUnix, cleared: false }};
    }}

    function isFavoriteNode(nodeId) {{
      const normalized = normalizeNodeId(nodeId);
      return isSelectableNodeId(normalized) && favoriteNodeIds.has(normalized);
    }}

    function isMutedNode(nodeId) {{
      const normalized = normalizeNodeId(nodeId);
      return isSelectableNodeId(normalized) && mutedNodeIds.has(normalized);
    }}

    function favoriteToggleButtonHtml(nodeId, extraClass = "") {{
      const normalized = normalizeNodeId(nodeId);
      if (!isSelectableNodeId(normalized)) return "";
      const active = favoriteNodeIds.has(normalized);
      const title = active ? "Remove from saved nodes" : "Save node";
      return `<button type="button" class="favorite-toggle-btn ${{extraClass}}${{active ? " active" : ""}}" data-node-id="${{escAttr(normalized)}}" title="${{title}}" aria-label="${{title}}" aria-pressed="${{active ? "true" : "false"}}"><span class="favorite-toggle-icon">${{active ? "★" : "☆"}}</span></button>`;
    }}

    function muteToggleButtonHtml(nodeId, extraClass = "") {{
      const normalized = normalizeNodeId(nodeId);
      if (!isSelectableNodeId(normalized) || isSelfNodeId(normalized)) return "";
      const active = mutedNodeIds.has(normalized);
      const title = active ? "Unmute this user in chat feed" : "Mute this user in chat feed";
      return `<button type="button" class="mute-toggle-btn ${{extraClass}}${{active ? " active" : ""}}" data-node-id="${{escAttr(normalized)}}" title="${{title}}" aria-label="${{title}}" aria-pressed="${{active ? "true" : "false"}}"><span class="mute-toggle-icon">${{active ? "🔇" : "🔊"}}</span></button>`;
    }}

    function renderSavedRailStatus() {{
      const count = Math.max(0, favoriteNodeIds.size);
      const explicitSelectedId = isSelectableNodeId(selectedNodeId) ? normalizeNodeId(selectedNodeId) : "";
      const selectedId = activeLayoutView === "saved"
        ? resolveSavedViewNodeId(latestState)
        : explicitSelectedId;
      const usingLocalFallback = activeLayoutView === "saved" && !explicitSelectedId && !!selectedId;
      const selectedName = selectedId
        ? (
            usingLocalFallback
              ? (resolveSavedViewNodeName(latestState, selectedId) || selectedId)
              : (resolveSelectedNodeName() || selectedId)
          )
        : "";
      const btn = document.querySelector('.teams-rail .rail-btn[data-view="saved"]');
      if (btn instanceof HTMLButtonElement) {{
        if (!btn.dataset.baseTitle) {{
          btn.dataset.baseTitle = btn.getAttribute("title") || "Node details and saved nodes";
        }}
        btn.textContent = "Node";
        const baseTitle = btn.dataset.baseTitle || "Node details and saved nodes";
        if (selectedId) {{
          btn.title = usingLocalFallback
            ? `${{baseTitle}}. Showing local node: ${{selectedName}}.`
            : `${{baseTitle}}. Selected: ${{selectedName}}.`;
        }} else {{
          btn.title = count > 0
            ? `${{baseTitle}}. ${{count}} saved node${{count === 1 ? "" : "s"}}.`
            : `${{baseTitle}}. No saved nodes yet.`;
        }}
        btn.setAttribute("aria-label", btn.title);
      }}

      const favMenuBtn = document.getElementById("favorite-menu-toggle-btn");
      if (favMenuBtn instanceof HTMLButtonElement) {{
        favMenuBtn.classList.toggle("has-saved", count > 0);
        favMenuBtn.classList.toggle("has-selected", !!selectedId);
        const title = selectedId
          ? (
              usingLocalFallback
                ? `Showing local node: ${{selectedName}}. Open node menu.`
                : `Selected node: ${{selectedName}}. Open node menu.`
            )
          : (count > 0
            ? `${{count}} saved node${{count === 1 ? "" : "s"}}. Open node menu.`
            : "No node selected. Open node menu.");
        favMenuBtn.title = title;
        favMenuBtn.setAttribute("aria-label", title);
      }}
    }}
