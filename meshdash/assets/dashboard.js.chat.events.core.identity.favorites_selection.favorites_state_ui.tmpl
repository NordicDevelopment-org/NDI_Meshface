    function nodeVisibilityPacketPasses(packetEntry) {{
      if (!nodeVisibilityListsActive()) return true;
      const summary = (packetEntry && typeof packetEntry.summary === "object") ? packetEntry.summary : packetEntry;
      const packet = (packetEntry && typeof packetEntry.packet === "object") ? packetEntry.packet : packetEntry;
      const fromId = normalizeNodeId(
        (summary && (summary.from_id ?? summary.fromId ?? summary.from))
        ?? (packet && (packet.from_id ?? packet.fromId ?? packet.from))
