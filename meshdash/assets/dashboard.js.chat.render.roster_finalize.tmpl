      if (activeChatChannel === "all" && participants.size === 0) {{
        for (const msg of baseMessages) {{
          if (classifyMessageChannel(msg) !== "all") continue;
          touchNodeById(msg.from, latestUnixTimestamp(msg.rx_time, msg.captured_at));
        }}
      }}
      if (activeChatChannel === "direct") {{
        for (const peerId of manualDirectPeerIds) {{
          if (!isCanonicalNodeId(peerId)) continue;
          if (isCanonicalNodeId(localNodeId) && peerId === localNodeId) continue;
          const snapshot = resolveChatNodeFreshness(peerId);
          const node = snapshot.node;
          const name = preferredNodeName(node) || nodeNameCache.get(peerId) || peerId;
          const existing = participants.get(peerId);
          if (!existing) {{
            participants.set(peerId, {{
              id: peerId,
              name,
              status: snapshot.status,
              lastSeenUnix: snapshot.lastSeenUnix,
              lastMessageUnix: null,
              p2pPinned: true,
            }});
            continue;
          }}
          existing.p2pPinned = true;
          if (name && name !== "Unknown node") {{
            existing.name = name;
          }}
          existing.lastSeenUnix = latestUnixTimestamp(existing.lastSeenUnix, snapshot.lastSeenUnix);
          existing.status = freshnessStatus(existing.lastSeenUnix, nowUnix);
        }}
      }}
      if (activeChatChannel === "direct" && isCanonicalNodeId(selectedNodeId)) {{
        touchNodeById(selectedNodeId);
      }}
      for (const node of nodes) {{
        touchNodeById(node && node.id);
      }}
      if (historyCapsById && typeof historyCapsById.keys === "function") {{
        for (const nodeId of historyCapsById.keys()) {{
          touchNodeById(nodeId);
        }}
      }}
      if (favoriteNodeIds && typeof favoriteNodeIds.forEach === "function") {{
        favoriteNodeIds.forEach((nodeId) => {{
          touchNodeById(nodeId);
        }});
      }}
      if (nodeNotesById && typeof nodeNotesById.forEach === "function") {{
        nodeNotesById.forEach((_entry, nodeId) => {{
          touchNodeById(nodeId);
        }});
      }}
      const feed = document.getElementById("chat-feed");
      if (feed) {{
        const emptyText = (activeChatChannel === "direct" && !isCanonicalNodeId(directSelectedId))
          ? "Select a user to view peer-to-peer messages."
          : `No ${{channelLabel(activeChatChannel).toLowerCase()}} messages yet.`;
        closeReactionPopover(true);
        feed.innerHTML = feedItems.length > 0
          ? feedItems.join("")
          : `<div class="chat-feed-empty">${{emptyText}}</div>`;
      }}
      renderChatChangeSummary(nowUnix);

      const rosterQuery = globalNodeSearchQuery();
      const roomList = document.getElementById("chat-room-list");
      const rosterAll = Array.from(participants.values())
        .sort((a, b) => {{
          const pinDiff = Number(!!b.p2pPinned) - Number(!!a.p2pPinned);
          if (pinDiff !== 0) return pinDiff;
          const rankDiff = statusRank(a.status) - statusRank(b.status);
          if (rankDiff !== 0) return rankDiff;
          const aTime = a.lastMessageUnix || 0;
          const bTime = b.lastMessageUnix || 0;
          if (aTime !== bTime) return bTime - aTime;
          return String(a.name || a.id).localeCompare(String(b.name || b.id));
        }});
      const roster = rosterAll;
      // Preserve the full (unfiltered) roster so tickFreshnessUI() can compute canonical
      // online/aging/stale counts even when the user is search-filtering the roster DOM.
      chatRosterModel = rosterAll;
      const rosterFiltered = roster.filter((item) => (
        matchesIdOrNameQuery(item.id, item.name, rosterQuery, {{
          node: nodesById.get(normalizeNodeId(item.id)),
        }})
      ));
      const buildNodePacketSparklinePath = (bucketValuesRaw, width = 56, height = 12) => {{
        const buckets = Array.isArray(bucketValuesRaw)
          ? bucketValuesRaw.map((value) => Math.max(0, Number(value) || 0))
          : [];
        const plotWidth = Math.max(12, Number(width) || 56);
        const plotHeight = Math.max(8, Number(height) || 12);
        const baselineY = Math.max(1, plotHeight - 1);
        if (buckets.length <= 0) {{
          return `M 0 ${{baselineY.toFixed(2)}} L ${{plotWidth.toFixed(2)}} ${{baselineY.toFixed(2)}}`;
        }}
        const maxValue = Math.max(0, ...buckets);
        const padY = 1;
        const usableHeight = Math.max(2, plotHeight - (padY * 2));
        const points = buckets.map((value, idx) => {{
          const x = buckets.length <= 1
            ? (plotWidth / 2)
            : ((idx / Math.max(1, buckets.length - 1)) * plotWidth);
          const y = maxValue > 0
            ? (padY + ((maxValue - value) / maxValue) * usableHeight)
            : baselineY;
          return {{
            x,
            y,
          }};
        }});
        if (typeof buildSmoothSvgPath === "function") {{
          const smoothPath = buildSmoothSvgPath(points, 0.2);
          if (smoothPath) {{
            return smoothPath;
          }}
        }}
        return points.map((point, idx) => (
          `${{idx === 0 ? "M" : "L"}} ${{point.x.toFixed(2)}} ${{point.y.toFixed(2)}}`
        )).join(" ");
      }};
      const classifyNodePacketSparklineTrend = (bucketValuesRaw) => {{
        const buckets = Array.isArray(bucketValuesRaw)
          ? bucketValuesRaw.map((value) => Math.max(0, Number(value) || 0))
          : [];
        if (buckets.length <= 1) return "trend-flat";
        const segmentSize = Math.max(1, Math.trunc(buckets.length / 3));
        const startSlice = buckets.slice(0, segmentSize);
        const endSlice = buckets.slice(-segmentSize);
        const avg = (rows) => {{
          const list = Array.isArray(rows) ? rows : [];
          if (list.length === 0) return 0;
          const total = list.reduce((sum, value) => sum + (Number(value) || 0), 0);
          return total / Math.max(1, list.length);
        }};
        const startAvg = avg(startSlice);
        const endAvg = avg(endSlice);
        const delta = endAvg - startAvg;
        const threshold = Math.max(0.5, Math.max(...buckets, 0) * 0.15);
        if (delta > threshold) return "trend-up";
        if (delta < -threshold) return "trend-down";
        return "trend-flat";
      }};
      const onlineCount = rosterAll.filter((item) => item.status === "online").length;
      const warnCount = rosterAll.filter((item) => item.status === "warn").length;
      const staleCount = rosterAll.filter((item) => item.status === "stale").length;
      if (roomList) {{
        roomList.innerHTML = rosterFiltered.length > 0
          ? rosterFiltered.map((item) => (
              (() => {{
                try {{
                const nodeId = normalizeNodeId(item.id);
                const snapshot = resolveChatNodeFreshness(nodeId);
                const node = nodesById.get(nodeId);
                const caps = (
                  historyCapsById && typeof historyCapsById.get === "function"
                    ? historyCapsById.get(nodeId)
                    : null
                );
                const statusKey = normalizeFreshnessKey(item.status);
                const statusLabel = statusKey === "online"
                  ? "Online"
                  : (statusKey === "warn" ? "Aging" : (statusKey === "stale" ? "Stale" : "Unknown"));
                const lastSeenText = Number.isFinite(snapshot.lastSeenUnix)
                  ? `${{formatLocalChatTime(snapshot.lastSeenUnix, "n/a", nowUnix)}} (${{formatIdleAge(snapshot.lastSeenUnix, nowUnix)}})`
                  : "n/a";
                const roleText = String((node && node.role) || "").trim() || "n/a";
                const hardwareText = String((node && (node.hardware_model || node.hardware)) || "").trim() || "n/a";
                const batteryRaw = Number(
                  (node && node.battery_level != null)
                    ? node.battery_level
                    : (caps && caps.battery_level)
                );
                const batteryText = Number.isFinite(batteryRaw)
                  ? `${{Math.max(0, Math.min(100, Math.round(batteryRaw)))}}%`
                  : "n/a";
                const hopsRaw = Number(
                  (node && node.hops_away != null)
                    ? node.hops_away
                    : (caps && caps.last_hops)
                );
                const hopsText = Number.isFinite(hopsRaw) && hopsRaw >= 0
                  ? String(Math.trunc(hopsRaw))
                  : "n/a";
                const hasLivePosition = (
                  node
                  && Number.isFinite(Number(node.lat))
                  && Number.isFinite(Number(node.lon))
                );
                const gpsText = hasLivePosition
                  ? `${{Number(node.lat).toFixed(5)}}, ${{Number(node.lon).toFixed(5)}}`
                  : ((caps && caps.has_position === true) ? "history only" : "n/a");
                const noteEntry = (typeof nodeNoteEntry === "function") ? nodeNoteEntry(nodeId) : null;
                const noteText = String((noteEntry && noteEntry.note) || "").trim();
                const idleText = Number.isFinite(snapshot.lastSeenUnix)
                  ? formatIdleAge(snapshot.lastSeenUnix, nowUnix)
                  : "n/a";
                const packetTicker = (
                  packetTickerByNode instanceof Map
                    ? (packetTickerByNode.get(nodeId) || null)
                    : null
                );
                const packetSparkline = (
                  packetSparklineByNode instanceof Map
                    ? (packetSparklineByNode.get(nodeId) || null)
                    : null
                );
                const packetSparklineBuckets = Array.isArray(packetSparkline && packetSparkline.buckets)
                  ? packetSparkline.buckets
                  : [];
                const packetSparklineWindowSec = Math.max(
                  60,
                  Math.trunc(Number(packetSparkline && packetSparkline.windowSec) || 3600)
                );
                const packetSparklineWindowMin = Math.max(1, Math.round(packetSparklineWindowSec / 60));
                const packetSparklinePath = buildNodePacketSparklinePath(packetSparklineBuckets, 56, 12);
                const packetSparklineTrend = classifyNodePacketSparklineTrend(packetSparklineBuckets);
                const packetTotal = Math.max(0, Math.trunc(Number(packetTicker && packetTicker.total) || 0));
                const packetRecent5m = Math.max(0, Math.trunc(Number(packetTicker && packetTicker.recent5m) || 0));
                const packetLastUnix = Number(packetTicker && packetTicker.lastPacketUnix);
                const packetLastText = (
                  Number.isFinite(packetLastUnix) && packetLastUnix > 0
                    ? `${{formatLocalChatTime(packetLastUnix, "n/a", nowUnix)}} (${{formatIdleAge(packetLastUnix, nowUnix)}})`
                    : "n/a"
                );
                const packetTickerDetail = packetTotal > 0
                  ? `Packets: ${{packetRecent5m}} in 5m, ${{packetTotal}} total, last ${{packetLastText}}. Trend window: ${{packetSparklineWindowMin}}m`
                  : "Packets: none in current packet buffer";
                const idleLine = `Idle: ${{idleText}}`;
                const tooltipLines = [
                  `${{item.name}} (${{item.id}})`,
                  `Status: ${{statusLabel}}`,
                  `Last seen: ${{lastSeenText}}`,
                  idleLine,
                  packetTickerDetail,
                  `Role: ${{roleText}}`,
                  `Hardware: ${{hardwareText}}`,
                  `Battery: ${{batteryText}}`,
                  `Hops: ${{hopsText}}`,
                  `GPS: ${{gpsText}}`,
                  `Saved P2P: ${{item.p2pPinned ? "yes" : "no"}}`,
                ];
                if (noteText) {{
                  tooltipLines.push(`Notes: ${{noteText}}`);
                }}
                const memberTitle = tooltipLines.join("\n");
                const removeBtn = (activeChatChannel === "direct" && item.p2pPinned)
                  ? `<button type="button" class="chat-peer-remove-btn" data-node-id="${{escAttr(item.id)}}" title="Remove from peer-to-peer list" aria-label="Remove ${{escAttr(item.id)}} from peer-to-peer list">&times;</button>`
                  : "";
                const idleRowTitle = Number.isFinite(snapshot.lastSeenUnix)
                  ? `Last seen ${{formatLocalChatTime(snapshot.lastSeenUnix, "n/a", nowUnix)}}`
                  : "Last seen n/a";
                const idleRowHtml = `<span class="chat-member-idle-time" title="${{escAttr(idleRowTitle)}}">Idle: ${{escAttr(idleText)}}</span>`;
                const packetRowTitle = packetTotal > 0
                  ? `Packet trend: last ${{packetSparklineWindowMin}}m. ${{packetRecent5m}} in last 5m, ${{packetTotal}} total. Last packet ${{packetLastText}}`
                  : `No packets from this node in the current packet buffer. Trend window: ${{packetSparklineWindowMin}}m`;
                const packetRowHtml = `<span class="chat-member-packet-trend metric-ticker ${{packetSparklineTrend}}" title="${{escAttr(packetRowTitle)}}">
                  <svg class="metric-ticker-chart chat-member-packet-sparkline" viewBox="0 0 56 12" preserveAspectRatio="none" aria-hidden="true" focusable="false">
                    <path d="${{escAttr(packetSparklinePath)}}" />
                  </svg>
                </span>`;
                const memberMetaRowHtml = `<span class="chat-member-meta-row">${{idleRowHtml}}${{packetRowHtml}}</span>`;
                const favoriteBtnHtml = (typeof favoriteToggleButtonHtml === "function")
                  ? favoriteToggleButtonHtml(item.id, "chat-favorite-btn")
                  : "";
                const muteBtnHtml = (typeof muteToggleButtonHtml === "function")
                  ? muteToggleButtonHtml(item.id, "chat-favorite-btn chat-mute-btn")
                  : "";
                return `<div class="chat-member-item status-${{item.status}}${{selectedNodeId === item.id ? " selected-node" : ""}}" data-node-id="${{escAttr(item.id)}}" title="${{escAttr(memberTitle)}}">
                <span class="chat-member-status status-${{item.status}}">●</span>
                <span class="chat-member-main">
                  <span class="chat-member-name-row">
                    <span class="chat-member-name-left">
                      <span class="chat-member-name status-${{item.status}}">${{escAttr(item.name)}}</span>
                    </span>
                    <span class="chat-member-actions">
                      ${{favoriteBtnHtml}}
                      ${{muteBtnHtml}}
                      ${{removeBtn}}
                    </span>
                  </span>
                  ${{memberMetaRowHtml}}
                </span>
              </div>`;
                }} catch (err) {{
                const fallbackId = normalizeNodeId(item && item.id);
                const fallbackName = String((item && item.name) || fallbackId || "Unknown node");
                try {{
                  if (typeof console !== "undefined" && typeof console.error === "function") {{
                    console.error("Node navigator row render failed", fallbackId || item, err);
                  }}
                }} catch (_consoleErr) {{
                }}
                return `<div class="chat-member-item status-unknown${{selectedNodeId === fallbackId ? " selected-node" : ""}}" data-node-id="${{escAttr(fallbackId)}}" title="Node navigator fallback row">
                <span class="chat-member-status status-unknown">●</span>
                <span class="chat-member-main">
                  <span class="chat-member-name-row">
                    <span class="chat-member-name-left">
                      <span class="chat-member-name status-unknown">${{escAttr(fallbackName)}}</span>
                    </span>
                    <span class="chat-member-actions"></span>
                  </span>
                  <span class="chat-member-idle-time">Idle: n/a</span>
                </span>
              </div>`;
                }}
              }})()
            )).join("")
          : (rosterQuery
              ? '<div class="chat-member-empty">No users match this search.</div>'
              : '<div class="chat-member-empty">No users discovered yet.</div>');
        for (const member of roomList.querySelectorAll(".chat-member-item")) {{
          member.addEventListener("click", () => {{
            selectNode(member.dataset.nodeId || "", true);
          }});
        }}
        for (const removeBtn of roomList.querySelectorAll(".chat-peer-remove-btn")) {{
          if (!(removeBtn instanceof HTMLButtonElement)) continue;
          removeBtn.addEventListener("click", (ev) => {{
            ev.preventDefault();
            ev.stopPropagation();
            const nodeId = normalizeNodeId(removeBtn.dataset.nodeId || "");
            if (!isCanonicalNodeId(nodeId)) return;
            const removed = removeManualDirectPeer(nodeId);
            if (!removed) return;
            setChatSendStatus(`Peer ${{nodeId}} removed from peer-to-peer list.`);
            renderChatPeerAddPanel(latestState);
          }});
        }}
      }}
      const leftSub = document.getElementById("chat-left-sub");
      if (leftSub) {{
        leftSub.textContent = `Scope: ${{channelLabel(activeChatChannel)}} • View Ch: ${{currentMeshChannelViewLabel()}} • Send Ch: ${{currentMeshChannelSendLabel()}} • ${{onlineCount}} online, ${{warnCount}} aging, ${{staleCount}} stale`;
      }}

      renderChatReplyContext();
      bindChatAutoScroll();
      bindChatFeedClicks();
      bindChatReactionControls();
      bindChatRetryControls();
      bindChatChangeSummaryControls();
      syncChatChangeAutoDismiss();
      renderChatPeerAddPanel(state);
      highlightNodeSelection();
      if (pendingSelectionScroll) {{
        scrollSelectionIntoView();
      }} else if (chatScroller instanceof HTMLElement && shouldStickBottom) {{
        requestAnimationFrame(() => {{
          chatScroller.scrollTop = chatScroller.scrollHeight;
          chatStickToBottom = true;
          syncChatChangeAutoDismiss();
        }});
      }}
      const chatRenderElapsedMs = (
        chatRenderStartMs > 0
        && typeof window.performance !== "undefined"
        && typeof window.performance.now === "function"
      ) ? Math.max(0, window.performance.now() - chatRenderStartMs) : 0;
      recordChatPerfSample(chatRenderElapsedMs, feedItems.length, rosterFiltered.length);

      const caption = document.getElementById("chat-caption");
      if (caption) {{
        const preset = formatModemPresetLabel(s.modem_preset, "unknown");
        const directTargetText = (() => {{
          if (activeChatChannel !== "direct") return "";
          if (!isCanonicalNodeId(directSelectedId)) return " Target: none selected.";
          const node = nodesById.get(directSelectedId);
          const targetName = preferredNodeName(node) || nodeNameCache.get(directSelectedId) || directSelectedId;
          return ` Target: ${{targetName}} (${{directSelectedId}}).`;
        }})();
        const perfSuffix = chatPerfEnabled
          ? ` Render: ${{chatPerfStats.lastMs.toFixed(1)}}ms (ema ${{chatPerfStats.emaMs.toFixed(1)}}ms, rows ${{chatPerfStats.lastFeedCount}}/${{chatPerfStats.lastRosterCount}}).`
          : "";
        caption.textContent = `LoRa preset: ${{preset}}. Scope: ${{channelLabel(activeChatChannel)}}.${{directTargetText}} View Ch: ${{currentMeshChannelViewLabel()}}. Send Ch: ${{currentMeshChannelSendLabel()}}. ${{onlineCount}} online, ${{warnCount}} aging, ${{staleCount}} stale.${{perfSuffix}} Message channels are encryption groups, not frequency slots.`;
        if (chatPerfEnabled) {{
          caption.title = `Chat render avg ${{chatPerfStats.avgMs.toFixed(1)}}ms, max ${{chatPerfStats.maxMs.toFixed(1)}}ms, samples ${{chatPerfStats.samples}}`;
        }} else {{
          caption.removeAttribute("title");
        }}
      }}
      const chatTitle = document.getElementById("chat-title");
      if (chatTitle instanceof HTMLElement) {{
        const titlePreset = formatModemPresetLabel(s.modem_preset, "Mesh");
        chatTitle.textContent = `${{titlePreset}} Chat`;
      }}
    }}
