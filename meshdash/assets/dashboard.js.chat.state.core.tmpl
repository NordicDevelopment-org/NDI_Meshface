      }}
      const historyInput = document.getElementById("chat-bot-history-enabled");
      if (historyInput instanceof HTMLInputElement && historyInput.dataset.bound !== "1") {{
        historyInput.dataset.bound = "1";
        historyInput.addEventListener("change", () => {{
          applyChatWhoisQuickActionConfig({{ historyEnabled: historyInput.checked }}, true);
        }});
      }}
      syncChatWhoisQuickActionControls();
    }}

    function bindBotCommandCatalogControls() {{
      const masterInput = document.getElementById("bots-command-master-enabled");
      if (masterInput instanceof HTMLInputElement && masterInput.dataset.bound !== "1") {{
        masterInput.dataset.bound = "1";
        masterInput.addEventListener("change", async () => {{
          const nextValue = !!masterInput.checked;
          const ok = await saveServerBotSettingsPatch({{ enabled: nextValue }});
          if (!ok) {{
            masterInput.checked = !!serverBotSettings.enabled;
          }}
          syncChatWhoisQuickActionControls();
        }});
      }}
      const list = document.getElementById("bots-command-list");
      if (list instanceof HTMLElement && list.dataset.bound !== "1") {{
        list.dataset.bound = "1";
        list.addEventListener("click", (event) => {{
          const target = event.target;
          if (!(target instanceof Element)) return;
          const item = target.closest(".bots-command-item");
          if (!(item instanceof HTMLButtonElement)) return;
          const commandName = String(item.dataset.commandName || "").trim().toLowerCase();
          if (!commandName) return;
          activeBotCommandSettingsId = commandName;
          renderManagedBotCommandList();
          syncChatWhoisQuickActionControls();
        }});
      }}
      const selectedEnabledInput = document.getElementById("bots-command-selected-enabled");
      if (selectedEnabledInput instanceof HTMLInputElement && selectedEnabledInput.dataset.bound !== "1") {{
        selectedEnabledInput.dataset.bound = "1";
        selectedEnabledInput.addEventListener("change", async () => {{
          const commandName = String(activeBotCommandSettingsId || "").trim().toLowerCase();
          if (!commandName) return;
          const ok = await saveServerBotSettingsPatch({{
            command_settings: {{
              [commandName]: !!selectedEnabledInput.checked,
            }},
          }});
          if (!ok) {{
            renderBotsView(latestState);
            return;
          }}
          syncChatWhoisQuickActionControls();
        }});
      }}
      const selectedPublicStartInput = document.getElementById("bots-command-selected-public-start-enabled");
      if (selectedPublicStartInput instanceof HTMLInputElement && selectedPublicStartInput.dataset.bound !== "1") {{
        selectedPublicStartInput.dataset.bound = "1";
        selectedPublicStartInput.addEventListener("change", async () => {{
          const ok = await saveServerBotSettingsPatch({{
            game_public_start_enabled: !!selectedPublicStartInput.checked,
          }});
          if (!ok) {{
            renderBotsView(latestState);
            return;
          }}
          syncChatWhoisQuickActionControls();
        }});
      }}
    }}

    function makeBotRequestHistoryId(seed = "") {{
      const cleanSeed = String(seed || "").trim().replace(/[^a-z0-9_-]/gi, "").toLowerCase().slice(0, 18);
      const rand = Math.random().toString(36).slice(2, 8);
      return `bot-${{Date.now().toString(36)}}-${{rand}}${{cleanSeed ? `-${{cleanSeed}}` : ""}}`;
    }}

    function normalizeTrackedBotCommandName(value) {{
      const raw = String(value || "").trim().toLowerCase();
      if (!raw) return "";
      let text = raw;
      if (text.startsWith("!") || text.startsWith("#")) {{
        text = text.slice(1);
      }}
      return Array.from(text).filter((ch) => (
        (ch >= "a" && ch <= "z")
        || (ch >= "0" && ch <= "9")
        || ch === "_"
        || ch === "-"
      )).join("");
    }}

    function botCommandHeadFromText(commandText) {{
      const raw = String(commandText || "").trim().toLowerCase();
      if (!raw) return "";
      const head = raw.split(/\\s+/)[0] || "";
      return head;
    }}

    function normalizeBotTrafficSnifferCommandHeads(raw) {{
      const parts = Array.isArray(raw)
        ? raw
        : String(raw || "").split(/[\\s,;]+/);
      const seen = new Set();
      const output = [];
      for (const part of parts) {{
        const clean = normalizeTrackedBotCommandName(part);
        if (!clean || seen.has(clean)) continue;
        seen.add(clean);
        output.push(clean);
      }}
      return output.length ? output : [...defaultBotTrafficSnifferCommandHeads];
    }}

    function persistBotTrafficSnifferCommandHeads() {{
      try {{
        window.localStorage.setItem(
          botTrafficSnifferCommandsStorageKey,
          JSON.stringify(botTrafficSnifferCommandHeads || [])
        );
      }} catch (_err) {{
      }}
    }}

    function syncBotTrafficSnifferControls() {{
      const input = document.getElementById("bots-sniffer-command-input");
      if (input instanceof HTMLInputElement) {{
        input.value = (botTrafficSnifferCommandHeads || []).join(", ");
      }}
    }}

    function applyBotTrafficSnifferCommandHeads(raw, persist = true) {{
      botTrafficSnifferCommandHeads = normalizeBotTrafficSnifferCommandHeads(raw);
      syncBotTrafficSnifferControls();
      if (persist) {{
        persistBotTrafficSnifferCommandHeads();
      }}
      if (activeLayoutView === "bots") {{
        renderBotsView(latestState);
      }}
    }}

    function loadBotTrafficSnifferCommandHeads() {{
      let loaded = [...defaultBotTrafficSnifferCommandHeads];
      try {{
        const raw = window.localStorage.getItem(botTrafficSnifferCommandsStorageKey);
        if (raw) {{
          const parsed = JSON.parse(raw);
          loaded = normalizeBotTrafficSnifferCommandHeads(parsed);
        }}
      }} catch (_err) {{
        loaded = [...defaultBotTrafficSnifferCommandHeads];
      }}
      botTrafficSnifferCommandHeads = loaded;
      syncBotTrafficSnifferControls();
      persistBotTrafficSnifferCommandHeads();
    }}

    function buildBotNodeLabelResolver(state = latestState) {{
      const nodes = (state && Array.isArray(state.nodes)) ? state.nodes : [];
      const nameById = new Map();
      for (const node of nodes) {{
        const nodeId = normalizeNodeId(node && node.id);
        if (!isCanonicalNodeId(nodeId)) continue;
        nameById.set(nodeId, preferredNodeName(node) || nodeNameCache.get(nodeId) || nodeId);
      }}
      return (nodeId) => {{
        const clean = normalizeNodeId(nodeId);
        if (!clean || clean === "^all") return "All";
        if (!isCanonicalNodeId(clean)) return clean || "n/a";
        return nameById.get(clean) || nodeNameCache.get(clean) || clean;
      }};
    }}

    function extractObservedBotTrafficEntries(state = latestState) {{
      const trackedHeads = new Set(normalizeBotTrafficSnifferCommandHeads(botTrafficSnifferCommandHeads));
      if (trackedHeads.size === 0) return [];
      const traffic = (state && state.traffic && typeof state.traffic === "object")
        ? state.traffic
        : {{}};
      const chatMessages = Array.isArray(traffic.recent_chat)
        ? traffic.recent_chat
        : [];
      const packets = Array.isArray(traffic.recent_packets)
        ? traffic.recent_packets
        : [];
      const output = [];
      const seen = new Set();
      const pushUnique = (row, dedupeKey) => {{
        const cleanKey = String(dedupeKey || row && row.id || "").trim();
        if (!row || !cleanKey || seen.has(cleanKey)) return;
        seen.add(cleanKey);
        output.push(row);
      }};

      for (const msg of chatMessages) {{
        if (!msg || typeof msg !== "object") continue;
        if (msg.local_echo === true || msg.localEcho === true) continue;
        const kind = normalizeChatMessageKind(msg, msg.is_reaction === true);
        if (kind !== "message") continue;
        const text = String(msg.text ?? msg.decoded_text ?? msg.payload_text ?? "").trim();
        if (!text) continue;
        const head = normalizeTrackedBotCommandName(String(text.split(/\\s+/)[0] || ""));
        if (!head || !trackedHeads.has(head)) continue;
        const fromId = normalizeNodeId(msg.from || "");
        if (!fromId) continue;
        const toId = normalizeNodeId(msg.to || msg.destination || "") || "^all";
        const channelIndex = messageMeshChannelIndex(msg);
        const receivedUnix = latestUnixTimestamp(
          msg.rx_time,
          msg.captured_at,
          msg.sent_at,
          msg.created_at
        ) || 0;
        const messageId = messageIdOfChatPacket(msg);
        const dedupeKey = messageId
          ? `chat:${{messageId}}`
          : `chat:${{fromId}}|${{toId}}|${{channelIndex}}|${{receivedUnix}}|${{text}}`;
        pushUnique({{
          id: `sniff-${{messageId || receivedUnix || output.length}}-${{head}}-${{fromId}}`,
          command: text,
          command_head: head,
          from_id: fromId,
          to_id: toId,
          channel_index: channelIndex,
          message_id: messageId,
          received_unix: receivedUnix,
          received_at: String(msg.rx_time ?? msg.captured_at ?? msg.sent_at ?? "").trim(),
          hops: hopCountOfChatPacket(msg),
        }}, dedupeKey);
      }}

      for (const entry of packets) {{
        if (!entry || typeof entry !== "object") continue;
        const summary = (entry.summary && typeof entry.summary === "object") ? entry.summary : {{}};
        const packet = (entry.packet && typeof entry.packet === "object") ? entry.packet : {{}};
        const decoded = (packet.decoded && typeof packet.decoded === "object") ? packet.decoded : {{}};
        const text = String(summary.decoded_text ?? decoded.text ?? "").trim();
        if (!text) continue;
        const head = normalizeTrackedBotCommandName(String(text.split(/\\s+/)[0] || ""));
        if (!head || !trackedHeads.has(head)) continue;
        const fromId = normalizeNodeId(summary.from ?? packet.fromId ?? packet.from_id ?? "");
        if (!fromId) continue;
        const toId = normalizeNodeId(summary.to ?? packet.toId ?? packet.to_id ?? "") || "^all";
        const channelIndex = normalizeMeshChannelIndex(summary.channel ?? packet.channel ?? 0);
        const receivedUnix = latestUnixTimestamp(
          summary.rx_time_unix,
          packet.rxTime,
          summary.rx_time,
          summary.captured_at,
          entry.rx_time_unix,
          entry.rx_time,
          entry.captured_at
        ) || 0;
        const packetId = parsePositiveMessageId(summary.packet_id ?? packet.id);
        const dedupeKey = packetId
          ? `packet:${{packetId}}`
          : `packet:${{fromId}}|${{toId}}|${{channelIndex}}|${{receivedUnix}}|${{text}}`;
        const hops = hopCountOfChatPacket({{
          hops: summary.hops,
          hop_start: summary.hop_start ?? packet.hopStart,
          hop_limit: summary.hop_limit ?? packet.hopLimit,
        }});
        pushUnique({{
          id: `sniff-${{packetId || receivedUnix || output.length}}-${{head}}-${{fromId}}`,
          command: text,
          command_head: head,
          from_id: fromId,
          to_id: toId,
          channel_index: channelIndex,
          message_id: packetId,
          received_unix: receivedUnix,
          received_at: String(summary.rx_time ?? summary.captured_at ?? "").trim(),
          hops,
        }}, dedupeKey);
      }}
      output.sort((a, b) => (
        (Number(b.received_unix) || 0) - (Number(a.received_unix) || 0)
      ));
      return output.slice(0, botRequestLogMaxEntries);
    }}

    function normalizeBotRequestHistoryEntry(raw) {{
      if (!raw || typeof raw !== "object") return null;
      const command = String(raw.command || "").trim();
      if (!command) return null;
      const source = String(raw.source || "local").trim().toLowerCase() || "local";
      const commandHead = String(raw.command_head || raw.commandHead || botCommandHeadFromText(command)).trim().toLowerCase();
      const prefix = knownWhoisCommandPrefixes.has(commandHead)
        ? normalizeWhoisCommandPrefix(raw.prefix || commandHead)
        : String(raw.prefix || commandHead || command.split(/\\s+/)[0] || "").trim().toLowerCase();
      const suffix = nodeIdSuffixForWhois(raw.suffix || command.split(/\\s+/).slice(1).join(" "));
      const fromId = normalizeNodeId(raw.from_id ?? raw.fromId ?? "");
      const destination = normalizeNodeId(raw.destination ?? raw.to_id ?? raw.toId ?? "^all") || "^all";
      const messageId = parsePositiveMessageId(raw.message_id ?? raw.messageId);
      const replyId = parsePositiveMessageId(raw.reply_id ?? raw.replyId);
      const sentAtText = String(raw.sent_at ?? raw.sentAt ?? raw.received_at ?? raw.receivedAt ?? "").trim();
      const sentMs = (
        parseDashboardTimeToMs(raw.sent_ms ?? raw.sentMs)
        || parseDashboardTimeToMs(raw.sent_at ?? raw.sentAt)
        || parseDashboardTimeToMs(raw.sent_unix ?? raw.sentUnix)
        || parseDashboardTimeToMs(raw.received_unix ?? raw.receivedUnix)
        || parseDashboardTimeToMs(raw.received_at ?? raw.receivedAt)
        || Date.now()
      );
      const sentUnix = (
        parseDashboardTimeToUnix(raw.sent_unix ?? raw.sentUnix)
        || parseDashboardTimeToUnix(raw.sent_at ?? raw.sentAt)
        || parseDashboardTimeToUnix(raw.received_unix ?? raw.receivedUnix)
        || parseDashboardTimeToUnix(raw.received_at ?? raw.receivedAt)
        || Math.floor(sentMs / 1000)
      );
      const responseMessageId = parsePositiveMessageId(raw.response_message_id ?? raw.responseMessageId);
      const responseMs = parseDashboardTimeToMs(raw.response_ms ?? raw.responseMs ?? raw.response_at ?? raw.responseAt);
      const responseUnix = parseDashboardTimeToUnix(raw.response_unix ?? raw.responseUnix ?? raw.response_at ?? raw.responseAt);
      const responseHopsRaw = Number(raw.response_hops ?? raw.responseHops);
      const responseHops = (Number.isFinite(responseHopsRaw) && responseHopsRaw >= 0)
        ? Math.trunc(responseHopsRaw)
        : null;
      const respondEnabled = parseBoolToken(raw.respond_enabled ?? raw.respondEnabled, true);
      const responded = parseBoolToken(raw.responded, !!responseMessageId);
      const responseError = String(raw.response_error ?? raw.responseError ?? "").trim();
      return {{
        id: String(raw.id || makeBotRequestHistoryId(suffix)).trim() || makeBotRequestHistoryId(suffix),
        source,
        command,
        command_head: commandHead,
        prefix,
        suffix,
        from_id: fromId,
        destination,
        channel_index: normalizeMeshChannelIndex(raw.channel_index ?? raw.channelIndex ?? 0),
        reply_id: replyId,
        reply_attached: parseBoolToken(raw.reply_attached ?? raw.replyAttached, !!replyId),
        message_id: messageId,
        sent_at: sentAtText,
        sent_ms: sentMs,
        sent_unix: sentUnix,
        respond_enabled: respondEnabled,
        responded,
        response_message_id: responseMessageId,
        response_ms: responseMs,
        response_unix: responseUnix,
        response_hops: responseHops,
        response_from: normalizeNodeId(raw.response_from ?? raw.responseFrom ?? ""),
        response_to: normalizeNodeId(raw.response_to ?? raw.responseTo ?? ""),
        response_text: String(raw.response_text ?? raw.responseText ?? "").trim(),
        response_error: responseError,
      }};
    }}

    function pruneBotRequestHistoryEntries(entries, nowUnix = Math.floor(Date.now() / 1000)) {{
      if (!Array.isArray(entries) || entries.length === 0) return [];
      const normalized = entries
        .map((entry) => normalizeBotRequestHistoryEntry(entry))
        .filter((entry) => !!entry)
        .sort((a, b) => (Number(b.sent_unix) || 0) - (Number(a.sent_unix) || 0));
      const seenIds = new Set();
      const output = [];
      for (const entry of normalized) {{
        if (seenIds.has(entry.id)) continue;
        seenIds.add(entry.id);
        const sentUnix = Number(entry.sent_unix) || 0;
        if (sentUnix > 0 && (nowUnix - sentUnix) > botRequestLogMaxAgeSeconds) {{
          continue;
        }}
        output.push(entry);
        if (output.length >= botRequestLogMaxEntries) {{
          break;
        }}
      }}
      return output;
    }}

    function persistBotRequestHistory() {{
      try {{
        window.localStorage.setItem(botRequestLogStorageKey, JSON.stringify(botRequestHistory || []));
      }} catch (_err) {{
      }}
    }}

    function loadBotRequestHistory() {{
      let loaded = [];
      try {{
        const raw = window.localStorage.getItem(botRequestLogStorageKey);
        if (raw) {{
          const parsed = JSON.parse(raw);
          if (Array.isArray(parsed)) {{
            loaded = parsed;
          }}
        }}
      }} catch (_err) {{
        loaded = [];
      }}
      botRequestHistory = pruneBotRequestHistoryEntries(loaded);
      persistBotRequestHistory();
      if (activeLayoutView === "bots") {{
        renderBotsView(latestState);
      }}
    }}

    function syncBackendBotRequestHistory(state = latestState) {{
      const raw = (state && Array.isArray(state.bot_requests)) ? state.bot_requests : [];
      backendBotRequestHistory = pruneBotRequestHistoryEntries(raw);
    }}

    function mergedBotRequestHistoryEntries(state = latestState) {{
      syncBackendBotRequestHistory(state);
      const localRows = Array.isArray(botRequestHistory) ? botRequestHistory : [];
      const backendRows = Array.isArray(backendBotRequestHistory) ? backendBotRequestHistory : [];
      return pruneBotRequestHistoryEntries([...(backendRows || []), ...(localRows || [])]);
    }}

    function parseTrackedBotCommandFromText(text) {{
      const raw = String(text || "").trim();
      if (!raw) return null;
      const parts = raw.split(/\\s+/).filter((part) => !!part);
      if (parts.length === 0) return null;
      const prefixRaw = String(parts[0] || "").trim().toLowerCase();
      if (knownBotSingleWordCommands.has(prefixRaw)) {{
        if (parts.length !== 1) return null;
        return {{
          command: raw,
          prefix: prefixRaw,
          suffix: "",
          head: prefixRaw,
          kind: "single",
        }};
      }}
      if (!knownBotArgumentCommands.has(prefixRaw)) return null;
      if (parts.length < 2) return null;
      const targetToken = String(parts[1] || "").trim();
      const isWeatherCommand = prefixRaw === "wx" || prefixRaw === "!wx" || prefixRaw === "#wx";
      const suffix = isWeatherCommand ? targetToken : nodeIdSuffixForWhois(targetToken);
      return {{
        command: raw,
        prefix: knownWhoisCommandPrefixes.has(prefixRaw) ? normalizeWhoisCommandPrefix(prefixRaw) : prefixRaw,
        suffix,
        head: prefixRaw,
        kind: "argument",
      }};
    }}

    function recordBotRequestHistoryFromSend(requestBody, payload) {{
      if (!chatBotHistoryEnabled || !chatBotCommandsEnabled) return;
      const parsed = parseTrackedBotCommandFromText(requestBody && requestBody.text);
      if (!parsed) return;
      const sentMs = (
        parseDashboardTimeToMs(payload && payload.sent_at)
        || parseDashboardTimeToMs(payload && payload.rx_time)
        || Date.now()
      );
      const sentUnix = (
        parseDashboardTimeToUnix(payload && payload.sent_at)
        || parseDashboardTimeToUnix(payload && payload.rx_time)
        || Math.floor(sentMs / 1000)
      );
      const messageId = messageIdOfChatPacket(payload || {{}});
      const replyId = parsePositiveMessageId(
        (payload && (payload.reply_id ?? payload.replyId))
        ?? (requestBody && requestBody.reply_id)
      );
      const entry = normalizeBotRequestHistoryEntry({{
        id: makeBotRequestHistoryId(parsed.suffix),
        command: parsed.command,
        command_head: parsed.head,
        prefix: parsed.prefix,
        suffix: parsed.suffix,
        destination: requestBody && requestBody.destination,
        channel_index: requestBody && requestBody.channel_index,
        reply_id: replyId,
        reply_attached: Number.isInteger(replyId) && replyId > 0,
        message_id: messageId,
        sent_at: (payload && payload.sent_at) || "",
        sent_ms: sentMs,
        sent_unix: sentUnix,
      }});
      if (!entry) return;
      botRequestHistory = pruneBotRequestHistoryEntries([entry, ...(botRequestHistory || [])], sentUnix);
      persistBotRequestHistory();
      if (activeLayoutView === "bots") {{
        renderBotsView(latestState);
      }}
    }}

    function syncBotRequestHistoryWithMessages(messages, state = latestState) {{
      if (!chatBotHistoryEnabled || !chatBotCommandsEnabled) return false;
      if (!Array.isArray(botRequestHistory) || botRequestHistory.length === 0) return false;
      const responseByReplyId = new Map();
      for (const msg of (Array.isArray(messages) ? messages : [])) {{
        if (!msg || typeof msg !== "object") continue;
        if (msg.local_echo === true || msg.localEcho === true) continue;
        const messageId = messageIdOfChatPacket(msg);
        const replyId = replyIdOfChatPacket(msg);
        if (!messageId || !replyId) continue;
        if (messageId === replyId) continue;
        const fromId = normalizeNodeId(msg.from || "");
        if (isSelfNodeId(fromId)) continue;
        const msgMs = latestTimestampMs(
          msg.rx_time,
          msg.captured_at,
          msg.sent_at,
          msg.created_at
        ) || Date.now();
        const unix = latestUnixTimestamp(
          msg.rx_time,
          msg.captured_at,
          msg.sent_at,
          msg.created_at
        ) || 0;
        const existing = responseByReplyId.get(replyId);
        if (existing && Number(existing.ms || 0) > msgMs) continue;
        responseByReplyId.set(replyId, {{
          messageId,
          ms: msgMs,
          unix,
          hops: hopCountOfChatPacket(msg),
          fromId,
          toId: normalizeNodeId(msg.to || msg.destination || ""),
          text: String(msg.text ?? msg.decoded_text ?? msg.payload_text ?? "").trim(),
        }});
      }}
      if (responseByReplyId.size === 0) return false;
      let changed = false;
      const next = [];
      for (const entry of botRequestHistory) {{
        const normalized = normalizeBotRequestHistoryEntry(entry);
        if (!normalized) continue;
        if (!normalized.response_message_id && normalized.message_id) {{
          const match = responseByReplyId.get(normalized.message_id);
          if (match) {{
            normalized.response_message_id = match.messageId;
            normalized.response_ms = Number(match.ms) > 0 ? Number(match.ms) : null;
            normalized.response_unix = Number(match.unix) > 0 ? Number(match.unix) : normalized.sent_unix;
            normalized.response_hops = Number.isInteger(match.hops) ? Number(match.hops) : null;
            normalized.response_from = match.fromId;
            normalized.response_to = match.toId;
            normalized.response_text = match.text;
            changed = true;
          }}
        }}
        next.push(normalized);
      }}
      if (!changed) return false;
      botRequestHistory = pruneBotRequestHistoryEntries(next);
      persistBotRequestHistory();
      if (activeLayoutView === "bots") {{
        renderBotsView(state);
      }}
      return true;
    }}

    function clearBotRequestHistory() {{
      botRequestHistory = [];
      persistBotRequestHistory();
      if (activeLayoutView === "bots") {{
        renderBotsView(latestState);
      }}
    }}

    function renderManagedBotCommandList() {{
      const listEl = document.getElementById("bots-command-list");
      const configEmptyEl = document.getElementById("bots-command-config-empty");
      const configFormEl = document.getElementById("bots-command-config-form");
      const selectedUsageEl = document.getElementById("bots-command-selected-usage");
      const selectedKindEl = document.getElementById("bots-command-selected-kind");
      const selectedNameEl = document.getElementById("bots-command-selected-name");
      const selectedDescriptionEl = document.getElementById("bots-command-selected-description");
      const selectedEnabledInput = document.getElementById("bots-command-selected-enabled");
      const publicStartWrap = document.getElementById("bots-command-selected-public-start-wrap");
      const publicStartInput = document.getElementById("bots-command-selected-public-start-enabled");
      const publicStartNote = document.getElementById("bots-command-selected-public-start-note");
      if (!(listEl instanceof HTMLElement)) return;
      const showConfigEmpty = (message) => {{
        if (configEmptyEl instanceof HTMLElement) {{
          configEmptyEl.textContent = String(message || "Select a command to configure.");
          configEmptyEl.hidden = false;
        }}
        if (configFormEl instanceof HTMLElement) {{
          configFormEl.hidden = true;
        }}
      }};
      if (!serverBotSettings.available) {{
        listEl.innerHTML = '<div class="bots-history-empty">Backend bot settings endpoint unavailable on this node.</div>';
        showConfigEmpty("Backend bot settings endpoint unavailable on this node.");
        return;
      }}
      const commands = Array.isArray(serverBotSettings.commands) ? serverBotSettings.commands : [];
      if (commands.length === 0) {{
        listEl.innerHTML = '<div class="bots-history-empty">No managed backend bot commands are currently exposed.</div>';
        showConfigEmpty("No managed backend bot commands are currently exposed.");
        return;
      }}
      const orderedNames = commands
        .map((command) => String(command && command.name || "").trim().toLowerCase())
        .filter((name) => !!name);
      const activeName = String(activeBotCommandSettingsId || "").trim().toLowerCase();
      if (!activeName || !orderedNames.includes(activeName)) {{
        activeBotCommandSettingsId = orderedNames[0] || "";
      }}
      const selectedName = String(activeBotCommandSettingsId || "").trim().toLowerCase();
      const selectedCommand = commands.find((command) => String(command && command.name || "").trim().toLowerCase() === selectedName) || null;
      const rows = commands.map((command, index) => {{
        const usage = String(command && command.usage || command && command.name || "").trim() || "unknown";
        const description = String(command && command.description || "").trim() || "Managed backend bot command.";
        const kindRaw = String(command && command.kind || "builtin").trim().toLowerCase();
        const kindLabel = kindRaw === "custom"
          ? "custom"
          : (kindRaw === "game" ? "game" : "built-in");
        const name = String(command && command.name || "").trim().toLowerCase();
        const enabled = !!(command && command.enabled);
        const orderLabel = `${{index + 1}}.`;
        const stateLabel = enabled ? "on" : "off";
        const disabledClass = enabled ? "" : " is-disabled";
        const activeClass = name === selectedName ? " is-active" : "";
        return `<button type="button" class="bots-command-item${{disabledClass}}${{activeClass}}" data-command-name="${{escAttr(name)}}" title="${{escAttr(description)}}" role="option" aria-selected="${{name === selectedName ? "true" : "false"}}">
          <span class="bots-command-item-order">${{escAttr(orderLabel)}}</span>
          <span class="bots-command-copy">
            <span class="bots-command-heading">
              <span class="bots-command-usage">${{escAttr(usage)}}</span>
              <span class="bots-command-kind">${{escAttr(kindLabel)}}</span>
            </span>
            <span class="bots-command-description">${{escAttr(description)}}</span>
          </span>
          <span class="bots-command-state">${{escAttr(stateLabel)}}</span>
        </button>`;
      }});
      listEl.innerHTML = rows.join("");
      if (!selectedCommand) {{
        showConfigEmpty("Select a command to configure.");
        return;
      }}
      if (configEmptyEl instanceof HTMLElement) {{
        configEmptyEl.hidden = true;
      }}
      if (configFormEl instanceof HTMLElement) {{
        configFormEl.hidden = false;
      }}
      const usageText = String(selectedCommand.usage || selectedCommand.name || "unknown").trim() || "unknown";
      const descriptionText = String(selectedCommand.description || "").trim() || "Managed backend bot command.";
      const kindRaw = String(selectedCommand.kind || "builtin").trim().toLowerCase();
      const kindLabel = kindRaw === "custom"
        ? "custom"
        : (kindRaw === "game" ? "game" : "built-in");
      if (selectedUsageEl instanceof HTMLElement) {{
        selectedUsageEl.textContent = usageText;
      }}
      if (selectedKindEl instanceof HTMLElement) {{
        selectedKindEl.textContent = kindLabel;
      }}
      if (selectedNameEl instanceof HTMLElement) {{
        selectedNameEl.textContent = `id: ${{selectedName}}`;
      }}
      if (selectedDescriptionEl instanceof HTMLElement) {{
        selectedDescriptionEl.textContent = descriptionText;
      }}
      if (selectedEnabledInput instanceof HTMLInputElement) {{
        selectedEnabledInput.checked = !!selectedCommand.enabled;
      }}
      const selectedIsZork = selectedName === "zork";
      if (publicStartWrap instanceof HTMLElement) {{
        publicStartWrap.hidden = !selectedIsZork;
      }}
      if (publicStartNote instanceof HTMLElement) {{
        publicStartNote.hidden = !selectedIsZork;
      }}
      if (publicStartInput instanceof HTMLInputElement) {{
        publicStartInput.checked = !!serverBotSettings.game_public_start_enabled;
      }}
    }}

    function syncBotsReviewTabUi() {{
      const historyBtn = document.getElementById("bots-tab-history-btn");
      const snifferBtn = document.getElementById("bots-tab-sniffer-btn");
      const historyPanel = document.getElementById("bots-history-tab-panel");
      const snifferPanel = document.getElementById("bots-sniffer-tab-panel");
      const clearBtn = document.getElementById("bots-history-clear-btn");
      const historyActive = activeBotsReviewTab !== "sniffer";
      if (historyBtn instanceof HTMLButtonElement) {{
        historyBtn.classList.toggle("is-active", historyActive);
        historyBtn.setAttribute("aria-selected", historyActive ? "true" : "false");
      }}
      if (snifferBtn instanceof HTMLButtonElement) {{
        snifferBtn.classList.toggle("is-active", !historyActive);
        snifferBtn.setAttribute("aria-selected", historyActive ? "false" : "true");
      }}
      if (historyPanel instanceof HTMLElement) {{
        historyPanel.hidden = !historyActive;
      }}
      if (snifferPanel instanceof HTMLElement) {{
        snifferPanel.hidden = historyActive;
      }}
      if (clearBtn instanceof HTMLButtonElement) {{
        clearBtn.hidden = !historyActive;
      }}
    }}

    function renderBotTrafficSnifferTab(state = latestState) {{
      const listEl = document.getElementById("bots-sniffer-list");
      const totalEl = document.getElementById("bots-sniffer-total");
      const sendersEl = document.getElementById("bots-sniffer-senders");
      const commandsEl = document.getElementById("bots-sniffer-commands");
      if (!(listEl instanceof HTMLElement)) return;

      syncBotTrafficSnifferControls();
      const entries = extractObservedBotTrafficEntries(state);
      const uniqueSenders = new Set(
        entries.map((entry) => normalizeNodeId(entry && entry.from_id)).filter((value) => !!value)
      );
      const uniqueCommands = new Set(
        entries.map((entry) => String(entry && entry.command_head || "").trim().toLowerCase()).filter((value) => !!value)
      );
      if (totalEl instanceof HTMLElement) totalEl.textContent = String(entries.length);
      if (sendersEl instanceof HTMLElement) sendersEl.textContent = String(uniqueSenders.size);
      if (commandsEl instanceof HTMLElement) commandsEl.textContent = String(uniqueCommands.size);

      if (entries.length === 0) {{
        const trackedText = (botTrafficSnifferCommandHeads || []).join(", ");
        listEl.innerHTML = `<div class="bots-history-empty">No matching bot traffic in retained decoded traffic for: <code>${{escAttr(trackedText || "none")}}</code>.</div>`;
        return;
      }}

      const nodeLabel = buildBotNodeLabelResolver(state);
      const rows = entries.map((entry) => {{
        const sentLabel = formatLocalChatTime(entry.received_unix, entry.received_at || "n/a");
        const fromLabel = nodeLabel(entry.from_id || "");
        const toLabel = nodeLabel(entry.to_id || "");
        const hasChannelIndex = Number.isInteger(entry.channel_index) && Number(entry.channel_index) >= 0;
        const channelLabel = hasChannelIndex
          ? meshChannelLabelForIndex(entry.channel_index, {{ allowAll: false }})
          : "Channel ?";
        const channelBadge = hasChannelIndex
          ? meshChannelBadgeHtml(entry.channel_index, channelLabel, {{
              allowAll: false,
              extraClass: "bots-history-channel",
              title: meshChannelLabelForIndex(entry.channel_index, {{ verbose: true, allowAll: false }}),
            }})
          : `<span>${{escAttr(channelLabel)}}</span>`;
        const hops = Number(entry.hops);
        const hopText = Number.isInteger(hops) && hops >= 0 ? `${{hops}} hop${{hops === 1 ? "" : "s"}}` : "hops n/a";
        return `<article class="bots-history-item">
          <div class="bots-history-item-head">
            <span class="bots-history-command">${{escAttr(entry.command)}}</span>
            <span class="bots-history-status-pill">${{escAttr(entry.command_head)}}</span>
          </div>
          <div class="bots-history-meta">
            <span>${{escAttr(sentLabel)}}</span>
            <span>from ${{escAttr(fromLabel || "n/a")}}</span>
            ${{channelBadge}}
            <span>to ${{escAttr(toLabel || "All")}}</span>
            <span>${{escAttr(hopText)}}</span>
          </div>
        </article>`;
      }});
      listEl.innerHTML = rows.join("");
    }}

    function renderBotsView(state = latestState) {{
      applyServerBotSettingsFromState(state);
      renderManagedBotCommandList();
      syncChatWhoisQuickActionControls();
      syncBotsReviewTabUi();
      renderBotTrafficSnifferTab(state);
      const listEl = document.getElementById("bots-history-list");
      const totalEl = document.getElementById("bots-history-total");
      const pendingEl = document.getElementById("bots-history-pending");
      const respondedEl = document.getElementById("bots-history-responded");
      if (!(listEl instanceof HTMLElement)) return;

      const entries = mergedBotRequestHistoryEntries(state);
      const total = entries.length;
      const responded = entries.reduce((acc, item) => (
        acc + ((item && (item.response_message_id || item.responded)) ? 1 : 0)
      ), 0);
      const pending = Math.max(0, total - responded);

      if (totalEl instanceof HTMLElement) totalEl.textContent = String(total);
      if (pendingEl instanceof HTMLElement) pendingEl.textContent = String(pending);
      if (respondedEl instanceof HTMLElement) respondedEl.textContent = String(responded);

      if (entries.length === 0) {{
        listEl.innerHTML = chatBotHistoryEnabled
          ? '<div class="bots-history-empty">No tracked bot requests yet. Send a <code>whois</code> or <code>ping</code> command, or wait for mesh bot traffic.</div>'
          : '<div class="bots-history-empty">Bot request history tracking is disabled.</div>';
        return;
      }}
      const commandsDisabledNotice = !chatBotCommandsEnabled
        ? '<div class="bots-history-empty">Quick actions are disabled for this browser. You can still type commands manually in chat; backend-observed mesh requests still appear here when available.</div>'
        : "";
      const disabledNotice = !chatBotHistoryEnabled
        ? '<div class="bots-history-empty">Tracking is disabled. Existing history is shown read-only; new requests and matches will not be recorded.</div>'
        : "";

      const nodeLabel = buildBotNodeLabelResolver(state);

      const rows = entries.map((entry) => {{
        let statusClass = "pending";
        let statusLabel = "Pending";
        if (entry.response_message_id || entry.responded) {{
          statusClass = "responded";
          statusLabel = "Responded";
        }} else if (entry.response_error) {{
          statusClass = "pending";
          statusLabel = "Error";
        }} else if (entry.respond_enabled === false) {{
          statusClass = "pending";
          statusLabel = "Observed";
        }}
        const sentLabel = formatLocalChatTime(entry.sent_unix, entry.sent_at || "n/a");
        const destLabel = entry.destination === "^all" ? "All" : nodeLabel(entry.destination);
        const fromLabel = nodeLabel(entry.from_id || "");
        const hasChannelIndex = Number.isInteger(entry.channel_index) && Number(entry.channel_index) >= 0;
        const channelLabel = hasChannelIndex
          ? meshChannelLabelForIndex(entry.channel_index, {{ allowAll: false }})
          : "Channel ?";
        const channelBadge = hasChannelIndex
          ? meshChannelBadgeHtml(entry.channel_index, channelLabel, {{
              allowAll: false,
              extraClass: "bots-history-channel",
              title: meshChannelLabelForIndex(entry.channel_index, {{ verbose: true, allowAll: false }}),
            }})
          : `<span>${{escAttr(channelLabel)}}</span>`;
        const replyHint = entry.reply_attached ? "reply attached" : "new request";
        const responseMeta = entry.response_message_id
          ? buildResponseTelemetryMetaHtml(entry.sent_ms, entry.response_ms, entry.response_hops)
          : "";
        const responseText = String(entry.response_text || "").trim();
        const responsePreview = responseText
          ? compactInlineMessage(responseText, 200)
          : "(no text)";
        const responseBlock = entry.response_message_id
          ? `<div class="bots-history-response"><strong>${{escAttr(nodeLabel(entry.response_from))}}:</strong> ${{escAttr(responsePreview)}}</div>`
          : (
            entry.response_error
              ? `<div class="bots-history-response"><strong>error:</strong> ${{escAttr(entry.response_error)}}</div>`
              : ""
          );
        return `<article class="bots-history-item">
          <div class="bots-history-item-head">
            <span class="bots-history-command">${{escAttr(entry.command)}}</span>
            <span class="bots-history-status-pill ${{statusClass}}">${{statusLabel}}</span>
          </div>
          <div class="bots-history-meta">
            <span>${{escAttr(sentLabel)}}</span>
            <span>from ${{escAttr(fromLabel || "n/a")}}</span>
            ${{channelBadge}}
            <span>to ${{escAttr(destLabel)}}</span>
            <span>${{escAttr(replyHint)}}</span>
          </div>
          ${{responseMeta}}
          ${{responseBlock}}
        </article>`;
      }});
      listEl.innerHTML = `${{commandsDisabledNotice}}${{disabledNotice}}${{rows.join("")}}`;
    }}

    function bindBotHistoryControls() {{
      const clearBtn = document.getElementById("bots-history-clear-btn");
      if (clearBtn instanceof HTMLButtonElement && clearBtn.dataset.bound !== "1") {{
        clearBtn.dataset.bound = "1";
        clearBtn.addEventListener("click", () => {{
          clearBotRequestHistory();
          setChatSendStatus("Cleared bot request history.");
        }});
      }}
    }}

    function bindBotsReviewControls() {{
      const historyBtn = document.getElementById("bots-tab-history-btn");
      if (historyBtn instanceof HTMLButtonElement && historyBtn.dataset.bound !== "1") {{
        historyBtn.dataset.bound = "1";
        historyBtn.addEventListener("click", () => {{
          activeBotsReviewTab = "history";
          syncBotsReviewTabUi();
        }});
      }}
      const snifferBtn = document.getElementById("bots-tab-sniffer-btn");
      if (snifferBtn instanceof HTMLButtonElement && snifferBtn.dataset.bound !== "1") {{
        snifferBtn.dataset.bound = "1";
        snifferBtn.addEventListener("click", () => {{
          activeBotsReviewTab = "sniffer";
          syncBotsReviewTabUi();
        }});
      }}
      const applyBtn = document.getElementById("bots-sniffer-apply-btn");
      const input = document.getElementById("bots-sniffer-command-input");
      if (applyBtn instanceof HTMLButtonElement && applyBtn.dataset.bound !== "1") {{
        applyBtn.dataset.bound = "1";
        applyBtn.addEventListener("click", () => {{
          applyBotTrafficSnifferCommandHeads(input instanceof HTMLInputElement ? input.value : "");
        }});
      }}
      if (input instanceof HTMLInputElement && input.dataset.bound !== "1") {{
        input.dataset.bound = "1";
        input.addEventListener("keydown", (event) => {{
          if (event.key !== "Enter") return;
          event.preventDefault();
          applyBotTrafficSnifferCommandHeads(input.value);
        }});
      }}
      const resetBtn = document.getElementById("bots-sniffer-reset-btn");
      if (resetBtn instanceof HTMLButtonElement && resetBtn.dataset.bound !== "1") {{
        resetBtn.dataset.bound = "1";
        resetBtn.addEventListener("click", () => {{
          applyBotTrafficSnifferCommandHeads(defaultBotTrafficSnifferCommandHeads);
        }});
      }}
    }}
