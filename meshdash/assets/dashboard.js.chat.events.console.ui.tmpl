    function syncConsoleTerminalScreenFillHeight() {{
      const terminalScreen = document.getElementById("console-terminal-screen");
      if (!(terminalScreen instanceof HTMLElement)) return;
      if (activeLayoutView !== "console") {{
        terminalScreen.style.removeProperty("height");
        terminalScreen.style.removeProperty("min-height");
        terminalScreen.style.removeProperty("max-height");
        return;
      }}
      const container = terminalScreen.parentElement;
      if (!(container instanceof HTMLElement)) return;
      const rect = terminalScreen.getBoundingClientRect();
      const containerRect = container.getBoundingClientRect();
      const consoleCard = terminalScreen.closest(".console");
      const layout = document.getElementById("dashboard-layout");
      const workspaceMain = terminalScreen.closest(".workspace-main");
      const top = Number(rect && rect.top);
      let bottom = Number(containerRect && containerRect.bottom);
      if (consoleCard instanceof HTMLElement) {{
        const cardRect = consoleCard.getBoundingClientRect();
        const cardBottom = Number(cardRect && cardRect.bottom);
        if (Number.isFinite(cardBottom) && cardBottom > bottom) {{
          bottom = cardBottom;
        }}
      }}
      if (layout instanceof HTMLElement) {{
        const layoutRect = layout.getBoundingClientRect();
        const layoutBottom = Number(layoutRect && layoutRect.bottom);
        if (Number.isFinite(layoutBottom) && layoutBottom > bottom) {{
          bottom = layoutBottom;
        }}
      }}
      if (workspaceMain instanceof HTMLElement) {{
        const mainRect = workspaceMain.getBoundingClientRect();
        const mainBottom = Number(mainRect && mainRect.bottom);
        if (Number.isFinite(mainBottom) && mainBottom > bottom) {{
          bottom = mainBottom;
        }}
      }}
      if (!Number.isFinite(top) || !Number.isFinite(bottom)) return;
      let bottomInset = 0;
      try {{
        const styles = window.getComputedStyle(container);
        bottomInset = Math.max(0, Number.parseFloat(styles.paddingBottom) || 0);
      }} catch (_err) {{
      }}
      const measuredHeight = Math.floor(bottom - top - bottomInset);
      if (!Number.isFinite(measuredHeight) || measuredHeight <= 0) {{
        terminalScreen.style.removeProperty("height");
        terminalScreen.style.removeProperty("min-height");
        terminalScreen.style.removeProperty("max-height");
        return;
      }}
      const nextHeight = Math.max(140, measuredHeight);
      terminalScreen.style.height = `${{nextHeight}}px`;
      terminalScreen.style.removeProperty("min-height");
      terminalScreen.style.removeProperty("max-height");
    }}

    function scheduleConsoleTerminalScreenFillHeight() {{
      if (typeof window === "undefined") return;
      if (consoleFrameFillRaf !== null && typeof window.cancelAnimationFrame === "function") {{
        try {{
          window.cancelAnimationFrame(consoleFrameFillRaf);
        }} catch (_err) {{
        }}
      }}
      if (typeof window.requestAnimationFrame !== "function") {{
        syncConsoleTerminalScreenFillHeight();
        return;
      }}
      consoleFrameFillRaf = window.requestAnimationFrame(() => {{
        consoleFrameFillRaf = null;
        syncConsoleTerminalScreenFillHeight();
      }});
    }}

    function isConsoleHotkeyTextEntryTarget(target) {{
      if (!(target instanceof Element)) return false;
      if (target instanceof HTMLTextAreaElement) return true;
      if (target instanceof HTMLSelectElement) return true;
      if (target instanceof HTMLInputElement) {{
        return target.id !== "console-command-input";
      }}
      if (target instanceof HTMLElement && target.isContentEditable) {{
        return true;
      }}
      const editableHost = target.closest("[contenteditable=''], [contenteditable='true'], [contenteditable='plaintext-only']");
      return editableHost instanceof HTMLElement;
    }}

    function bindConsoleDropdownHotkey() {{
      if (document.body.dataset.consoleHotkeyBound === "1") return;
      document.body.dataset.consoleHotkeyBound = "1";
      document.addEventListener("keydown", (ev) => {{
        if (!ev || ev.defaultPrevented) return;
        if (ev.isComposing || ev.repeat) return;
        if (ev.ctrlKey || ev.metaKey || ev.altKey) return;
        const key = String(ev.key || "");
        const code = String(ev.code || "");
        if (!(code === "Backquote" || key === "`" || key === "~")) return;
        const target = ev.target;
        if (
          activeLayoutView !== "console"
          && isConsoleHotkeyTextEntryTarget(target instanceof Element ? target : null)
        ) {{
          return;
        }}
        const remembered = normalizeLayoutView(consoleHotkeyReturnLayoutView || "chat");
        const nextView = activeLayoutView === "console"
          ? (remembered === "console" ? "chat" : remembered)
          : "console";
        ev.preventDefault();
        applyLayoutView(nextView, true);
      }});
    }}

    function consoleContextMenuElement() {{
      const menu = document.getElementById("console-context-menu");
      return menu instanceof HTMLElement ? menu : null;
    }}

    function canUseConsoleMenuScriptPaste() {{
      return !!(
        window.isSecureContext
        && navigator.clipboard
        && typeof navigator.clipboard.readText === "function"
      );
    }}

    function resolveConsoleContextMenuSelectionText() {{
      const pre = document.getElementById("live-console");
      return selectionTextWithin(pre instanceof HTMLElement ? pre : null);
    }}

    function selectAllConsoleText() {{
      const pre = document.getElementById("live-console");
      const selection = window.getSelection ? window.getSelection() : null;
      if (!(pre instanceof HTMLElement) || !selection || typeof selection.removeAllRanges !== "function") {{
        return false;
      }}
      try {{
        const range = document.createRange();
        range.selectNodeContents(pre);
        selection.removeAllRanges();
        selection.addRange(range);
        consoleContextMenuSelectionText = String(selection.toString() || "");
        return consoleContextMenuSelectionText.trim().length > 0;
      }} catch (_err) {{
        return false;
      }}
    }}

    function syncConsoleContextMenuActionState(menuEl = null) {{
      const menu = menuEl instanceof HTMLElement ? menuEl : consoleContextMenuElement();
      if (!(menu instanceof HTMLElement)) return;
      const pasteBtn = document.getElementById("console-context-menu-paste");
      const pasteLabel = document.getElementById("console-context-menu-paste-label");
      const pasteHint = document.getElementById("console-context-menu-paste-hint");
      const copyBtn = document.getElementById("console-context-menu-copy");
      const selectAllBtn = document.getElementById("console-context-menu-select-all");
      const selectionText = consoleContextMenuSelectionText || resolveConsoleContextMenuSelectionText();
      const pre = document.getElementById("live-console");
      const hasConsoleText = pre instanceof HTMLElement && String(pre.textContent || "").trim().length > 0;
      const supportsScriptPaste = canUseConsoleMenuScriptPaste();
      if (pasteLabel instanceof HTMLElement) {{
        pasteLabel.textContent = supportsScriptPaste ? "Paste" : "Use Ctrl+V";
      }}
      if (pasteHint instanceof HTMLElement) {{
        pasteHint.textContent = supportsScriptPaste ? "Ctrl+V" : "HTTP";
      }}
      if (pasteBtn instanceof HTMLButtonElement) {{
        pasteBtn.disabled = false;
        pasteBtn.title = supportsScriptPaste
          ? "Paste clipboard into the console"
          : "This HTTP page cannot read the clipboard directly. Click here to focus the console, then press Ctrl+V.";
      }}
      if (copyBtn instanceof HTMLButtonElement) {{
        copyBtn.disabled = selectionText.trim().length < 1;
        copyBtn.title = copyBtn.disabled
          ? "Select console text to copy"
          : "Copy the current console selection";
      }}
      if (selectAllBtn instanceof HTMLButtonElement) {{
        selectAllBtn.disabled = !hasConsoleText;
        selectAllBtn.title = hasConsoleText
          ? "Select the full console output"
          : "No console text to select";
      }}
    }}

    function setConsoleContextMenuOpen(open, options = null) {{
      const menu = consoleContextMenuElement();
      if (!(menu instanceof HTMLElement)) {{
        consoleContextMenuOpen = false;
        consoleContextMenuSelectionText = "";
        return;
      }}
      consoleContextMenuOpen = !!open;
      if (!consoleContextMenuOpen) {{
        consoleContextMenuSelectionText = "";
        menu.hidden = true;
        menu.style.removeProperty("left");
        menu.style.removeProperty("top");
        menu.style.removeProperty("visibility");
        return;
      }}
      const terminalScreen = document.getElementById("console-terminal-screen");
      if (!(terminalScreen instanceof HTMLElement)) {{
        consoleContextMenuOpen = false;
        menu.hidden = true;
        return;
      }}
      consoleContextMenuSelectionText = resolveConsoleContextMenuSelectionText();
      menu.hidden = false;
      menu.style.visibility = "hidden";
      syncConsoleContextMenuActionState(menu);
      const terminalRect = terminalScreen.getBoundingClientRect();
      const opts = (options && typeof options === "object") ? options : {{}};
      const rawClientX = Number(opts.clientX);
      const rawClientY = Number(opts.clientY);
      const clientX = Number.isFinite(rawClientX) && rawClientX > 0
        ? rawClientX
        : (terminalRect.left + 16);
      const clientY = Number.isFinite(rawClientY) && rawClientY > 0
        ? rawClientY
        : (terminalRect.top + 16);
      const menuRect = menu.getBoundingClientRect();
      const maxLeft = Math.max(8, terminalRect.width - menuRect.width - 8);
      const maxTop = Math.max(8, terminalRect.height - menuRect.height - 8);
      const nextLeft = Math.max(8, Math.min(maxLeft, clientX - terminalRect.left));
      const nextTop = Math.max(8, Math.min(maxTop, clientY - terminalRect.top));
      menu.style.left = `${{Math.round(nextLeft)}}px`;
      menu.style.top = `${{Math.round(nextTop)}}px`;
      menu.style.visibility = "";
    }}

    async function pasteConsoleFromContextMenu() {{
      focusConsoleCommandInput(false);
      const input = consoleCommandInputElement();
      if (!(input instanceof HTMLInputElement)) return false;
      if (!canUseConsoleMenuScriptPaste()) {{
        return false;
      }}
      try {{
        const pastedText = String(await navigator.clipboard.readText() || "");
        if (insertTextIntoConsoleCommandInput(pastedText, input)) {{
          return true;
        }}
      }} catch (_err) {{
      }}
      return false;
    }}

    function bindConsoleControls() {{
      ensureConsoleCommandsRegistered();
      bindConsoleDropdownHotkey();
      const pre = document.getElementById("live-console");
      if (pre instanceof HTMLElement && pre.dataset.scrollBound !== "1") {{
        pre.dataset.scrollBound = "1";
        pre.addEventListener("scroll", () => {{
          const maxTop = Math.max(0, pre.scrollHeight - pre.clientHeight);
          const remaining = Math.max(0, maxTop - pre.scrollTop);
          const atBottom = remaining <= 3;
          if (consoleAutoscroll !== atBottom) {{
            consoleAutoscroll = atBottom;
          }}
          if (typeof syncConsoleScrollStatus === "function") {{
            syncConsoleScrollStatus(pre);
          }}
        }});
        pre.addEventListener("mouseup", () => {{
          void copyConsoleSelectionToClipboard();
          if (consoleRenderDeferred) {{
            renderConsoleBuffer(false);
          }}
        }});
      }}
      if (
        pre instanceof HTMLElement
        && !consoleResizeObserver
        && typeof ResizeObserver !== "undefined"
      ) {{
        consoleResizeObserver = new ResizeObserver(() => {{
          if (activeLayoutView !== "console") return;
          applyConsoleBottomAnchor(pre);
          applyConsoleAutoscroll(pre, false);
          scheduleConsoleAnchorRefresh(pre, false);
        }});
        consoleResizeObserver.observe(pre);
      }}
      const terminalScreen = document.getElementById("console-terminal-screen");
      if (terminalScreen instanceof HTMLElement && terminalScreen.dataset.bound !== "1") {{
        terminalScreen.dataset.bound = "1";
        terminalScreen.addEventListener("click", (ev) => {{
          const target = ev.target;
          if (target instanceof HTMLButtonElement) return;
          const pre = document.getElementById("live-console");
          const selection = window.getSelection ? window.getSelection() : null;
          const hasConsoleSelection = selectionIntersectsElement(
            selection,
            pre instanceof HTMLElement ? pre : null
          ) && String(selection ? selection.toString() : "").trim();
          if (hasConsoleSelection) return;
          focusConsoleCommandInput(false);
        }});
        terminalScreen.addEventListener("paste", (ev) => {{
          handleConsolePasteEvent(ev);
        }});
        terminalScreen.addEventListener("contextmenu", (ev) => {{
          if (activeLayoutView !== "console") return;
          ev.preventDefault();
          setConsoleContextMenuOpen(true, {{
            clientX: ev.clientX,
            clientY: ev.clientY,
          }});
        }});
      }}
      if (terminalScreen instanceof HTMLElement && terminalScreen.dataset.fillBound !== "1") {{
        terminalScreen.dataset.fillBound = "1";
        const scheduleConsoleFillOnResume = () => {{
          if (activeLayoutView !== "console") return;
          scheduleConsoleTerminalScreenFillHeight();
        }};
        window.addEventListener("resize", () => {{
          if (consoleContextMenuOpen) {{
            setConsoleContextMenuOpen(false);
          }}
          scheduleConsoleTerminalScreenFillHeight();
        }}, {{ passive: true }});
        window.addEventListener("focus", scheduleConsoleFillOnResume, {{ passive: true }});
        window.addEventListener("pageshow", scheduleConsoleFillOnResume, {{ passive: true }});
        document.addEventListener("visibilitychange", () => {{
          if (!document.hidden) {{
            scheduleConsoleFillOnResume();
          }}
        }});
        if (window.visualViewport && typeof window.visualViewport.addEventListener === "function") {{
          window.visualViewport.addEventListener("resize", () => {{
            scheduleConsoleTerminalScreenFillHeight();
          }}, {{ passive: true }});
        }}
      }}
      applyConsoleFontSizePreference();
      scheduleConsoleTerminalScreenFillHeight();
      const input = consoleCommandInputElement();
      if (input instanceof HTMLInputElement && input.dataset.bound !== "1") {{
        input.dataset.bound = "1";
        input.addEventListener("focus", () => {{
          consoleCursorVisible = true;
          renderConsolePromptBuffer(false);
        }});
        input.addEventListener("blur", () => {{
          consoleCursorVisible = false;
          resetConsoleAutocompleteState();
          renderConsolePromptBuffer(false);
        }});
        input.addEventListener("input", () => {{
          resetConsoleAutocompleteState();
          const searchState = (typeof syncConsoleSearchFromDraft === "function")
            ? syncConsoleSearchFromDraft(input.value)
            : {{ active: false, changed: false }};
          if (searchState.active || searchState.changed) {{
            renderConsoleBuffer(false);
            return;
          }}
          renderConsolePromptBuffer(false);
        }});
        const rerenderForCaretMove = () => {{
          if (document.activeElement === input) {{
            renderConsolePromptBuffer(false);
          }}
        }};
        input.addEventListener("select", rerenderForCaretMove);
        input.addEventListener("keyup", rerenderForCaretMove);
        input.addEventListener("click", rerenderForCaretMove);
        input.addEventListener("mouseup", rerenderForCaretMove);
        input.addEventListener("paste", (ev) => {{
          handleConsolePasteEvent(ev);
        }});
        input.addEventListener("keydown", (ev) => {{
          const resetInputAfterInterrupt = () => {{
            input.value = "";
            consoleCommandHistoryCursor = -1;
            consoleCommandDraft = "";
            resetConsoleAutocompleteState();
            renderConsolePromptBuffer(false);
          }};
          if ((ev.ctrlKey || ev.metaKey) && !ev.shiftKey && !ev.altKey && String(ev.key || "").toLowerCase() === "c") {{
            const pre = document.getElementById("live-console");
            const selection = window.getSelection ? window.getSelection() : null;
            const hasConsoleSelection = selectionIntersectsElement(
              selection,
              pre instanceof HTMLElement ? pre : null
            ) && String(selection ? selection.toString() : "").trim();
            if (!consoleRunningCommand && !consoleInteractiveSession && hasConsoleSelection) {{
              ev.preventDefault();
              void copyConsoleSelectionToClipboard();
              return;
            }}
            if (consoleRunningCommand || consoleInteractiveSession) {{
              ev.preventDefault();
              appendConsoleEventLine("^C");
              if (!stopConsoleRunningCommand("interrupted", true)) {{
                stopConsoleInteractiveSession("interrupted", true);
              }}
              resetInputAfterInterrupt();
            }}
            return;
          }}
          if (
            !ev.ctrlKey
            && !ev.metaKey
            && !ev.altKey
            && String(ev.key || "").toLowerCase() === "q"
            && consoleRunningCommand
            && String(consoleRunningCommand.name || "").trim().toLowerCase() === "live"
          ) {{
            ev.preventDefault();
            stopConsoleRunningCommand("quit", true);
            resetInputAfterInterrupt();
            return;
          }}
          if (ev.key === "Tab" && !ev.ctrlKey && !ev.metaKey && !ev.altKey) {{
            ev.preventDefault();
            handleConsoleTabAutocomplete(input, latestState, ev.shiftKey);
            return;
          }}
          if (ev.key === "Enter" && !ev.shiftKey && !ev.ctrlKey && !ev.metaKey && !ev.altKey) {{
            ev.preventDefault();
            const searchState = (typeof syncConsoleSearchFromDraft === "function")
              ? syncConsoleSearchFromDraft(input.value)
              : {{ active: false }};
            if (searchState.active) {{
              renderConsoleBuffer(false);
              focusConsoleCommandInput(false);
              return;
            }}
            const cmdLine = input.value;
            input.value = "";
            consoleCommandHistoryCursor = -1;
            consoleCommandDraft = "";
            resetConsoleAutocompleteState();
            renderConsolePromptBuffer(false);
            void runConsoleCommandLine(cmdLine);
            focusConsoleCommandInput(false);
            return;
          }}
          if (ev.key === "ArrowUp" && !ev.shiftKey && !ev.ctrlKey && !ev.metaKey && !ev.altKey) {{
            ev.preventDefault();
            resetConsoleAutocompleteState();
            navigateConsoleHistory(-1, input);
            return;
          }}
          if (ev.key === "ArrowDown" && !ev.shiftKey && !ev.ctrlKey && !ev.metaKey && !ev.altKey) {{
            ev.preventDefault();
            resetConsoleAutocompleteState();
            navigateConsoleHistory(1, input);
          }}
        }});
      }}
      const contextMenu = consoleContextMenuElement();
      if (contextMenu instanceof HTMLElement && contextMenu.dataset.bound !== "1") {{
        contextMenu.dataset.bound = "1";
        contextMenu.addEventListener("mousedown", (ev) => {{
          const target = ev.target;
          if (!(target instanceof Element)) return;
          if (target.closest(".console-context-menu-item")) {{
            ev.preventDefault();
          }}
        }});
        contextMenu.addEventListener("contextmenu", (ev) => {{
          ev.preventDefault();
          ev.stopPropagation();
        }});
        contextMenu.addEventListener("click", async (ev) => {{
          const target = ev.target;
          if (!(target instanceof Element)) return;
          const item = target.closest(".console-context-menu-item");
          if (!(item instanceof HTMLButtonElement)) return;
          ev.preventDefault();
          ev.stopPropagation();
          const action = String(item.dataset.consoleAction || "").trim().toLowerCase();
          const selectionText = consoleContextMenuSelectionText || resolveConsoleContextMenuSelectionText();
          setConsoleContextMenuOpen(false);
          if (action === "paste") {{
            await pasteConsoleFromContextMenu();
            return;
          }}
          if (action === "copy") {{
            if (selectionText.trim() && typeof copyTextToClipboard === "function") {{
              await copyTextToClipboard(selectionText);
            }}
            return;
          }}
          if (action === "select-all") {{
            selectAllConsoleText();
          }}
        }});
      }}
      if (document.body.dataset.consoleContextMenuDocBound !== "1") {{
        document.body.dataset.consoleContextMenuDocBound = "1";
        document.addEventListener("pointerdown", (ev) => {{
          if (!consoleContextMenuOpen) return;
          const target = ev.target;
          if (target instanceof Element && target.closest("#console-context-menu")) {{
            return;
          }}
          if (
            target instanceof Element
            && target.closest("#console-terminal-screen")
            && Number(ev.button) === 2
          ) {{
            return;
          }}
          setConsoleContextMenuOpen(false);
        }});
        document.addEventListener("keydown", (ev) => {{
          if (ev.key !== "Escape" || !consoleContextMenuOpen) return;
          setConsoleContextMenuOpen(false);
        }});
        document.addEventListener("scroll", () => {{
          if (consoleContextMenuOpen) {{
            setConsoleContextMenuOpen(false);
          }}
        }}, true);
        window.addEventListener("blur", () => {{
          if (consoleContextMenuOpen) {{
            setConsoleContextMenuOpen(false);
          }}
        }});
      }}
      startConsoleCursorBlink();
      syncConsoleCommandInputState();
      renderConsoleBuffer(false);
    }}

    function renderConsole(traffic) {{
      if (consoleLiveModeActive) {{
        const packets = Array.isArray(traffic && traffic.recent_packets) ? traffic.recent_packets : [];
        const verbosityLevel = Math.max(0, Math.min(4, Number(consoleLiveVerbosity) || 0));
        const layerSignature = formatConsoleLiveLayerLabel(consoleLiveLayers)
          .replace(/\s+/g, "")
          .toLowerCase();
        const viewSignature = `v${{verbosityLevel}}|${{layerSignature || "legacy"}}`;
        for (const entry of packets) {{
          const key = packetConsoleKey(entry);
          const summary = entry && entry.summary && typeof entry.summary === "object" ? entry.summary : {{}};
          const packetUnix = latestUnixTimestamp(summary.captured_at, summary.rx_time);
          const packetMs = Number.isFinite(packetUnix) && packetUnix > 0
            ? packetUnix * 1000
            : Date.now();
          const lines = formatConsoleLine(entry, consoleLiveVerbosity);
          const lineList = Array.isArray(lines) ? lines : [String(lines == null ? "" : lines)];
          lineList.forEach((line, index) => {{
            appendConsoleLine(`${{key}}|${{viewSignature}}|${{index}}`, line, packetMs);
          }});
        }}
      }}
      renderConsoleBuffer();
    }}
