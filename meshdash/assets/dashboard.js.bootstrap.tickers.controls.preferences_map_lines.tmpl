    function bindMapPacketLinesControl() {{
      const toggle = document.getElementById("map-lines-toggle");
      if (toggle instanceof HTMLInputElement && toggle.dataset.bound !== "1") {{
        toggle.dataset.bound = "1";
        toggle.checked = mapPacketLinesEnabled;
        toggle.addEventListener("change", () => {{
          mapPacketLinesEnabled = !!toggle.checked;
          persistMapPacketLinesPreference();
          updateMapPacketLinesControl();
          lastMapSignature = "";
          lastMapGraphSignature = "";
          lastMapRenderMode = "";
          if (latestState && activeLayoutView === "network") {{
            renderMap(
              latestState.nodes || [],
              (latestState.traffic || {{}}).edges || [],
              null
            );
          }}
        }});
      }}
      updateMapPacketLinesControl();
    }}

