    function buildFileTransferRows(state = latestState) {{
      const frameState = collectFileTransferFrames(state, {{ respectActiveChannel: true }});
      const transfers = frameState.transfers;
      const ackByTransferKey = frameState.ackByTransferKey;
      const nodesById = frameState.nodesById;
      const localNodeId = frameState.localNodeId;
      const rows = [];
      for (const transfer of transfers.values()) {{
        const direction = fileTransferDirectionMeta(transfer.fromId, transfer.toId, localNodeId);
        const peerMeta = fileTransferPeerMeta(direction.peerId, nodesById, localNodeId);
        const expectedChunks = Number.isInteger(transfer.totalChunks) && transfer.totalChunks > 0
          ? transfer.totalChunks
          : Math.max(transfer.chunks.size, 1);
        const receivedChunks = transfer.chunks.size;
        let contiguous = receivedChunks >= expectedChunks;
        if (contiguous) {{
          for (let idx = 0; idx < expectedChunks; idx += 1) {{
            if (!(transfer.chunks.get(idx) instanceof Uint8Array)) {{
              contiguous = false;
              break;
            }}
          }}
        }}

        let observedBytes = 0;
        for (const bytes of transfer.chunks.values()) {{
          observedBytes += Number(bytes && bytes.length) || 0;
        }}

        const declaredBytes = Number.isFinite(transfer.fileSize) ? Math.max(0, Math.trunc(Number(transfer.fileSize) || 0)) : null;
        let assembled = null;
        let complete = false;
        let assembleError = "";
        if (contiguous && expectedChunks > 0) {{
          let totalLen = 0;
          for (let idx = 0; idx < expectedChunks; idx += 1) {{
            const part = transfer.chunks.get(idx);
            totalLen += Number(part && part.length) || 0;
          }}
          const merged = new Uint8Array(totalLen);
          let cursor = 0;
          for (let idx = 0; idx < expectedChunks; idx += 1) {{
            const part = transfer.chunks.get(idx);
            if (!(part instanceof Uint8Array)) {{
              assembleError = "Missing chunk data";
              break;
            }}
            merged.set(part, cursor);
            cursor += part.length;
          }}
          if (!assembleError) {{
            let mergedView = merged;
            if (declaredBytes != null) {{
              if (declaredBytes < merged.length) {{
                mergedView = merged.slice(0, declaredBytes);
              }} else if (declaredBytes > merged.length) {{
                assembleError = `Missing ${{declaredBytes - merged.length}} byte${{declaredBytes - merged.length === 1 ? "" : "s"}}`;
              }}
            }}
            if (!assembleError) {{
              assembled = new Uint8Array(mergedView);
              complete = true;
            }}
          }}
        }}

        const percent = Math.max(
          0,
          Math.min(100, Math.round((receivedChunks / Math.max(expectedChunks, 1)) * 100))
        );
        const outgoing = direction.className === "outbound";
        const ack = outgoing ? (ackByTransferKey.get(transfer.key) || null) : null;
        const ackedChunks = ack
          ? Math.max(
            0,
            Math.min(
              expectedChunks,
              Math.max(
                Number(ack.receivedCount || 0),
                (ack.receivedSet instanceof Set ? ack.receivedSet.size : 0)
              )
            )
          )
          : 0;
        const deliveryPct = Math.max(0, Math.min(100, Math.round((ackedChunks / Math.max(expectedChunks, 1)) * 100)));
        const outgoingSession = outgoing
          ? findOutgoingFileTransferSession(transfer.transferId, transfer.toId, transfer.channelIndex)
          : null;
        const transferChannelIndex = fileTransferExplicitChannelIndex(transfer.channelIndex);
        const sessionChannelIndex = fileTransferExplicitChannelIndex(outgoingSession && outgoingSession.channelIndex);
        const resolvedChannelIndex = transferChannelIndex != null ? transferChannelIndex : sessionChannelIndex;
        let delivered = outgoing
          ? !!(ack && ack.complete && ackedChunks >= expectedChunks)
          : complete;
        if (outgoingSession && outgoingSession.delivered) {{
          delivered = true;
        }}

        let progressLabel = "";
        let progressSort = 0;
        let outgoingRetrying = false;
        if (outgoing) {{
          if (outgoingSession && outgoingSession.failed && !delivered) {{
            progressLabel = `Delivery failed (${{ackedChunks}}/${{expectedChunks}} acked)`;
            progressSort = deliveryPct;
          }} else if (delivered) {{
            progressLabel = `Delivered (${{Math.max(ackedChunks, expectedChunks)}}/${{expectedChunks}} acked)`;
            progressSort = 220;
          }} else if (ack) {{
            progressLabel = `${{deliveryPct}}% delivered (${{ackedChunks}}/${{expectedChunks}} acked)`;
            progressSort = 100 + deliveryPct;
          }} else {{
            progressLabel = `Awaiting ACK (0/${{expectedChunks}} acked)`;
            progressSort = 25;
          }}
          const activeRetries = Math.max(
            0,
            Math.trunc(Number(outgoingSession && outgoingSession.retriesSinceProgress) || Number(outgoingSession && outgoingSession.retryAttempts) || 0)
          );
          if (outgoingSession && !outgoingSession.delivered && !outgoingSession.failed && activeRetries > 0) {{
            outgoingRetrying = true;
            progressLabel = `${{progressLabel}} • retry ${{activeRetries}}/${{outgoingSession.maxRetries}}`;
          }}
        }} else {{
          progressLabel = complete
            ? "Complete"
            : `${{percent}}% (${{receivedChunks}}/${{expectedChunks}} chunks)`;
          progressSort = complete ? 100 : percent;
          if (!complete && transfer.hasDecodeError) {{
            progressLabel = "Error (invalid chunk)";
          }} else if (!complete && assembleError) {{
            progressLabel = `Error (${{assembleError}})`;
          }}
        }}

        const sizeLabel = (() => {{
          if (declaredBytes == null) {{
            return formatFileTransferSize(observedBytes);
          }}
          if (complete || observedBytes <= 0) {{
            return formatFileTransferSize(declaredBytes);
          }}
          if (observedBytes === declaredBytes) {{
            return formatFileTransferSize(declaredBytes);
          }}
          return `${{formatFileTransferSize(observedBytes)}} / ${{formatFileTransferSize(declaredBytes)}}`;
        }})();
        const fileName = normalizeFileTransferName(transfer.fileName || `file-${{transfer.transferId}}.bin`);
        const channelLabel = resolvedChannelIndex == null
          ? "Unknown"
          : meshChannelLabelForIndex(resolvedChannelIndex, {{ allowAll: false }});
        const sortUnix = Number(transfer.latestUnix || transfer.firstUnix || 0);
        rows.push({{
          key: transfer.key,
          transferId: transfer.transferId,
          unix: sortUnix > 0 ? sortUnix : null,
          sortUnix,
          directionClass: direction.className,
          directionLabel: direction.label,
          peerId: direction.peerId,
          peerLabel: peerMeta.label,
          peerTitle: peerMeta.title,
          fileName,
          downloadName: safeFileTransferDownloadName(fileName),
          progressLabel,
          progressSort,
          sizeLabel,
          sizeSort: declaredBytes != null ? declaredBytes : observedBytes,
          channelIndex: resolvedChannelIndex,
          channelLabel,
          delivered,
          outgoingRetrying,
          canDownload: complete && assembled instanceof Uint8Array,
          bytes: assembled,
        }});
      }}

      rows.sort((a, b) => {{
        const unixDiff = Number(b.sortUnix || 0) - Number(a.sortUnix || 0);
        if (unixDiff !== 0) return unixDiff;
        const nameDiff = String(a.fileName || "").localeCompare(String(b.fileName || ""));
        if (nameDiff !== 0) return nameDiff;
        return String(a.key || "").localeCompare(String(b.key || ""));
      }});
      return rows;
    }}

