            manualInput.focus({{ preventScroll: true }});
          }}
        }});
      }}

      if (detectedAddBtn instanceof HTMLButtonElement && detectedAddBtn.dataset.bound !== "1") {{
        detectedAddBtn.dataset.bound = "1";
        detectedAddBtn.addEventListener("click", () => {{
          const chosenId = normalizeNodeId(
            detectedSelect instanceof HTMLSelectElement ? detectedSelect.value : ""
          );
          const result = addManualDirectPeer(chosenId, {{ select: true }});
          if (!result.ok) {{
            setChatSendStatus(result.error || "Unable to add peer.", true);
            return;
          }}
          setChatSendStatus(
            result.added
              ? `Peer ${{result.id}} added to peer-to-peer list.`
              : `Peer ${{result.id}} is already in your peer-to-peer list.`
          );
          renderChatPeerAddPanel(latestState);
        }});
      }}

      if (detectedSelect instanceof HTMLSelectElement && detectedSelect.dataset.bound !== "1") {{
        detectedSelect.dataset.bound = "1";
        detectedSelect.addEventListener("change", () => {{
          renderChatPeerAddPanel(latestState);
        }});
      }}

      const submitManualPeer = () => {{
        const raw = manualInput instanceof HTMLInputElement ? manualInput.value : "";
        const result = addManualDirectPeer(raw, {{ select: true }});
        if (!result.ok) {{
          setChatSendStatus(result.error || "Unable to add peer.", true);
          if (manualInput instanceof HTMLInputElement) {{
            manualInput.focus({{ preventScroll: true }});
          }}
          return;
        }}
        if (manualInput instanceof HTMLInputElement) {{
          manualInput.value = "";
          manualInput.focus({{ preventScroll: true }});
        }}
        setChatSendStatus(
          result.added
            ? `Peer ${{result.id}} added to peer-to-peer list.`
            : `Peer ${{result.id}} is already in your peer-to-peer list.`
        );
        renderChatPeerAddPanel(latestState);
      }};

      if (manualAddBtn instanceof HTMLButtonElement && manualAddBtn.dataset.bound !== "1") {{
        manualAddBtn.dataset.bound = "1";
        manualAddBtn.addEventListener("click", () => {{
          submitManualPeer();
        }});
      }}

      if (manualInput instanceof HTMLInputElement && manualInput.dataset.bound !== "1") {{
        manualInput.dataset.bound = "1";
        manualInput.addEventListener("keydown", (ev) => {{
          if (ev.key !== "Enter") return;
          ev.preventDefault();
          submitManualPeer();
        }});
      }}

      if (savedList instanceof HTMLElement && savedList.dataset.bound !== "1") {{
        savedList.dataset.bound = "1";
        savedList.addEventListener("click", (ev) => {{
          const target = ev.target;
          if (!(target instanceof Element)) return;
          const removeBtn = target.closest(".chat-peer-saved-remove-btn");
          if (!(removeBtn instanceof HTMLButtonElement)) return;
          ev.preventDefault();
          ev.stopPropagation();
          const nodeId = normalizeNodeId(removeBtn.dataset.nodeId || "");
          if (!isCanonicalNodeId(nodeId)) return;
          const removed = removeManualDirectPeer(nodeId);
          if (!removed) return;
          setChatSendStatus(`Peer ${{nodeId}} removed from peer-to-peer list.`);
          renderChatPeerAddPanel(latestState);
        }});
      }}

      renderChatPeerAddPanel(latestState);
    }}

    function normalizeChatEmojiGroup(raw) {{
      const clean = String(raw || "").trim().toLowerCase();
      if (!clean || clean === "all") return "all";
      return chatEmojiGroupsById.has(clean) ? clean : "all";
    }}

    function normalizeChatEmojiSearchQuery(raw) {{
      const lowered = String(raw || "").trim().toLowerCase();
      if (!lowered) return "";
      const noShortcodeColons = lowered.replace(/(^:+|:+$)/g, " ");
      return noShortcodeColons
        .replace(/[_-]+/g, " ")
        .replace(/[^a-z0-9+ ]+/g, " ")
        .replace(/\s+/g, " ")
        .trim();
    }}

    function stemChatEmojiSearchToken(rawToken) {{
      const token = String(rawToken || "").trim().toLowerCase();
      if (!token) return "";
      if (token.endsWith("ies") && token.length > 4) {{
        return `${{token.slice(0, -3)}}y`;
      }}
      if (token.endsWith("ing") && token.length > 5) {{
        return token.slice(0, -3);
      }}
      if (token.endsWith("ed") && token.length > 4) {{
        return token.slice(0, -2);
      }}
      if (token.endsWith("es") && token.length > 4) {{
        return token.slice(0, -2);
      }}
      if (token.endsWith("s") && token.length > 3) {{
        return token.slice(0, -1);
      }}
      return token;
    }}

    function tokenizeChatEmojiSearchQuery(rawQuery) {{
      const normalized = normalizeChatEmojiSearchQuery(rawQuery);
      if (!normalized) return [];
      const seen = new Set();
      const out = [];
      for (const rawToken of normalized.split(/\s+/g)) {{
        const token = String(rawToken || "").trim();
        if (!token) continue;
        if (!seen.has(token)) {{
          seen.add(token);
          out.push(token);
        }}
        const stemmed = stemChatEmojiSearchToken(token);
        if (stemmed && !seen.has(stemmed)) {{
          seen.add(stemmed);
          out.push(stemmed);
        }}
      }}
      return out;
    }}

    function tokenizeChatEmojiSearchAliasParts(queryParts) {{
      const base = Array.isArray(queryParts) ? queryParts : [];
      if (!base.length) return [];
      const seen = new Set(base);
      const out = [];
      for (const token of base) {{
        const aliasText = String(chatEmojiQueryKeywordAliases[token] || "").trim();
        if (!aliasText) continue;
        for (const aliasToken of tokenizeChatEmojiSearchQuery(aliasText)) {{
          if (!aliasToken || seen.has(aliasToken)) continue;
          seen.add(aliasToken);
          out.push(aliasToken);
        }}
      }}
      return out;
    }}

    function collectChatEmojiCodepointAliasParts(rawEmoji) {{
      const text = String(rawEmoji || "").trim();
      if (!text) return [];
      const out = [];
      const seen = new Set();
      for (const ch of text) {{
        const cp = ch.codePointAt(0);
        if (!Number.isInteger(cp)) continue;
        if (chatEmojiCodepointIgnoredSet.has(cp)) continue;
        if (cp >= 0xe0020 && cp <= 0xe007f) continue;
        const key = cp.toString(16);
        const keywords = String(chatEmojiCodepointKeywordMap[key] || "").trim();
        if (!keywords) continue;
        for (const part of tokenizeChatEmojiSearchQuery(keywords)) {{
          if (!part || seen.has(part)) continue;
          seen.add(part);
          out.push(part);
        }}
      }}
      return out;
    }}

    function boundedLevenshteinDistance(aRaw, bRaw, maxDistance = 2) {{
      const a = String(aRaw || "");
      const b = String(bRaw || "");
      if (a === b) return 0;
      if (!a || !b) {{
        return Math.max(a.length, b.length);
      }}
      const aLen = a.length;
      const bLen = b.length;
      if (Math.abs(aLen - bLen) > maxDistance) {{
        return maxDistance + 1;
      }}
      let prev = new Array(bLen + 1).fill(0);
      let curr = new Array(bLen + 1).fill(0);
      for (let j = 0; j <= bLen; j += 1) {{
        prev[j] = j;
      }}
      for (let i = 1; i <= aLen; i += 1) {{
        curr[0] = i;
        for (let j = 1; j <= bLen; j += 1) {{
          const cost = a[i - 1] === b[j - 1] ? 0 : 1;
          curr[j] = Math.min(
            prev[j] + 1,
            curr[j - 1] + 1,
            prev[j - 1] + cost
          );
        }}
        const swap = prev;
        prev = curr;
        curr = swap;
      }}
      return prev[bLen];
    }}

    function scoreChatEmojiPartMatch(part, tokens, searchText, allowFuzzy = false) {{
      if (!part) return 0;
      let best = 0;
      for (const token of tokens) {{
        if (!token) continue;
        if (token === part) {{
          best = Math.max(best, 460);
          continue;
        }}
        if (token.startsWith(part)) {{
          best = Math.max(best, 320);
          continue;
        }}
        if (token.includes(part)) {{
          best = Math.max(best, 180);
        }}
      }}
      if (best > 0) {{
        return best;
      }}
      if (searchText.includes(part)) {{
        return 120;
      }}
      if (!allowFuzzy || part.length < 4) {{
        return 0;
      }}

      const maxDistance = part.length >= 8 ? 2 : 1;
      let closest = maxDistance + 1;
      for (const token of tokens) {{
        if (!token || token.length < 3) continue;
        const distance = boundedLevenshteinDistance(part, token, maxDistance);
        if (distance < closest) {{
          closest = distance;
        }}
        if (closest === 0) {{
          break;
        }}
      }}
      if (closest > maxDistance) {{
        return 0;
      }}
      return closest <= 1 ? 90 : 52;
    }}

    function scoreChatEmojiSearchMatch(emoji, queryText, queryParts, allowFuzzy = false) {{
      const tokens = chatEmojiSearchTokensByEmoji.get(emoji) || [];
      if (!tokens.length) {{
        return 0;
      }}
      const searchText = String(chatEmojiSearchMetaByEmoji.get(emoji) || "");
      let score = 0;
      for (const part of queryParts) {{
        const partScore = scoreChatEmojiPartMatch(part, tokens, searchText, allowFuzzy);
        if (partScore <= 0) {{
          return 0;
        }}
        score += partScore;
      }}
      if (queryText && searchText.includes(queryText)) {{
        score += 35;
      }}
      return score;
    }}

    function rankChatEmojiSearchMatches(rawQuery, queryParts, allowFuzzy = false) {{
      const queryText = normalizeChatEmojiSearchQuery(rawQuery);
      const ranked = [];
      const seen = new Set();
      for (const emoji of chatEmojiAllChoices) {{
        if (seen.has(emoji)) continue;
        seen.add(emoji);
        const score = scoreChatEmojiSearchMatch(
          emoji,
          queryText,
          queryParts,
          allowFuzzy,
        );
        if (score <= 0) {{
          continue;
        }}
        ranked.push({{
          emoji,
          score,
          order: Number(chatEmojiChoiceOrder.get(emoji) || 0),
        }});
      }}
      ranked.sort((a, b) => (b.score - a.score) || (a.order - b.order));
      return ranked.map((entry) => entry.emoji);
    }}

    function rankChatEmojiSearchMatchesAnyPart(rawQuery, queryParts, allowFuzzy = false) {{
      const queryText = normalizeChatEmojiSearchQuery(rawQuery);
      const ranked = [];
      const seen = new Set();
      for (const emoji of chatEmojiAllChoices) {{
        if (seen.has(emoji)) continue;
        seen.add(emoji);
        const tokens = chatEmojiSearchTokensByEmoji.get(emoji) || [];
        if (!tokens.length) continue;
        const searchText = String(chatEmojiSearchMetaByEmoji.get(emoji) || "");
        let matchedParts = 0;
        let score = 0;
        for (const part of queryParts) {{
          const partScore = scoreChatEmojiPartMatch(part, tokens, searchText, allowFuzzy);
          if (partScore <= 0) continue;
          matchedParts += 1;
          score += partScore;
        }}
        if (matchedParts <= 0) {{
          continue;
        }}
        if (queryText && searchText.includes(queryText)) {{
          score += 28;
        }}
        score += matchedParts * 24;
        ranked.push({{
          emoji,
          score,
          matchedParts,
          order: Number(chatEmojiChoiceOrder.get(emoji) || 0),
        }});
      }}
      ranked.sort((a, b) => (
        (b.score - a.score)
        || (b.matchedParts - a.matchedParts)
        || (a.order - b.order)
      ));
      return ranked.map((entry) => entry.emoji);
    }}

    const reactionEmojiIgnoredCodepoints = new Set([0xFE0E, 0xFE0F]);

    function reactionEmojiCodepoint(rawEmoji) {{
      const text = String(rawEmoji == null ? "" : rawEmoji).trim();
      if (!text) return null;
      let baseCodepoint = null;
      for (const ch of text) {{
        const cp = ch.codePointAt(0);
        if (!Number.isInteger(cp)) continue;
        if (reactionEmojiIgnoredCodepoints.has(cp)) continue;
        if (baseCodepoint !== null) {{
          return null;
        }}
        baseCodepoint = cp;
      }}
      return Number.isInteger(baseCodepoint) && baseCodepoint > 0 ? baseCodepoint : null;
    }}

    function isReactionCompatibleEmoji(rawEmoji) {{
      return Number.isInteger(reactionEmojiCodepoint(rawEmoji));
    }}

    function reactionCompatibleEmojiChoices(rawChoices) {{
      const list = Array.isArray(rawChoices) ? rawChoices : [];
      const deduped = [];
      const seen = new Set();
      for (const emoji of list) {{
        const clean = String(emoji || "").trim();
        if (!clean || seen.has(clean)) continue;
        seen.add(clean);
        if (!isReactionCompatibleEmoji(clean)) continue;
        deduped.push(clean);
      }}
      return deduped;
    }}

    function chatEmojiChoicesForGroup(groupId) {{
      const key = normalizeChatEmojiGroup(groupId);
      if (key === "all") return chatEmojiAllChoices;
      const group = chatEmojiGroupsById.get(key);
      if (group && Array.isArray(group.emojis)) {{
        return group.emojis;
      }}
      return chatEmojiAllChoices;
    }}

    function chatEmojiChoicesForSearch(rawQuery) {{
      const rawText = String(rawQuery || "").trim();
      if (rawText && chatEmojiChoiceSet.has(rawText)) {{
        return [rawText];
      }}
      const query = normalizeChatEmojiSearchQuery(rawQuery);
      if (!query) return [];
      const cached = chatEmojiSearchCache.get(query);
      if (Array.isArray(cached)) {{
        return cached;
      }}

      const parts = tokenizeChatEmojiSearchQuery(query);
      if (!parts.length) return [];
      const aliasParts = tokenizeChatEmojiSearchAliasParts(parts);
      let matches = rankChatEmojiSearchMatches(query, parts, false);
      if (!matches.length) {{
        matches = rankChatEmojiSearchMatches(query, parts, true);
      }}
      if (!matches.length) {{
        const fallbackParts = aliasParts.length ? parts.concat(aliasParts) : parts;
        matches = rankChatEmojiSearchMatchesAnyPart(query, fallbackParts, false);
      }}
      if (!matches.length) {{
        const fallbackParts = aliasParts.length ? parts.concat(aliasParts) : parts;
        matches = rankChatEmojiSearchMatchesAnyPart(query, fallbackParts, true);
      }}
      chatEmojiSearchCache.set(query, matches);
      return matches;
    }}

    function buildChatEmojiNode(emoji, extraClass = "") {{
      const btn = document.createElement("button");
      btn.type = "button";
      btn.className = extraClass ? `chat-emoji-item ${{extraClass}}` : "chat-emoji-item";
      btn.setAttribute("data-emoji", emoji);
      btn.setAttribute("title", emoji);
      btn.textContent = emoji;
      return btn;
    }}

    function chatEmojiNodesForGroup(groupId) {{
      const key = normalizeChatEmojiGroup(groupId);
      const cached = chatEmojiNodesByGroup.get(key);
      if (Array.isArray(cached)) {{
        return cached;
      }}
      const nodes = [];
      for (const emoji of chatEmojiChoicesForGroup(key)) {{
        nodes.push(buildChatEmojiNode(emoji));
      }}
      chatEmojiNodesByGroup.set(key, nodes);
      return nodes;
    }}

    function chatEmojiUsageEntries() {{
      const enforceChoiceSet = chatEmojiChoiceSet.size > 0;
      return Array.from(chatEmojiUsageCounts.entries())
        .filter(([emoji, count]) => (
          (!enforceChoiceSet || chatEmojiChoiceSet.has(emoji))
          && Number.isFinite(count)
          && count > 0
        ))
        .sort((a, b) => (b[1] - a[1]) || String(a[0]).localeCompare(String(b[0])));
    }}

    function chatEmojiTopChoices() {{
      const picked = [];
      const used = new Set();
      for (const [emoji] of chatEmojiUsageEntries()) {{
        if (used.has(emoji)) continue;
        used.add(emoji);
        picked.push(emoji);
        if (picked.length >= chatEmojiTopUsageCount) {{
          return picked;
        }}
      }}
      for (const emoji of chatEmojiPopularDefaults) {{
        if (!chatEmojiChoiceSet.has(emoji) || used.has(emoji)) continue;
        used.add(emoji);
        picked.push(emoji);
        if (picked.length >= chatEmojiTopUsageCount) {{
          break;
        }}
      }}
      return picked;
    }}

    function persistChatEmojiUsage() {{
      try {{
        const entries = chatEmojiUsageEntries().slice(0, chatEmojiUsagePersistMax);
        const payload = {{}};
        for (const [emoji, count] of entries) {{
          payload[emoji] = count;
        }}
        window.localStorage.setItem(chatEmojiUsageStorageKey, JSON.stringify(payload));
      }} catch (_err) {{
      }}
    }}

    function loadChatEmojiUsage() {{
      const next = new Map();
      const enforceChoiceSet = chatEmojiChoiceSet.size > 0;
      try {{
        const raw = window.localStorage.getItem(chatEmojiUsageStorageKey);
        if (raw) {{
          const parsed = JSON.parse(raw);
          if (parsed && typeof parsed === "object" && !Array.isArray(parsed)) {{
            for (const [emojiRaw, countRaw] of Object.entries(parsed)) {{
              const emoji = String(emojiRaw || "").trim();
              const count = Math.floor(Number(countRaw));
              if (!emoji || (enforceChoiceSet && !chatEmojiChoiceSet.has(emoji)) || !Number.isFinite(count) || count <= 0) {{
                continue;
              }}
              next.set(emoji, count);
            }}
          }}
        }}
      }} catch (_err) {{
      }}
      chatEmojiUsageCounts = next;
    }}

    function noteChatEmojiUsage(rawEmoji) {{
      const emoji = String(rawEmoji || "").trim();
      if (!emoji) return;
      if (chatEmojiChoiceSet.size > 0 && !chatEmojiChoiceSet.has(emoji)) return;
      const nextCount = (chatEmojiUsageCounts.get(emoji) || 0) + 1;
      chatEmojiUsageCounts.set(emoji, nextCount);
      persistChatEmojiUsage();
    }}

    function persistChatEmojiPickerState() {{
      try {{
        window.localStorage.setItem(
          chatEmojiPickerStateStorageKey,
          JSON.stringify({{
            group: chatEmojiPickerGroup,
          }})
        );
      }} catch (_err) {{
      }}
    }}

    function loadChatEmojiPickerState() {{
      let preferredGroup = chatEmojiDefaultGroup;
      try {{
        const raw = window.localStorage.getItem(chatEmojiPickerStateStorageKey);
        if (raw) {{
          const parsed = JSON.parse(raw);
          if (parsed && typeof parsed === "object" && !Array.isArray(parsed)) {{
            const storedGroup = String(parsed.group || "").trim();
            if (storedGroup) {{
              if (chatEmojiGroupsById.size <= 0) {{
                preferredGroup = String(storedGroup || "").trim().toLowerCase() || chatEmojiDefaultGroup;
              }} else {{
                const normalized = normalizeChatEmojiGroup(storedGroup);
                preferredGroup = (
                  normalized === "all" && storedGroup.toLowerCase() !== "all"
                ) ? chatEmojiDefaultGroup : normalized;
              }}
            }}
          }}
        }}
      }} catch (_err) {{
      }}
      chatEmojiPickerGroup = preferredGroup;
    }}

    function classifyMessageChannel(msg) {{
      if (!msg || typeof msg !== "object") return "all";
      const toId = normalizeNodeId(msg.to || msg.destination || "");
      if (!toId || toId === "^all" || toId === "all" || toId === "broadcast") {{
        return "all";
      }}
      if (typeof msg.scope === "string" && msg.scope.trim()) {{
        return normalizeChatChannel(msg.scope);
      }}
      return "direct";
    }}

    async function sendChatPayload(body, successMessage) {{
      if (chatSendInFlight) return null;
      setChatSendBusy(true);
      setChatSendStatus("Sending...");
      try {{
        const resp = await fetch("/api/chat/send", {{
          method: "POST",
          headers: {{ "Content-Type": "application/json" }},
          body: JSON.stringify(body || {{}}),
        }});
        const payload = await resp.json().catch(() => ({{}}));
        if (!resp.ok || !payload.ok) {{
          const msg = payload && payload.error ? payload.error : `send failed (${{resp.status}})`;
          throw new Error(msg);
        }}
        setChatSendStatus(successMessage || `Sent at ${{payload.sent_at || "now"}}`);
        await poll();
        return payload;
      }} catch (err) {{
        setChatSendStatus(`Send error: ${{err.message || err}}`, true);
        return null;
      }} finally {{
        setChatSendBusy(false);
        flushQueuedComposerSend();
      }}
    }}

    async function postStandaloneZorkCommand(text, sessionId = "") {{
      const body = {{
        text: String(text == null ? "" : text),
      }};
      const cleanSessionId = String(sessionId == null ? "" : sessionId).trim();
      if (cleanSessionId) {{
        body.session_id = cleanSessionId;
      }}
      const resp = await fetch("/api/games/zork", {{
        method: "POST",
        headers: {{ "Content-Type": "application/json" }},
        body: JSON.stringify(body),
      }});
      const payload = await resp.json().catch(() => ({{}}));
      if (!resp.ok || !payload.ok) {{
        const msg = payload && payload.error ? payload.error : `standalone zork failed (${{resp.status}})`;
        throw new Error(msg);
      }}
      return payload;
    }}

    function restoreChatInputFocus(input) {{
      if (!(input instanceof HTMLInputElement)) return;
      window.requestAnimationFrame(() => {{
        if (input.disabled) return;
        input.focus({{ preventScroll: true }});
        const tail = input.value.length;
        input.setSelectionRange(tail, tail);
      }});
    }}

    function flushQueuedComposerSend() {{
      if (!queuedComposerSend || chatSendInFlight) return;
      const input = document.getElementById("chat-input");
      const hasText = input instanceof HTMLInputElement && String(input.value || "").trim().length > 0;
      const preserveFocus = !!queuedComposerFocus;
      queuedComposerSend = false;
      queuedComposerFocus = false;
      if (!hasText) return;
      window.setTimeout(() => {{
        void sendChatMessage({{ preserveFocus }});
      }}, 0);
    }}

    async function sendChatMessage(options = null) {{
      const input = document.getElementById("chat-input");
      if (!(input instanceof HTMLInputElement)) return;
      const preserveFocus = !!(options && options.preserveFocus);
      const hadFocus = preserveFocus && document.activeElement === input;
      if (chatSendInFlight) {{
        const queuedText = String(input.value || "").trim();
        if (queuedText) {{
          queuedComposerSend = true;
          if (preserveFocus || document.activeElement === input) {{
            queuedComposerFocus = true;
          }}
          setChatSendStatus("Send in progress. Queued your message...");
        }}
        return;
      }}
      const text = input.value.trim();
      if (!text) {{
        setChatSendStatus("Enter a message before sending.", true);
        if (hadFocus) {{
          restoreChatInputFocus(input);
        }}
        return;
      }}
      let destination = "^all";
      if (activeChatChannel === "direct") {{
        const directPeer = resolvedDirectPeerForComposer();
        if (!isCanonicalNodeId(directPeer)) {{
          setChatSendStatus("Select a user before sending a peer-to-peer message.", true);
          if (hadFocus) {{
            restoreChatInputFocus(input);
          }}
          return;
        }}
        destination = directPeer;
        if (isSelfNodeId(destination)) {{
          setChatSendStatus("Cannot send peer-to-peer message to your own radio.", true);
          if (hadFocus) {{
            restoreChatInputFocus(input);
          }}
          return;
        }}
      }}
      const replyId = Number(chatReplyTargetId);
      const sendCtx = meshChannelSendContext();
      const requestBody = {{
        text,
        destination,
        channel_index: sendCtx.sendIndex,
      }};
      if (Number.isInteger(replyId) && replyId > 0) {{
        requestBody.reply_id = replyId;
      }}
      const payload = await sendChatPayload(
        requestBody,
        null
      );
      if (payload && payload.ok) {{
        recordBotRequestHistoryFromSend(requestBody, payload);
        input.value = "";
        const replied = Number.isInteger(replyId) && replyId > 0;
        clearChatReplyTarget();
        if (destination === "^all") {{
          setChatSendStatus(`${{replied ? "Reply sent" : "Sent"}} to Everyone on ${{sendCtx.sendLabel}} at ${{payload.sent_at || "now"}}`);
        }} else {{
          const awaitingAck = payload.ack_requested === true && normalizeDeliveryState(payload.delivery_state) === "pending";
          if (awaitingAck) {{
            setChatSendStatus(`${{replied ? "Reply sent direct" : "Sent direct"}} to ${{destination}} on ${{sendCtx.sendLabel}} at ${{payload.sent_at || "now"}} (awaiting ACK)`);
          }} else {{
            setChatSendStatus(`${{replied ? "Reply sent direct" : "Sent direct"}} to ${{destination}} on ${{sendCtx.sendLabel}} at ${{payload.sent_at || "now"}}`);
          }}
        }}
      }}
      if (hadFocus) {{
        restoreChatInputFocus(input);
      }}
    }}

    async function sendChatReaction(replyId, emoji) {{
      const replyNum = Number(replyId);
      const cleanEmoji = String(emoji || "").trim();
      if (!Number.isInteger(replyNum) || replyNum <= 0) {{
        setChatSendStatus("Cannot react: target message id is missing.", true);
        return;
      }}
      if (!cleanEmoji) {{
        setChatSendStatus("Choose an emoji reaction.", true);
        return;
      }}
      if (!isReactionCompatibleEmoji(cleanEmoji)) {{
        setChatSendStatus("Choose a single-codepoint emoji for reactions.", true);
        return;
      }}
      let destination = "^all";
      const sendCtx = meshChannelSendContext();
      if (activeChatChannel === "direct") {{
        const directPeer = resolvedDirectPeerForComposer();
        if (isCanonicalNodeId(directPeer)) {{
          destination = directPeer;
        }}
        if (isSelfNodeId(destination)) {{
          setChatSendStatus("Cannot react in peer-to-peer mode to your own radio.", true);
          return;
        }}
      }}
      const payload = await sendChatPayload(
        {{
          destination,
          channel_index: sendCtx.sendIndex,
          reply_id: replyNum,
          emoji: cleanEmoji,
        }},
        null
      );
      if (payload && payload.ok) {{
        setChatSendStatus(`Reacted ${{cleanEmoji}} on ${{sendCtx.sendLabel}} at ${{payload.sent_at || "now"}}`);
      }}
    }}

    async function sendChatAck(options = null) {{
      if (chatSendInFlight) return null;
      const replyId = Number(options && options.reply_id);
      if (!Number.isInteger(replyId) || replyId <= 0) {{
        setChatSendStatus("Cannot ACK: target message id is missing.", true);
        return null;
      }}
      const textMode = String((options && options.text_mode) || "").trim().toLowerCase();
      let text = String((options && options.text) || "").trim();
      if (textMode === "pong") {{
        try {{
          const pongText = await buildPongStyleAckReplyText(options, latestState);
          if (pongText) {{
            text = String(pongText).trim();
          }}
        }} catch (_err) {{
          // Fall back to the pre-baked ACK text if pong-style generation fails.
        }}
      }}
      if (!text) {{
        setChatSendStatus("Cannot ACK: message details are unavailable.", true);
        return null;
      }}
      let destination = normalizeNodeId((options && options.destination) || "^all");
      if (!destination) destination = "^all";
      if (destination !== "^all" && !isCanonicalNodeId(destination)) {{
        setChatSendStatus("Cannot ACK: destination is unavailable.", true);
        return null;
      }}
      const channelRaw = Number(options && options.channel_index);
      const channelIndex = Number.isInteger(channelRaw) && channelRaw >= 0 ? channelRaw : 0;
      const targetLabel = String((options && options.target_label) || "").trim()
        || (destination === "^all" ? "Everyone" : destination);
      const payload = await sendChatPayload(
        {{
          text,
          destination,
          channel_index: channelIndex,
          reply_id: replyId,
        }},
        null
      );
      if (payload && payload.ok) {{
        setChatSendStatus(`ACK sent to ${{targetLabel}} on ${{meshChannelLabelForIndex(channelIndex)}} at ${{payload.sent_at || "now"}}`);
      }}
      return payload;
    }}

    function chatAckOptionsFromButton(button) {{
      if (!(button instanceof HTMLElement)) return null;
      return {{
        reply_id: Number(button.dataset.ackReplyId || ""),
        text: button.dataset.ackText || "",
        text_mode: button.dataset.ackTextMode || "",
        destination: button.dataset.ackDestination || "^all",
        channel_index: Number(button.dataset.ackChannel || ""),
        target_label: button.dataset.ackTargetLabel || "",
        source_id: button.dataset.ackSourceId || "",
        source_label: button.dataset.ackSourceLabel || "",
        received_unix: button.dataset.ackReceivedUnix || "",
        hops: button.dataset.ackHopCount || "",
        rx_snr: button.dataset.ackRxSnr || "",
        rx_rssi: button.dataset.ackRxRssi || "",
      }};
    }}

    async function retryChatMessage(options) {{
      const text = String((options && options.text) || "").trim();
      if (!text) {{
        setChatSendStatus("Cannot retry: message text is empty.", true);
        return;
      }}

      let destination = String((options && options.destination) || "^all").trim() || "^all";
      if (destination.toLowerCase() === "all" || destination.toLowerCase() === "broadcast") {{
        destination = "^all";
      }}
      if (!(destination === "^all" || destination.startsWith("!"))) {{
        setChatSendStatus("Cannot retry: destination is invalid.", true);
        return;
      }}

      const channelRaw = Number(options && options.channel_index);
      const channelIndex = Number.isInteger(channelRaw) && channelRaw >= 0 ? channelRaw : 0;
      const replyRaw = Number(options && options.reply_id);
      const retryOfRaw = Number(options && options.retry_of);

      const body = {{
        text,
        destination,
        channel_index: channelIndex,
      }};
      if (Number.isInteger(replyRaw) && replyRaw > 0) {{
        body.reply_id = replyRaw;
      }}
      if (Number.isInteger(retryOfRaw) && retryOfRaw > 0) {{
        body.retry_of = retryOfRaw;
      }}

      const payload = await sendChatPayload(body, null);
      if (payload && payload.ok) {{
        const destLabel = destination === "^all" ? "Everyone" : destination;
        setChatSendStatus(`Retried to ${{destLabel}} at ${{payload.sent_at || "now"}}`);
      }}
    }}

    function normalizeChatEmojiPinnedChoices(rawChoices, maxCount = chatEmojiTopUsageCount) {{
      const list = Array.isArray(rawChoices) ? rawChoices : [];
      const out = [];
      const seen = new Set();
      for (const rawEmoji of list) {{
        const emoji = String(rawEmoji || "").trim();
        if (!emoji || seen.has(emoji) || !chatEmojiChoiceSet.has(emoji)) continue;
        seen.add(emoji);
        out.push(emoji);
        if (out.length >= maxCount) {{
          break;
        }}
      }}
      return out;
    }}

    function renderChatEmojiTopRow(options = null) {{
      const topLabel = document.getElementById("chat-emoji-top-label");
      const topGrid = document.getElementById("chat-emoji-top-grid");
      if (!(topGrid instanceof HTMLElement)) return;

      const preferredChoices = normalizeChatEmojiPinnedChoices(
        options && Array.isArray(options.choices) ? options.choices : [],
        chatEmojiTopUsageCount,
      );
      const usePreferredChoices = preferredChoices.length > 0;
      const sourceChoices = usePreferredChoices ? preferredChoices : chatEmojiTopChoices();
      const labelText = usePreferredChoices
        ? String((options && options.label) || "Top matches").trim() || "Top matches"
        : "Top used";
      const choices = chatEmojiMode === "react"
        ? reactionCompatibleEmojiChoices(sourceChoices)
        : sourceChoices;
      const signature = `${{chatEmojiMode}}:${{labelText}}:${{choices.join("\u0000")}}`;
      if ((topGrid.dataset.signature || "") === signature) {{
        return;
      }}

      if (topLabel instanceof HTMLElement) {{
        topLabel.textContent = labelText;
      }}
      topGrid.setAttribute("aria-label", labelText);

      if (!choices.length) {{
        const empty = document.createElement("div");
        empty.className = "chat-emoji-top-empty";
        empty.textContent = usePreferredChoices
          ? (chatEmojiMode === "react"
            ? "No compatible matches found."
            : "No quick matches found.")
          : (chatEmojiMode === "react"
            ? "No compatible reaction emojis in your top list yet."
            : "Use emojis and your top 8 will appear here.");
        topGrid.replaceChildren(empty);
        topGrid.dataset.signature = signature;
        return;
      }}
      const nodes = choices.map((emoji) => buildChatEmojiNode(emoji, "chat-emoji-top-item"));
      topGrid.replaceChildren(...nodes);
      topGrid.dataset.signature = signature;
    }}

    function renderChatEmojiPickerPanel() {{
      const groupSelect = document.getElementById("chat-emoji-group-select");
      const searchInput = document.getElementById("chat-emoji-search");
      const grid = document.getElementById("chat-emoji-grid");
      const meta = document.getElementById("chat-emoji-meta");
      if (!(grid instanceof HTMLElement)) return;

      const selectedSearch = normalizeChatEmojiSearchQuery(
        (searchInput instanceof HTMLInputElement)
          ? searchInput.value
          : chatEmojiSearchQuery
      );
      chatEmojiSearchQuery = selectedSearch;
      if (searchInput instanceof HTMLInputElement && searchInput.value !== selectedSearch) {{
        searchInput.value = selectedSearch;
      }}

      if (!chatEmojiCatalogLoaded) {{
        if (groupSelect instanceof HTMLSelectElement) {{
          const loadingOption = '<option value="all">All groups (loading...)</option>';
          if (groupSelect.innerHTML !== loadingOption) {{
            groupSelect.innerHTML = loadingOption;
          }}
          groupSelect.value = "all";
          groupSelect.disabled = true;
        }}
        if (searchInput instanceof HTMLInputElement) {{
          searchInput.disabled = true;
        }}
        if (meta instanceof HTMLElement) {{
          if (chatEmojiCatalogLoadError) {{
            meta.textContent = "Emoji catalog unavailable";
            meta.title = chatEmojiCatalogLoadError;
          }} else {{
            meta.textContent = "Loading emoji catalog...";
            meta.title = "Fetching Unicode emoji catalog...";
          }}
        }}
        const loadingKey = chatEmojiCatalogLoadError ? "emoji-catalog:error" : "emoji-catalog:loading";
        if ((grid.dataset.key || "") !== loadingKey) {{
          const empty = document.createElement("div");
          empty.className = "chat-emoji-empty";
          empty.textContent = chatEmojiCatalogLoadError
            ? "Emoji catalog unavailable. Try again in a moment."
            : "Loading emoji catalog...";
          grid.replaceChildren(empty);
          grid.dataset.key = loadingKey;
          grid.scrollTop = 0;
        }}
        renderChatEmojiTopRow(null);
        return;
      }}

      if (searchInput instanceof HTMLInputElement) {{
        searchInput.disabled = false;
      }}
      if (groupSelect instanceof HTMLSelectElement) {{
        groupSelect.disabled = false;
        const catalogSignature = `${{chatEmojiTotalChoices}}:${{chatEmojiGroups.map((group) => `${{group.id}}:${{group.emojis.length}}`).join("|")}}`;
        if ((groupSelect.dataset.catalogSignature || "") !== catalogSignature) {{
          const groupOptions = [
            `<option value="all">All groups (${{chatEmojiTotalChoices}})</option>`,
            ...chatEmojiGroups.map((group) => (
              `<option value="${{escAttr(group.id)}}">${{escAttr(group.label)}} (${{group.emojis.length}})</option>`
            )),
          ].join("");
          groupSelect.innerHTML = groupOptions;
          groupSelect.dataset.catalogSignature = catalogSignature;
          groupSelect.value = normalizeChatEmojiGroup(chatEmojiPickerGroup);
        }}
      }}

      const selectedGroup = normalizeChatEmojiGroup(
        (groupSelect instanceof HTMLSelectElement)
          ? groupSelect.value
          : chatEmojiPickerGroup
      );
      const previousGroup = chatEmojiPickerGroup;
      chatEmojiPickerGroup = selectedGroup;
      if (groupSelect instanceof HTMLSelectElement && groupSelect.value !== selectedGroup) {{
        groupSelect.value = selectedGroup;
      }}

      const searchActive = !!selectedSearch;
      const sourceChoices = searchActive
        ? chatEmojiChoicesForSearch(selectedSearch)
        : chatEmojiChoicesForGroup(selectedGroup);
      const choices = chatEmojiMode === "react"
        ? reactionCompatibleEmojiChoices(sourceChoices)
        : sourceChoices;
      const groupLabel = searchActive
        ? `Search all: "${{selectedSearch}}"`
        : (selectedGroup === "all"
          ? "All groups"
          : ((chatEmojiGroupsById.get(selectedGroup) || {{}}).label || "All groups"));
      if (meta instanceof HTMLElement) {{
        const countText = chatEmojiMode === "react"
          ? `${{choices.length}} / ${{sourceChoices.length}} compatible`
          : `${{choices.length}} / ${{chatEmojiTotalChoices}}`;
        meta.textContent = `${{groupLabel}} · ${{countText}}`;
        meta.title = `Unicode Emoji ${{chatEmojiDataVersion}} (${{
          chatEmojiDataDate
        }})`;
      }}
      const renderModeKey = chatEmojiMode === "react" ? "react" : "compose";
      const renderKey = searchActive
        ? `${{renderModeKey}}:search:${{selectedSearch}}`
        : `${{renderModeKey}}:group:${{selectedGroup}}`;
      if ((grid.dataset.key || "") !== renderKey) {{
        if (choices.length) {{
          const shouldUseCachedGroupNodes = !searchActive && chatEmojiMode !== "react";
          const nodes = shouldUseCachedGroupNodes
            ? chatEmojiNodesForGroup(selectedGroup)
            : choices.map((emoji) => buildChatEmojiNode(emoji));
          grid.replaceChildren(...nodes);
        }} else {{
          const empty = document.createElement("div");
          empty.className = "chat-emoji-empty";
          empty.textContent = chatEmojiMode === "react"
            ? "No compatible single-codepoint emojis matched."
            : "No emojis matched your search.";
          grid.replaceChildren(empty);
        }}
        grid.dataset.key = renderKey;
        grid.scrollTop = 0;
      }}
      if (previousGroup !== selectedGroup) {{
        persistChatEmojiPickerState();
      }}
      const topRowOptions = searchActive && choices.length
        ? {{
          choices: choices.slice(0, chatEmojiTopUsageCount),
          label: chatEmojiMode === "react" ? "Top reaction matches" : "Top matches",
        }}
        : null;
      renderChatEmojiTopRow(topRowOptions);
    }}

    function focusChatEmojiSearchInput() {{
      const panel = document.getElementById("chat-emoji-panel");
      const searchInput = document.getElementById("chat-emoji-search");
      if (!(panel instanceof HTMLElement) || panel.hidden) {{
        return false;
      }}
      if (!(searchInput instanceof HTMLInputElement)) {{
        return false;
      }}
      requestAnimationFrame(() => {{
        if (panel.hidden) return;
        searchInput.focus({{ preventScroll: true }});
        const end = searchInput.value.length;
        searchInput.setSelectionRange(end, end);
      }});
      return true;
    }}

    function openChatEmojiPanel(mode = "compose", reactionTargetId = null) {{
      const panel = document.getElementById("chat-emoji-panel");
      const btn = document.getElementById("chat-emoji-btn");
      if (!(panel instanceof HTMLElement)) return;
      chatEmojiMode = mode === "react" ? "react" : "compose";
      const parsedTarget = Number(reactionTargetId);
      chatReactionTargetId = (
        chatEmojiMode === "react" && Number.isInteger(parsedTarget) && parsedTarget > 0
      ) ? parsedTarget : null;
      renderChatEmojiPickerPanel();
      panel.hidden = false;
      focusChatEmojiSearchInput();
      if (btn instanceof HTMLButtonElement) {{
        btn.setAttribute("aria-expanded", "true");
      }}
      if (!chatEmojiCatalogLoaded) {{
        void ensureChatEmojiCatalogLoaded(true).then((loaded) => {{
          if (!loaded || panel.hidden) return;
          renderChatEmojiPickerPanel();
        }});
      }}
      if (chatEmojiMode === "react") {{
        setChatSendStatus("Pick a single-codepoint reaction emoji...");
      }}
    }}

    function closeChatEmojiPanel() {{
      const panel = document.getElementById("chat-emoji-panel");
      const btn = document.getElementById("chat-emoji-btn");
      chatEmojiMode = "compose";
      chatReactionTargetId = null;
      chatEmojiSearchQuery = "";
      if (panel instanceof HTMLElement) {{
        panel.hidden = true;
      }}
      const searchInput = document.getElementById("chat-emoji-search");
      if (searchInput instanceof HTMLInputElement) {{
        searchInput.value = "";
      }}
      if (btn instanceof HTMLButtonElement) {{
        btn.setAttribute("aria-expanded", "false");
      }}
    }}

    function insertEmojiAtCursor(emoji) {{
      const input = document.getElementById("chat-input");
      if (!(input instanceof HTMLInputElement)) return;
      const value = input.value || "";
      const start = Number.isFinite(input.selectionStart) ? input.selectionStart : value.length;
      const end = Number.isFinite(input.selectionEnd) ? input.selectionEnd : value.length;
      input.value = value.slice(0, start) + emoji + value.slice(end);
      const next = start + emoji.length;
      input.focus({{ preventScroll: true }});
      input.setSelectionRange(next, next);
    }}

    function bindEmojiPicker() {{
      const panel = document.getElementById("chat-emoji-panel");
      const btn = document.getElementById("chat-emoji-btn");
      if (!(panel instanceof HTMLElement) || !(btn instanceof HTMLButtonElement)) return;

      if (panel.dataset.init !== "1") {{
        const groupOptions = '<option value="all">All groups (loading...)</option>';
        panel.innerHTML = `<div id="chat-emoji-top-label" class="chat-emoji-top-label">Top used</div>
        <div id="chat-emoji-top-grid" class="chat-emoji-top-grid" aria-label="Top used"></div>
        <div class="chat-emoji-toolbar chat-emoji-search-row">
          <input
            id="chat-emoji-search"
            class="chat-emoji-filter chat-emoji-search"
            type="search"
            placeholder="Search all categories..."
            aria-label="Search emojis across all categories"
            autocomplete="off"
            spellcheck="false"
            title="Shortcut: Ctrl/Cmd+E"
          />
        </div>
        <div class="chat-emoji-toolbar">
          <select id="chat-emoji-group-select" class="chat-emoji-filter" aria-label="Emoji group">
            ${{groupOptions}}
          </select>
          <span id="chat-emoji-meta" class="chat-emoji-meta"></span>
        </div>
        <div id="chat-emoji-grid" class="chat-emoji-grid"></div>`;
        panel.dataset.init = "1";

        const groupSelect = document.getElementById("chat-emoji-group-select");
        if (groupSelect instanceof HTMLSelectElement && groupSelect.dataset.bound !== "1") {{
          groupSelect.dataset.bound = "1";
          groupSelect.value = normalizeChatEmojiGroup(chatEmojiPickerGroup);
          groupSelect.addEventListener("change", () => {{
            renderChatEmojiPickerPanel();
          }});
        }}
        const searchInput = document.getElementById("chat-emoji-search");
        if (searchInput instanceof HTMLInputElement && searchInput.dataset.bound !== "1") {{
          searchInput.dataset.bound = "1";
          searchInput.value = chatEmojiSearchQuery;
          searchInput.addEventListener("input", () => {{
            chatEmojiSearchQuery = normalizeChatEmojiSearchQuery(searchInput.value);
            renderChatEmojiPickerPanel();
          }});
        }}

        void ensureChatEmojiCatalogLoaded(false).then((loaded) => {{
          if (!loaded) return;
          renderChatEmojiPickerPanel();
        }});
      }}

      if (btn.dataset.emojiBound !== "1") {{
        btn.dataset.emojiBound = "1";
        btn.addEventListener("click", (ev) => {{
          ev.preventDefault();
          if (chatSendInFlight) return;
          if (panel.hidden) {{
            openChatEmojiPanel("compose", null);
          }} else {{
            closeChatEmojiPanel();
          }}
        }});
      }}

      if (panel.dataset.bound !== "1") {{
        panel.dataset.bound = "1";
        panel.addEventListener("click", (ev) => {{
          const target = ev.target;
          if (!(target instanceof Element)) return;
          const emojiBtn = target.closest(".chat-emoji-item");
          if (!(emojiBtn instanceof HTMLButtonElement)) return;
          const emoji = String(emojiBtn.getAttribute("data-emoji") || emojiBtn.textContent || "").trim();
          if (!emoji) return;
          if (chatEmojiMode === "react" && !isReactionCompatibleEmoji(emoji)) {{
            setChatSendStatus("Choose a single-codepoint emoji for reactions.", true);
            return;
          }}
          noteChatEmojiUsage(emoji);
          if (chatEmojiMode === "react" && Number.isInteger(chatReactionTargetId) && chatReactionTargetId > 0) {{
            sendChatReaction(chatReactionTargetId, emoji);
          }} else {{
            insertEmojiAtCursor(emoji);
          }}
          closeChatEmojiPanel();
        }});
      }}

      if (document.body.dataset.chatEmojiCloseBound !== "1") {{
        document.body.dataset.chatEmojiCloseBound = "1";
        document.addEventListener("pointerdown", (ev) => {{
          const target = ev.target;
          if (!(target instanceof Element)) return;
          if (!target.closest("#chat-emoji-panel") && !target.closest("#chat-emoji-btn")) {{
            closeChatEmojiPanel();
          }}
        }});
        document.addEventListener("keydown", (ev) => {{
          if (ev.key === "Escape") {{
            closeChatEmojiPanel();
            return;
          }}
          const key = String(ev.key || "").toLowerCase();
          if ((ev.ctrlKey || ev.metaKey) && !ev.altKey && !ev.shiftKey && key === "e") {{
            ev.preventDefault();
            if (panel.hidden) {{
              if (chatSendInFlight) return;
              openChatEmojiPanel("compose", null);
              return;
            }}
            focusChatEmojiSearchInput();
          }}
        }});
      }}
    }}

