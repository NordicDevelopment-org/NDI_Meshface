    function ensureChannelsViewLocalStateHydrated(force = false) {{
      if (channelsViewHydrateInFlight) {{
        return channelsViewHydrateInFlight;
      }}
      const cached = settingsLocalStateCache && typeof settingsLocalStateCache === "object"
        ? settingsLocalStateCache
        : null;
      const stale = !settingsLocalStateFetchedAt || (Date.now() - settingsLocalStateFetchedAt) > 60000;
      const missingChannels = !(cached && Array.isArray(cached.channels));
      if (!force && !missingChannels && !stale) {{
        return Promise.resolve(cached);
      }}
      channelsViewHydrateInFlight = hydrateMeshChannelOptions(force)
        .catch(() => null)
        .then(() => {{
          if (activeLayoutView === "channels") {{
            renderChannelsView(latestState);
          }}
          return settingsLocalStateCache;
        }})
        .finally(() => {{
          channelsViewHydrateInFlight = null;
        }});
      return channelsViewHydrateInFlight;
    }}

    function applyMeshChannelIndex(rawIndex, persist = true) {{
      const idx = normalizeMeshChannelIndex(rawIndex, {{ allowAll: true }});
      const changed = idx !== activeMeshChannelIndex;
      const shouldFollowForSend = idx !== meshChannelAllIndex;
      activeMeshChannelIndex = idx;
      syncMeshChannelViewControl();

      const select = document.getElementById("mesh-channel-select");
      if (select instanceof HTMLSelectElement) {{
        select.value = String(activeMeshChannelIndex);
