    function renderTimeline(timelineId, rows, padLeft, padRight, width, resolveUnix) {{
      const timeline = document.getElementById(String(timelineId || "").trim());
      if (!(timeline instanceof HTMLElement)) return;

      const total = Array.isArray(rows) ? rows.length : 0;
      if (!total) {{
        setTimelineMessage(timelineId, "Timeline available when history points are present.");
        return;
