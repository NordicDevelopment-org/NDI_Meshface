      }}
      setTimelineMessage("weekly-summary-timeline", "Loading timeline...");
    }}

    function renderWeeklySummaryError(message) {{
      historyTrendCharts.weekly.points = [];
      resetHistoryTrendZoom(historyTrendCharts.weekly);
      const caption = document.getElementById("weekly-summary-caption");
      if (caption) {{
        caption.textContent = `Weekly summary error: ${{message || "unknown error"}}`;
      }}
      const overview = document.getElementById("weekly-summary-overview");
      if (overview) {{
        overview.innerHTML = "";
      }}
      const svg = document.getElementById("weekly-summary-chart");
      if (svg instanceof SVGElement) {{
        svg.innerHTML = "";
        svg.classList.remove("zoomed", "chart-dragging");
      }}
      const empty = document.getElementById("weekly-summary-empty");
      if (empty) {{
        empty.hidden = false;
        empty.textContent = "Unable to load weekly summary metrics.";
      }}
      setTimelineMessage("weekly-summary-timeline", "Timeline unavailable due to weekly summary error.");
    }}

    function renderWeeklySummaryChartRows(rows, metricMeta, emptyMessage) {{
      const svg = document.getElementById("weekly-summary-chart");
      const empty = document.getElementById("weekly-summary-empty");
      if (!(svg instanceof SVGElement) || !(empty instanceof HTMLElement)) {{
        return false;
      }}

      const chartState = historyTrendCharts.weekly;
      bindHistoryTrendChartZoom(
        chartState,
        () => rerenderWeeklySummaryChartFromCache(),
        "Weekly trend chart"
      );

      const sourceRows = Array.isArray(rows) ? rows : [];
      chartState.points = sourceRows;
      const visible = getVisibleHistoryTrendRows(chartState, sourceRows);
      const plotRows = visible.rows;
      const chartLabel = `${{metricMeta.label}} trend chart`;
      setHistoryTrendChartTitle(svg, chartLabel, visible.zoomed);

      const fallbackMessage = String(emptyMessage || "No weekly summary history yet.").trim();
      const seriesDefs = [];
      if (metricMeta && Array.isArray(metricMeta.seriesOrder) && metricMeta.seriesOrder.length > 0) {{
        const labels = (metricMeta.seriesLabels && typeof metricMeta.seriesLabels === "object")
          ? metricMeta.seriesLabels
          : {{}};
        const styles = (metricMeta.seriesStyles && typeof metricMeta.seriesStyles === "object")
          ? metricMeta.seriesStyles
          : {{}};
        for (const key of metricMeta.seriesOrder) {{
          if (!key) continue;
          const style = (styles && typeof styles[key] === "object") ? styles[key] : {{}};
          seriesDefs.push({{
            key: String(key),
            label: String(labels[key] || key),
            tone: String(style.tone || ""),
            dashed: style.dashed === true,
            width: Number(style.width),
            color: String(style.color || "").trim(),
            labelColor: String(style.labelColor || "").trim(),
            readValue: (row) => row && row.series && row.series[key],
          }});
        }}
      }} else {{
        seriesDefs.push({{
          key: "primary",
          label: String(metricMeta && metricMeta.label ? metricMeta.label : "Series"),
          tone: "line",
          dashed: false,
          width: 2.3,
          readValue: (row) => row && row.value,
        }});
        seriesDefs.push({{
          key: "compare",
          label: String(metricMeta && metricMeta.compareLabel ? metricMeta.compareLabel : "Comparison"),
          tone: "compare",
          dashed: true,
          width: 2.0,
          readValue: (row) => row && row.compareValue,
        }});
      }}

      const seriesEntries = [];
      for (let s = 0; s < seriesDefs.length; s += 1) {{
        const def = seriesDefs[s];
        const values = [];
        const points = [];
        let pendingBreak = false;
        for (let i = 0; i < plotRows.length; i += 1) {{
          if (plotRows[i] && plotRows[i].breakBefore) {{
            pendingBreak = true;
          }}
          const rawValue = def.readValue(plotRows[i]);
          if (rawValue === null || rawValue === undefined) continue;
          const value = Number(rawValue);
          if (!Number.isFinite(value)) continue;
          values.push(value);
          points.push({{
            idx: i,
            value,
            breakBefore: pendingBreak,
          }});
          pendingBreak = false;
        }}
        if (!points.length) continue;
        seriesEntries.push({{
          ...def,
          index: s,
          values,
          points,
        }});
      }}

      if (!seriesEntries.length) {{
        svg.innerHTML = "";
        empty.hidden = false;
        empty.textContent = fallbackMessage;
        renderTimeline(
          chartState.timelineId,
          plotRows,
          historyTrendChartLayout.padLeft,
          historyTrendChartLayout.padRight,
          historyTrendChartLayout.width,
          (row) => timelinePointUnix(row, "bucketUnix", ["bucketText"])
        );
        return false;
      }}
      empty.hidden = true;

      const smoothingWindow = normalizeSmoothingWindow(
        metricMeta && metricMeta.smoothingWindow,
        plotRows.length
      );
      const trendWindow = normalizeSmoothingWindow(
        smoothingWindow <= 1
          ? 1
          : Math.max(
              smoothingWindow,
              Math.round(Math.max(3, smoothingWindow) * 2.2)
            ),
        plotRows.length
      );
      const rawBucketWidthPx = 1.05;
      const trendBucketWidthPx = 4.0;
      const trendTension = 0.28;
      const plottedSeriesEntries = seriesEntries.map((entry) => {{
        const rawPoints = entry.points.map((point) => ({{ ...point }}));
        const plottedPoints = smoothSeriesPointsWithBreaks(entry.points, trendWindow);
        const rawValues = rawPoints
          .map((point) => Number(point && point.value))
          .filter((value) => Number.isFinite(value));
        const plottedValues = plottedPoints
          .map((point) => Number(point && point.value))
          .filter((value) => Number.isFinite(value));
        return {{
          ...entry,
          rawPoints,
          rawValues,
          plottedPoints,
          plottedValues,
        }};
      }});

      const allValues = plottedSeriesEntries.flatMap((entry) => (
        entry.rawValues.concat(entry.plottedValues)
      ));
      let minVal = Math.min(...allValues);
      let maxVal = Math.max(...allValues);
      if ((maxVal - minVal) < 1e-6) {{
        maxVal = minVal + 1;
      }}

      const width = historyTrendChartLayout.width;
      const height = historyTrendChartLayout.height;
      const padLeft = historyTrendChartLayout.padLeft;
      const padRight = historyTrendChartLayout.padRight;
      const padTop = historyTrendChartLayout.padTop;
      const padBottom = historyTrendChartLayout.padBottom;
      const plotW = width - padLeft - padRight;
      const plotH = height - padTop - padBottom;
      const n = plotRows.length;
      const dayBoundaries = [];
      if (n > 1) {{
        let lastDayKey = "";
        for (let i = 0; i < plotRows.length; i += 1) {{
          const unixTs = timelinePointUnix(plotRows[i], "bucketUnix", ["bucketText"]);
          const dayKey = timelineDayKey(unixTs);
          if (!dayKey) continue;
          if (!lastDayKey) {{
            lastDayKey = dayKey;
            continue;
          }}
          if (dayKey !== lastDayKey) {{
            dayBoundaries.push({{
              idx: i,
              unixTs,
            }});
            lastDayKey = dayKey;
          }}
        }}
      }}
      const darkTheme = document.documentElement.getAttribute("data-theme") === "dark";
      const chartPalette = darkTheme
        ? {{
            grid: "#324152",
            line: "#58c878",
            compare: "#79c0ff",
            aux1: "#f3b36b",
            aux2: "#6fcad8",
            aux3: "#d0e18a",
            label: "#9ce7b8",
            compareLabel: "#a4d0ff",
            aux1Label: "#f6c88e",
            aux2Label: "#8ddde8",
            aux3Label: "#dde8a8",
          }}
        : {{
            grid: "#dce8df",
            line: "#1f6f53",
            compare: "#265d7b",
            aux1: "#a95f27",
            aux2: "#2f6e78",
            aux3: "#6d7a2f",
            label: "#1f6f53",
            compareLabel: "#265d7b",
            aux1Label: "#a95f27",
            aux2Label: "#2f6e78",
            aux3Label: "#6d7a2f",
          }};
      const toneFallbacks = ["line", "compare", "aux1", "aux2", "aux3"];
      const toneStroke = (tone, index) => {{
        const key = tone && chartPalette[tone] ? tone : toneFallbacks[index] || "compare";
        return chartPalette[key] || chartPalette.compare;
      }};
      const toneLabel = (tone, index) => {{
        const key = tone && chartPalette[`${{tone}}Label`] ? `${{tone}}Label` : `${{toneFallbacks[index] || "compare"}}Label`;
        return chartPalette[key] || chartPalette.compareLabel;
      }};
      const buildLinearPath = (points) => (
        points.map((pt, idx) => (
          `${{idx === 0 || pt.breakBefore ? "M" : "L"}} ${{pt.x.toFixed(2)}} ${{pt.y.toFixed(2)}}`
        )).join(" ")
      );
      const enrichSeries = plottedSeriesEntries.map((entry, index) => {{
        const stroke = toneStroke(entry.tone, index);
        const labelColor = toneLabel(entry.tone, index);
        const resolvedStroke = entry.color || stroke;
        const resolvedLabelColor = entry.labelColor || labelColor;
        const widthPx = Number.isFinite(Number(entry.width))
          ? Math.max(1.2, Number(entry.width))
          : (index === 0 ? 2.3 : 2.0);
        const dashText = entry.dashed ? "5 3" : "";
        const dashAttr = dashText ? ` stroke-dasharray="${{dashText}}"` : "";
        const toScreenPoint = (point) => {{
          const x = padLeft + ((Math.max(0, point.idx) / Math.max(1, n - 1)) * plotW);
          const y = padTop + ((maxVal - point.value) / (maxVal - minVal)) * plotH;
          return {{
            x,
            y,
            breakBefore: !!point.breakBefore,
          }};
        }};
        const rawPointsXY = entry.rawPoints.map((point) => toScreenPoint(point));
        const trendPointsXY = entry.plottedPoints.map((point) => toScreenPoint(point));
        const rawPlotPoints = aggregatePointsByXPixels(rawPointsXY, rawBucketWidthPx);
        const trendPlotPoints = aggregatePointsByXPixels(trendPointsXY, trendBucketWidthPx);
        const rawPath = buildLinearPath(rawPlotPoints);
        const trendLinearPath = buildLinearPath(trendPlotPoints);
        const trendPath = buildSmoothSvgPath(trendPlotPoints, trendTension) || trendLinearPath;
        const rawWidthPx = Math.max(0.8, widthPx * 0.58);
        const rawOpacity = entry.dashed ? 0.16 : 0.2;
        return {{
          ...entry,
          stroke: resolvedStroke,
          labelColor: resolvedLabelColor,
          widthPx,
          rawWidthPx,
          rawOpacity,
          trendOpacity: 1,
          dashAttr,
          rawPath,
          trendPath,
        }};
      }});
      const axisTicks = buildLinearAxisTicks(minVal, maxVal, 5);
      const axisLabelColor = enrichSeries[0] ? enrichSeries[0].labelColor : chartPalette.label;
      const axisLines = axisTicks.map((tick) => {{
        const y = padTop + (tick.ratio * plotH);
        return `<line x1="${{padLeft}}" y1="${{y.toFixed(2)}}" x2="${{width - padRight}}" y2="${{y.toFixed(2)}}" stroke="${{chartPalette.grid}}" stroke-width="1"></line>`;
      }}).join("");
      const axisLabels = axisTicks.map((tick) => {{
        const y = padTop + (tick.ratio * plotH);
        return `<text x="${{padLeft - 4}}" y="${{(y + 4).toFixed(2)}}" font-size="10" text-anchor="end" fill="${{axisLabelColor}}">${{formatMetricValue(tick.value, metricMeta.decimals)}}</text>`;
      }}).join("");
      const dayGuideLines = dayBoundaries.map((boundary) => {{
        const x = padLeft + ((Math.max(0, boundary.idx) / Math.max(1, n - 1)) * plotW);
        return `<line x1="${{x.toFixed(2)}}" y1="${{padTop}}" x2="${{x.toFixed(2)}}" y2="${{height - padBottom}}" stroke="${{chartPalette.grid}}" stroke-width="1" stroke-dasharray="2 3" stroke-opacity="${{darkTheme ? "0.45" : "0.65"}}"></line>`;
      }}).join("");
      const legendX = Math.max(padLeft + 8, width - padRight - 260);
      const legendItems = enrichSeries.slice(0, 5).map((entry, index) => {{
        const y = padTop + 8 + (index * 14);
        return `
          <line x1="${{legendX}}" y1="${{y}}" x2="${{legendX + 22}}" y2="${{y}}" stroke="${{entry.stroke}}" stroke-width="${{entry.widthPx.toFixed(1)}}"${{entry.dashAttr}}></line>
          <text x="${{legendX + 28}}" y="${{y + 3}}" font-size="10" fill="${{entry.labelColor}}">${{entry.label}}</text>
        `;
      }}).join("");
      const paths = enrichSeries.map((entry) => (
        `
          <path d="${{entry.rawPath}}" fill="none" stroke="${{entry.stroke}}" stroke-width="${{entry.rawWidthPx.toFixed(1)}}" stroke-linecap="round" stroke-linejoin="round" stroke-opacity="${{entry.rawOpacity.toFixed(2)}}"></path>
          <path d="${{entry.trendPath}}" fill="none" stroke="${{entry.stroke}}" stroke-width="${{entry.widthPx.toFixed(1)}}" stroke-linecap="round" stroke-linejoin="round" stroke-opacity="${{entry.trendOpacity.toFixed(2)}}"${{entry.dashAttr}}></path>
        `
      )).join("");
      svg.setAttribute("viewBox", `0 0 ${{width}} ${{height}}`);
      svg.innerHTML = `
        <rect x="0" y="0" width="${{width}}" height="${{height}}" fill="none"></rect>
        <line x1="${{padLeft}}" y1="${{padTop}}" x2="${{padLeft}}" y2="${{height - padBottom}}" stroke="${{chartPalette.grid}}" stroke-width="1"></line>
        ${{axisLines}}
        ${{dayGuideLines}}
        ${{paths}}
        ${{axisLabels}}
        ${{legendItems}}
      `;
      renderTimeline(
        chartState.timelineId,
        plotRows,
        padLeft,
        padRight,
        width,
        (row) => timelinePointUnix(row, "bucketUnix", ["bucketText"])
      );
      return true;
    }}

    function renderWeeklySummary(summaryHistory) {{
      const metricKey = normalizeWeeklySummaryMetric(weeklySummaryMetric);
      const metricMeta = resolveWeeklySummaryMetricMeta(metricKey, weeklySummaryNodeSeriesEnabled);
      const payload = (summaryHistory && typeof summaryHistory === "object") ? summaryHistory : {{}};
      const points = Array.isArray(payload.points) ? payload.points : [];
      const rows = [];
      const packetRateMetric = metricKey === "packets";
      const nodesMetric = metricKey === "nodes";
      const linksMetric = metricKey === "links";
      let prevPacketBucketUnix = null;
      let prevPacketTotal = null;
      let prevLiveCounter = null;
      let packetPendingBreak = false;
      const continuitySeries = new Set(["known_nodes", "saved_nodes", "position_nodes", "real_edge_count"]);
      const continuityStateBySeries = new Map();
      const continuityAdjustedValue = (seriesKey, rawValue, resetBreak) => {{
        const numeric = Number(rawValue);
        if (!Number.isFinite(numeric)) return null;
        if (!continuitySeries.has(seriesKey)) return numeric;
        let state = continuityStateBySeries.get(seriesKey);
        if (!(state && typeof state === "object")) {{
          state = {{ offset: 0, lastAdjusted: null }};
          continuityStateBySeries.set(seriesKey, state);
        }}
        if (
          resetBreak
          && Number.isFinite(state.lastAdjusted)
          && (numeric + 1 < Number(state.lastAdjusted))
        ) {{
          // Re-anchor continuity at reset without compounding prior offsets.
          state.offset = Number(state.lastAdjusted) - numeric;
        }}
        const adjusted = numeric + Number(state.offset || 0);
        state.lastAdjusted = adjusted;
        return adjusted;
      }};
      for (const point of points) {{
        if (!point || typeof point !== "object") continue;
        const bucketUnix = Number(point.bucket_unix);
        const bucketText = String(point.bucket_time || "").trim();
        const liveCounter = Number(point.live_packet_count);
        const resetBreak = hasLiveCounterReset(prevLiveCounter, liveCounter);
        if (Number.isFinite(liveCounter)) {{
          prevLiveCounter = liveCounter;
        }}
        if (packetRateMetric) {{
          const packetTotal = liveCounter;
          if (!Number.isFinite(bucketUnix) || !Number.isFinite(packetTotal) || bucketUnix <= 0) continue;
          if (Number.isFinite(prevPacketBucketUnix) && Number.isFinite(prevPacketTotal) && bucketUnix > prevPacketBucketUnix) {{
            if (hasLiveCounterReset(prevPacketTotal, packetTotal)) {{
              packetPendingBreak = true;
              prevPacketBucketUnix = bucketUnix;
              prevPacketTotal = packetTotal;
              continue;
            }}
            const spanMinutes = Math.max(1 / 60, (bucketUnix - prevPacketBucketUnix) / 60);
            const packetRate = Math.max(0, (packetTotal - prevPacketTotal) / spanMinutes);
            rows.push({{
              value: packetRate,
              totalValue: packetTotal,
              bucketText,
              bucketUnix,
              breakBefore: packetPendingBreak,
            }});
            packetPendingBreak = false;
          }}
          prevPacketBucketUnix = bucketUnix;
          prevPacketTotal = packetTotal;
          continue;
        }}
        if (linksMetric) {{
          const value = continuityAdjustedValue("real_edge_count", point.real_edge_count, resetBreak);
          if (!Number.isFinite(value)) continue;
          rows.push({{
            value,
            bucketText,
            bucketUnix: Number.isFinite(bucketUnix) && bucketUnix > 0 ? bucketUnix : null,
          }});
          continue;
        }}
        if (!nodesMetric) {{
          continue;
        }}
        const onlineValue = Number(point.online_node_count);
        const knownRawValue = Number(point.node_count);
        const savedRawValue = Number(point.saved_node_count);
        const positionRawValue = Number(point.nodes_with_position);
        const knownValue = continuityAdjustedValue("known_nodes", knownRawValue, resetBreak);
        const savedValue = continuityAdjustedValue("saved_nodes", savedRawValue, resetBreak);
        const positionValue = continuityAdjustedValue("position_nodes", positionRawValue, resetBreak);
        const primaryValue = Number.isFinite(onlineValue) ? onlineValue : knownValue;
        if (!Number.isFinite(primaryValue)) continue;
        const seriesValues = {{}};
        if (Number.isFinite(onlineValue)) seriesValues.online_nodes = onlineValue;
        if (Number.isFinite(knownValue)) seriesValues.known_nodes = knownValue;
        if (Number.isFinite(savedValue)) seriesValues.saved_nodes = savedValue;
        if (Number.isFinite(positionValue)) seriesValues.position_nodes = positionValue;
        rows.push({{
          value: primaryValue,
          series: seriesValues,
          knownNodeCount: Number.isFinite(knownRawValue) ? knownRawValue : null,
          savedNodeCount: Number.isFinite(savedRawValue) ? savedRawValue : null,
          positionNodeCount: Number.isFinite(positionRawValue) ? positionRawValue : null,
          bucketText,
          bucketUnix: Number.isFinite(bucketUnix) && bucketUnix > 0 ? bucketUnix : null,
        }});
      }}
      let chartRows = rows;
      if (nodesMetric && rows.length > 0) {{
        const firstPositiveIndex = rows.findIndex((row) => Number(row && row.value) > 0);
        if (firstPositiveIndex > 0) {{
          chartRows = rows.slice(firstPositiveIndex);
        }}
      }}

      const caption = document.getElementById("weekly-summary-caption");
      const overview = document.getElementById("weekly-summary-overview");
      const svg = document.getElementById("weekly-summary-chart");
      const empty = document.getElementById("weekly-summary-empty");
      if (!(svg instanceof SVGElement) || !(empty instanceof HTMLElement)) return;
      if (!(overview instanceof HTMLElement)) return;

      const emptyMessage = packetRateMetric
        ? "Need at least two saved samples to estimate packets/min."
        : "No weekly summary history yet.";

      if (chartRows.length === 0) {{
        overview.innerHTML = "";
        renderWeeklySummaryChartRows([], metricMeta, emptyMessage);
        if (caption) {{
          caption.textContent = `Weekly trend for ${{metricMeta.label}}. ${{emptyMessage}}`;
        }}
        return;
      }}

      const rendered = renderWeeklySummaryChartRows(chartRows, metricMeta, emptyMessage);
      if (!rendered) {{
        overview.innerHTML = "";
        if (caption) {{
          caption.textContent = `Weekly trend for ${{metricMeta.label}}. ${{emptyMessage}}`;
        }}
        return;
      }}

      const firstValue = Number(chartRows[0].value);
      const lastValue = Number(chartRows[chartRows.length - 1].value);
      const delta = lastValue - firstValue;
      const values = chartRows.map((row) => Number(row.value)).filter((value) => Number.isFinite(value));
      const avg = values.reduce((sum, value) => sum + value, 0) / Math.max(1, values.length);
      const averageDecimals = metricKey === "nodes" || metricKey === "links"
        ? Math.max(1, Number(metricMeta.decimals) || 0)
        : metricMeta.decimals;
      const windowHours = Number(payload.window_hours);
      const startLabel = chartRows[0].bucketText || "";
      const endLabel = chartRows[chartRows.length - 1].bucketText || "";
      if (caption) {{
        const selectedNodeSeriesLabels = Array.isArray(metricMeta && metricMeta.seriesOrder)
          ? metricMeta.seriesOrder.map((seriesKey) => (
            String((metricMeta.seriesLabels && metricMeta.seriesLabels[seriesKey]) || seriesKey)
          ))
          : [];
        const compareNote = nodesMetric
          ? (selectedNodeSeriesLabels.length > 1
            ? ` Showing lines: ${{selectedNodeSeriesLabels.join(", ")}}.`
            : ` Showing ${{selectedNodeSeriesLabels[0] || "Online Nodes"}} line.`)
          : "";
        caption.textContent = `Weekly trend for ${{metricMeta.label}}. Window: ${{Number.isFinite(windowHours) ? windowHours : weeklySummaryHours}}h, samples: ${{chartRows.length}}.${{compareNote}}`;
      }}
      const items = [
        ["Metric", metricMeta.label],
        ["Window", `${{Number.isFinite(windowHours) ? Math.round(windowHours) : weeklySummaryHours}}h`],
        ["Samples", String(chartRows.length)],
        ["Latest", formatMetricValue(lastValue, metricMeta.decimals)],
        ["Delta", formatMetricValue(delta, metricMeta.decimals)],
        ["Average", formatMetricValue(avg, averageDecimals)],
        ["Peak", formatMetricValue(Math.max(...values), metricMeta.decimals)],
        ["Range", `${{startLabel || "n/a"}} to ${{endLabel || "n/a"}}`],
      ];
      if (packetRateMetric) {{
        const latestTotal = Number(chartRows[chartRows.length - 1] && chartRows[chartRows.length - 1].totalValue);
        if (Number.isFinite(latestTotal)) {{
          items.push(["Total Packets", formatMetricValue(latestTotal, 0)]);
        }}
      }} else if (nodesMetric) {{
        const latestRow = chartRows[chartRows.length - 1] || null;
        const latestKnownNodes = Number(latestRow && latestRow.knownNodeCount);
        const latestSavedNodes = Number(latestRow && latestRow.savedNodeCount);
        const latestPositionNodes = Number(latestRow && latestRow.positionNodeCount);
        if (Number.isFinite(latestKnownNodes)) {{
          items.push(["Known Nodes (Radio)", formatMetricValue(latestKnownNodes, 0)]);
        }}
        if (Number.isFinite(latestSavedNodes)) {{
          items.push(["Saved Nodes (DB)", formatMetricValue(latestSavedNodes, 0)]);
        }}
        if (Number.isFinite(latestPositionNodes)) {{
          items.push(["Nodes With Position", formatMetricValue(latestPositionNodes, 0)]);
        }}
        if (Number.isFinite(latestSavedNodes) && Number.isFinite(latestKnownNodes)) {{
          if (latestKnownNodes > 0) {{
            const ratioPercent = (latestSavedNodes / latestKnownNodes) * 100;
            items.push(["Saved / Known", `${{formatMetricValue(ratioPercent, 1)}}%`]);
          }} else {{
            items.push(["Saved / Known", "n/a"]);
          }}
        }}
      }}
      overview.innerHTML = items.map(([k, v]) => (
        `<div class="overview-item"><div class="k">${{k}}</div><div class="v">${{v}}</div></div>`
      )).join("");
    }}

    function resolveTrafficRenderContext(source, fallbackState = latestState) {{
      const safeFallback = (fallbackState && typeof fallbackState === "object") ? fallbackState : {{}};
      const safeSource = (source && typeof source === "object") ? source : {{}};
      const sourceHasTraffic = !!(safeSource.traffic && typeof safeSource.traffic === "object");
      const traffic = sourceHasTraffic
        ? safeSource.traffic
        : safeSource;
      const nodes = sourceHasTraffic
        ? (Array.isArray(safeSource.nodes) ? safeSource.nodes : [])
        : (Array.isArray(safeFallback.nodes) ? safeFallback.nodes : []);
      return {{
        traffic: (traffic && typeof traffic === "object") ? traffic : {{}},
        nodes,
      }};
    }}

    function buildHistoryNodeIdentityResolver(nodes) {{
      const rows = Array.isArray(nodes) ? nodes : [];
      const nodesById = new Map(
        rows
          .map((node) => [normalizeNodeId(node && node.id ? node.id : ""), node])
          .filter(([nodeId]) => !!nodeId)
      );
      return (rawNodeId) => {{
        const clean = normalizeNodeId(rawNodeId);
        if (!clean) {{
          return {{
            sort: "n/a",
            title: "n/a",
            html: '<div class="history-node-cell"><span class="history-node-primary">n/a</span></div>',
          }};
        }}
        if (clean === "^all") {{
          return {{
            sort: "^all",
            title: "Broadcast / all nodes",
            html: '<div class="history-node-cell"><span class="history-node-primary">All</span><span class="history-node-secondary">broadcast</span></div>',
          }};
        }}
        if (clean === "local") {{
          return {{
            sort: "local",
            title: "Local node",
            html: '<div class="history-node-cell"><span class="history-node-primary">Local</span><span class="history-node-secondary">this node</span></div>',
          }};
        }}

        const node = nodesById.get(clean);
        const longName = String(node && node.long_name ? node.long_name : "").trim();
        const shortName = String(node && node.short_name ? node.short_name : "").trim();
        const cachedName = String(nodeNameCache.get(clean) || "").trim();
        const primary = longName || cachedName || shortName || clean;
        const secondaryParts = [];
        if (shortName && shortName !== primary) {{
          secondaryParts.push(shortName);
        }}
        if (clean && clean !== primary) {{
          secondaryParts.push(clean);
        }} else if (!secondaryParts.length && clean) {{
          secondaryParts.push(clean);
        }}
        const secondary = secondaryParts.join(" • ");
        const titleParts = [];
        if (longName) titleParts.push(`Long: ${{longName}}`);
        if (shortName) titleParts.push(`Short: ${{shortName}}`);
        if (!longName && !shortName && cachedName && cachedName !== clean) {{
          titleParts.push(`Name: ${{cachedName}}`);
        }}
        titleParts.push(`ID: ${{clean}}`);
        return {{
          sort: `${{primary}} ${{shortName}} ${{clean}}`.trim(),
          title: titleParts.join(" | "),
          html: `<div class="history-node-cell"><span class="history-node-primary">${{escAttr(primary)}}</span>${{secondary ? `<span class="history-node-secondary">${{escAttr(secondary)}}</span>` : ""}}</div>`,
        }};
      }};
    }}

    function renderHistoryMessageCell(entry, renderedText) {{
      const kind = normalizeChatMessageKind(entry, entry && entry.is_reaction === true);
      const textHtml = chatPlainTextToHtml(renderedText, true) || "&nbsp;";
      if (kind !== "status") {{
        return textHtml;
      }}
      const statusEvent = String(entry && entry.status_event ? entry.status_event : "").trim().toLowerCase();
      const pillLabel = statusEvent === "name_change" ? "Name change" : "Status";
      const pillClass = statusEvent === "name_change" ? " history-message-pill-name-change" : "";
      return `<div class="history-message-cell"><span class="history-message-pill${{pillClass}}">${{escAttr(pillLabel)}}</span><span class="history-message-body">${{textHtml}}</span></div>`;
    }}

    function renderHistoryChat(source) {{
      const context = resolveTrafficRenderContext(source);
      const traffic = context.traffic;
      const describeNode = buildHistoryNodeIdentityResolver(context.nodes);
      const messages = Array.isArray(traffic && traffic.recent_chat) ? traffic.recent_chat : [];
      const rows = messages.slice(0, 240).map((entry) => {{
        const capturedAt = String((entry && (entry.captured_at || entry.rx_time)) || "n/a");
        const fromId = String((entry && entry.from) || "n/a");
        const toId = String((entry && entry.to) || "n/a");
        const fromNodeId = normalizeNodeId(fromId);
        const toNodeId = normalizeNodeId(toId);
        const fromIdentity = describeNode(fromId);
        const toIdentity = describeNode(toId);
        const text = String((entry && entry.text) || "").trim();
        const emoji = String((entry && entry.emoji) || "").trim();
        const isReaction = entry && entry.is_reaction === true;
        const renderedText = text
          ? text
          : (isReaction ? `Reaction ${{emoji || ""}}`.trim() : (emoji || "n/a"));
        const rowSelectable = isSelectableNodeId(fromNodeId) || isSelectableNodeId(toNodeId);
        const rowSelected = !!selectedNodeId && (
          (isSelectableNodeId(fromNodeId) && fromNodeId === selectedNodeId)
          || (isSelectableNodeId(toNodeId) && toNodeId === selectedNodeId)
        );
        return {{
          className: `${{rowSelectable ? "history-node-selectable" : ""}}${{rowSelected ? " selected-node" : ""}}`,
          dataset: {{
            "from-node-id": fromNodeId,
            "to-node-id": toNodeId,
          }},
          cells: [
            {{ sort: capturedAt, text: capturedAt }},
            {{
              sort: fromIdentity.sort,
              html: fromIdentity.html,
              title: fromIdentity.title,
              className: isSelectableNodeId(fromNodeId) ? "history-node-clickable" : "",
            }},
            {{
              sort: toIdentity.sort,
              html: toIdentity.html,
              title: toIdentity.title,
              className: isSelectableNodeId(toNodeId) ? "history-node-clickable" : "",
            }},
            {{ sort: renderedText, html: renderHistoryMessageCell(entry, renderedText) }},
          ],
        }};
      }});
      renderSortableListboxTable("history-chat-table", rows, {{
        emptyText: "No saved chat or derived status history yet.",
        emptyColspan: 4,
      }});
      const caption = document.getElementById("history-chat-caption");
      if (caption) {{
        caption.textContent = rows.length
          ? `Showing ${{rows.length}} most recent saved chat and derived status entries.`
          : "No saved chat or derived status history yet.";
      }}
      renderHistoryNotificationLog();
    }}

    function collectHistoryNotificationRows() {{
      return collectSystemNotificationRows();
    }}

    function renderHistoryNotificationLog(nowUnix = Math.floor(Date.now() / 1000)) {{
      const host = document.getElementById("history-notification-list");
      if (!(host instanceof HTMLElement)) return;
      const caption = document.getElementById("history-notification-caption");
      const rows = collectHistoryNotificationRows();
      if (caption instanceof HTMLElement) {{
        caption.textContent = rows.length
          ? `Showing ${{rows.length}} recent inbound system notifications from this browser log.`
          : "No saved system notification history yet in this browser.";
      }}
      if (!rows.length) {{
        host.innerHTML = '<div class="history-notification-empty">No system notification history yet in this browser.</div>';
        return;
      }}
      host.innerHTML = rows.map((row) => {{
        const channelKey = normalizeChatChannel(row && row.channel ? row.channel : "all");
        const channelLabel = channelKey === "direct" ? "Peer-to-peer" : "Everyone";
        const kindRaw = String(row && row.kind ? row.kind : "").trim().toLowerCase();
        const kind = kindRaw === "reaction"
          ? "reaction"
          : (kindRaw === "status" ? "status" : "message");
        const kindLabel = kind === "reaction"
          ? "Reaction"
          : (kind === "status" ? "Status" : "Message");
        const isSeen = row && row.seen === true;
        const statusLabel = isSeen ? "Seen" : "New";
        const unixRaw = Number(row && row.unix);
        const unix = Number.isFinite(unixRaw) && unixRaw > 0 ? Math.trunc(unixRaw) : null;
        const when = unix ? savedDetailAge(unix, nowUnix) : "just now";
        const whenAbs = unix ? formatConsoleListTime(unix) : "n/a";
        const sender = String(row && row.sender ? row.sender : "Unknown node");
        const preview = String(row && row.preview ? row.preview : "update");
        return `<div class="history-notification-item ${{isSeen ? "is-seen" : "is-new"}}" title="${{escAttr(`${{channelLabel}} | ${{kindLabel}} | ${{whenAbs}}`)}}">
          <div class="history-notification-meta">
            <span class="history-notification-pill status-${{isSeen ? "seen" : "new"}}">${{statusLabel}}</span>
            <span class="history-notification-pill kind-${{kind}}">${{kindLabel}}</span>
            <span class="history-notification-pill">${{escAttr(channelLabel)}}</span>
          </div>
          <div class="history-notification-text"><strong>${{escAttr(sender)}}</strong>: ${{escAttr(preview)}}</div>
          <div class="history-notification-time" title="${{escAttr(whenAbs)}}">${{escAttr(when)}}</div>
        </div>`;
      }}).join("");
    }}

    function bindHistoryNotificationControls() {{
      const clearBtn = document.getElementById("history-notification-clear-btn");
      if (!(clearBtn instanceof HTMLButtonElement) || clearBtn.dataset.bound === "1") return;
      clearBtn.dataset.bound = "1";
      clearBtn.addEventListener("click", (ev) => {{
        ev.preventDefault();
        clearChatChangeNotices();
        clearChatFeedChangeFocus();
        renderChatChangeSummary();
        if (latestState) {{
          renderChat(latestState);
        }} else {{
          renderHistoryNotificationLog();
        }}
      }});
    }}

    function renderNodeHistoryOverview(history, node) {{
      const summary = history.summary || {{}};
      const target = document.getElementById("node-history-overview");
      if (!target) return;
      const historyNodeId = normalizeNodeId(history.node_id || "");
      const fallbackNodeId = resolveSavedViewNodeId(latestState);
      const label = node ? nodeLabel(node) : (historyNodeId || fallbackNodeId || "node");
      const items = [
        ["Node", `${{label}}`],
        ["Node ID", `${{historyNodeId || fallbackNodeId || "n/a"}}`],
        ["Points", `${{summary.points ?? (history.points || []).length ?? 0}}`],
        ["Trail Points", `${{summary.trail_points ?? (history.positions || []).length ?? 0}}`],
        ["Packets", `${{summary.total_packets ?? 0}}`],
        ["Window", `${{history.window_hours ?? nodeHistoryHours}}h`],
        ["Last Seen", `${{summary.last_seen || "n/a"}}`],
        ["Trail Range", `${{summary.trail_start || "n/a"}} to ${{summary.trail_end || "n/a"}}`],
        ["SNR Range", `${{formatMetricValue(summary.snr_min, 1)}} to ${{formatMetricValue(summary.snr_max, 1)}} dB`],
        ["RSSI Range", `${{formatMetricValue(summary.rssi_min, 0)}} to ${{formatMetricValue(summary.rssi_max, 0)}} dBm`],
      ];
      target.innerHTML = items.map(([k, v]) => (
        `<div class="overview-item"><div class="k">${{k}}</div><div class="v">${{v}}</div></div>`
      )).join("");
    }}

    function renderNodeHistory(history, nodes) {{
      setMapDataMode("node");
      const historyNodeId = normalizeNodeId(history.node_id || "");
      const node = (nodes || []).find((entry) => normalizeNodeId(entry && entry.id) === historyNodeId)
        || savedViewNodeFrom(nodes, latestState);
      const caption = document.getElementById("node-history-caption");
      if (caption) {{
        const fallbackNodeId = resolveSavedViewNodeId(latestState);
        const name = node ? nodeLabel(node) : (historyNodeId || fallbackNodeId || "node");
        const span = history.summary || {{}};
        const trailPoints = Number.isFinite(Number(span.trail_points))
          ? Number(span.trail_points)
          : (Array.isArray(history.positions) ? history.positions.length : 0);
        const loc = (node && typeof node.lat === "number" && typeof node.lon === "number")
          ? `Current location: ${{node.lat.toFixed(5)}}, ${{node.lon.toFixed(5)}}.`
          : "No current location available from live node state.";
        caption.textContent = `${{name}} (${{historyNodeId || fallbackNodeId || "n/a"}}). ${{loc}} History window: ${{history.window_hours || nodeHistoryHours}}h, packets: ${{span.total_packets ?? 0}}, trail points: ${{trailPoints}}.`;
      }}
      renderSignalChart(history.points || []);
      renderNodeHistoryOverview(history, node);
      setHistoryTab(activeHistoryTab);
    }}

    async function fetchNodeHistory(nodeId, opts = null) {{
      if (!isSelectableNodeId(nodeId)) return null;
      const options = (opts && typeof opts === "object") ? opts : {{}};
      const force = options.force === true;
      const signal = options.signal || undefined;
      const cached = nodeHistoryCache.get(nodeId);
      const nowMs = Date.now();
      // Node history changes much slower than live state; avoid hammering the DB.
      const ttlMs = Math.max(refreshMs * 2, 8000);
      if (!force && cached && (nowMs - (cached.fetchedAt || 0)) < ttlMs) {{
        return cached.data;
      }}
      const url = `/api/history/node?node_id=${{encodeURIComponent(nodeId)}}&hours=${{nodeHistoryHours}}&points=${{nodeHistoryMaxPoints}}`;
      const resp = await fetch(url, {{ cache: "no-store", signal }});
      if (!resp.ok) throw new Error(`history API ${{resp.status}}`);
      const data = await resp.json();
      nodeHistoryCache.set(nodeId, {{ fetchedAt: nowMs, data }});
      return data;
    }}

    function cachedNodeHistory(nodeId) {{
      const clean = normalizeNodeId(nodeId || "");
      if (!isSelectableNodeId(clean)) return null;
      const cached = nodeHistoryCache.get(clean);
      if (!cached || !cached.data) return null;
      const dataId = normalizeNodeId(cached.data.node_id || "");
      if (dataId && dataId !== clean) return null;
      return cached.data;
    }}

    function abortNodeHistoryFetch() {{
      if (nodeHistoryFetchAbort) {{
        try {{
          nodeHistoryFetchAbort.abort();
        }} catch (_err) {{
        }}
      }}
      nodeHistoryFetchAbort = null;
      nodeHistoryFetchNodeId = "";
    }}

    function applyNodeHistoryToView(nodeHistory) {{
      const state = latestState;
      if (!state) return;
      const nodes = state.nodes || [];
      const traffic = (state.traffic || {{}});
      const edges = traffic.edges || [];

      if (activeLayoutView === "saved" || activeLayoutView === "network") {{
        renderMap(nodes, edges, nodeHistory);
      }}

      if (activeLayoutView === "network" && pendingMapHistoryFocus) {{
        const historyNodeId = normalizeNodeId((nodeHistory && nodeHistory.node_id) || "");
        const selectionId = normalizeNodeId(selectedNodeId || "");
        if (historyNodeId && selectionId && historyNodeId === selectionId) {{
          focusSelectedNodeOnMap(nodeHistory);
          pendingMapHistoryFocus = false;
        }}
      }}

      // The signal plot lives in the map-data panel, rendered by renderTraffic.
      if (activeLayoutView === "saved" || activeLayoutView === "network") {{
        renderTraffic(traffic, nodes, nodeHistory);
      }}

      if (activeLayoutView === "saved") {{
        renderSavedNodeDetails(state, nodeHistory);
      }}
    }}

    async function refreshSelectedNodeHistory(force = false) {{
      const nodeId = activeLayoutView === "saved"
        ? resolveSavedViewNodeId(latestState)
        : normalizeNodeId(selectedNodeId || "");
      if (!isSelectableNodeId(nodeId)) {{
        abortNodeHistoryFetch();
        return null;
      }}
      if (!(activeLayoutView === "saved" || activeLayoutView === "network")) {{
        // No need to load node history unless the map views that can use it are visible.
        abortNodeHistoryFetch();
        return null;
      }}
      if (mapDataFocus === "activity") {{
        // When showing online activity, keep node history idle.
        abortNodeHistoryFetch();
        return null;
      }}

      const nowMs = Date.now();
      const ttlMs = Math.max(refreshMs * 2, 8000);
      const cached = nodeHistoryCache.get(nodeId);
      const cachedData = cached && cached.data ? cached.data : null;
      const cacheFresh = !!cachedData && (nowMs - (cached.fetchedAt || 0)) < ttlMs;

      if (!force && cacheFresh) {{
        // Ensure the UI is actually showing the cached history (selection changes can
        // switch the UI into a loading state without re-rendering the chart).
        applyNodeHistoryToView(cachedData);
        return cachedData;
      }}

      if (!force && nodeHistoryFetchAbort && nodeHistoryFetchNodeId === nodeId) {{
        return null;
      }}

      abortNodeHistoryFetch();
      nodeHistoryFetchSeq += 1;
      const seq = nodeHistoryFetchSeq;
      nodeHistoryFetchNodeId = nodeId;
      nodeHistoryFetchAbort = new AbortController();
      const signal = nodeHistoryFetchAbort.signal;

      if (!cachedData && activeLayoutView === "saved") {{
        renderNodeHistoryLoading(nodeId);
      }}

      try {{
        const data = await fetchNodeHistory(nodeId, {{ force: true, signal }});
        if (seq !== nodeHistoryFetchSeq) return null;
        const activeNodeId = activeLayoutView === "saved"
          ? resolveSavedViewNodeId(latestState)
          : normalizeNodeId(selectedNodeId || "");
        if (activeNodeId !== nodeId) return null;
        if (!(activeLayoutView === "saved" || activeLayoutView === "network")) return null;
        if (mapDataFocus === "activity") return null;
        applyNodeHistoryToView(data);
        return data;
      }} catch (err) {{
        if (err && err.name === "AbortError") return null;
        if (seq !== nodeHistoryFetchSeq) return null;
        const msg = err instanceof Error ? err.message : String(err || "unknown error");
        const caption = document.getElementById("node-history-caption");
        if (caption && activeLayoutView === "saved") {{
          caption.textContent = `History error for ${{nodeId}}: ${{msg}}`;
        }}
        return null;
      }} finally {{
        if (seq === nodeHistoryFetchSeq) {{
          nodeHistoryFetchAbort = null;
          nodeHistoryFetchNodeId = "";
        }}
      }}
    }}

    async function fetchOnlineActivity(hoursOverride = nodeHistoryHours) {{
      const cleanHours = Math.max(1, Math.round(Number(hoursOverride) || nodeHistoryHours));
      const cacheKey = String(cleanHours);
      const cached = onlineActivityCache.get(cacheKey);
      const nowMs = Date.now();
      // Online activity is an aggregate rollup; refresh less frequently.
      if (cached && (nowMs - (cached.fetchedAt || 0)) < Math.max(refreshMs * 5, 30000)) {{
        return cached.data;
      }}
      const url = `/api/history/online?hours=${{encodeURIComponent(cleanHours)}}`;
      const resp = await fetch(url, {{ cache: "no-store" }});
      if (!resp.ok) throw new Error(`online activity API ${{resp.status}}`);
      const data = await resp.json();
      onlineActivityCache.set(cacheKey, {{ fetchedAt: nowMs, data }});
      return data;
    }}

    async function fetchSummaryMetrics(hoursOverride = nodeHistoryHours) {{
      const cleanHours = Math.max(1, Math.round(Number(hoursOverride) || nodeHistoryHours));
      const cacheKey = String(cleanHours);
      const cached = summaryMetricsCache.get(cacheKey);
      const nowMs = Date.now();
      if (cached && (nowMs - (cached.fetchedAt || 0)) < Math.max(refreshMs * 10, 60000)) {{
        return cached.data;
      }}
      const url = `/api/history/summary?hours=${{encodeURIComponent(cleanHours)}}`;
      const resp = await fetch(url, {{ cache: "no-store" }});
      if (!resp.ok) throw new Error(`summary metrics API ${{resp.status}}`);
      const data = await resp.json();
      summaryMetricsCache.set(cacheKey, {{ fetchedAt: nowMs, data }});
      return data;
    }}

    async function fetchConsoleHistorySearch(opts = null) {{
      const options = (opts && typeof opts === "object") ? opts : {{}};
      const queryText = String(options.queryText ?? options.query ?? "").trim();
      const params = new URLSearchParams();
      params.set("q", queryText);
      const limit = Number(options.limit);
      const before = Number(options.before);
      const after = Number(options.after);
      const scanLimit = Number(options.scanLimit);
      const scope = String(options.scope || "").trim().toLowerCase();
      if (Number.isFinite(limit) && limit > 0) {{
        params.set("limit", String(Math.trunc(limit)));
      }}
      if (Number.isFinite(before) && before >= 0) {{
        params.set("before", String(Math.trunc(before)));
      }}
      if (Number.isFinite(after) && after >= 0) {{
        params.set("after", String(Math.trunc(after)));
      }}
      if (Number.isFinite(scanLimit) && scanLimit > 0) {{
        params.set("scan", String(Math.trunc(scanLimit)));
      }}
      if (scope) {{
        params.set("scope", scope);
      }}
      const resp = await fetch(`/api/history/search?${{params.toString()}}`, {{ cache: "no-store" }});
      if (!resp.ok) throw new Error(`history search API ${{resp.status}}`);
      const payload = await resp.json();
      return (payload && typeof payload === "object") ? payload : {{}};
    }}

    function hydrateTickerSeriesFromSummaryMetrics(historyPayload) {{
      const payload = (historyPayload && typeof historyPayload === "object") ? historyPayload : {{}};
      const points = sliceSummaryPointsAfterLiveCounterReset(payload.points);
      const byKey = new Map([
        ["nodes", []],
        ["online_nodes", []],
        ["live_packets", []],
        ["live_packets_per_min", []],
        ["real_links", []],
      ]);
      for (const point of points) {{
        if (!point || typeof point !== "object") continue;
        const bucketUnix = Number(point.bucket_unix);
        if (!Number.isFinite(bucketUnix) || bucketUnix <= 0) continue;
        const bucketMs = Math.floor(bucketUnix) * 1000;
        const nodeCount = Number(point.node_count);
        const onlineCount = Number(point.online_node_count);
        const livePackets = Number(point.live_packet_count);
        const realLinks = Number(point.real_edge_count);
        if (Number.isFinite(nodeCount)) {{
          byKey.get("nodes").push({{ ms: bucketMs, value: nodeCount }});
        }}
        if (Number.isFinite(onlineCount)) {{
          byKey.get("online_nodes").push({{ ms: bucketMs, value: onlineCount }});
        }}
        if (Number.isFinite(livePackets)) {{
          byKey.get("live_packets").push({{ ms: bucketMs, value: livePackets }});
        }}
        if (Number.isFinite(realLinks)) {{
          byKey.get("real_links").push({{ ms: bucketMs, value: realLinks }});
        }}
      }}

      const livePacketTotals = byKey.get("live_packets") || [];
      const livePacketRates = derivePacketsPerMinuteSeriesFromTotals(livePacketTotals);
      if (livePacketRates.length > 0) {{
        byKey.set("live_packets_per_min", livePacketRates);
      }}

      const cutoffMs = Date.now() - metricTickerWindowMs;
      for (const [metricKey, series] of byKey.entries()) {{
        if (!Array.isArray(series) || series.length === 0) continue;
        series.sort((a, b) => Number(a.ms) - Number(b.ms));
        trimMetricTickerPoints(series, cutoffMs);
        metricTickerSeries.set(metricKey, series);
      }}
    }}

    async function hydrateSummaryMetricTickers(hoursOverride = Math.max(2, Math.min(24, nodeHistoryHours))) {{
      try {{
        const data = await fetchSummaryMetrics(hoursOverride);
        hydrateTickerSeriesFromSummaryMetrics(data);
        summaryMetricsHydrated = true;
        if (latestState) {{
          renderSummary(latestState);
        }}
      }} catch (_err) {{
        summaryMetricsHydrated = false;
      }}
    }}

    async function refreshHistoryPanels(force = false) {{
      if (activeLayoutView !== "history") return;
      setMapDataMode("activity");
      const weeklyKey = String(weeklySummaryHours);
      if (force) {{
        summaryMetricsCache.delete(weeklyKey);
      }}
      const cachedWeekly = summaryMetricsCache.get(weeklyKey);
      if (cachedWeekly && cachedWeekly.data) {{
        renderWeeklySummary(cachedWeekly.data);
      }} else {{
        renderWeeklySummaryLoading();
      }}

      try {{
        const weekly = await fetchSummaryMetrics(weeklySummaryHours);
        if (activeLayoutView !== "history") return;
        renderWeeklySummary(weekly);
      }} catch (reason) {{
        if (activeLayoutView !== "history") return;
        const message = reason instanceof Error ? reason.message : String(reason || "unknown error");
        renderWeeklySummaryError(message);
      }}
    }}

    function renderTraffic(traffic, nodes, nodeHistory) {{
      if (mapDataFocus === "activity") {{
        setMapDataMode("activity");
        return;
      }}

      const savedNodeId = activeLayoutView === "saved"
        ? resolveSavedViewNodeId(latestState)
        : "";
      const showNodeHistory = activeLayoutView === "saved" && isSelectableNodeId(savedNodeId);
      if (showNodeHistory) {{
        if (nodeHistory && normalizeNodeId(nodeHistory.node_id) === savedNodeId) {{
          renderNodeHistory(nodeHistory, nodes);
        }} else {{
          renderNodeHistoryLoading(savedNodeId);
        }}
        return;
      }}

      setMapDataMode("live");
      const ports = (traffic.port_counts || []).slice(0, 30).map((item) => (
        `<tr><td data-sort="${{escAttr(item.portnum ?? "")}}">${{item.portnum}}</td><td data-sort="${{escAttr(item.count ?? "")}}">${{item.count}}</td></tr>`
      ));
      fillTable("ports-table", ports);

      const links = (traffic.edges || []).slice(0, 60).map((edge) => (
        `<tr>
          <td data-sort="${{escAttr(edge.from ?? "")}}">${{edge.from}}</td>
          <td data-sort="${{escAttr(edge.to ?? "")}}">${{edge.to}}</td>
          <td data-sort="${{escAttr(edge.lifetime_count ?? edge.count ?? 0)}}">${{edge.lifetime_count ?? edge.count ?? 0}}</td>
          <td data-sort="${{escAttr(edge.avg_hops ?? "")}}">${{edge.avg_hops == null ? "n/a" : edge.avg_hops}}</td>
          <td data-sort="${{escAttr(edge.confidence || (edge.is_real ? "confirmed" : "observed"))}}">${{edge.confidence || (edge.is_real ? "confirmed" : "observed")}}</td>
          <td data-sort="${{escAttr(edge.last_rx_time ?? "")}}">${{edge.last_rx_time || "n/a"}}</td>
        </tr>`
      ));
      fillTable("links-table", links);
    }}

