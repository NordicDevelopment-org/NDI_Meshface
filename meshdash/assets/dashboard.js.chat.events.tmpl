    function selectNodeFromDirectionalRow(row, targetCell, fromColIndex, toColIndex) {{
      if (!(row instanceof HTMLTableRowElement)) return "";
      const fromNodeId = normalizeNodeId(row.dataset.fromNodeId || "");
      const toNodeId = normalizeNodeId(row.dataset.toNodeId || "");
      const fromSelectable = isSelectableNodeId(fromNodeId);
      const toSelectable = isSelectableNodeId(toNodeId);
      if (!(fromSelectable || toSelectable)) return "";

      if (targetCell instanceof HTMLTableCellElement && targetCell.parentElement === row) {{
        const colIndex = Array.from(row.cells).indexOf(targetCell);
        if (colIndex === fromColIndex && fromSelectable) return fromNodeId;
        if (colIndex === toColIndex && toSelectable) return toNodeId;
      }}

      if (fromSelectable) return fromNodeId;
      if (toSelectable) return toNodeId;
      return "";
    }}

