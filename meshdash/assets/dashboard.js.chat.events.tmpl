    function updateChatChangeBadge(count) {{
      const safeCount = Math.max(0, Math.floor(Number(count) || 0));
      const btn = document.getElementById("chat-change-toggle-btn");
      if (btn instanceof HTMLButtonElement) {{
        btn.classList.toggle("has-unread", safeCount > 0);
        const countLabel = safeCount > 99 ? "99+" : String(safeCount);
        btn.title = safeCount > 0
          ? `${{countLabel}} inbound system notification${{safeCount === 1 ? "" : "s"}}`
          : "No inbound system notifications";
        btn.setAttribute(
          "aria-label",
          safeCount > 0
            ? `System notifications (${{countLabel}})`
            : "System notifications"
        );
      }}
      const badge = document.getElementById("chat-change-badge");
      if (badge instanceof HTMLElement) {{
        if (safeCount > 0) {{
          badge.hidden = false;
          badge.textContent = safeCount > 99 ? "99+" : String(safeCount);
        }} else {{
          badge.hidden = true;
          badge.textContent = "0";
        }}
      }}
    }}

    function renderChatChangeSummary(nowUnix = Math.floor(Date.now() / 1000)) {{
      const panel = document.getElementById("chat-change-summary");
      if (!(panel instanceof HTMLElement)) return;
      const notices = collectSystemNotificationRows();
      const count = notices.length;
      const alertCount = notices.filter((notice) => notice && notice.seen !== true).length;
      updateChatChangeBadge(alertCount);
      if (!notices.length) {{
        panel.innerHTML = '<div class="chat-change-empty">No inbound system notifications while you were away.</div>';
        panel.hidden = !chatChangeMenuOpen;
        return;
      }}
      const recent = notices.slice(-chatChangeSummaryMaxRows).reverse();
      const rows = recent.map((notice) => {{
        const sender = escAttr(String(notice && notice.sender ? notice.sender : "Unknown node"));
        const preview = escAttr(String(notice && notice.preview ? notice.preview : "update"));
        const kindRaw = String(notice && notice.kind ? notice.kind : "").trim().toLowerCase();
        const kind = kindRaw === "reaction"
          ? "reaction"
          : (kindRaw === "status" ? "status" : "message");
        const kindLabel = kind === "reaction"
          ? "Reaction"
          : (kind === "status" ? "Status" : "Message");
        const kindClass = kind === "reaction" ? "reaction" : "message";
        const resolvedKindClass = kind === "status" ? "status" : kindClass;
        const focusKey = escAttr(String((notice && (notice.focusKey || notice.key)) || ""));
        const targetView = escAttr(normalizeLayoutView(notice && notice.targetView ? notice.targetView : "chat"));
        const targetChatChannel = escAttr(normalizeChatChannel(notice && notice.targetChatChannel ? notice.targetChatChannel : notice && notice.channel ? notice.channel : "all"));
        const peerNodeId = escAttr(normalizeNodeId(notice && notice.peerNodeId ? notice.peerNodeId : ""));
        const when = notice && Number.isFinite(Number(notice.unix))
          ? savedDetailAge(Number(notice.unix), nowUnix)
          : "just now";
        return `<button type="button" class="chat-change-item" data-change-focus-key="${{focusKey}}" data-change-target-view="${{targetView}}" data-change-chat-channel="${{targetChatChannel}}" data-change-peer-node-id="${{peerNodeId}}" title="Open this update">
          <span class="chat-change-item-main">
            <span class="chat-change-kind ${{resolvedKindClass}}">${{kindLabel}}</span>
            <span class="chat-change-item-text"><strong>${{sender}}</strong>: ${{preview}}</span>
          </span>
          <span class="chat-change-item-age">${{escAttr(when)}}</span>
        </button>`;
      }}).join("");
      const headline = `${{count}} inbound system notification${{count === 1 ? "" : "s"}}`;
      panel.innerHTML = `<div class="chat-change-head">
        <div class="chat-change-title">${{escAttr(headline)}}</div>
        <button type="button" id="chat-change-clear-btn" class="chat-change-clear-btn" title="Clear inbound system notifications">Clear</button>
      </div>
      <div class="chat-change-list">${{rows}}</div>`;
      panel.hidden = !chatChangeMenuOpen;
    }}

    function findChatFeedItemByMessageKey(messageKey) {{
      const key = String(messageKey || "").trim();
      if (!key) return null;
      for (const item of document.querySelectorAll("#chat-feed .chat-feed-item")) {{
        if (!(item instanceof HTMLElement)) continue;
        if (String(item.dataset.messageKey || "") === key) {{
          return item;
        }}
      }}
      return null;
    }}

    function clearChatFeedChangeFocus() {{
      for (const item of document.querySelectorAll("#chat-feed .chat-feed-item.change-focus")) {{
        if (!(item instanceof HTMLElement)) continue;
        item.classList.remove("change-focus");
      }}
      if (chatChangeFocusTimer !== null) {{
        clearTimeout(chatChangeFocusTimer);
        chatChangeFocusTimer = null;
      }}
    }}

    function focusChatFeedItem(item) {{
      if (!(item instanceof HTMLElement)) return;
      clearChatFeedChangeFocus();
      item.classList.add("change-focus");
      chatChangeFocusTimer = window.setTimeout(() => {{
        item.classList.remove("change-focus");
        chatChangeFocusTimer = null;
      }}, 1600);
    }}

    function focusChatNoticeByMessageKey(messageKey) {{
      const key = String(messageKey || "").trim();
      if (!key) return false;
      const target = findChatFeedItemByMessageKey(key);
      if (!(target instanceof HTMLElement)) return false;
      target.scrollIntoView({{ behavior: "smooth", block: "center" }});
      focusChatFeedItem(target);
      return true;
    }}

    function openNoticeTarget(targetViewRaw, focusKeyRaw, chatChannelRaw = "all", peerNodeIdRaw = "") {{
      const targetView = normalizeLayoutView(targetViewRaw || "chat");
      const focusKey = String(focusKeyRaw || "").trim();
      const targetChatChannel = normalizeChatChannel(chatChannelRaw || "all");
      const peerNodeId = normalizeNodeId(peerNodeIdRaw || "");
      const switchedView = activeLayoutView !== targetView;
      if (switchedView) {{
        applyLayoutView(targetView, true);
      }}
      const finalize = () => {{
        if (targetView === "chat") {{
          applyChatChannel(targetChatChannel, true);
          if (targetChatChannel === "direct" && isSelectableNodeId(peerNodeId)) {{
            selectNode(peerNodeId, false, false);
          }}
          if (!focusChatNoticeByMessageKey(focusKey)) {{
            setChatSendStatus("Change is older than the visible chat window.", true);
          }}
          return;
        }}
        if ((targetView === "saved" || targetView === "network") && isSelectableNodeId(focusKey)) {{
          selectNode(focusKey, true, false);
        }}
      }};
      if (switchedView) {{
        window.requestAnimationFrame(finalize);
      }} else {{
        finalize();
      }}
    }}

    function bindChatChangeSummaryControls() {{
      const btn = document.getElementById("chat-change-toggle-btn");
      if (btn instanceof HTMLButtonElement && btn.dataset.bound !== "1") {{
        btn.dataset.bound = "1";
        btn.addEventListener("click", (ev) => {{
          ev.preventDefault();
          ev.stopPropagation();
          markChatChangeAlertsAcknowledged();
          const nextOpen = !chatChangeMenuOpen;
          setChatChangeMenuOpen(nextOpen);
          if (nextOpen) {{
            setChatSettingsMenuOpen(false);
            setFavoriteMenuOpen(false);
          }}
          renderChatChangeSummary();
          if (nextOpen) {{
            bindChatChangeSummaryControls();
          }}
        }});
      }}

      if (document.body.dataset.chatChangeMenuDocBound !== "1") {{
        document.body.dataset.chatChangeMenuDocBound = "1";
        document.addEventListener("pointerdown", (ev) => {{
          if (!chatChangeMenuOpen) return;
          const target = ev.target;
          if (!(target instanceof Element)) {{
            setChatChangeMenuOpen(false);
            return;
          }}
          if (target.closest("#chat-change-toggle-btn") || target.closest("#chat-change-summary")) {{
            return;
          }}
          setChatChangeMenuOpen(false);
        }});
        document.addEventListener("keydown", (ev) => {{
          if (ev.key !== "Escape" || !chatChangeMenuOpen) return;
          setChatChangeMenuOpen(false);
        }});
      }}

      const panel = document.getElementById("chat-change-summary");
      if (!(panel instanceof HTMLElement) || panel.hidden) return;
      const clearBtn = panel.querySelector("#chat-change-clear-btn");
      if (clearBtn instanceof HTMLButtonElement) {{
        clearBtn.addEventListener("click", (ev) => {{
          ev.preventDefault();
          clearChatChangeNotices();
          clearChatFeedChangeFocus();
          if (latestState) {{
            renderChat(latestState);
          }} else {{
            renderChatChangeSummary();
          }}
        }});
      }}
      for (const itemBtn of panel.querySelectorAll(".chat-change-item")) {{
        if (!(itemBtn instanceof HTMLButtonElement)) continue;
        itemBtn.addEventListener("click", (ev) => {{
          ev.preventDefault();
          setChatChangeMenuOpen(false);
          const targetView = normalizeLayoutView(itemBtn.dataset.changeTargetView || "chat");
          const focusKey = String(itemBtn.dataset.changeFocusKey || "").trim();
          const targetChatChannel = normalizeChatChannel(itemBtn.dataset.changeChatChannel || "all");
          const peerNodeId = normalizeNodeId(itemBtn.dataset.changePeerNodeId || "");
          openNoticeTarget(targetView, focusKey, targetChatChannel, peerNodeId);
        }});
