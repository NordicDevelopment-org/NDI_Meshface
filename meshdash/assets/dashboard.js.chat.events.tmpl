    function sortedConfigSectionNames(scopeObj, excludedNames = []) {{
      if (!scopeObj || typeof scopeObj !== "object") return [];
      const excluded = new Set(excludedNames.map((name) => String(name || "").trim().toLowerCase()));
      const names = [];
      for (const [name, value] of Object.entries(scopeObj)) {{
        if (!name || excluded.has(String(name).toLowerCase())) continue;
        if (!value || typeof value !== "object" || Array.isArray(value)) continue;
        names.push(name);
