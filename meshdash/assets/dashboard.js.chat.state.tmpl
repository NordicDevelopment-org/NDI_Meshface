      }}
      if (filesSelect instanceof HTMLSelectElement) {{
        filesSelect.value = String(activeMeshSendChannelIndex);
        filesSelect.title = `Outgoing file transfer channel: ${{sendLabel}}`;
      }}
      if (filesHint instanceof HTMLElement) {{
        filesHint.textContent = `Files send on ${{sendLabel}}. Message channels are encryption groups, not frequency slots.`;
      }}
      const btn = document.getElementById("chat-send-channel-menu-btn");
      if (btn instanceof HTMLButtonElement) {{
        btn.innerHTML = `${{meshChannelPrimaryBadgeHtml(activeMeshSendChannelIndex)}}<span class="mesh-channel-menu-btn-label">${{escAttr(sendLabel)}}</span>`;
        btn.title = meta.title === sendLabel ? meta.title : `${{meta.title}} • ${{sendLabel}}`;
        const select = document.getElementById("chat-send-channel-select");
