    function renderFileTransferConsole() {{
      const logEl = document.getElementById("files-console-log");
      if (!(logEl instanceof HTMLElement)) return;
      const shouldStickBottom = (
        logEl.scrollHeight - (logEl.scrollTop + logEl.clientHeight)
      ) <= 20;
      const lines = fileTransferConsoleLines.slice(-fileTransferConsoleMaxEntries);
      logEl.textContent = lines.length ? lines.join("\n") : "No file transfer activity yet.";
      if (shouldStickBottom) {{
        logEl.scrollTop = logEl.scrollHeight;
      }}
    }}

    function appendFileTransferConsole(message, options = null) {{
      const text = String(message == null ? "" : message).trim();
      if (!text) return;
      const levelRaw = String(options && options.level ? options.level : "info").trim().toLowerCase();
      const level = levelRaw === "error" || levelRaw === "warn" ? levelRaw : "info";
      const tag = level === "error" ? "ERR" : level === "warn" ? "WRN" : "INF";
      fileTransferConsoleLines.push(`${{fileTransferConsoleTimestamp()}} [${{tag}}] ${{text}}`);
      if (fileTransferConsoleLines.length > fileTransferConsoleMaxEntries) {{
        fileTransferConsoleLines.splice(0, fileTransferConsoleLines.length - fileTransferConsoleMaxEntries);
      }}
      renderFileTransferConsole();
    }}

    function clearFileTransferConsole() {{
      fileTransferConsoleLines.length = 0;
      renderFileTransferConsole();
    }}

    async function copyFileTransferConsoleToClipboard() {{
      const text = fileTransferConsoleLines.length
        ? fileTransferConsoleLines.join("\n")
        : "No file transfer activity yet.";
      if (navigator.clipboard && typeof navigator.clipboard.writeText === "function") {{
        try {{
          await navigator.clipboard.writeText(text);
          return true;
        }} catch (_err) {{
        }}
      }}
      try {{
        // Browser fallback for non-secure contexts where navigator.clipboard is blocked.
        const ta = document.createElement("textarea");
        ta.value = text;
        ta.setAttribute("readonly", "readonly");
        ta.style.position = "fixed";
        ta.style.left = "-9999px";
        ta.style.top = "0";
        document.body.appendChild(ta);
        ta.focus();
        ta.select();
        ta.setSelectionRange(0, ta.value.length);
        let copied = false;
        try {{
          copied = document.execCommand("copy");
        }} catch (_err) {{
          copied = false;
        }}
        ta.remove();
        return !!copied;
      }} catch (_err) {{
        return false;
      }}
    }}

