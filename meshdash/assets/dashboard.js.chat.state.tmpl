    function classifyMessageChannel(msg) {{
      if (!msg || typeof msg !== "object") return "all";
      const toId = normalizeNodeId(msg.to || msg.destination || "");
      if (!toId || toId === "^all" || toId === "all" || toId === "broadcast") {{
        return "all";
      }}
      if (typeof msg.scope === "string" && msg.scope.trim()) {{
        return normalizeChatChannel(msg.scope);
      }}
      return "direct";
    }}

    function utf8ByteLength(value) {{
      const raw = String(value == null ? "" : value);
      if (typeof TextEncoder !== "undefined") {{
        try {{
          return new TextEncoder().encode(raw).length;
        }} catch (_err) {{
        }}
      }}
      const encoded = encodeURIComponent(raw);
      let count = 0;
      for (let i = 0; i < encoded.length; i += 1) {{
        if (encoded[i] === "%" && i + 2 < encoded.length) {{
          count += 1;
          i += 2;
        }} else {{
          count += 1;
        }}
      }}
      return count;
    }}

    function waitFileTransferFrameGap() {{
      const delayMs = Math.max(0, Math.trunc(Number(fileTransferInterFrameDelayMs) || 0));
      if (delayMs <= 0) return Promise.resolve();
      return new Promise((resolve) => {{
        window.setTimeout(resolve, delayMs);
      }});
    }}

    function formatFileTransferSize(rawBytes) {{
      const bytes = Number(rawBytes);
      if (!Number.isFinite(bytes) || bytes < 0) return "n/a";
      if (bytes < 1024) return `${{Math.trunc(bytes)}} B`;
      const kib = bytes / 1024;
      if (kib < 1024) return `${{kib.toFixed(kib >= 100 ? 0 : 1)}} KiB`;
      const mib = kib / 1024;
      return `${{mib.toFixed(mib >= 100 ? 0 : 1)}} MiB`;
    }}

    function normalizeFileTransferName(rawName) {{
      const compact = String(rawName == null ? "" : rawName)
        .replace(/\r\n/g, " ")
        .replace(/\r/g, " ")
        .replace(/\n/g, " ")
        .replace(/\s+/g, " ")
        .trim();
      const fallback = "mesh-file.bin";
      if (!compact) return fallback;
      const maxChars = 64;
      return compact.length > maxChars ? compact.slice(0, maxChars) : compact;
    }}

    function buildFileTransferId() {{
      const stamp = Date.now().toString(36);
      const rand = Math.random().toString(36).slice(2, 10);
      return `${{stamp}}${{rand}}`.replace(/[^a-z0-9]/gi, "").toLowerCase().slice(0, 20);
    }}

    function buildFileTransferNameEncoding(rawName, maxEncodedLen = 92) {{
      const normalized = normalizeFileTransferName(rawName);
      const fallback = "mesh-file.bin";
      let candidate = normalized;
      while (candidate.length > 1) {{
        const encoded = encodeURIComponent(candidate);
        if (encoded.length <= maxEncodedLen) {{
          return {{ name: candidate, encoded }};
        }}
        candidate = candidate.slice(0, -1).trim();
      }}
      return {{
        name: fallback,
        encoded: encodeURIComponent(fallback),
      }};
    }}

    function buildFileTransferMetaFrame(transferId, fileName, fileSize, totalChunks) {{
      const cleanId = String(transferId || "").trim().toLowerCase();
      const cleanSize = Math.max(0, Math.trunc(Number(fileSize) || 0));
      const cleanChunks = Math.max(1, Math.trunc(Number(totalChunks) || 1));
      const nameBits = buildFileTransferNameEncoding(fileName);
      return `${{fileTransferProtocolPrefix}}|M|${{cleanId}}|${{nameBits.encoded}}|${{cleanSize}}|${{cleanChunks}}`;
    }}

    function buildFileTransferChunkFrame(transferId, chunkIndex, payloadBase64) {{
      const cleanId = String(transferId || "").trim().toLowerCase();
      const cleanIdx = Math.max(0, Math.trunc(Number(chunkIndex) || 0));
      const payload = String(payloadBase64 || "").trim();
      return `${{fileTransferProtocolPrefix}}|C|${{cleanId}}|${{cleanIdx}}|${{payload}}`;
    }}

    function buildFileTransferChunkBitmapBase64(totalChunks, chunkIndexes) {{
      const total = Math.max(0, Math.trunc(Number(totalChunks) || 0));
      if (total <= 0) return "";
      const byteLen = Math.max(1, Math.ceil(total / 8));
      const bitmap = new Uint8Array(byteLen);
      const indexes = Array.isArray(chunkIndexes)
        ? chunkIndexes
        : Array.from(chunkIndexes || []);
      for (const rawIdx of indexes) {{
        const idx = Math.trunc(Number(rawIdx));
        if (!Number.isFinite(idx) || idx < 0 || idx >= total) continue;
        const byteIdx = Math.floor(idx / 8);
        const bitMask = 1 << (idx % 8);
        bitmap[byteIdx] |= bitMask;
      }}
      return encodeBytesToBase64(bitmap);
    }}

    function decodeFileTransferChunkBitmap(rawBase64, totalChunks) {{
      const total = Math.max(0, Math.trunc(Number(totalChunks) || 0));
      const received = new Set();
      if (total <= 0) return received;
      const bytes = decodeBase64ToBytes(rawBase64);
      if (!(bytes instanceof Uint8Array) || bytes.length <= 0) return received;
      for (let idx = 0; idx < total; idx += 1) {{
        const byteIdx = Math.floor(idx / 8);
        if (byteIdx >= bytes.length) break;
        const bitMask = 1 << (idx % 8);
        if ((bytes[byteIdx] & bitMask) !== 0) {{
          received.add(idx);
        }}
      }}
      return received;
    }}

    function buildFileTransferAckFrame(transferId, receivedCount, totalChunks, bitmapBase64) {{
      const cleanId = String(transferId || "").trim().toLowerCase();
      const total = Math.max(1, Math.trunc(Number(totalChunks) || 1));
      const received = Math.max(0, Math.min(total, Math.trunc(Number(receivedCount) || 0)));
      const bitmap = String(bitmapBase64 || "").trim();
      return `${{fileTransferProtocolPrefix}}|A|${{cleanId}}|${{received}}|${{total}}|${{bitmap}}`;
    }}

    function safeDecodeUriComponent(rawValue) {{
      const text = String(rawValue == null ? "" : rawValue);
      if (!text) return "";
      try {{
        return decodeURIComponent(text);
      }} catch (_err) {{
        return text;
      }}
    }}

    function parseFileTransferFrameText(rawText) {{
      const text = String(rawText == null ? "" : rawText).trim();
      const prefix = `${{fileTransferProtocolPrefix}}|`;
      if (!text || !text.startsWith(prefix)) return null;
      const parts = text.split("|");
      if (parts.length < 4) return null;
      const frameType = String(parts[1] || "").trim().toUpperCase();
      const transferId = String(parts[2] || "").trim().toLowerCase();
      if (!/^[a-z0-9]{4,24}$/.test(transferId)) return null;
      if (frameType === "M") {{
        if (parts.length < 6) return null;
        const fileName = normalizeFileTransferName(safeDecodeUriComponent(parts[3] || ""));
        const fileSize = Math.trunc(Number(parts[4]));
        const totalChunks = Math.trunc(Number(parts[5]));
        if (!Number.isFinite(fileSize) || fileSize < 0) return null;
        if (!Number.isFinite(totalChunks) || totalChunks <= 0) return null;
        return {{
          kind: "meta",
          transferId,
          fileName,
          fileSize,
          totalChunks,
        }};
      }}
      if (frameType === "C") {{
        if (parts.length < 5) return null;
        const chunkIndex = Math.trunc(Number(parts[3]));
        const chunkData = String(parts[4] || "").trim();
        if (!Number.isFinite(chunkIndex) || chunkIndex < 0) return null;
        if (!chunkData || !/^[A-Za-z0-9+/=]+$/.test(chunkData)) return null;
        return {{
          kind: "chunk",
          transferId,
          chunkIndex,
          chunkData,
        }};
      }}
      if (frameType === "A") {{
        if (parts.length < 6) return null;
        const receivedCount = Math.trunc(Number(parts[3]));
        const totalChunks = Math.trunc(Number(parts[4]));
        const bitmap = String(parts[5] || "").trim();
        if (!Number.isFinite(receivedCount) || receivedCount < 0) return null;
        if (!Number.isFinite(totalChunks) || totalChunks <= 0) return null;
        if (!bitmap || !/^[A-Za-z0-9+/=]+$/.test(bitmap)) return null;
        return {{
          kind: "ack",
          transferId,
          receivedCount: Math.min(receivedCount, totalChunks),
          totalChunks,
          bitmap,
        }};
      }}
      return null;
    }}

    function isFileTransferProtocolMessage(msg) {{
      if (!msg || typeof msg !== "object") return false;
      const text = String(msg.text == null ? "" : msg.text).trim();
      if (!text.startsWith(`${{fileTransferProtocolPrefix}}|`)) return false;
      return parseFileTransferFrameText(text) != null;
    }}

    function encodeBytesToBase64(bytes) {{
      const source = bytes instanceof Uint8Array ? bytes : new Uint8Array(bytes || []);
      if (!source.length) return "";
      let binary = "";
      const step = 0x8000;
      for (let offset = 0; offset < source.length; offset += step) {{
        const slice = source.subarray(offset, Math.min(source.length, offset + step));
        binary += String.fromCharCode(...slice);
      }}
      try {{
        return btoa(binary);
      }} catch (_err) {{
        return "";
      }}
    }}

    function decodeBase64ToBytes(rawBase64) {{
      const text = String(rawBase64 || "").trim();
      if (!text) return null;
      let binary = "";
      try {{
        binary = atob(text);
      }} catch (_err) {{
        return null;
      }}
      const out = new Uint8Array(binary.length);
      for (let i = 0; i < binary.length; i += 1) {{
        out[i] = binary.charCodeAt(i);
      }}
      return out;
    }}

    function explicitMessageMeshChannelIndex(msg) {{
      if (!msg || typeof msg !== "object") return null;
      const raw = msg.channel_index ?? msg.channelIndex ?? msg.channel;
      if (raw == null || raw === "") return null;
      const num = Number(raw);
      return Number.isInteger(num) && num >= 0 ? Math.trunc(num) : null;
    }}

    function messageMeshChannelIndex(msg) {{
      const explicit = explicitMessageMeshChannelIndex(msg);
      return Number.isInteger(explicit) && explicit >= 0 ? explicit : 0;
    }}

    function messageMatchesActiveMeshChannel(msg) {{
      const activeIdx = activeMeshChannelFilterIndex();
      if (activeIdx === meshChannelAllIndex) return true;
      return messageMeshChannelIndex(msg) === activeIdx;
    }}

