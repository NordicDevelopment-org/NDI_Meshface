    function resolveFileTransferDestination() {{
      const input = document.getElementById("files-destination-input");
      const rawInput = input instanceof HTMLInputElement ? input.value : "";
      let destination = normalizeNodeId(rawInput || fileTransferDestinationId || "");
      if (!isCanonicalNodeId(destination) && isSelectableNodeId(selectedNodeId)) {{
        destination = normalizeNodeId(selectedNodeId || "");
      }}
      if (!isCanonicalNodeId(destination)) return "";
