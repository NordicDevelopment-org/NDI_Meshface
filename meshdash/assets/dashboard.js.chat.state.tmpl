    function setMeshChannelSendMenuOpen(open) {{
      meshChannelSendMenuOpen = !!open;
      const panel = document.getElementById("chat-send-channel-menu");
      if (panel instanceof HTMLElement) {{
        panel.hidden = !meshChannelSendMenuOpen;
      }}
      const btn = document.getElementById("chat-send-channel-menu-btn");
      if (btn instanceof HTMLButtonElement) {{
        btn.setAttribute("aria-expanded", meshChannelSendMenuOpen ? "true" : "false");
      }}
    }}

    function collectMeshChannelOptionsFromLocalState(localState, options = {{}}) {{
      const root = (localState && typeof localState === "object") ? localState : {{}};
      const rawChannels = Array.isArray(root.channels) ? root.channels : [];
      const byIndex = new Map();
      const includeFallback = options.includeFallback !== false;
      const fallbackCount = Math.max(1, Math.trunc(Number(options.fallbackCount) || 0));

      for (let i = 0; i < rawChannels.length; i++) {{
        const ch = rawChannels[i];
        if (!ch || typeof ch !== "object") continue;

        const idxRaw = ch.index ?? ch.channel_index ?? ch.channelIndex ?? i;
        const idxNum = Math.trunc(Number(idxRaw));
        const index = Number.isInteger(idxNum) && idxNum >= 0 ? idxNum : i;

        const roleRaw = ch.role ?? ch.channel_role ?? ch.channelRole;
        const role = typeof roleRaw === "string" ? roleRaw.trim() : (roleRaw != null ? String(roleRaw) : "");
        const roleUpper = role.toUpperCase();
        const roleNum = Number(role);
        const disabled = (
          roleUpper === "DISABLED"
          || roleUpper === "CHANNEL_ROLE_DISABLED"
          || (Number.isInteger(roleNum) && roleNum === 0)
        );

        const settings = (ch.settings && typeof ch.settings === "object") ? ch.settings
          : (ch.channel_settings && typeof ch.channel_settings === "object") ? ch.channel_settings
          : (ch.channelSettings && typeof ch.channelSettings === "object") ? ch.channelSettings
          : null;
        const nameRaw = (
          settings && typeof settings.name === "string" ? settings.name
          : settings && typeof settings.channel_name === "string" ? settings.channel_name
          : settings && typeof settings.short_name === "string" ? settings.short_name
          : typeof ch.name === "string" ? ch.name
          : typeof ch.channel_name === "string" ? ch.channel_name
          : ""
        );
        const name = typeof nameRaw === "string" ? nameRaw.trim() : "";
        const pskRaw = (
          settings && settings.psk != null ? settings.psk
          : settings && settings.channel_psk != null ? settings.channel_psk
          : ch.psk != null ? ch.psk
          : ch.channel_psk != null ? ch.channel_psk
          : null
        );
        const hasPsk = Array.isArray(pskRaw)
          ? pskRaw.length > 0
          : (pskRaw != null && String(pskRaw).trim() !== "");

        const opt = {{ index, name, role, disabled, hasPsk }};
        if (!byIndex.has(index)) {{
          byIndex.set(index, opt);
        }} else {{
          const prev = byIndex.get(index);
          if (prev && typeof prev === "object") {{
            if (!prev.name && name) prev.name = name;
            if (!prev.role && role) prev.role = role;
            prev.hasPsk = prev.hasPsk === true || hasPsk === true;
            prev.disabled = prev.disabled && disabled;
          }}
        }}
      }}

      if (includeFallback) {{
        const fillCount = Math.max(fallbackCount, rawChannels.length || 0);
        for (let i = 0; i < fillCount; i++) {{
          if (!byIndex.has(i)) {{
            byIndex.set(i, {{ index: i, name: "", role: "", disabled: false, hasPsk: false }});
          }}
        }}
      }}

      const collectedOptions = Array.from(byIndex.values())
        .filter((opt) => opt && Number.isInteger(Number(opt.index)) && Number(opt.index) >= 0)
        .sort((a, b) => Number(a.index) - Number(b.index));

      if (collectedOptions.length) return collectedOptions;
      if (!includeFallback) return [];
      return [{{ index: 0, name: "", role: "", disabled: false, hasPsk: false }}];
    }}

    function buildMeshChannelOptionsFromLocalState(localState) {{
      const hasLocalChannels = !!(localState && Array.isArray(localState.channels) && localState.channels.length);
      const collected = collectMeshChannelOptionsFromLocalState(localState, {{
        includeFallback: !hasLocalChannels,
        fallbackCount: Math.max(8, (localState && Array.isArray(localState.channels)) ? localState.channels.length : 0),
      }}).filter((opt) => !(opt && opt.disabled));
      if (collected.length) return collected;
      return [{{ index: 0, name: "", role: "", disabled: false, hasPsk: false }}];
    }}

    function buildMeshChannelSendOptionsFromLocalState(localState) {{
      const hasLocalChannels = !!(localState && Array.isArray(localState.channels) && localState.channels.length);
      const collected = collectMeshChannelOptionsFromLocalState(localState, {{
        includeFallback: !hasLocalChannels,
        fallbackCount: Math.max(8, (localState && Array.isArray(localState.channels)) ? localState.channels.length : 0),
      }}).filter((opt) => !(opt && opt.disabled));
      if (collected.length) return collected;
      return [{{ index: 0, name: "", role: "", disabled: false, hasPsk: false }}];
    }}

    function renderMeshChannelSelect(options) {{
      const select = document.getElementById("mesh-channel-select");
      if (!(select instanceof HTMLSelectElement)) return;

      const normalized = Array.isArray(options) ? options : [];
      select.innerHTML = "";
      const allOption = document.createElement("option");
      allOption.value = String(meshChannelAllIndex);
      allOption.textContent = "All channels (view)";
      allOption.title = "All channels view";
      select.appendChild(allOption);
      for (const opt of normalized) {{
        const idx = normalizeMeshChannelIndex(opt && opt.index);
        const plainLabel = meshChannelViewOptionLabel({{ ...opt, index: idx }}) || `Ch ${{idx}}`;
        const optionEl = document.createElement("option");
        optionEl.value = String(idx);
        optionEl.textContent = plainLabel;
        optionEl.disabled = !!(opt && opt.disabled);
        if (opt && opt.role) {{
          optionEl.title = String(opt.role);
        }}
        select.appendChild(optionEl);
      }}

      // Pick an enabled value.
      const desired = String(normalizeMeshChannelIndex(activeMeshChannelIndex, {{ allowAll: true }}));
      const desiredOpt = Array.from(select.options).find((o) => o.value === desired && !o.disabled);
      if (desiredOpt) {{
        select.value = desired;
        return;
      }}
      const firstEnabled = Array.from(select.options).find((o) => !o.disabled);
      const nextValue = firstEnabled ? firstEnabled.value : "0";
      select.value = nextValue;
      activeMeshChannelIndex = normalizeMeshChannelIndex(nextValue, {{ allowAll: true }});
      syncMeshChannelViewControl();
      try {{
        window.localStorage.setItem(meshChannelIndexStorageKey, String(activeMeshChannelIndex));
      }} catch (_err) {{}}
    }}

    function renderMeshChannelSendSelect(options, {{ preserveCurrent = false }} = {{}}) {{
      const selects = meshChannelSendSelectElements();
      if (!selects.length) return;

      const normalized = Array.isArray(options) ? options.slice() : [];
      const desiredIndex = normalizeMeshChannelIndex(activeMeshSendChannelIndex);
      if (preserveCurrent && !normalized.some((opt) => normalizeMeshChannelIndex(opt && opt.index) === desiredIndex)) {{
        normalized.unshift({{ index: desiredIndex, name: "", role: "", disabled: false, hasPsk: false }});
      }}
      const fillSelect = (select) => {{
        select.innerHTML = "";
        for (const opt of normalized) {{
          const idx = normalizeMeshChannelIndex(opt && opt.index);
          const label = meshChannelSendOptionLabel({{ ...opt, index: idx }}) || `Ch ${{idx}}`;
          const optionEl = document.createElement("option");
          optionEl.value = String(idx);
          optionEl.textContent = label;
          optionEl.disabled = !!(opt && opt.disabled);
          optionEl.title = `${{label}} • Ch ${{idx}}`;
          select.appendChild(optionEl);
        }}
      }};
      for (const select of selects) {{
        fillSelect(select);
      }}

      const pickEnabledValue = (select, desiredValue) => {{
        const desiredOpt = Array.from(select.options).find((o) => o.value === desiredValue && !o.disabled);
        if (desiredOpt) return desiredValue;
        const firstEnabled = Array.from(select.options).find((o) => !o.disabled);
        return firstEnabled ? firstEnabled.value : "0";
      }};

      const desired = String(desiredIndex);
      const resolvedValue = pickEnabledValue(selects[0], desired);
      if (resolvedValue !== desired) {{
        activeMeshSendChannelIndex = normalizeMeshChannelIndex(resolvedValue);
        try {{
          window.localStorage.setItem(meshChannelSendIndexStorageKey, String(activeMeshSendChannelIndex));
        }} catch (_err) {{}}
      }}
      for (const select of selects) {{
        select.value = pickEnabledValue(select, resolvedValue);
      }}
    }}

    function renderMeshChannelSendMenu(options, {{ preserveCurrent = false }} = {{}}) {{
      const panel = document.getElementById("chat-send-channel-menu");
      if (!(panel instanceof HTMLElement)) return;

      const normalized = Array.isArray(options) ? options.slice() : [];
      const desiredIndex = normalizeMeshChannelIndex(activeMeshSendChannelIndex);
      if (preserveCurrent && !normalized.some((opt) => normalizeMeshChannelIndex(opt && opt.index) === desiredIndex)) {{
        normalized.unshift({{ index: desiredIndex, name: "", role: "", disabled: false, hasPsk: false }});
      }}

      panel.innerHTML = normalized.map((opt) => {{
        const idx = normalizeMeshChannelIndex(opt && opt.index);
        const label = meshChannelSendOptionLabel({{ ...opt, index: idx }}) || `Ch ${{idx}}`;
        const active = desiredIndex === idx;
        const meta = meshChannelColorMeta(idx, {{ allowAll: false }});
        const primaryBadge = meshChannelPrimaryBadgeHtml(idx);
        return `<button
          type="button"
          class="mesh-channel-menu-item${{active ? " active" : ""}}"
          role="option"
          aria-selected="${{active ? "true" : "false"}}"
          data-mesh-send-channel-index="${{escAttr(idx)}}"
          title="${{escAttr(meta.title === label ? meta.title : `${{meta.title}} • ${{label}}`)}}"
        >
          <span class="channel-color-dot" style="--channel-dot-fill: ${{meta.fill}};" aria-hidden="true"></span>
          <span class="mesh-channel-menu-item-main">
            <span class="mesh-channel-menu-item-title">${{primaryBadge}}<span>${{escAttr(label)}}</span></span>
          </span>
        </button>`;
      }}).join("");
    }}

    async function hydrateMeshChannelOptions(force = false) {{
      const nowMs = Date.now();
      const ttlMs = 60000;

      let localState = (settingsLocalStateCache && typeof settingsLocalStateCache === "object")
        ? settingsLocalStateCache
        : null;
      const stale = !settingsLocalStateFetchedAt || (nowMs - settingsLocalStateFetchedAt) > ttlMs;
      if (force || !localState || stale || !Array.isArray(localState.channels)) {{
        try {{
          const data = await fetchRawJson("/api/raw/local_state", rawDataCache.localState, ttlMs);
          const obj = (data && typeof data === "object") ? data : null;
          if (obj) {{
            settingsLocalStateCache = obj;
            settingsLocalStateFetchedAt = nowMs;
            localState = obj;
          }}
        }} catch (_err) {{}}
      }}

      const options = buildMeshChannelOptionsFromLocalState(localState);
      const sendOptions = buildMeshChannelSendOptionsFromLocalState(localState);
      meshChannelOptions = options;
      meshChannelSendOptions = sendOptions;
      renderMeshChannelSelect(options);
      renderMeshChannelPills(options);
      renderMeshChannelSendSelect(sendOptions);
      renderMeshChannelSendMenu(sendOptions, {{ preserveCurrent: true }});
      syncMeshChannelSendControl();
      return options;
    }}

    function ensureChannelsViewLocalStateHydrated(force = false) {{
      if (channelsViewHydrateInFlight) {{
        return channelsViewHydrateInFlight;
      }}
      const cached = settingsLocalStateCache && typeof settingsLocalStateCache === "object"
        ? settingsLocalStateCache
        : null;
      const stale = !settingsLocalStateFetchedAt || (Date.now() - settingsLocalStateFetchedAt) > 60000;
      const missingChannels = !(cached && Array.isArray(cached.channels));
      if (!force && !missingChannels && !stale) {{
        return Promise.resolve(cached);
      }}
      channelsViewHydrateInFlight = hydrateMeshChannelOptions(force)
        .catch(() => null)
        .then(() => {{
          if (activeLayoutView === "channels") {{
            renderChannelsView(latestState);
          }}
          return settingsLocalStateCache;
        }})
        .finally(() => {{
          channelsViewHydrateInFlight = null;
        }});
      return channelsViewHydrateInFlight;
    }}

    function applyMeshChannelIndex(rawIndex, persist = true) {{
      const idx = normalizeMeshChannelIndex(rawIndex, {{ allowAll: true }});
      const changed = idx !== activeMeshChannelIndex;
      const shouldFollowForSend = idx !== meshChannelAllIndex;
      activeMeshChannelIndex = idx;
      syncMeshChannelViewControl();

      const select = document.getElementById("mesh-channel-select");
      if (select instanceof HTMLSelectElement) {{
        select.value = String(activeMeshChannelIndex);
      }}
      renderMeshChannelPills(meshChannelOptions);

      if (persist) {{
        try {{
          window.localStorage.setItem(meshChannelIndexStorageKey, String(activeMeshChannelIndex));
        }} catch (_err) {{}}
      }}

      if (shouldFollowForSend) {{
        applyMeshSendChannelIndex(idx, persist, false);
      }}

      if (activeLayoutView === "chat" && !document.hidden && tabHasFocus) {{
        clearVisibleChatUnread(activeChatChannel);
      }}

      if ((changed || shouldFollowForSend) && latestState) {{
        if (activeLayoutView === "chat") {{
          renderChat(latestState);
        }} else if (activeLayoutView === "files") {{
          renderFilesView(latestState);
        }}
      }}
    }}

    function applyMeshSendChannelIndex(rawIndex, persist = true, rerenderChat = true) {{
      const idx = normalizeMeshChannelIndex(rawIndex);
      const changed = idx !== activeMeshSendChannelIndex;
      activeMeshSendChannelIndex = idx;

      for (const select of meshChannelSendSelectElements()) {{
        select.value = String(activeMeshSendChannelIndex);
      }}
      syncMeshChannelSendControl();
      renderMeshChannelSendMenu(meshChannelSendOptions, {{ preserveCurrent: true }});

      if (persist) {{
        try {{
          window.localStorage.setItem(meshChannelSendIndexStorageKey, String(activeMeshSendChannelIndex));
        }} catch (_err) {{}}
      }}

      if (rerenderChat && changed && latestState && activeLayoutView === "chat") {{
        renderChat(latestState);
      }}
    }}

    function loadMeshChannelIndex() {{
      let preferred = 0;
      let preferredSend = null;
      try {{
        preferred = normalizeMeshChannelIndex(
          window.localStorage.getItem(meshChannelIndexStorageKey) || "0",
          {{ allowAll: true }}
        );
        const storedSend = window.localStorage.getItem(meshChannelSendIndexStorageKey);
        if (storedSend != null && String(storedSend).trim() !== "") {{
          preferredSend = normalizeMeshChannelIndex(storedSend);
        }}
      }} catch (_err) {{}}
      activeMeshChannelIndex = preferred;
      activeMeshSendChannelIndex = preferredSend == null
        ? normalizeMeshChannelIndex(preferred)
        : normalizeMeshChannelIndex(preferredSend);
    }}

    function bindMeshChannelControl() {{
      const select = document.getElementById("mesh-channel-select");
      if (!(select instanceof HTMLSelectElement) || select.dataset.bound === "1") return;
      select.dataset.bound = "1";

      select.addEventListener("change", () => {{
        applyMeshChannelIndex(select.value, true);
      }});

      // Seed fast fallback so the control is usable before the radio query returns.
      const fallback = buildMeshChannelOptionsFromLocalState({{ channels: [] }});
      const sendFallback = buildMeshChannelSendOptionsFromLocalState(null);
      meshChannelOptions = fallback;
      meshChannelSendOptions = sendFallback;
      renderMeshChannelSelect(fallback);
      renderMeshChannelPills(fallback);
      renderMeshChannelSendSelect(sendFallback, {{ preserveCurrent: true }});
      renderMeshChannelSendMenu(sendFallback, {{ preserveCurrent: true }});
      select.value = String(activeMeshChannelIndex);
      syncMeshChannelViewControl();
      syncMeshChannelSendControl();

      void hydrateMeshChannelOptions(false);
    }}

    function bindMeshChannelMenuControl() {{
      const panel = document.getElementById("mesh-channel-pill-strip");
      if (!(panel instanceof HTMLElement) || panel.dataset.bound === "1") return;
      panel.dataset.bound = "1";

      panel.addEventListener("pointerdown", (ev) => {{
        const target = ev.target;
        if (!(target instanceof Element)) return;
        const item = target.closest(".mesh-channel-pill");
        if (!(item instanceof HTMLButtonElement)) return;
        ev.preventDefault();
        ev.stopPropagation();
        applyMeshChannelIndex(item.dataset.meshChannelIndex || meshChannelAllIndex, true);
      }});

      syncMeshChannelViewControl();
      renderMeshChannelPills(meshChannelOptions);
    }}

    function bindMeshChannelSendMenuControl() {{
      const btn = document.getElementById("chat-send-channel-menu-btn");
      const panel = document.getElementById("chat-send-channel-menu");
      if (!(btn instanceof HTMLButtonElement) || !(panel instanceof HTMLElement) || btn.dataset.bound === "1") return;
      btn.dataset.bound = "1";

      btn.addEventListener("click", (ev) => {{
        ev.preventDefault();
        if (btn.disabled) return;
        setMeshChannelSendMenuOpen(!meshChannelSendMenuOpen);
      }});

      panel.addEventListener("pointerdown", (ev) => {{
        const target = ev.target;
        if (!(target instanceof Element)) return;
        const item = target.closest(".mesh-channel-menu-item");
        if (!(item instanceof HTMLButtonElement)) return;
        ev.preventDefault();
        ev.stopPropagation();
        applyMeshSendChannelIndex(item.dataset.meshSendChannelIndex || 0, true);
        setMeshChannelSendMenuOpen(false);
      }});

      if (document.body.dataset.meshChannelSendMenuBound !== "1") {{
        document.body.dataset.meshChannelSendMenuBound = "1";
        document.addEventListener("pointerdown", (ev) => {{
          const target = ev.target;
          if (!(target instanceof Element)) return;
          if (target.closest("#chat-send-channel-menu-btn") || target.closest("#chat-send-channel-menu")) return;
          setMeshChannelSendMenuOpen(false);
        }});
        document.addEventListener("keydown", (ev) => {{
          if (ev.key === "Escape") {{
            setMeshChannelSendMenuOpen(false);
          }}
        }});
      }}

      syncMeshChannelSendControl();
      renderMeshChannelSendMenu(meshChannelSendOptions, {{ preserveCurrent: true }});
    }}

    function bindMeshChannelSendControl() {{
      const selects = meshChannelSendSelectElements();
      if (!selects.length) return;
      for (const select of selects) {{
        if (!(select instanceof HTMLSelectElement) || select.dataset.bound === "1") continue;
        select.dataset.bound = "1";
        select.addEventListener("change", () => {{
          applyMeshSendChannelIndex(select.value, true);
        }});
      }}

      renderMeshChannelSendSelect(
        meshChannelSendOptions.length ? meshChannelSendOptions : buildMeshChannelSendOptionsFromLocalState(null),
        {{ preserveCurrent: true }},
      );
      renderMeshChannelSendMenu(
        meshChannelSendOptions.length ? meshChannelSendOptions : buildMeshChannelSendOptionsFromLocalState(null),
        {{ preserveCurrent: true }},
      );
      syncMeshChannelSendControl();
    }}


    function normalizeChannelsUiMode(raw) {{
      const text = String(raw == null ? "" : raw).trim().toLowerCase();
      if (text === "advanced" || text === "1" || text === "true" || text === "on") return "advanced";
      return "simple";
    }}

    function applyChannelsUiMode() {{
      const root = document.body;
      if (root) {{
        root.classList.toggle("channels-advanced-ui", !!channelsUiAdvanced);
      }}
      const addOnlyBtn = document.getElementById("settings-channels-import-url-add-btn");
      if (addOnlyBtn instanceof HTMLButtonElement) {{
        addOnlyBtn.hidden = !channelsUiAdvanced;
      }}
    }}

    function setChannelsUiAdvanced(enabled, persist = true) {{
      channelsUiAdvanced = !!enabled;
      if (persist) {{
        try {{
          window.localStorage.setItem(
            channelsUiModeStorageKey,
            channelsUiAdvanced ? "advanced" : "simple"
          );
        }} catch (_err) {{}}
      }}
      applyChannelsUiMode();
    }}

    function setChannelsExperimentalEnabled(enabled, persist = true) {{
      channelsExperimentalEnabled = !!enabled;
      if (persist) {{
        try {{
          window.localStorage.setItem(
            channelsExperimentalStorageKey,
            channelsExperimentalEnabled ? "1" : "0"
          );
        }} catch (_err) {{}}
      }}
    }}

    function loadChannelsUiMode() {{
      let stored = "simple";
      try {{
        stored = normalizeChannelsUiMode(window.localStorage.getItem(channelsUiModeStorageKey) || "simple");
      }} catch (_err) {{}}
      channelsUiAdvanced = stored === "advanced";
    }}

    function loadChannelsExperimentalPreference() {{
      let stored = false;
      try {{
        stored = parseBoolToken(window.localStorage.getItem(channelsExperimentalStorageKey), false);
      }} catch (_err) {{}}
      channelsExperimentalEnabled = !!stored;
    }}


    function requestImmediatePoll(delayMs = 0) {{
      const waitMs = Math.max(0, Math.trunc(Number(delayMs) || 0));
      if (chatImmediatePollTimer !== null) {{
        clearTimeout(chatImmediatePollTimer);
        chatImmediatePollTimer = null;
      }}
      chatImmediatePollTimer = window.setTimeout(() => {{
        chatImmediatePollTimer = null;
        if (document.hidden) return;
        if (typeof pollOnce === "function") {{
          void pollOnce();
          return;
        }}
        void poll();
      }}, waitMs);
    }}

    function persistManualDirectPeers() {{
      try {{
        const ids = Array.from(manualDirectPeerIds)
          .map((entry) => normalizeNodeId(entry))
          .filter((entry) => isCanonicalNodeId(entry))
          .sort((a, b) => a.localeCompare(b));
        window.localStorage.setItem(chatDirectPeersStorageKey, JSON.stringify(ids));
      }} catch (_err) {{
      }}
    }}

    function loadManualDirectPeers() {{
      manualDirectPeerIds.clear();
      try {{
        const raw = window.localStorage.getItem(chatDirectPeersStorageKey);
        if (!raw) return;
        const parsed = JSON.parse(raw);
        if (!Array.isArray(parsed)) return;
        for (const entry of parsed) {{
          const nodeId = normalizeNodeId(entry);
          if (!isCanonicalNodeId(nodeId)) continue;
          manualDirectPeerIds.add(nodeId);
        }}
      }} catch (_err) {{
      }}
    }}

    function addManualDirectPeer(rawNodeId, options = null) {{
      const opts = (options && typeof options === "object") ? options : {{}};
      const shouldSelect = opts.select !== false;
      const nodeId = normalizeNodeId(rawNodeId);
      if (!nodeId) {{
        return {{ ok: false, error: "Enter a node ID to add." }};
      }}
      if (!isCanonicalNodeId(nodeId)) {{
        return {{ ok: false, error: "Use a node ID like !49b54790." }};
      }}
      if (isSelfNodeId(nodeId)) {{
        return {{ ok: false, error: "Cannot add your own radio to peer-to-peer list." }};
      }}
      const added = !manualDirectPeerIds.has(nodeId);
      manualDirectPeerIds.add(nodeId);
      persistManualDirectPeers();
      if (shouldSelect) {{
        selectNode(nodeId, true, false);
      }} else if (latestState) {{
        renderChat(latestState);
      }}
      return {{ ok: true, added, id: nodeId }};
    }}

    function removeManualDirectPeer(rawNodeId) {{
      const nodeId = normalizeNodeId(rawNodeId);
      if (!isCanonicalNodeId(nodeId)) return false;
      if (!manualDirectPeerIds.delete(nodeId)) return false;
      persistManualDirectPeers();
      if (selectedNodeId && normalizeNodeId(selectedNodeId) === nodeId) {{
        clearNodeSelection();
      }} else if (latestState) {{
        renderChat(latestState);
      }}
      return true;
    }}

    function detectedPeerCandidates(state = latestState) {{
      const safeState = (state && typeof state === "object") ? state : {{}};
      const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
      const selfId = resolveLocalNodeId(safeState);
      const unique = new Map();
      for (const node of nodes) {{
        const nodeId = normalizeNodeId(node && node.id);
        if (isCanonicalNodeId(selfId) && nodeId === selfId) continue;
        if (!isCanonicalNodeId(nodeId) || unique.has(nodeId)) continue;
        const name = preferredNodeName(node) || nodeNameCache.get(nodeId) || nodeId;
        const lastSeenUnix = nodeLastHeardUnix(node);
        unique.set(nodeId, {{ id: nodeId, name, lastSeenUnix }});
      }}
      return Array.from(unique.values()).sort((a, b) => {{
        const aSeen = Number(a.lastSeenUnix) || 0;
        const bSeen = Number(b.lastSeenUnix) || 0;
        if (aSeen !== bSeen) return bSeen - aSeen;
        const nameDiff = String(a.name || "").localeCompare(String(b.name || ""));
        if (nameDiff !== 0) return nameDiff;
        return String(a.id || "").localeCompare(String(b.id || ""));
      }});
    }}

    function renderChatPeerAddPanel(state = latestState) {{
      const toggleBtn = document.getElementById("chat-peer-add-toggle-btn");
      const panel = document.getElementById("chat-peer-add-panel");
      const detectedSelect = document.getElementById("chat-peer-detected-select");
      const detectedAddBtn = document.getElementById("chat-peer-add-detected-btn");
      const manualInput = document.getElementById("chat-peer-manual-input");
      const manualAddBtn = document.getElementById("chat-peer-add-manual-btn");
      const savedList = document.getElementById("chat-peer-saved-list");
      const directMode = activeChatChannel === "direct";
      if (toggleBtn instanceof HTMLButtonElement) {{
        toggleBtn.hidden = !directMode;
        toggleBtn.setAttribute("aria-expanded", directMode && chatPeerAddPanelOpen ? "true" : "false");
      }}
      if (panel instanceof HTMLElement) {{
        panel.hidden = !(directMode && chatPeerAddPanelOpen);
      }}

      const candidates = detectedPeerCandidates(state);
      if (detectedSelect instanceof HTMLSelectElement) {{
        const previousValue = normalizeNodeId(detectedSelect.value || "");
        const options = ['<option value="">Detected nodes...</option>'];
        for (const entry of candidates) {{
          const savedSuffix = manualDirectPeerIds.has(entry.id) ? " (saved)" : "";
          const label = `${{entry.name}} (${{entry.id}})${{savedSuffix}}`;
          options.push(`<option value="${{escAttr(entry.id)}}">${{escAttr(label)}}</option>`);
        }}
        detectedSelect.innerHTML = options.join("");
        if (previousValue && candidates.some((entry) => entry.id === previousValue)) {{
          detectedSelect.value = previousValue;
        }} else if (isCanonicalNodeId(selectedNodeId) && candidates.some((entry) => entry.id === selectedNodeId)) {{
          detectedSelect.value = normalizeNodeId(selectedNodeId);
        }} else {{
          detectedSelect.value = "";
        }}
        detectedSelect.disabled = !directMode || candidates.length === 0;
      }}
      if (detectedAddBtn instanceof HTMLButtonElement) {{
        const hasChoice = detectedSelect instanceof HTMLSelectElement
          && isCanonicalNodeId(detectedSelect.value || "");
        detectedAddBtn.disabled = !directMode || !hasChoice;
      }}
      if (manualInput instanceof HTMLInputElement) {{
        manualInput.disabled = !directMode;
      }}
      if (manualAddBtn instanceof HTMLButtonElement) {{
        manualAddBtn.disabled = !directMode;
      }}

      if (savedList instanceof HTMLElement) {{
        const safeState = (state && typeof state === "object") ? state : {{}};
        const selfId = resolveLocalNodeId(safeState);
        const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
        const nodesById = new Map(
          nodes.map((node) => [normalizeNodeId(node && node.id), node])
        );
        const savedPeers = Array.from(manualDirectPeerIds)
          .map((entry) => normalizeNodeId(entry))
          .filter((entry) => isCanonicalNodeId(entry))
          .filter((entry) => !(isCanonicalNodeId(selfId) && entry === selfId))
          .map((entry) => {{
            const node = nodesById.get(entry);
            const name = preferredNodeName(node) || nodeNameCache.get(entry) || entry;
            return {{ id: entry, name }};
          }})
          .sort((a, b) => String(a.name || a.id).localeCompare(String(b.name || b.id)));
        if (savedPeers.length === 0) {{
          savedList.innerHTML = '<div class="chat-peer-saved-empty">No saved peers yet.</div>';
        }} else {{
          savedList.innerHTML = savedPeers.map((entry) => (
            `<div class="chat-peer-saved-item">
              <span class="chat-peer-saved-main">
                <span class="chat-peer-saved-name">${{escAttr(entry.name)}}</span>
                <span class="chat-peer-saved-id">${{escAttr(entry.id)}}</span>
              </span>
              <button type="button" class="chat-peer-saved-remove-btn" data-node-id="${{escAttr(entry.id)}}" title="Remove ${{escAttr(entry.id)}} from peer-to-peer list" aria-label="Remove ${{escAttr(entry.id)}} from peer-to-peer list">&times;</button>
            </div>`
          )).join("");
        }}
      }}
    }}

    function bindChatPeerControls() {{
      const toggleBtn = document.getElementById("chat-peer-add-toggle-btn");
      const detectedSelect = document.getElementById("chat-peer-detected-select");
      const detectedAddBtn = document.getElementById("chat-peer-add-detected-btn");
      const manualInput = document.getElementById("chat-peer-manual-input");
      const manualAddBtn = document.getElementById("chat-peer-add-manual-btn");
      const savedList = document.getElementById("chat-peer-saved-list");

      if (toggleBtn instanceof HTMLButtonElement && toggleBtn.dataset.bound !== "1") {{
        toggleBtn.dataset.bound = "1";
        toggleBtn.addEventListener("click", () => {{
          if (activeChatChannel !== "direct") return;
          chatPeerAddPanelOpen = !chatPeerAddPanelOpen;
          renderChatPeerAddPanel(latestState);
          if (chatPeerAddPanelOpen && manualInput instanceof HTMLInputElement) {{
            manualInput.focus({{ preventScroll: true }});
          }}
        }});
      }}

      if (detectedAddBtn instanceof HTMLButtonElement && detectedAddBtn.dataset.bound !== "1") {{
        detectedAddBtn.dataset.bound = "1";
        detectedAddBtn.addEventListener("click", () => {{
          const chosenId = normalizeNodeId(
            detectedSelect instanceof HTMLSelectElement ? detectedSelect.value : ""
          );
          const result = addManualDirectPeer(chosenId, {{ select: true }});
          if (!result.ok) {{
            setChatSendStatus(result.error || "Unable to add peer.", true);
            return;
          }}
          setChatSendStatus(
            result.added
              ? `Peer ${{result.id}} added to peer-to-peer list.`
              : `Peer ${{result.id}} is already in your peer-to-peer list.`
          );
          renderChatPeerAddPanel(latestState);
        }});
      }}

      if (detectedSelect instanceof HTMLSelectElement && detectedSelect.dataset.bound !== "1") {{
        detectedSelect.dataset.bound = "1";
        detectedSelect.addEventListener("change", () => {{
          renderChatPeerAddPanel(latestState);
        }});
      }}

      const submitManualPeer = () => {{
        const raw = manualInput instanceof HTMLInputElement ? manualInput.value : "";
        const result = addManualDirectPeer(raw, {{ select: true }});
        if (!result.ok) {{
          setChatSendStatus(result.error || "Unable to add peer.", true);
          if (manualInput instanceof HTMLInputElement) {{
            manualInput.focus({{ preventScroll: true }});
          }}
          return;
        }}
        if (manualInput instanceof HTMLInputElement) {{
          manualInput.value = "";
          manualInput.focus({{ preventScroll: true }});
        }}
        setChatSendStatus(
          result.added
            ? `Peer ${{result.id}} added to peer-to-peer list.`
            : `Peer ${{result.id}} is already in your peer-to-peer list.`
        );
        renderChatPeerAddPanel(latestState);
      }};

      if (manualAddBtn instanceof HTMLButtonElement && manualAddBtn.dataset.bound !== "1") {{
        manualAddBtn.dataset.bound = "1";
        manualAddBtn.addEventListener("click", () => {{
          submitManualPeer();
        }});
      }}

      if (manualInput instanceof HTMLInputElement && manualInput.dataset.bound !== "1") {{
        manualInput.dataset.bound = "1";
        manualInput.addEventListener("keydown", (ev) => {{
          if (ev.key !== "Enter") return;
          ev.preventDefault();
          submitManualPeer();
        }});
      }}

      if (savedList instanceof HTMLElement && savedList.dataset.bound !== "1") {{
        savedList.dataset.bound = "1";
        savedList.addEventListener("click", (ev) => {{
          const target = ev.target;
          if (!(target instanceof Element)) return;
          const removeBtn = target.closest(".chat-peer-saved-remove-btn");
          if (!(removeBtn instanceof HTMLButtonElement)) return;
          ev.preventDefault();
          ev.stopPropagation();
          const nodeId = normalizeNodeId(removeBtn.dataset.nodeId || "");
          if (!isCanonicalNodeId(nodeId)) return;
          const removed = removeManualDirectPeer(nodeId);
          if (!removed) return;
          setChatSendStatus(`Peer ${{nodeId}} removed from peer-to-peer list.`);
          renderChatPeerAddPanel(latestState);
        }});
      }}

      renderChatPeerAddPanel(latestState);
    }}

    function normalizeChatEmojiGroup(raw) {{
      const clean = String(raw || "").trim().toLowerCase();
      if (!clean || clean === "all") return "all";
      return chatEmojiGroupsById.has(clean) ? clean : "all";
    }}

    function normalizeChatEmojiSearchQuery(raw) {{
      const lowered = String(raw || "").trim().toLowerCase();
      if (!lowered) return "";
      const noShortcodeColons = lowered.replace(/(^:+|:+$)/g, " ");
      return noShortcodeColons
        .replace(/[_-]+/g, " ")
        .replace(/[^a-z0-9+ ]+/g, " ")
        .replace(/\s+/g, " ")
        .trim();
    }}

    function stemChatEmojiSearchToken(rawToken) {{
      const token = String(rawToken || "").trim().toLowerCase();
      if (!token) return "";
      if (token.endsWith("ies") && token.length > 4) {{
        return `${{token.slice(0, -3)}}y`;
      }}
      if (token.endsWith("ing") && token.length > 5) {{
        return token.slice(0, -3);
      }}
      if (token.endsWith("ed") && token.length > 4) {{
        return token.slice(0, -2);
      }}
      if (token.endsWith("es") && token.length > 4) {{
        return token.slice(0, -2);
      }}
      if (token.endsWith("s") && token.length > 3) {{
        return token.slice(0, -1);
      }}
      return token;
    }}

    function tokenizeChatEmojiSearchQuery(rawQuery) {{
      const normalized = normalizeChatEmojiSearchQuery(rawQuery);
      if (!normalized) return [];
      const seen = new Set();
      const out = [];
      for (const rawToken of normalized.split(/\s+/g)) {{
        const token = String(rawToken || "").trim();
        if (!token) continue;
        if (!seen.has(token)) {{
          seen.add(token);
          out.push(token);
        }}
        const stemmed = stemChatEmojiSearchToken(token);
        if (stemmed && !seen.has(stemmed)) {{
          seen.add(stemmed);
          out.push(stemmed);
        }}
      }}
      return out;
    }}

    function tokenizeChatEmojiSearchAliasParts(queryParts) {{
      const base = Array.isArray(queryParts) ? queryParts : [];
      if (!base.length) return [];
      const seen = new Set(base);
      const out = [];
      for (const token of base) {{
        const aliasText = String(chatEmojiQueryKeywordAliases[token] || "").trim();
        if (!aliasText) continue;
        for (const aliasToken of tokenizeChatEmojiSearchQuery(aliasText)) {{
          if (!aliasToken || seen.has(aliasToken)) continue;
          seen.add(aliasToken);
          out.push(aliasToken);
        }}
      }}
      return out;
    }}

    function collectChatEmojiCodepointAliasParts(rawEmoji) {{
      const text = String(rawEmoji || "").trim();
      if (!text) return [];
      const out = [];
      const seen = new Set();
      for (const ch of text) {{
        const cp = ch.codePointAt(0);
        if (!Number.isInteger(cp)) continue;
        if (chatEmojiCodepointIgnoredSet.has(cp)) continue;
        if (cp >= 0xe0020 && cp <= 0xe007f) continue;
        const key = cp.toString(16);
        const keywords = String(chatEmojiCodepointKeywordMap[key] || "").trim();
        if (!keywords) continue;
        for (const part of tokenizeChatEmojiSearchQuery(keywords)) {{
          if (!part || seen.has(part)) continue;
          seen.add(part);
          out.push(part);
        }}
      }}
      return out;
    }}

    function boundedLevenshteinDistance(aRaw, bRaw, maxDistance = 2) {{
      const a = String(aRaw || "");
      const b = String(bRaw || "");
      if (a === b) return 0;
      if (!a || !b) {{
        return Math.max(a.length, b.length);
      }}
      const aLen = a.length;
      const bLen = b.length;
      if (Math.abs(aLen - bLen) > maxDistance) {{
        return maxDistance + 1;
      }}
      let prev = new Array(bLen + 1).fill(0);
      let curr = new Array(bLen + 1).fill(0);
      for (let j = 0; j <= bLen; j += 1) {{
        prev[j] = j;
      }}
      for (let i = 1; i <= aLen; i += 1) {{
        curr[0] = i;
        for (let j = 1; j <= bLen; j += 1) {{
          const cost = a[i - 1] === b[j - 1] ? 0 : 1;
          curr[j] = Math.min(
            prev[j] + 1,
            curr[j - 1] + 1,
            prev[j - 1] + cost
          );
        }}
        const swap = prev;
        prev = curr;
        curr = swap;
      }}
      return prev[bLen];
    }}

    function scoreChatEmojiPartMatch(part, tokens, searchText, allowFuzzy = false) {{
      if (!part) return 0;
      let best = 0;
      for (const token of tokens) {{
        if (!token) continue;
        if (token === part) {{
          best = Math.max(best, 460);
          continue;
        }}
        if (token.startsWith(part)) {{
          best = Math.max(best, 320);
          continue;
        }}
        if (token.includes(part)) {{
          best = Math.max(best, 180);
        }}
      }}
      if (best > 0) {{
        return best;
      }}
      if (searchText.includes(part)) {{
        return 120;
      }}
      if (!allowFuzzy || part.length < 4) {{
        return 0;
      }}

      const maxDistance = part.length >= 8 ? 2 : 1;
      let closest = maxDistance + 1;
      for (const token of tokens) {{
        if (!token || token.length < 3) continue;
        const distance = boundedLevenshteinDistance(part, token, maxDistance);
        if (distance < closest) {{
          closest = distance;
        }}
        if (closest === 0) {{
          break;
        }}
      }}
      if (closest > maxDistance) {{
        return 0;
      }}
      return closest <= 1 ? 90 : 52;
    }}

    function scoreChatEmojiSearchMatch(emoji, queryText, queryParts, allowFuzzy = false) {{
      const tokens = chatEmojiSearchTokensByEmoji.get(emoji) || [];
      if (!tokens.length) {{
        return 0;
      }}
      const searchText = String(chatEmojiSearchMetaByEmoji.get(emoji) || "");
      let score = 0;
      for (const part of queryParts) {{
        const partScore = scoreChatEmojiPartMatch(part, tokens, searchText, allowFuzzy);
        if (partScore <= 0) {{
          return 0;
        }}
        score += partScore;
      }}
      if (queryText && searchText.includes(queryText)) {{
        score += 35;
      }}
      return score;
    }}

    function rankChatEmojiSearchMatches(rawQuery, queryParts, allowFuzzy = false) {{
      const queryText = normalizeChatEmojiSearchQuery(rawQuery);
      const ranked = [];
      const seen = new Set();
      for (const emoji of chatEmojiAllChoices) {{
        if (seen.has(emoji)) continue;
        seen.add(emoji);
        const score = scoreChatEmojiSearchMatch(
          emoji,
          queryText,
          queryParts,
          allowFuzzy,
        );
        if (score <= 0) {{
          continue;
        }}
        ranked.push({{
          emoji,
          score,
          order: Number(chatEmojiChoiceOrder.get(emoji) || 0),
        }});
      }}
      ranked.sort((a, b) => (b.score - a.score) || (a.order - b.order));
      return ranked.map((entry) => entry.emoji);
    }}

    function rankChatEmojiSearchMatchesAnyPart(rawQuery, queryParts, allowFuzzy = false) {{
      const queryText = normalizeChatEmojiSearchQuery(rawQuery);
      const ranked = [];
      const seen = new Set();
      for (const emoji of chatEmojiAllChoices) {{
        if (seen.has(emoji)) continue;
        seen.add(emoji);
        const tokens = chatEmojiSearchTokensByEmoji.get(emoji) || [];
        if (!tokens.length) continue;
        const searchText = String(chatEmojiSearchMetaByEmoji.get(emoji) || "");
        let matchedParts = 0;
        let score = 0;
        for (const part of queryParts) {{
          const partScore = scoreChatEmojiPartMatch(part, tokens, searchText, allowFuzzy);
          if (partScore <= 0) continue;
          matchedParts += 1;
          score += partScore;
        }}
        if (matchedParts <= 0) {{
          continue;
        }}
        if (queryText && searchText.includes(queryText)) {{
          score += 28;
        }}
        score += matchedParts * 24;
        ranked.push({{
          emoji,
          score,
          matchedParts,
          order: Number(chatEmojiChoiceOrder.get(emoji) || 0),
        }});
      }}
      ranked.sort((a, b) => (
        (b.score - a.score)
        || (b.matchedParts - a.matchedParts)
        || (a.order - b.order)
      ));
      return ranked.map((entry) => entry.emoji);
    }}

    const reactionEmojiIgnoredCodepoints = new Set([0xFE0E, 0xFE0F]);

    function reactionEmojiCodepoint(rawEmoji) {{
      const text = String(rawEmoji == null ? "" : rawEmoji).trim();
      if (!text) return null;
      let baseCodepoint = null;
      for (const ch of text) {{
        const cp = ch.codePointAt(0);
        if (!Number.isInteger(cp)) continue;
        if (reactionEmojiIgnoredCodepoints.has(cp)) continue;
        if (baseCodepoint !== null) {{
          return null;
        }}
        baseCodepoint = cp;
      }}
      return Number.isInteger(baseCodepoint) && baseCodepoint > 0 ? baseCodepoint : null;
    }}

    function isReactionCompatibleEmoji(rawEmoji) {{
      return Number.isInteger(reactionEmojiCodepoint(rawEmoji));
    }}

    function reactionCompatibleEmojiChoices(rawChoices) {{
      const list = Array.isArray(rawChoices) ? rawChoices : [];
      const deduped = [];
      const seen = new Set();
      for (const emoji of list) {{
        const clean = String(emoji || "").trim();
        if (!clean || seen.has(clean)) continue;
        seen.add(clean);
        if (!isReactionCompatibleEmoji(clean)) continue;
        deduped.push(clean);
      }}
      return deduped;
    }}

    function chatEmojiChoicesForGroup(groupId) {{
      const key = normalizeChatEmojiGroup(groupId);
      if (key === "all") return chatEmojiAllChoices;
      const group = chatEmojiGroupsById.get(key);
      if (group && Array.isArray(group.emojis)) {{
        return group.emojis;
      }}
      return chatEmojiAllChoices;
    }}

    function chatEmojiChoicesForSearch(rawQuery) {{
      const rawText = String(rawQuery || "").trim();
      if (rawText && chatEmojiChoiceSet.has(rawText)) {{
        return [rawText];
      }}
      const query = normalizeChatEmojiSearchQuery(rawQuery);
      if (!query) return [];
      const cached = chatEmojiSearchCache.get(query);
      if (Array.isArray(cached)) {{
        return cached;
      }}

      const parts = tokenizeChatEmojiSearchQuery(query);
      if (!parts.length) return [];
      const aliasParts = tokenizeChatEmojiSearchAliasParts(parts);
      let matches = rankChatEmojiSearchMatches(query, parts, false);
      if (!matches.length) {{
        matches = rankChatEmojiSearchMatches(query, parts, true);
      }}
      if (!matches.length) {{
        const fallbackParts = aliasParts.length ? parts.concat(aliasParts) : parts;
        matches = rankChatEmojiSearchMatchesAnyPart(query, fallbackParts, false);
      }}
      if (!matches.length) {{
        const fallbackParts = aliasParts.length ? parts.concat(aliasParts) : parts;
        matches = rankChatEmojiSearchMatchesAnyPart(query, fallbackParts, true);
      }}
      chatEmojiSearchCache.set(query, matches);
      return matches;
    }}

    function buildChatEmojiNode(emoji, extraClass = "") {{
      const btn = document.createElement("button");
      btn.type = "button";
      btn.className = extraClass ? `chat-emoji-item ${{extraClass}}` : "chat-emoji-item";
      btn.setAttribute("data-emoji", emoji);
      btn.setAttribute("title", emoji);
      btn.textContent = emoji;
      return btn;
    }}

    function chatEmojiNodesForGroup(groupId) {{
      const key = normalizeChatEmojiGroup(groupId);
      const cached = chatEmojiNodesByGroup.get(key);
      if (Array.isArray(cached)) {{
        return cached;
      }}
      const nodes = [];
      for (const emoji of chatEmojiChoicesForGroup(key)) {{
        nodes.push(buildChatEmojiNode(emoji));
      }}
      chatEmojiNodesByGroup.set(key, nodes);
      return nodes;
    }}

    function chatEmojiUsageEntries() {{
      const enforceChoiceSet = chatEmojiChoiceSet.size > 0;
      return Array.from(chatEmojiUsageCounts.entries())
        .filter(([emoji, count]) => (
          (!enforceChoiceSet || chatEmojiChoiceSet.has(emoji))
          && Number.isFinite(count)
          && count > 0
        ))
        .sort((a, b) => (b[1] - a[1]) || String(a[0]).localeCompare(String(b[0])));
    }}

    function chatEmojiTopChoices() {{
      const picked = [];
      const used = new Set();
      for (const [emoji] of chatEmojiUsageEntries()) {{
        if (used.has(emoji)) continue;
        used.add(emoji);
        picked.push(emoji);
        if (picked.length >= chatEmojiTopUsageCount) {{
          return picked;
        }}
      }}
      for (const emoji of chatEmojiPopularDefaults) {{
        if (!chatEmojiChoiceSet.has(emoji) || used.has(emoji)) continue;
        used.add(emoji);
        picked.push(emoji);
        if (picked.length >= chatEmojiTopUsageCount) {{
          break;
        }}
      }}
      return picked;
    }}

    function persistChatEmojiUsage() {{
      try {{
        const entries = chatEmojiUsageEntries().slice(0, chatEmojiUsagePersistMax);
        const payload = {{}};
        for (const [emoji, count] of entries) {{
          payload[emoji] = count;
        }}
        window.localStorage.setItem(chatEmojiUsageStorageKey, JSON.stringify(payload));
      }} catch (_err) {{
      }}
    }}

    function loadChatEmojiUsage() {{
      const next = new Map();
      const enforceChoiceSet = chatEmojiChoiceSet.size > 0;
      try {{
        const raw = window.localStorage.getItem(chatEmojiUsageStorageKey);
        if (raw) {{
          const parsed = JSON.parse(raw);
          if (parsed && typeof parsed === "object" && !Array.isArray(parsed)) {{
            for (const [emojiRaw, countRaw] of Object.entries(parsed)) {{
              const emoji = String(emojiRaw || "").trim();
              const count = Math.floor(Number(countRaw));
              if (!emoji || (enforceChoiceSet && !chatEmojiChoiceSet.has(emoji)) || !Number.isFinite(count) || count <= 0) {{
                continue;
              }}
              next.set(emoji, count);
            }}
          }}
        }}
      }} catch (_err) {{
      }}
      chatEmojiUsageCounts = next;
    }}

    function noteChatEmojiUsage(rawEmoji) {{
      const emoji = String(rawEmoji || "").trim();
      if (!emoji) return;
      if (chatEmojiChoiceSet.size > 0 && !chatEmojiChoiceSet.has(emoji)) return;
      const nextCount = (chatEmojiUsageCounts.get(emoji) || 0) + 1;
      chatEmojiUsageCounts.set(emoji, nextCount);
      persistChatEmojiUsage();
    }}

