    function ensureMapOfflineGridPane() {{
      let pane = map.getPane(mapOfflineGridPaneName);
      if (!pane) {{
        pane = map.createPane(mapOfflineGridPaneName);
      }}
      if (pane) {{
        pane.style.zIndex = "180";
        pane.style.pointerEvents = "none";
      }}
      return pane;
    }}

    function normalizeOfflineAtlasCollection(value) {{
      if (!value || typeof value !== "object" || Array.isArray(value)) {{
        return {{ type: "FeatureCollection", features: [] }};
      }}
      const features = Array.isArray(value.features) ? value.features : [];
      return {{
        type: "FeatureCollection",
        features,
      }};
    }}

    async function fetchOfflineAtlasPayload() {{
      if (mapOfflineAtlasPayload && mapOfflineAtlasPayload.ok) {{
        return mapOfflineAtlasPayload;
      }}
      if (mapOfflineAtlasFetchPromise) {{
        return mapOfflineAtlasFetchPromise;
      }}
      mapOfflineAtlasFetchPromise = (async () => {{
        try {{
          const resp = await fetch(mapOfflineAtlasEndpoint, {{ cache: "force-cache" }});
          if (!resp.ok) {{
            throw new Error(`API ${{resp.status}}`);
          }}
          const payload = await resp.json();
          if (!payload || typeof payload !== "object" || payload.ok === false) {{
            throw new Error(payload && payload.error ? String(payload.error) : "atlas payload unavailable");
          }}
          mapOfflineAtlasPayload = payload;
          return payload;
        }} catch (err) {{
          const msg = err instanceof Error ? err.message : String(err || "unknown error");
          appendConsoleLine(`offline-atlas|${{Date.now()}}|${{msg}}`, `[offline atlas] load failed: ${{msg}}`);
          return null;
        }} finally {{
          mapOfflineAtlasFetchPromise = null;
        }}
      }})();
      return mapOfflineAtlasFetchPromise;
    }}

    function sanitizeOfflineLabel(value, fallback = "") {{
      const text = String(value == null ? "" : value).replace(/\\s+/g, " ").trim();
      return text || fallback;
    }}

    function parseOfflineCityRank(value, fallback = 9) {{
      const numeric = Number(value);
      if (!Number.isFinite(numeric)) {{
        return fallback;
      }}
      return Math.max(0, Math.floor(numeric));
    }}

    function parseOfflineCityWeight(value, fallback = 0) {{
      const numeric = Number(value);
      if (!Number.isFinite(numeric)) {{
        return fallback;
      }}
      return Math.max(0, numeric);
    }}

    function offlineCityMinZoom(rank) {{
      if (rank <= 0) return 0;
      if (rank <= 1) return 2;
      if (rank <= 2) return 4;
      return 6;
    }}

    function offlineCityVisibilityBudget(zoom) {{
      if (zoom < 3) return 24;
      if (zoom < 4) return 42;
      if (zoom < 5) return 72;
      if (zoom < 6) return 120;
      if (zoom < 7) return 160;
      if (zoom < 8) return 240;
      if (zoom < 9) return 360;
      return 820;
    }}

    function offlineCitySpacingByZoom(zoom) {{
      if (zoom < 4) return 86;
      if (zoom < 5) return 76;
      if (zoom < 6) return 66;
      if (zoom < 7) return 66;
      if (zoom < 8) return 58;
      if (zoom < 9) return 40;
      return 34;
    }}

    function offlineCityRangeSpacingPx(zoom) {{
      const mapSize = map && typeof map.getSize === "function" ? map.getSize() : null;
      if (!mapSize || !Number.isFinite(mapSize.x) || !Number.isFinite(mapSize.y)) {{
        return offlineCitySpacingByZoom(zoom);
      }}
      const centerPoint = L.point(mapSize.x * 0.5, mapSize.y * 0.5);
      const samplePoint = L.point(centerPoint.x + 64, centerPoint.y);
      const centerLatLng = map.containerPointToLatLng(centerPoint);
      const sampleLatLng = map.containerPointToLatLng(samplePoint);
      const sampleDistance = map.distance(centerLatLng, sampleLatLng);
      const metersPerPixel = sampleDistance > 0 ? (sampleDistance / 64) : 0;
      if (!Number.isFinite(metersPerPixel) || metersPerPixel <= 0) {{
        return offlineCitySpacingByZoom(zoom);
      }}
      const loraRangePx = (mapOfflineLandmarkCoverageKm * 1000) / metersPerPixel;
      // We want landmarks to feel local and dense, not one-per-range-circle.
      const spacingFromRange = loraRangePx * 0.18;
      const spacingFromZoom = offlineCitySpacingByZoom(zoom);
      return clampNumber(
        Math.max(spacingFromRange, spacingFromZoom),
        mapOfflineLandmarkMinSpacingPx,
        mapOfflineLandmarkMaxSpacingPx,
        spacingFromZoom
      );
    }}

    function syncOfflineCityVisibility() {{
      if (!Array.isArray(mapOfflineCityMarkers) || mapOfflineCityMarkers.length === 0) {{
        return;
      }}
      const zoom = Number(map.getZoom());
      const safeZoom = Number.isFinite(zoom) ? zoom : 0;
      const bounds = map.getBounds();
      const paddedBounds = bounds && typeof bounds.pad === "function" ? bounds.pad(0.2) : null;
      const minSpacingPx = offlineCityRangeSpacingPx(safeZoom);
      const minSpacingSq = minSpacingPx * minSpacingPx;
      const cellSize = Math.max(16, minSpacingPx);
      const visibleBudget = offlineCityVisibilityBudget(safeZoom);
      const candidates = [];

      for (const entry of mapOfflineCityMarkers) {{
        const marker = entry && entry.marker;
        if (!marker || typeof marker.setOpacity !== "function") {{
          continue;
        }}
        const rank = parseOfflineCityRank(entry.rank, 9);
        const markerLatLng = entry.latlng
          || (typeof marker.getLatLng === "function" ? marker.getLatLng() : null);
        if (!markerLatLng || safeZoom < offlineCityMinZoom(rank)) {{
          marker.setOpacity(0);
          continue;
        }}
        if (paddedBounds && typeof paddedBounds.contains === "function" && !paddedBounds.contains(markerLatLng)) {{
          marker.setOpacity(0);
          continue;
        }}
        const point = map.latLngToContainerPoint(markerLatLng);
        const weight = parseOfflineCityWeight(entry.weight, 0);
        candidates.push({{ marker, rank, weight, point }});
      }}

      candidates.sort((a, b) => {{
        if (a.rank !== b.rank) return a.rank - b.rank;
        if (a.weight !== b.weight) return b.weight - a.weight;
        if (a.point.y !== b.point.y) return a.point.y - b.point.y;
        return a.point.x - b.point.x;
      }});

      const grid = new Map();
      const selected = [];
      const selectedLabelBoxes = [];

      function cellKey(cx, cy) {{
        return `${{cx}}:${{cy}}`;
      }}

      function isTooClose(point) {{
        const cx = Math.floor(point.x / cellSize);
        const cy = Math.floor(point.y / cellSize);
        for (let ox = -1; ox <= 1; ox += 1) {{
          for (let oy = -1; oy <= 1; oy += 1) {{
            const bucket = grid.get(cellKey(cx + ox, cy + oy));
            if (!bucket) continue;
            for (const other of bucket) {{
              const dx = point.x - other.x;
              const dy = point.y - other.y;
              if ((dx * dx) + (dy * dy) < minSpacingSq) {{
                return true;
              }}
            }}
          }}
        }}
        return false;
      }}

      function rememberPoint(point) {{
        const cx = Math.floor(point.x / cellSize);
        const cy = Math.floor(point.y / cellSize);
        const key = cellKey(cx, cy);
        const bucket = grid.get(key);
        if (bucket) {{
          bucket.push(point);
        }} else {{
          grid.set(key, [point]);
        }}
      }}

      function hasLabelOverlap(point) {{
        const xBand = Math.max(34, minSpacingPx * 1.08);
        const yBand = Math.max(14, minSpacingPx * 0.34);
        for (const box of selectedLabelBoxes) {{
          if (!box) continue;
          const dx = Math.abs(point.x - box.x);
          const dy = Math.abs(point.y - box.y);
          if (dx < xBand && dy < yBand) {{
            return true;
          }}
        }}
        return false;
      }}

      for (const candidate of candidates) {{
        if (selected.length >= visibleBudget) {{
          candidate.marker.setOpacity(0);
          continue;
        }}
        const forceInclude = candidate.rank <= 1 && safeZoom <= 4;
        if (!forceInclude && isTooClose(candidate.point)) {{
          candidate.marker.setOpacity(0);
          continue;
        }}
        if (!forceInclude && hasLabelOverlap(candidate.point)) {{
          candidate.marker.setOpacity(0);
          continue;
        }}
        candidate.marker.setOpacity(1);
        selected.push(candidate);
        rememberPoint(candidate.point);
        selectedLabelBoxes.push({{ x: candidate.point.x, y: candidate.point.y }});
      }}
    }}

    function buildOfflineAtlasLayers(payload) {{
      const layers = payload && typeof payload === "object" && payload.layers && typeof payload.layers === "object"
        ? payload.layers
        : {{}};
      mapOfflineCityMarkers = [];
      const countriesData = normalizeOfflineAtlasCollection(layers.countries);
      const coastlineData = normalizeOfflineAtlasCollection(layers.coastline);
      const bordersData = normalizeOfflineAtlasCollection(layers.borders);
      const urbanData = normalizeOfflineAtlasCollection(layers.urban);
      const statesData = normalizeOfflineAtlasCollection(layers.states);
      const riversData = normalizeOfflineAtlasCollection(layers.rivers);
      const lakesData = normalizeOfflineAtlasCollection(layers.lakes);
      const citiesData = normalizeOfflineAtlasCollection(layers.cities);

      mapOfflineCountriesLayer = L.geoJSON(countriesData, {{
        pane: mapOfflineGridPaneName,
        interactive: false,
        style: () => ({{
          color: "#3f5f84",
          weight: 1.2,
          opacity: 0.58,
          fill: false,
        }}),
      }});
      mapOfflineCoastlineLayer = L.geoJSON(coastlineData, {{
        pane: mapOfflineGridPaneName,
        interactive: false,
        style: () => ({{
          color: "#5f8cbc",
          weight: 1.25,
          opacity: 0.7,
        }}),
      }});
      mapOfflineBordersLayer = L.geoJSON(bordersData, {{
        pane: mapOfflineGridPaneName,
        interactive: false,
        style: () => ({{
          color: "#6f8fb2",
          weight: 0.95,
          opacity: 0.55,
          dashArray: "3 3",
        }}),
      }});
      mapOfflineUrbanLayer = L.geoJSON(urbanData, {{
        pane: mapOfflineGridPaneName,
        interactive: false,
        style: () => ({{
          color: "#4f6f94",
          weight: 0.6,
          opacity: 0.42,
          fillColor: "#5f81aa",
          fillOpacity: 0.08,
        }}),
      }});
      mapOfflineStatesLayer = L.geoJSON(statesData, {{
        pane: mapOfflineGridPaneName,
        interactive: false,
        style: () => ({{
          color: "#5b7da7",
          weight: 1.15,
          opacity: 0.75,
          fill: false,
        }}),
      }});
      mapOfflineRiversLayer = L.geoJSON(riversData, {{
        pane: mapOfflineGridPaneName,
        interactive: false,
        style: () => ({{
          color: "#6ca1d4",
          weight: 1.5,
          opacity: 0.78,
        }}),
      }});
      mapOfflineLakesLayer = L.geoJSON(lakesData, {{
        pane: mapOfflineGridPaneName,
        interactive: false,
        style: () => ({{
          color: "#7aa7d3",
          weight: 0.9,
          opacity: 0.82,
          fillColor: "#90b8df",
          fillOpacity: 0.2,
        }}),
      }});
      mapOfflineCitiesLayer = L.geoJSON(citiesData, {{
        pane: mapOfflineGridPaneName,
        interactive: false,
        pointToLayer: (feature, latlng) => {{
          const props = feature && feature.properties && typeof feature.properties === "object"
            ? feature.properties
            : {{}};
          const name = sanitizeOfflineLabel(props.name, "City");
          const rank = parseOfflineCityRank(props.scalerank, 9);
          const weight = parseOfflineCityWeight(props.population, 0);
          const marker = L.marker(latlng, {{
            interactive: false,
            keyboard: false,
            pane: mapOfflineGridPaneName,
            icon: L.divIcon({{
              className: "offline-landmark-icon",
              html: `<span>${{escAttr(name)}}</span>`,
              iconSize: [0, 0],
              iconAnchor: [0, 0],
            }}),
          }});
          mapOfflineCityMarkers.push({{
            marker,
            rank,
            weight,
            latlng,
            label: name,
          }});
          return marker;
        }},
      }});
    }}

    function addOfflineAtlasLayersToMap() {{
      for (const layer of [
        mapOfflineCountriesLayer,
        mapOfflineCoastlineLayer,
        mapOfflineBordersLayer,
        mapOfflineUrbanLayer,
        mapOfflineStatesLayer,
        mapOfflineRiversLayer,
        mapOfflineLakesLayer,
        mapOfflineCitiesLayer,
      ]) {{
        if (layer && !map.hasLayer(layer)) {{
          map.addLayer(layer);
        }}
      }}
      syncOfflineCityVisibility();
    }}

    function removeOfflineAtlasLayersFromMap() {{
      for (const layer of [
        mapOfflineCountriesLayer,
        mapOfflineCoastlineLayer,
        mapOfflineBordersLayer,
        mapOfflineUrbanLayer,
        mapOfflineStatesLayer,
        mapOfflineRiversLayer,
        mapOfflineLakesLayer,
        mapOfflineCitiesLayer,
      ]) {{
        if (layer && map.hasLayer(layer)) {{
          map.removeLayer(layer);
        }}
      }}
      mapOfflineCityMarkers = [];
    }}

    function shouldShowOfflineAtlas() {{
      return mapBasemapMode === "offline" || mapOfflineFallbackActive;
    }}

    async function ensureOfflineAtlasLayers() {{
      const shouldAttach = shouldShowOfflineAtlas();
      if (
        mapOfflineCountriesLayer
        && mapOfflineCoastlineLayer
        && mapOfflineBordersLayer
        && mapOfflineUrbanLayer
        && mapOfflineStatesLayer
        && mapOfflineRiversLayer
        && mapOfflineLakesLayer
        && mapOfflineCitiesLayer
      ) {{
        if (shouldAttach) {{
          addOfflineAtlasLayersToMap();
        }}
        return true;
      }}
      const payload = await fetchOfflineAtlasPayload();
      if (!payload) {{
        return false;
      }}
      buildOfflineAtlasLayers(payload);
      // Guard against race conditions: atlas fetch may finish after mode switched back online.
      if (shouldShowOfflineAtlas()) {{
        addOfflineAtlasLayersToMap();
      }}
      return true;
    }}

    function clearMapTileProbeTimer() {{
      if (mapTileProbeTimer !== null) {{
        clearTimeout(mapTileProbeTimer);
        mapTileProbeTimer = null;
      }}
    }}

    function normalizeMapBasemapMode(raw) {{
      return String(raw || "").trim().toLowerCase() === "offline" ? "offline" : "online";
    }}

    function activeMapTileTheme() {{
      const activeTheme = String(document.documentElement.getAttribute("data-theme") || "").trim().toLowerCase();
      return activeTheme === "dark" ? "dark" : "light";
    }}

    function persistMapBasemapMode() {{
      try {{
        window.localStorage.setItem(mapBasemapModeStorageKey, mapBasemapMode);
      }} catch (_err) {{
      }}
    }}

    function loadMapBasemapModePreference() {{
      let stored = "online";
      try {{
        stored = window.localStorage.getItem(mapBasemapModeStorageKey) || "online";
      }} catch (_err) {{
      }}
      mapBasemapMode = normalizeMapBasemapMode(stored);
    }}

    function setMapBasemapStatus(status, detail = "") {{
      const el = document.getElementById("map-basemap-status");
      if (!(el instanceof HTMLElement)) {{
        return;
      }}
      const manualOffline = mapBasemapMode === "offline";
      const mode = manualOffline
        ? "offline"
        : (status === "online" || status === "offline" ? status : "loading");
      el.classList.remove("status-online", "status-loading", "status-offline");
      el.classList.add(`status-${{mode}}`);
      if (manualOffline) {{
        el.textContent = "Basemap: offline (forced)";
      }} else if (mode === "online") {{
        el.textContent = "Basemap: online";
      }} else if (mode === "offline") {{
        el.textContent = "Basemap: offline atlas";
      }} else {{
        el.textContent = "Basemap: checking...";
      }}
      if (el instanceof HTMLButtonElement) {{
        el.setAttribute("aria-pressed", manualOffline ? "true" : "false");
      }}
      const titleText = String(detail || "").trim();
      const toggleHint = manualOffline
        ? "Click to switch back to online tiles."
        : "Click to force offline atlas mode.";
      if (titleText) {{
        el.title = `${{titleText}} ${{toggleHint}}`;
      }} else if (manualOffline) {{
        el.title = `Offline mode is forced. Showing offline atlas (countries, coastline, borders, states, urban areas, rivers, lakes, cities). ${{toggleHint}}`;
      }} else if (mode === "offline") {{
        el.title = `Map tiles unavailable. Showing offline atlas (countries, coastline, borders, states, urban areas, rivers, lakes, cities). ${{toggleHint}}`;
      }} else if (mode === "online") {{
        el.title = `Map tiles loaded normally. ${{toggleHint}}`;
      }} else {{
        el.title = `Checking map tile availability. ${{toggleHint}}`;
      }}
    }}

    function setMapBasemapMode(mode, persist = true, reason = "") {{
      const next = normalizeMapBasemapMode(mode);
      mapBasemapMode = next;
      if (persist) {{
        persistMapBasemapMode();
      }}
      if (next === "offline") {{
        clearMapTileProbeTimer();
        if (mapTileLayer && map.hasLayer(mapTileLayer)) {{
          map.removeLayer(mapTileLayer);
        }}
        setMapOfflineFallbackState(true, reason || "Offline mode is forced by user.");
        return;
      }}

      // In online mode we never want offline vectors lingering underneath tiles.
      setMapOfflineFallbackState(false, "Online mode enabled.");
      setMapBasemapStatus("loading", reason || "Online mode enabled. Loading map tiles...");
      applyMapTiles(activeMapTileTheme());
    }}

    function bindMapBasemapToggleControl() {{
      const btn = document.getElementById("map-basemap-status");
      if (!(btn instanceof HTMLButtonElement) || btn.dataset.bound === "1") {{
        return;
      }}
      btn.dataset.bound = "1";
      btn.addEventListener("click", () => {{
        const nextMode = mapBasemapMode === "offline" ? "online" : "offline";
        const reason = nextMode === "offline"
          ? "Offline mode forced by user."
          : "Online mode restored by user.";
        setMapBasemapMode(nextMode, true, reason);
      }});
      setMapBasemapStatus(mapOfflineFallbackActive ? "offline" : "loading");
    }}

    function setMapOfflineFallbackState(enabled, reason = "") {{
      const active = !!enabled;
      if (active === mapOfflineFallbackActive) {{
        if (active) {{
          ensureMapOfflineGridPane();
          void ensureOfflineAtlasLayers();
        }}
        if (active) {{
          setMapBasemapStatus("offline", reason);
        }} else if (mapTileLoadSuccesses > 0) {{
          setMapBasemapStatus("online", reason);
        }}
        if (mapFrameElement instanceof HTMLElement) {{
          mapFrameElement.classList.toggle("map-basemap-offline", active);
        }}
        return;
      }}
      mapOfflineFallbackActive = active;
      if (active) {{
        ensureMapOfflineGridPane();
        void ensureOfflineAtlasLayers();
        setMapBasemapStatus("offline", reason);
      }} else {{
        removeOfflineAtlasLayersFromMap();
        if (mapTileLoadSuccesses > 0) {{
          setMapBasemapStatus("online", reason);
        }}
      }}
      if (mapFrameElement instanceof HTMLElement) {{
        mapFrameElement.classList.toggle("map-basemap-offline", active);
      }}
    }}

    function scheduleMapTileProbe(sessionId) {{
      clearMapTileProbeTimer();
      mapTileProbeTimer = window.setTimeout(() => {{
        if (mapBasemapMode === "offline") {{
          return;
        }}
        if (sessionId !== mapTileLoadSession) {{
          return;
        }}
        if (mapTileLoadSuccesses > 0) {{
          return;
        }}
        const offlineHint = typeof navigator !== "undefined" && navigator && navigator.onLine === false;
        const reason = offlineHint
          ? "Browser is offline. Showing offline atlas reference map."
          : "Map tiles unavailable. Showing offline atlas reference map.";
        setMapOfflineFallbackState(true, reason);
      }}, 2500);
    }}

    function bindMapBasemapConnectivityHandlers() {{
      if (document.body.dataset.mapBasemapConnectivityBound === "1") {{
        return;
      }}
      document.body.dataset.mapBasemapConnectivityBound = "1";
      window.addEventListener("offline", () => {{
        if (mapBasemapMode === "offline") {{
          setMapBasemapStatus("offline", "Offline mode is forced by user.");
          return;
        }}
        if (mapTileLoadSuccesses <= 0) {{
          setMapOfflineFallbackState(true, "Browser is offline. Showing offline atlas reference map.");
        }} else {{
          setMapBasemapStatus(
            "loading",
            "Browser is offline. Cached tiles may remain visible; offline atlas will show if tiles become unavailable."
          );
        }}
      }});
      window.addEventListener("online", () => {{
        if (mapBasemapMode === "offline") {{
          setMapBasemapStatus("offline", "Offline mode is forced by user.");
          return;
        }}
        setMapBasemapStatus("loading", "Connection restored. Checking map tiles...");
        if (mapTileLayer) {{
          mapTileLoadSuccesses = 0;
          mapTileLoadErrors = 0;
          mapTileLayer.redraw();
          scheduleMapTileProbe(mapTileLoadSession);
        }}
      }});
    }}

    function applyMapTiles(themeName) {{
      const nextTheme = themeName === "dark" ? "dark" : "light";
      if (mapTileLayer
        && mapTileTheme === nextTheme
        && mapBasemapMode !== "offline"
        && map.hasLayer(mapTileLayer)) {{
        return;
      }}
      const cfg = mapTileConfigs[nextTheme] || mapTileConfigs.light;
      if (mapTileLayer) {{
        mapTileLayer.off();
        map.removeLayer(mapTileLayer);
      }}
      mapTileLoadSession += 1;
      const sessionId = mapTileLoadSession;
      mapTileLoadSuccesses = 0;
      mapTileLoadErrors = 0;
      setMapBasemapStatus("loading", "Checking map tile availability...");
      const layerOptions = Object.assign({{}}, cfg.options || {{}}, {{
        crossOrigin: true,
      }});
      mapTileLayer = L.tileLayer(cfg.url, layerOptions);
      mapTileLayer.on("tileloadstart", () => {{
        if (mapBasemapMode === "offline") {{
          return;
        }}
        if (sessionId !== mapTileLoadSession) {{
          return;
        }}
        if (mapTileLoadSuccesses <= 0) {{
          setMapBasemapStatus("loading", "Loading map tiles...");
        }}
      }});
      mapTileLayer.on("tileload", () => {{
        if (mapBasemapMode === "offline") {{
          return;
        }}
        if (sessionId !== mapTileLoadSession) {{
          return;
        }}
        mapTileLoadSuccesses += 1;
        mapTileLoadErrors = 0;
        setMapOfflineFallbackState(false, "Map tiles loaded.");
      }});
      mapTileLayer.on("tileerror", () => {{
        if (mapBasemapMode === "offline") {{
          return;
        }}
        if (sessionId !== mapTileLoadSession) {{
          return;
        }}
        mapTileLoadErrors += 1;
        if (mapTileLoadSuccesses <= 0 && mapTileLoadErrors >= 2) {{
          setMapOfflineFallbackState(true, "Tile requests failed. Showing offline atlas reference map.");
        }} else if (mapTileLoadSuccesses <= 0) {{
          setMapBasemapStatus("loading", `Retrying map tiles (${{mapTileLoadErrors}} errors)...`);
        }}
      }});
      mapTileLayer.on("load", () => {{
        if (mapBasemapMode === "offline") {{
          return;
        }}
        if (sessionId !== mapTileLoadSession) {{
          return;
        }}
        if (mapTileLoadSuccesses > 0) {{
          setMapOfflineFallbackState(false, "Map tiles loaded.");
        }} else if (mapTileLoadErrors > 0) {{
          setMapOfflineFallbackState(true, "Map tile load cycle completed without valid tiles.");
        }}
      }});
      if (mapBasemapMode === "offline") {{
        setMapOfflineFallbackState(true, "Offline mode is forced by user.");
      }} else {{
        mapTileLayer.addTo(map);
        scheduleMapTileProbe(sessionId);
      }}
      mapTileTheme = nextTheme;
    }}

