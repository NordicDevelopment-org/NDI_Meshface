    function normalizeChatNodeNavigatorSortKeyPref(value) {{
      const clean = String(value || "").trim().toLowerCase();
      return chatNodeNavigatorSortDefById.has(clean) ? clean : chatNodeNavigatorDefaultSortKey;
    }}

    function normalizeChatNodeNavigatorSortDirPref(value) {{
      const clean = String(value || "").trim().toLowerCase();
      return clean === "desc" ? "desc" : "asc";
    }}

    function normalizeChatNodeNavigatorMetaFieldIdsPref(rawIds) {{
      const defs = nodeExplorerRosterMetadataFieldDefs();
      const allowed = new Set(defs.map((def) => String(def && def.id || "")));
      const source = Array.isArray(rawIds)
        ? rawIds
        : (rawIds == null ? [] : [rawIds]);
      const normalized = [];
      for (const value of source) {{
        const fieldId = normalizeNodeExplorerFieldId(value);
        if (!fieldId || !allowed.has(fieldId) || normalized.includes(fieldId)) continue;
        normalized.push(fieldId);
      }}
      if (normalized.length > 0) return normalized;
      return nodeExplorerDefaultRosterMetadataFieldIds();
    }}

    function chatNodeNavigatorMetaFieldIdsEqual(a, b) {{
      const left = Array.isArray(a) ? a : [];
      const right = Array.isArray(b) ? b : [];
      if (left.length !== right.length) return false;
      for (let i = 0; i < left.length; i += 1) {{
        if (String(left[i] || "") !== String(right[i] || "")) return false;
      }}
      return true;
    }}

    function persistChatNodeNavigatorPreferences() {{
      try {{
        const payload = {{
          sortKey: normalizeChatNodeNavigatorSortKeyPref(chatNodeNavigatorSortKey),
          sortDir: normalizeChatNodeNavigatorSortDirPref(chatNodeNavigatorSortDir),
          metaFields: normalizeChatNodeNavigatorMetaFieldIdsPref(chatNodeNavigatorMetaFieldIds),
        }};
        window.localStorage.setItem(chatNodeNavigatorPrefsStorageKey, JSON.stringify(payload));
      }} catch (_err) {{
      }}
    }}

    function applyChatNodeNavigatorPreferences(nextPrefs, options = null) {{
      const prefs = nextPrefs && typeof nextPrefs === "object" ? nextPrefs : {{}};
      const opts = options && typeof options === "object" ? options : {{}};
      const nextSortKey = normalizeChatNodeNavigatorSortKeyPref(
        prefs.sortKey != null ? prefs.sortKey : chatNodeNavigatorSortKey
      );
      const nextSortDir = normalizeChatNodeNavigatorSortDirPref(
        prefs.sortDir != null ? prefs.sortDir : chatNodeNavigatorSortDir
      );
      const nextMetaFieldIds = normalizeChatNodeNavigatorMetaFieldIdsPref(
        prefs.metaFields != null ? prefs.metaFields : chatNodeNavigatorMetaFieldIds
      );
      const changed = (
        nextSortKey !== chatNodeNavigatorSortKey
        || nextSortDir !== chatNodeNavigatorSortDir
        || !chatNodeNavigatorMetaFieldIdsEqual(nextMetaFieldIds, chatNodeNavigatorMetaFieldIds)
      );
      chatNodeNavigatorSortKey = nextSortKey;
      chatNodeNavigatorSortDir = nextSortDir;
      chatNodeNavigatorMetaFieldIds = nextMetaFieldIds;
      if (opts.persist !== false) {{
        persistChatNodeNavigatorPreferences();
      }}
      renderChatNodeNavigatorMenuControls();
      if (changed && opts.rerender !== false && latestState) {{
        renderChat(latestState);
      }}
      return changed;
    }}

    function loadChatNodeNavigatorPreferences() {{
      let parsed = null;
      try {{
        const raw = window.localStorage.getItem(chatNodeNavigatorPrefsStorageKey);
        parsed = raw ? JSON.parse(raw) : null;
      }} catch (_err) {{
      }}
      applyChatNodeNavigatorPreferences(parsed || {{}}, {{
        persist: false,
        rerender: false,
      }});
    }}

    function chatNodeNavigatorCompareSortValues(left, right) {{
      if (typeof normalizeSortValue === "function" && typeof compareSortValues === "function") {{
        return compareSortValues(normalizeSortValue(left), normalizeSortValue(right));
      }}
      const leftNum = Number(left);
      const rightNum = Number(right);
      const leftHasNum = Number.isFinite(leftNum);
      const rightHasNum = Number.isFinite(rightNum);
      if (leftHasNum && rightHasNum) return leftNum - rightNum;
      return String(left == null ? "" : left).localeCompare(String(right == null ? "" : right));
    }}

    function chatNodeNavigatorSortValue(item, projection, sortKeyRaw) {{
      const sortKey = normalizeChatNodeNavigatorSortKeyPref(sortKeyRaw);
      const safeItem = item && typeof item === "object" ? item : {{}};
      const safeProjection = projection && typeof projection === "object"
        ? projection
        : nodeExplorerBuildProjection(null);
      if (sortKey === "status") {{
        return Number.isFinite(Number(safeProjection.statusSort))
          ? Number(safeProjection.statusSort)
          : 99;
      }}
      if (sortKey === "activity") {{
        return Number(safeItem.lastMessageUnix) || 0;
      }}
      const fieldId = normalizeNodeExplorerFieldId(sortKey);
      const field = fieldId && safeProjection.fields
        ? safeProjection.fields[fieldId]
        : null;
      return field ? field.sort : "";
    }}

    function sortChatNodeNavigatorParticipants(participantsList, nodesById, nowUnix = Math.floor(Date.now() / 1000)) {{
      const rows = Array.isArray(participantsList) ? participantsList : [];
      const sourceNodes = nodesById instanceof Map ? nodesById : new Map();
      const sortKey = normalizeChatNodeNavigatorSortKeyPref(chatNodeNavigatorSortKey);
      const sortDir = normalizeChatNodeNavigatorSortDirPref(chatNodeNavigatorSortDir);
      const projectionById = new Map();
      const projectionFor = (entry) => {{
        const nodeId = normalizeNodeId(entry && entry.id);
        if (projectionById.has(nodeId)) {{
          return projectionById.get(nodeId);
        }}
        const node = sourceNodes.get(nodeId) || null;
        const projection = nodeExplorerBuildProjection(
          node || {{ id: nodeId, long_name: (entry && entry.name) || nodeId }},
          {{ nowUnix }}
        );
        projectionById.set(nodeId, projection);
        return projection;
      }};
      rows.sort((a, b) => {{
        const pinDiff = Number(!!(b && b.p2pPinned)) - Number(!!(a && a.p2pPinned));
        if (pinDiff !== 0) return pinDiff;

        const aProjection = projectionFor(a);
        const bProjection = projectionFor(b);
        const aValue = chatNodeNavigatorSortValue(a, aProjection, sortKey);
        const bValue = chatNodeNavigatorSortValue(b, bProjection, sortKey);
        const cmp = chatNodeNavigatorCompareSortValues(aValue, bValue);
        if (cmp !== 0) {{
          return sortDir === "desc" ? -cmp : cmp;
        }}

        const statusCmp = chatNodeNavigatorCompareSortValues(aProjection.statusSort, bProjection.statusSort);
        if (statusCmp !== 0) return statusCmp;

        const activityCmp = chatNodeNavigatorCompareSortValues(
          Number(b && b.lastMessageUnix) || 0,
          Number(a && a.lastMessageUnix) || 0
        );
        if (activityCmp !== 0) return activityCmp;

        const nameCmp = String((a && (a.name || a.id)) || "").localeCompare(String((b && (b.name || b.id)) || ""));
        if (nameCmp !== 0) return nameCmp;
        return String((a && a.id) || "").localeCompare(String((b && b.id) || ""));
      }});
      return rows;
    }}

    function renderChatNodeNavigatorMenuControls() {{
      const menuBtn = document.getElementById("chat-node-navigator-menu-btn");
      const menu = document.getElementById("chat-node-navigator-menu");
      const sortSelect = document.getElementById("chat-node-navigator-sort-select");
      const dirBtn = document.getElementById("chat-node-navigator-sort-dir-btn");
      const fieldsHost = document.getElementById("chat-node-navigator-fields");

      if (menuBtn instanceof HTMLButtonElement) {{
        menuBtn.setAttribute("aria-expanded", chatNodeNavigatorMenuOpen ? "true" : "false");
      }}
      if (menu instanceof HTMLElement) {{
        menu.hidden = !chatNodeNavigatorMenuOpen;
      }}

      if (sortSelect instanceof HTMLSelectElement) {{
        const optionsHtml = chatNodeNavigatorSortDefs.map((def) => (
          `<option value="${{escAttr(def.id)}}">${{escAttr(def.label)}}</option>`
        )).join("");
        if (sortSelect.__meshOptionsHtml !== optionsHtml) {{
          sortSelect.innerHTML = optionsHtml;
          sortSelect.__meshOptionsHtml = optionsHtml;
        }}
        const sortKey = normalizeChatNodeNavigatorSortKeyPref(chatNodeNavigatorSortKey);
        if (sortSelect.value !== sortKey) {{
          sortSelect.value = sortKey;
        }}
      }}

      if (dirBtn instanceof HTMLButtonElement) {{
        const dir = normalizeChatNodeNavigatorSortDirPref(chatNodeNavigatorSortDir);
        dirBtn.textContent = dir === "desc" ? "Desc" : "Asc";
        dirBtn.title = dir === "desc"
          ? "Sorting descending. Click to sort ascending."
          : "Sorting ascending. Click to sort descending.";
        dirBtn.setAttribute("aria-label", dirBtn.title);
      }}

      if (fieldsHost instanceof HTMLElement) {{
        const selected = new Set(
          normalizeChatNodeNavigatorMetaFieldIdsPref(chatNodeNavigatorMetaFieldIds)
        );
        const fieldsHtml = nodeExplorerRosterMetadataFieldDefs().map((def) => {{
          const fieldId = normalizeNodeExplorerFieldId(def && def.id);
          if (!fieldId) return "";
          const checked = selected.has(fieldId) ? " checked" : "";
          return `<label class="chat-node-navigator-field-option">
            <input type="checkbox" data-meta-field-id="${{escAttr(fieldId)}}"${{checked}} />
            <span>${{escAttr(def.label || fieldId)}}</span>
          </label>`;
        }}).join("");
        if (fieldsHost.__meshFieldsHtml !== fieldsHtml) {{
          fieldsHost.innerHTML = fieldsHtml;
          fieldsHost.__meshFieldsHtml = fieldsHtml;
        }} else {{
          for (const input of fieldsHost.querySelectorAll('input[type="checkbox"][data-meta-field-id]')) {{
            if (!(input instanceof HTMLInputElement)) continue;
            const fieldId = normalizeNodeExplorerFieldId(input.dataset.metaFieldId || "");
            input.checked = selected.has(fieldId);
          }}
        }}
      }}
    }}

    function bindChatNodeNavigatorMenuControls() {{
      const menuBtn = document.getElementById("chat-node-navigator-menu-btn");
      const sortSelect = document.getElementById("chat-node-navigator-sort-select");
      const dirBtn = document.getElementById("chat-node-navigator-sort-dir-btn");
      const fieldsHost = document.getElementById("chat-node-navigator-fields");

      if (menuBtn instanceof HTMLButtonElement && menuBtn.dataset.bound !== "1") {{
        menuBtn.dataset.bound = "1";
        menuBtn.addEventListener("click", (ev) => {{
          ev.preventDefault();
          chatNodeNavigatorMenuOpen = !chatNodeNavigatorMenuOpen;
          renderChatNodeNavigatorMenuControls();
        }});
      }}

      if (sortSelect instanceof HTMLSelectElement && sortSelect.dataset.bound !== "1") {{
        sortSelect.dataset.bound = "1";
        sortSelect.addEventListener("change", () => {{
          applyChatNodeNavigatorPreferences({{
            sortKey: sortSelect.value,
          }}, {{
            persist: true,
            rerender: true,
          }});
        }});
      }}

      if (dirBtn instanceof HTMLButtonElement && dirBtn.dataset.bound !== "1") {{
        dirBtn.dataset.bound = "1";
        dirBtn.addEventListener("click", (ev) => {{
          ev.preventDefault();
          const currentDir = normalizeChatNodeNavigatorSortDirPref(chatNodeNavigatorSortDir);
          const nextDir = currentDir === "desc" ? "asc" : "desc";
          applyChatNodeNavigatorPreferences({{
            sortDir: nextDir,
          }}, {{
            persist: true,
            rerender: true,
          }});
        }});
      }}

      if (fieldsHost instanceof HTMLElement && fieldsHost.dataset.bound !== "1") {{
        fieldsHost.dataset.bound = "1";
        fieldsHost.addEventListener("change", (ev) => {{
          const target = ev.target;
          if (!(target instanceof HTMLInputElement)) return;
          if (target.type !== "checkbox") return;
          const nextFields = [];
          for (const input of fieldsHost.querySelectorAll('input[type="checkbox"][data-meta-field-id]')) {{
            if (!(input instanceof HTMLInputElement) || !input.checked) continue;
            nextFields.push(input.dataset.metaFieldId || "");
          }}
          applyChatNodeNavigatorPreferences({{
            metaFields: nextFields,
          }}, {{
            persist: true,
            rerender: true,
          }});
        }});
      }}

      if (document.body.dataset.chatNodeNavigatorMenuOutsideBound !== "1") {{
        document.body.dataset.chatNodeNavigatorMenuOutsideBound = "1";
        document.addEventListener("pointerdown", (ev) => {{
          if (!chatNodeNavigatorMenuOpen) return;
          const target = ev.target;
          if (!(target instanceof Node)) return;
          const btn = document.getElementById("chat-node-navigator-menu-btn");
          const panel = document.getElementById("chat-node-navigator-menu");
          if ((btn instanceof HTMLElement) && btn.contains(target)) return;
          if ((panel instanceof HTMLElement) && panel.contains(target)) return;
          chatNodeNavigatorMenuOpen = false;
          renderChatNodeNavigatorMenuControls();
        }});
      }}

      renderChatNodeNavigatorMenuControls();
    }}

    function bindChatNotificationScopeControl() {{
      const select = document.getElementById("chat-change-scope");
      if (!(select instanceof HTMLSelectElement) || select.dataset.bound === "1") return;
      select.dataset.bound = "1";
      syncChatNotificationScopeControl();
      select.addEventListener("change", () => {{
        applyChatNotificationScope(select.value, true);
      }});
    }}

    function bindChatTrendsViewControl() {{
      const btn = document.getElementById("chat-trends-view-btn");
      if (!(btn instanceof HTMLButtonElement) || btn.dataset.bound === "1") return;
      btn.dataset.bound = "1";
      syncChatTrendsViewControl();
      btn.addEventListener("click", () => {{
        applyChatTrendsViewEnabled(!chatTrendsViewEnabled, true);
      }});
    }}

    // Meshtastic has its own notion of "channels" (0..N) which are distinct from this UI's
    // chat scopes (Everyone vs Peer-to-peer).
    //
    // We expose a lightweight selector so outgoing chat packets can be sent on a user-chosen
    // channel index. Default is channel 0.

    function requestImmediatePoll(delayMs = 0) {{
      const waitMs = Math.max(0, Math.trunc(Number(delayMs) || 0));
      if (chatImmediatePollTimer !== null) {{
        clearTimeout(chatImmediatePollTimer);
        chatImmediatePollTimer = null;
      }}
      chatImmediatePollTimer = window.setTimeout(() => {{
        chatImmediatePollTimer = null;
        if (document.hidden) return;
        if (typeof pollOnce === "function") {{
          void pollOnce();
          return;
        }}
        void poll();
      }}, waitMs);
    }}

    function persistManualDirectPeers() {{
      try {{
        const ids = Array.from(manualDirectPeerIds)
          .map((entry) => normalizeNodeId(entry))
          .filter((entry) => isCanonicalNodeId(entry))
          .sort((a, b) => a.localeCompare(b));
        window.localStorage.setItem(chatDirectPeersStorageKey, JSON.stringify(ids));
      }} catch (_err) {{
      }}
    }}

    function loadManualDirectPeers() {{
      manualDirectPeerIds.clear();
      try {{
        const raw = window.localStorage.getItem(chatDirectPeersStorageKey);
        if (!raw) return;
        const parsed = JSON.parse(raw);
        if (!Array.isArray(parsed)) return;
        for (const entry of parsed) {{
          const nodeId = normalizeNodeId(entry);
          if (!isCanonicalNodeId(nodeId)) continue;
          manualDirectPeerIds.add(nodeId);
        }}
      }} catch (_err) {{
      }}
    }}

    function addManualDirectPeer(rawNodeId, options = null) {{
      const opts = (options && typeof options === "object") ? options : {{}};
      const shouldSelect = opts.select !== false;
      const nodeId = normalizeNodeId(rawNodeId);
      if (!nodeId) {{
        return {{ ok: false, error: "Enter a node ID to add." }};
      }}
      if (!isCanonicalNodeId(nodeId)) {{
        return {{ ok: false, error: "Use a node ID like !49b54790." }};
      }}
      if (isSelfNodeId(nodeId)) {{
        return {{ ok: false, error: "Cannot add your own radio to peer-to-peer list." }};
      }}
      const added = !manualDirectPeerIds.has(nodeId);
      manualDirectPeerIds.add(nodeId);
      persistManualDirectPeers();
      if (shouldSelect) {{
        selectNode(nodeId, true, false);
      }} else if (latestState) {{
        renderChat(latestState);
      }}
      return {{ ok: true, added, id: nodeId }};
    }}

    function removeManualDirectPeer(rawNodeId) {{
      const nodeId = normalizeNodeId(rawNodeId);
      if (!isCanonicalNodeId(nodeId)) return false;
      if (!manualDirectPeerIds.delete(nodeId)) return false;
      persistManualDirectPeers();
      if (selectedNodeId && normalizeNodeId(selectedNodeId) === nodeId) {{
        clearNodeSelection();
      }} else if (latestState) {{
        renderChat(latestState);
      }}
      return true;
    }}

    function detectedPeerCandidates(state = latestState) {{
      const safeState = (state && typeof state === "object") ? state : {{}};
      const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
      const selfId = resolveLocalNodeId(safeState);
      const unique = new Map();
      for (const node of nodes) {{
        const nodeId = normalizeNodeId(node && node.id);
        if (isCanonicalNodeId(selfId) && nodeId === selfId) continue;
        if (!isCanonicalNodeId(nodeId) || unique.has(nodeId)) continue;
        const name = preferredNodeName(node) || nodeNameCache.get(nodeId) || nodeId;
        const lastSeenUnix = nodeLastHeardUnix(node);
        unique.set(nodeId, {{ id: nodeId, name, lastSeenUnix }});
      }}
      return Array.from(unique.values()).sort((a, b) => {{
        const aSeen = Number(a.lastSeenUnix) || 0;
        const bSeen = Number(b.lastSeenUnix) || 0;
        if (aSeen !== bSeen) return bSeen - aSeen;
        const nameDiff = String(a.name || "").localeCompare(String(b.name || ""));
        if (nameDiff !== 0) return nameDiff;
        return String(a.id || "").localeCompare(String(b.id || ""));
      }});
    }}

    function renderChatPeerAddPanel(state = latestState) {{
      const toggleBtn = document.getElementById("chat-peer-add-toggle-btn");
      const panel = document.getElementById("chat-peer-add-panel");
      const detectedSelect = document.getElementById("chat-peer-detected-select");
      const detectedAddBtn = document.getElementById("chat-peer-add-detected-btn");
      const manualInput = document.getElementById("chat-peer-manual-input");
      const manualAddBtn = document.getElementById("chat-peer-add-manual-btn");
      const savedList = document.getElementById("chat-peer-saved-list");
      const directMode = activeChatChannel === "direct";
      if (toggleBtn instanceof HTMLButtonElement) {{
        toggleBtn.hidden = !directMode;
        toggleBtn.setAttribute("aria-expanded", directMode && chatPeerAddPanelOpen ? "true" : "false");
      }}
      if (panel instanceof HTMLElement) {{
        panel.hidden = !(directMode && chatPeerAddPanelOpen);
      }}
      renderChatNodeNavigatorMenuControls();

      const candidates = detectedPeerCandidates(state);
      if (detectedSelect instanceof HTMLSelectElement) {{
        const previousValue = normalizeNodeId(detectedSelect.value || "");
        const options = ['<option value="">Detected nodes...</option>'];
        for (const entry of candidates) {{
          const savedSuffix = manualDirectPeerIds.has(entry.id) ? " (saved)" : "";
          const label = `${{entry.name}} (${{entry.id}})${{savedSuffix}}`;
          options.push(`<option value="${{escAttr(entry.id)}}">${{escAttr(label)}}</option>`);
        }}
        detectedSelect.innerHTML = options.join("");
        if (previousValue && candidates.some((entry) => entry.id === previousValue)) {{
          detectedSelect.value = previousValue;
        }} else if (isCanonicalNodeId(selectedNodeId) && candidates.some((entry) => entry.id === selectedNodeId)) {{
          detectedSelect.value = normalizeNodeId(selectedNodeId);
        }} else {{
          detectedSelect.value = "";
        }}
        detectedSelect.disabled = !directMode || candidates.length === 0;
      }}
      if (detectedAddBtn instanceof HTMLButtonElement) {{
        const hasChoice = detectedSelect instanceof HTMLSelectElement
          && isCanonicalNodeId(detectedSelect.value || "");
        detectedAddBtn.disabled = !directMode || !hasChoice;
      }}
      if (manualInput instanceof HTMLInputElement) {{
        manualInput.disabled = !directMode;
      }}
      if (manualAddBtn instanceof HTMLButtonElement) {{
        manualAddBtn.disabled = !directMode;
      }}

      if (savedList instanceof HTMLElement) {{
        const safeState = (state && typeof state === "object") ? state : {{}};
        const selfId = resolveLocalNodeId(safeState);
        const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
        const nodesById = new Map(
          nodes.map((node) => [normalizeNodeId(node && node.id), node])
        );
        const savedPeers = Array.from(manualDirectPeerIds)
          .map((entry) => normalizeNodeId(entry))
          .filter((entry) => isCanonicalNodeId(entry))
          .filter((entry) => !(isCanonicalNodeId(selfId) && entry === selfId))
          .map((entry) => {{
            const node = nodesById.get(entry);
            const name = preferredNodeName(node) || nodeNameCache.get(entry) || entry;
            return {{ id: entry, name }};
          }})
          .sort((a, b) => String(a.name || a.id).localeCompare(String(b.name || b.id)));
        if (savedPeers.length === 0) {{
          savedList.innerHTML = '<div class="chat-peer-saved-empty">No saved peers yet.</div>';
        }} else {{
          savedList.innerHTML = savedPeers.map((entry) => (
            `<div class="chat-peer-saved-item">
              <span class="chat-peer-saved-main">
                <span class="chat-peer-saved-name">${{escAttr(entry.name)}}</span>
                <span class="chat-peer-saved-id">${{escAttr(entry.id)}}</span>
              </span>
              <button type="button" class="chat-peer-saved-remove-btn" data-node-id="${{escAttr(entry.id)}}" title="Remove ${{escAttr(entry.id)}} from peer-to-peer list" aria-label="Remove ${{escAttr(entry.id)}} from peer-to-peer list">&times;</button>
            </div>`
          )).join("");
        }}
      }}
    }}

    function bindChatPeerControls() {{
      const toggleBtn = document.getElementById("chat-peer-add-toggle-btn");
      const detectedSelect = document.getElementById("chat-peer-detected-select");
      const detectedAddBtn = document.getElementById("chat-peer-add-detected-btn");
      const manualInput = document.getElementById("chat-peer-manual-input");
      const manualAddBtn = document.getElementById("chat-peer-add-manual-btn");
      const savedList = document.getElementById("chat-peer-saved-list");

      if (toggleBtn instanceof HTMLButtonElement && toggleBtn.dataset.bound !== "1") {{
        toggleBtn.dataset.bound = "1";
        toggleBtn.addEventListener("click", () => {{
          if (activeChatChannel !== "direct") return;
          chatPeerAddPanelOpen = !chatPeerAddPanelOpen;
          renderChatPeerAddPanel(latestState);
          if (chatPeerAddPanelOpen && manualInput instanceof HTMLInputElement) {{
            manualInput.focus({{ preventScroll: true }});
          }}
        }});
      }}

      if (detectedAddBtn instanceof HTMLButtonElement && detectedAddBtn.dataset.bound !== "1") {{
        detectedAddBtn.dataset.bound = "1";
        detectedAddBtn.addEventListener("click", () => {{
          const chosenId = normalizeNodeId(
            detectedSelect instanceof HTMLSelectElement ? detectedSelect.value : ""
          );
          const result = addManualDirectPeer(chosenId, {{ select: true }});
          if (!result.ok) {{
            setChatSendStatus(result.error || "Unable to add peer.", true);
            return;
          }}
          setChatSendStatus(
            result.added
              ? `Peer ${{result.id}} added to peer-to-peer list.`
              : `Peer ${{result.id}} is already in your peer-to-peer list.`
          );
          renderChatPeerAddPanel(latestState);
        }});
      }}

      if (detectedSelect instanceof HTMLSelectElement && detectedSelect.dataset.bound !== "1") {{
        detectedSelect.dataset.bound = "1";
        detectedSelect.addEventListener("change", () => {{
          renderChatPeerAddPanel(latestState);
        }});
      }}

      const submitManualPeer = () => {{
        const raw = manualInput instanceof HTMLInputElement ? manualInput.value : "";
        const result = addManualDirectPeer(raw, {{ select: true }});
        if (!result.ok) {{
          setChatSendStatus(result.error || "Unable to add peer.", true);
          if (manualInput instanceof HTMLInputElement) {{
            manualInput.focus({{ preventScroll: true }});
          }}
          return;
        }}
        if (manualInput instanceof HTMLInputElement) {{
          manualInput.value = "";
          manualInput.focus({{ preventScroll: true }});
        }}
        setChatSendStatus(
          result.added
            ? `Peer ${{result.id}} added to peer-to-peer list.`
            : `Peer ${{result.id}} is already in your peer-to-peer list.`
        );
        renderChatPeerAddPanel(latestState);
      }};

      if (manualAddBtn instanceof HTMLButtonElement && manualAddBtn.dataset.bound !== "1") {{
        manualAddBtn.dataset.bound = "1";
        manualAddBtn.addEventListener("click", () => {{
          submitManualPeer();
        }});
      }}

      if (manualInput instanceof HTMLInputElement && manualInput.dataset.bound !== "1") {{
        manualInput.dataset.bound = "1";
        manualInput.addEventListener("keydown", (ev) => {{
          if (ev.key !== "Enter") return;
          ev.preventDefault();
          submitManualPeer();
        }});
      }}

      if (savedList instanceof HTMLElement && savedList.dataset.bound !== "1") {{
        savedList.dataset.bound = "1";
        savedList.addEventListener("click", (ev) => {{
          const target = ev.target;
          if (!(target instanceof Element)) return;
          const removeBtn = target.closest(".chat-peer-saved-remove-btn");
          if (!(removeBtn instanceof HTMLButtonElement)) return;
          ev.preventDefault();
          ev.stopPropagation();
          const nodeId = normalizeNodeId(removeBtn.dataset.nodeId || "");
          if (!isCanonicalNodeId(nodeId)) return;
          const removed = removeManualDirectPeer(nodeId);
          if (!removed) return;
          setChatSendStatus(`Peer ${{nodeId}} removed from peer-to-peer list.`);
          renderChatPeerAddPanel(latestState);
        }});
      }}

      renderChatPeerAddPanel(latestState);
    }}
