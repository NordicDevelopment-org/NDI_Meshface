    function syncSearchTextInputClearButton(inputOrId) {{
      const input = typeof inputOrId === "string"
        ? document.getElementById(inputOrId)
        : inputOrId;
      if (!(input instanceof HTMLInputElement)) return null;
      const host = input.parentElement;
      if (!(host instanceof HTMLElement)) return null;
      const buttonId = String(input.dataset.clearButtonId || "").trim();
      const button = buttonId ? document.getElementById(buttonId) : null;
      const hasValue = String(input.value == null ? "" : input.value).length > 0;
      host.classList.toggle("search-input-clear-host", !!button);
      host.classList.toggle("has-value", !!button && hasValue);
      if (button instanceof HTMLButtonElement) {{
        button.hidden = !hasValue;
        button.disabled = !hasValue;
        button.setAttribute("aria-hidden", hasValue ? "false" : "true");
      }}
      return button instanceof HTMLButtonElement ? button : null;
    }}

    function ensureSearchTextInputClearButton(inputOrId, options = {{}}) {{
      const input = typeof inputOrId === "string"
        ? document.getElementById(inputOrId)
        : inputOrId;
      if (!(input instanceof HTMLInputElement)) return null;
      const host = input.parentElement;
      if (!(host instanceof HTMLElement)) return null;

      const opts = options && typeof options === "object" ? options : {{}};
      const label = String(opts.label || input.getAttribute("aria-label") || input.placeholder || "search").trim();
      const clearLabel = String(opts.clearLabel || `Clear ${{label}}`).trim() || "Clear search";
      const clearTitle = String(opts.clearTitle || clearLabel).trim() || clearLabel;
      const buttonId = input.dataset.clearButtonId
        || `${{input.id || "search-input"}}-clear-btn`;
      input.dataset.clearButtonId = buttonId;
      host.classList.add("search-input-clear-host");
      input.classList.add("has-search-clear-button");

      let button = document.getElementById(buttonId);
      if (!(button instanceof HTMLButtonElement)) {{
        button = document.createElement("button");
        button.type = "button";
        button.id = buttonId;
        button.className = "search-input-clear-btn";
        button.setAttribute("aria-label", clearLabel);
        button.setAttribute("title", clearTitle);
        button.innerHTML = '<span aria-hidden="true">&times;</span>';
        host.appendChild(button);
      }}

      if (button.dataset.bound !== "1") {{
        button.dataset.bound = "1";
        button.addEventListener("mousedown", (ev) => {{
          ev.preventDefault();
        }});
        button.addEventListener("click", (ev) => {{
          ev.preventDefault();
          ev.stopPropagation();
          if (input.disabled || input.readOnly) return;
          if (String(input.value == null ? "" : input.value) !== "") {{
            input.value = "";
            syncSearchTextInputClearButton(input);
            input.dispatchEvent(new Event("input", {{ bubbles: true }}));
          }}
          try {{
            input.focus({{ preventScroll: true }});
          }} catch (_err) {{
            input.focus();
          }}
        }});
      }}

      if (input.dataset.clearButtonStateBound !== "1") {{
        input.dataset.clearButtonStateBound = "1";
        input.addEventListener("input", () => {{
          syncSearchTextInputClearButton(input);
        }});
      }}

      syncSearchTextInputClearButton(input);
      return button;
    }}

    function bindSearchTextInput(inputId, options = {{}}) {{
      const input = document.getElementById(inputId);
      if (!(input instanceof HTMLInputElement)) return null;

      const normalize = typeof options.normalize === "function"
        ? options.normalize
        : ((value) => String(value == null ? "" : value));
      const onInput = typeof options.onInput === "function"
        ? options.onInput
        : null;

      if (input.dataset.bound !== "1") {{
        input.dataset.bound = "1";
        if (onInput) {{
          input.addEventListener("input", () => {{
            const rawValue = String(input.value == null ? "" : input.value);
            onInput(normalize(rawValue), rawValue, input);
          }});
        }}
      }}

      if (Object.prototype.hasOwnProperty.call(options || {{}}, "value")) {{
        const valueText = String(options.value == null ? "" : options.value);
        if (input.value !== valueText) {{
          input.value = valueText;
        }}
      }}

      if (options.clearable === true) {{
        ensureSearchTextInputClearButton(input, options);
      }} else {{
        syncSearchTextInputClearButton(input);
      }}

      return input;
    }}

    function renderSortableListboxTable(tableId, rowModels, options = {{}}) {{
      const rows = Array.isArray(rowModels) ? rowModels : [];
      const emptyTextRaw = options && options.emptyText != null
        ? String(options.emptyText)
        : "No rows.";
      const emptyText = emptyTextRaw.trim() || "No rows.";
      const emptyColspan = Math.max(1, Math.trunc(Number(options && options.emptyColspan) || 1));
      if (!rows.length) {{
        fillTable(tableId, [`<tr><td colspan="${{emptyColspan}}">${{escAttr(emptyText)}}</td></tr>`]);
        return;
      }}

      const renderedRows = rows.map((row) => {{
        const rowModel = (row && typeof row === "object") ? row : {{}};
        const cells = Array.isArray(rowModel.cells) ? rowModel.cells : [];
        const className = String(rowModel.className || "").trim();
        const dataset = (rowModel.dataset && typeof rowModel.dataset === "object")
          ? rowModel.dataset
          : {{}};

        const attrs = [];
        if (className) {{
          attrs.push(`class="${{escAttr(className)}}"`);
        }}
        for (const [rawKey, rawValue] of Object.entries(dataset)) {{
          const key = String(rawKey || "").trim().replace(/[^a-zA-Z0-9_-]/g, "");
          if (!key) continue;
          attrs.push(`data-${{key}}="${{escAttr(String(rawValue == null ? "" : rawValue))}}"`);
        }}

        const renderedCells = cells.map((cell) => {{
          const cellModel = (cell && typeof cell === "object") ? cell : {{}};
          const sortValue = String(cellModel.sort == null ? "" : cellModel.sort);
          const titleValue = String(cellModel.title == null ? "" : cellModel.title);
          const cellClass = String(cellModel.className || "").trim();
          const content = cellModel.html != null
            ? String(cellModel.html)
            : escAttr(String(cellModel.text == null ? "" : cellModel.text));
          const tdAttrs = [`data-sort="${{escAttr(sortValue)}}"`];
          if (titleValue) {{
            tdAttrs.push(`title="${{escAttr(titleValue)}}"`);
          }}
          if (cellClass) {{
            tdAttrs.push(`class="${{escAttr(cellClass)}}"`);
          }}
          return `<td ${{tdAttrs.join(" ")}}>${{content}}</td>`;
        }});

        return `<tr ${{attrs.join(" ")}}>${{renderedCells.join("")}}</tr>`;
      }});

      fillTable(tableId, renderedRows);
    }}
