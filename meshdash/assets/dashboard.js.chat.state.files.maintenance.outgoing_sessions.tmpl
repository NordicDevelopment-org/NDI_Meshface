    async function maintainOutgoingFileTransferSessions(state = latestState) {{
      if (!(state && typeof state === "object")) return;
      if (fileTransferOutgoingByToken.size <= 0) return;
      const frameState = collectFileTransferFrames(state, {{ respectActiveChannel: false }});
      const ackByTransferKey = frameState.ackByTransferKey;
      const localNodeId = normalizeNodeId(frameState.localNodeId || "");
      const nowMs = Date.now();
      for (const [token, session] of fileTransferOutgoingByToken.entries()) {{
        if (!session || typeof session !== "object") {{
          fileTransferOutgoingByToken.delete(token);
          continue;
        }}
        if (session.delivered || session.failed) {{
          continue;
        }}
        session.srttMs = Math.max(0, Number(session.srttMs) || 0);
        session.rttvarMs = Math.max(0, Number(session.rttvarMs) || 0);
        session.rtoMs = Math.max(
          fileTransferRtoMinMs,
          Math.min(
            fileTransferRtoMaxMs,
            Math.trunc(Number(session.rtoMs) || fileTransferRtoInitialMs)
          )
        );
        session.cwndChunks = Math.max(
          fileTransferCwndMinChunks,
          Math.min(
            fileTransferCwndMaxChunks,
            Number(session.cwndChunks) || fileTransferCwndInitialChunks
          )
        );
        session.ssthreshChunks = Math.max(
          fileTransferCwndMinChunks,
          Math.min(
            fileTransferCwndMaxChunks,
            Math.trunc(Number(session.ssthreshChunks) || fileTransferSsthreshInitialChunks)
          )
        );
        session.lastWindowSendAtMs = Math.max(0, Math.trunc(Number(session.lastWindowSendAtMs) || 0));
        session.lastCongestionBackoffAtMs = Math.max(0, Math.trunc(Number(session.lastCongestionBackoffAtMs) || 0));
        const ack = findAckForOutgoingSession(session, ackByTransferKey, localNodeId);
        if (ack) {{
          const ackChannelIndex = fileTransferExplicitChannelIndex(ack.channelIndex);
          const sendChannelIndex = fileTransferExplicitChannelIndex(session.channelIndex);
          if (ackChannelIndex != null && sendChannelIndex != null && ackChannelIndex !== sendChannelIndex) {{
            const priorLoggedAckChannel = fileTransferExplicitChannelIndex(session.lastAckChannelIndex);
            if (priorLoggedAckChannel !== ackChannelIndex) {{
              appendFileTransferConsole(
                `ACK for ${{fileTransferShortTransferId(session.transferId)}} arrived on ${{meshChannelLabelForIndex(ackChannelIndex, {{ allowAll: false }})}} (send channel was ${{meshChannelLabelForIndex(sendChannelIndex, {{ allowAll: false }})}}).`
              );
            }}
          }}
          session.lastAckChannelIndex = ackChannelIndex;
          const priorAckedChunks = Math.max(
            0,
            Math.min(
              session.totalChunks,
              Math.trunc(Number(session.ackedChunks) || 0)
            )
          );
          const ackedChunksObserved = Math.max(
            0,
            Math.min(
              session.totalChunks,
              Math.max(
                Number(ack.receivedCount || 0),
                (ack.receivedSet instanceof Set ? ack.receivedSet.size : 0)
              )
            )
          );
          const ackedChunks = Math.max(priorAckedChunks, ackedChunksObserved);
          session.ackedChunks = ackedChunks;
          session.sentChunks = Math.max(
            ackedChunks,
            Math.min(
              session.totalChunks,
              Math.max(
                Math.trunc(Number(session.sentChunks) || 0),
                ackedChunks
              )
            )
          );
          session.lastAckUnix = ack.latestUnix || session.lastAckUnix || null;
          if (ackedChunks > priorAckedChunks) {{
            const ackDelta = Math.max(1, ackedChunks - priorAckedChunks);
            const sampleRttMs = session.lastWindowSendAtMs > 0
              ? Math.max(1, nowMs - session.lastWindowSendAtMs)
              : 0;
            if (sampleRttMs > 0) {{
              if (session.srttMs <= 0) {{
                session.srttMs = sampleRttMs;
                session.rttvarMs = Math.max(1, sampleRttMs / 2);
              }} else {{
                const rttErr = Math.abs(session.srttMs - sampleRttMs);
                session.rttvarMs = ((1 - fileTransferRttBeta) * session.rttvarMs) + (fileTransferRttBeta * rttErr);
                session.srttMs = ((1 - fileTransferRttAlpha) * session.srttMs) + (fileTransferRttAlpha * sampleRttMs);
              }}
              const adaptiveRtoMs = Math.round(session.srttMs + (4 * Math.max(1, session.rttvarMs)));
              session.rtoMs = Math.max(
                fileTransferRtoMinMs,
                Math.min(fileTransferRtoMaxMs, adaptiveRtoMs)
              );
            }}
            if (session.cwndChunks < session.ssthreshChunks) {{
              // Slow start: increase window quickly while ACK growth is healthy.
              session.cwndChunks = Math.min(fileTransferCwndMaxChunks, session.cwndChunks + ackDelta);
            }} else {{
              // Congestion avoidance: linear growth.
              const add = Math.max(ackDelta / Math.max(1, session.cwndChunks), 0.2);
              session.cwndChunks = Math.min(fileTransferCwndMaxChunks, session.cwndChunks + add);
            }}
            session.retriesSinceProgress = 0;
            session.lastAckProgressAtMs = nowMs;
            appendFileTransferConsole(
              `ACK progress for ${{fileTransferShortTransferId(session.transferId)}} from ${{session.destination}}: ${{ackedChunks}}/${{session.totalChunks}}.`
            );
          }}
          if (ackedChunks >= session.totalChunks) {{
            session.delivered = true;
            session.deliveredAtMs = nowMs;
            appendFileTransferConsole(
              `Delivered ${{fileTransferShortTransferId(session.transferId)}} to ${{session.destination}} (${{session.totalChunks}}/${{session.totalChunks}} acked).`
            );
            continue;
          }}
        }}

        const stallRetryAttempts = Math.max(
          0,
          Math.trunc(Number(session.retriesSinceProgress) || Number(session.retryAttempts) || 0)
        );
        const lastProgressAtMs = Math.max(0, Math.trunc(Number(session.lastAckProgressAtMs) || 0));
        const lastSendAtMs = Number(session.lastSendAtMs) || Number(session.createdAtMs) || 0;
        const maxedRetries = stallRetryAttempts >= session.maxRetries;
        let retryCapped = false;
        if (maxedRetries) {{
          // After the aggressive retry budget is exhausted, continue low-rate recovery retries.
          // Only fail once we have both exhausted retries and seen sustained no-progress.
          const finalAckGraceMs = Math.max(fileTransferAckWaitBeforeRetryMs, fileTransferAckFinalGraceMs);
          const waitingForLateAck = lastSendAtMs > 0 && (nowMs - lastSendAtMs) < finalAckGraceMs;
          const progressAnchorMs = lastProgressAtMs > 0
            ? lastProgressAtMs
            : Math.max(0, Math.trunc(Number(session.createdAtMs) || 0));
          const stalledTooLong = progressAnchorMs > 0 && (nowMs - progressAnchorMs) >= fileTransferAckProgressStallFailMs;
          if (!waitingForLateAck && stalledTooLong) {{
            session.failed = true;
            session.failedAtMs = nowMs;
            appendFileTransferConsole(
              `Delivery failed for ${{fileTransferShortTransferId(session.transferId)}} to ${{session.destination}} after ${{stallRetryAttempts}}/${{session.maxRetries}} retries without ACK progress.`,
              {{ level: "error" }}
            );
            continue;
          }}
          retryCapped = true;
        }}

        const lastRetryAtMs = Number(session.lastRetryAtMs) || 0;
        const noAckYet = !ack;
        const receivedSet = ack && ack.receivedSet instanceof Set
          ? ack.receivedSet
          : new Set();
        const missingIndexes = noAckYet
          ? Array.from({{ length: session.totalChunks }}, (_value, idx) => idx)
          : fileTransferMissingChunkIndexes(session.totalChunks, receivedSet);
        if (!missingIndexes.length) {{
          continue;
        }}
        const endgame = !noAckYet
          && missingIndexes.length > 0
          && missingIndexes.length <= fileTransferEndgameMissingChunkThreshold;
        const lastProgressDeltaMs = lastProgressAtMs > 0
          ? Math.max(0, nowMs - lastProgressAtMs)
          : Number.POSITIVE_INFINITY;
        const hasRecentAckProgress = !noAckYet
          && lastProgressAtMs > 0
          && lastProgressDeltaMs <= (45 * 1000);
        const adaptiveRtoMs = Math.max(
          fileTransferRtoMinMs,
          Math.min(fileTransferRtoMaxMs, Math.trunc(Number(session.rtoMs) || fileTransferRtoInitialMs))
        );
        let legacyRetryIntervalMs = fileTransferAckResendIntervalMs;
        if (noAckYet) {{
          legacyRetryIntervalMs = Math.max(fileTransferAckWaitBeforeRetryMs, fileTransferAckResendIntervalMs);
        }} else {{
          const missingCount = missingIndexes.length;
          if (missingCount >= 30) {{
            legacyRetryIntervalMs = hasRecentAckProgress ? 9000 : 28000;
          }} else if (missingCount >= 20) {{
            legacyRetryIntervalMs = hasRecentAckProgress ? 7000 : 20000;
          }} else if (missingCount >= 12) {{
            legacyRetryIntervalMs = hasRecentAckProgress ? 5200 : 14000;
          }} else if (missingCount >= 8) {{
            legacyRetryIntervalMs = hasRecentAckProgress ? 3800 : 9000;
          }} else if (missingCount >= 5) {{
            legacyRetryIntervalMs = hasRecentAckProgress ? 2600 : 5500;
          }} else {{
            legacyRetryIntervalMs = fileTransferEndgameResendIntervalMs;
          }}
        }}
        let retryIntervalMs = hasRecentAckProgress
          ? Math.round((legacyRetryIntervalMs * 0.45) + (adaptiveRtoMs * 0.55))
          : Math.round((legacyRetryIntervalMs + adaptiveRtoMs) / 2);
        const backoffSteps = Math.max(0, stallRetryAttempts - 1);
        if (backoffSteps > 0) {{
          retryIntervalMs = Math.round(retryIntervalMs * Math.pow(1.12, backoffSteps));
        }}
        const maxIntervalMs = endgame
          ? 7000
          : (hasRecentAckProgress ? 9000 : fileTransferRtoMaxMs);
        retryIntervalMs = Math.max(fileTransferRtoMinMs, Math.min(maxIntervalMs, retryIntervalMs));
        if (retryCapped) {{
          retryIntervalMs = Math.max(retryIntervalMs, fileTransferRetryRecoveryIntervalMs);
        }}
        const noAckGateMs = Math.max(
          fileTransferMaintenanceCooldownMs,
          Math.min(fileTransferAckWaitBeforeRetryMs, retryIntervalMs)
        );
        if (noAckYet && (nowMs - lastSendAtMs) < noAckGateMs) {{
          continue;
        }}
        if (!noAckYet && (nowMs - lastRetryAtMs) < retryIntervalMs) {{
          continue;
        }}
        if (!noAckYet && (nowMs - lastSendAtMs) < fileTransferMaintenanceCooldownMs) {{
          continue;
        }}
        const framesToSend = [];
        const includeMeta = !!session.metaFrame && (
          noAckYet
            ? (
              stallRetryAttempts === 0
              || (
                stallRetryAttempts % Math.max(
                  1,
                  Math.trunc(Number(fileTransferNoAckMetaResendEveryRetries) || 1)
                )
              ) === 0
            )
            : (!endgame && (stallRetryAttempts % 4 === 0))
        );
        if (includeMeta) {{
          framesToSend.push(session.metaFrame);
        }}
        const sessionAckedChunks = Math.max(
          0,
          Math.min(session.totalChunks, Math.trunc(Number(session.ackedChunks) || 0))
        );
        const sessionSentChunks = Math.max(
          sessionAckedChunks,
          Math.min(session.totalChunks, Math.trunc(Number(session.sentChunks) || 0))
        );
        session.sentChunks = sessionSentChunks;
        const inFlightChunks = Math.max(0, sessionSentChunks - sessionAckedChunks);
        const congestionWindow = Math.max(
          fileTransferCwndMinChunks,
          Math.min(fileTransferCwndMaxChunks, Number(session.cwndChunks) || fileTransferCwndInitialChunks)
        );
        const cwndBudget = Math.max(0, Math.floor(congestionWindow) - inFlightChunks);
        let retryMissingIndexes = missingIndexes.slice();
        if (missingIndexes.length > 0) {{
          let burstSize = missingIndexes.length;
          if (endgame) {{
            burstSize = Math.max(1, Math.min(2, missingIndexes.length));
          }} else if (noAckYet) {{
            const baseBurst = Math.max(
              1,
              Math.trunc(Number(fileTransferNoAckBurstMin) || 1)
            );
            const maxBurst = Math.max(
              baseBurst,
              Math.trunc(Number(fileTransferNoAckBurstMax) || baseBurst)
            );
            const growth = Math.max(0, Math.floor(stallRetryAttempts / 2));
            burstSize = Math.max(
              1,
              Math.min(
                missingIndexes.length,
                maxBurst,
                baseBurst + growth
              )
            );
          }} else if (missingIndexes.length >= 20) {{
            burstSize = 14;
          }} else if (missingIndexes.length >= 12) {{
            burstSize = 10;
          }} else if (missingIndexes.length >= 8) {{
            burstSize = 8;
          }}
          const budgetFloor = cwndBudget > 0 ? cwndBudget : 1;
          burstSize = Math.max(1, Math.min(burstSize, budgetFloor));
          if (missingIndexes.length > burstSize) {{
            const cursorRaw = Math.max(0, Math.trunc(Number(session.retryChunkCursor) || 0));
            const selected = [];
            for (let idxPos = 0; idxPos < burstSize; idxPos += 1) {{
              const pick = missingIndexes[(cursorRaw + idxPos) % missingIndexes.length];
              if (!selected.includes(pick)) {{
                selected.push(pick);
              }}
            }}
            retryMissingIndexes = selected;
            session.retryChunkCursor = (cursorRaw + burstSize) % missingIndexes.length;
          }} else {{
            session.retryChunkCursor = 0;
          }}
        }} else {{
          session.retryChunkCursor = 0;
        }}
        const duplicateSends = endgame
          ? Math.max(1, Math.min(4, fileTransferEndgameDuplicateSends + (retryMissingIndexes.length <= 2 ? 1 : 0)))
          : 1;
        for (const chunkIdx of retryMissingIndexes) {{
          const frame = session.chunkFrames[chunkIdx];
          if (typeof frame === "string" && frame.trim()) {{
            if (endgame) {{
              for (let copyIdx = 0; copyIdx < duplicateSends; copyIdx += 1) {{
                framesToSend.push(frame.trim());
              }}
            }} else {{
              framesToSend.push(frame.trim());
            }}
          }}
        }}
        if (!framesToSend.length) {{
          continue;
        }}
        let sentCount = 0;
        let firstSendError = "";
        for (let frameIdx = 0; frameIdx < framesToSend.length; frameIdx += 1) {{
          const frame = framesToSend[frameIdx];
          try {{
            await sendFileTransferFrameText(
              frame,
              session.destination,
              session.channelIndex
            );
            sentCount += 1;
            if (frameIdx + 1 < framesToSend.length) {{
              await waitFileTransferFrameGap();
            }}
          }} catch (err) {{
            firstSendError = err instanceof Error ? err.message : String(err || "send failed");
            break;
          }}
        }}
        if (sentCount > 0) {{
          const priorSentChunks = Math.max(
            0,
            Math.min(session.totalChunks, Math.trunc(Number(session.sentChunks) || 0))
          );
          if (stallRetryAttempts > 0 && !endgame) {{
            const backoffWindowMs = Math.max(fileTransferRtoMinMs, Math.trunc(Number(session.rtoMs) || fileTransferRtoInitialMs));
            if ((nowMs - Math.max(0, Number(session.lastCongestionBackoffAtMs) || 0)) >= backoffWindowMs) {{
              const priorCwnd = Math.max(
                fileTransferCwndMinChunks,
                Math.min(fileTransferCwndMaxChunks, Number(session.cwndChunks) || fileTransferCwndInitialChunks)
              );
              const ssthresh = Math.max(
                fileTransferCwndMinChunks,
                Math.min(fileTransferCwndMaxChunks, Math.floor(priorCwnd / 2))
              );
              session.ssthreshChunks = ssthresh;
              session.cwndChunks = Math.max(fileTransferCwndMinChunks, ssthresh);
              session.lastCongestionBackoffAtMs = nowMs;
            }}
          }}
          let frontierAdvance = 0;
          for (const idxRaw of retryMissingIndexes) {{
            const idx = Math.trunc(Number(idxRaw));
            if (!Number.isFinite(idx) || idx < priorSentChunks) continue;
            frontierAdvance += 1;
          }}
          session.sentChunks = Math.max(
            priorSentChunks,
            Math.min(session.totalChunks, priorSentChunks + frontierAdvance)
          );
          session.retryAttempts = Math.max(0, Math.trunc(Number(session.retryAttempts) || 0)) + 1;
          session.retriesSinceProgress = Math.max(0, Math.trunc(Number(session.retriesSinceProgress) || 0)) + 1;
          session.lastRetryAtMs = nowMs;
          session.lastSendAtMs = Date.now();
          session.lastWindowSendAtMs = nowMs;
          const activeRetries = Math.max(0, Math.trunc(Number(session.retriesSinceProgress) || 0));
          const intervalSec = (retryIntervalMs / 1000).toFixed(retryIntervalMs < 10000 ? 1 : 0);
          const cwndLabel = Math.max(
            fileTransferCwndMinChunks,
            Math.min(fileTransferCwndMaxChunks, Number(session.cwndChunks) || fileTransferCwndInitialChunks)
          ).toFixed(1);
          const rtoLabelMs = Math.max(fileTransferRtoMinMs, Math.trunc(Number(session.rtoMs) || fileTransferRtoInitialMs));
          const noAckLabel = noAckYet
            ? ` (no ACK yet, paced burst of ${{retryMissingIndexes.length}} chunk${{retryMissingIndexes.length === 1 ? "" : "s"}}, ~${{intervalSec}}s cadence, cwnd ${{cwndLabel}}, rto ${{rtoLabelMs}}ms)`
            : "";
          const endgameLabel = endgame
            ? ` (endgame, ${{missingIndexes.length}} missing chunk${{missingIndexes.length === 1 ? "" : "s"}}, ~${{intervalSec}}s cadence, cwnd ${{cwndLabel}}, rto ${{rtoLabelMs}}ms)`
            : "";
          appendFileTransferConsole(
            `Retry ${{activeRetries}}/${{session.maxRetries}} for ${{fileTransferShortTransferId(session.transferId)}}: resent ${{sentCount}} frame${{sentCount === 1 ? "" : "s"}} to ${{session.destination}}${{noAckLabel || endgameLabel}}.`,
            {{ level: "warn" }}
          );
        }} else if (firstSendError) {{
          const lastRetryErrorAtMs = Math.max(0, Math.trunc(Number(session.lastRetryErrorAtMs) || 0));
          if ((nowMs - lastRetryErrorAtMs) >= fileTransferRetryErrorLogIntervalMs) {{
            session.lastRetryErrorAtMs = nowMs;
            appendFileTransferConsole(
              `Retry send failed for ${{fileTransferShortTransferId(session.transferId)}} to ${{session.destination}}: ${{firstSendError}}.`,
              {{ level: "warn" }}
            );
          }}
        }}
      }}
      pruneOutgoingFileTransferSessions(nowMs);
    }}
