    async function clearOriginCacheStorage() {{
      if (
        typeof window === "undefined"
        || !("caches" in window)
        || !window.caches
        || typeof window.caches.keys !== "function"
      ) {{
        return {{ attempted: 0, cleared: 0, supported: false }};
      }}

      let keys = [];
      try {{
        keys = await window.caches.keys();
      }} catch (_err) {{
        return {{ attempted: 0, cleared: 0, supported: true }};
      }}

      let attempted = 0;
      let cleared = 0;
      for (const rawKey of (Array.isArray(keys) ? keys : [])) {{
        const key = String(rawKey || "");
        if (!key) continue;
        attempted += 1;
        try {{
          const deleted = await window.caches.delete(key);
          if (deleted) {{
            cleared += 1;
          }}
        }} catch (_err) {{
        }}
      }}
      return {{ attempted, cleared, supported: true }};
    }}

    async function deleteIndexedDbDatabaseByName(name) {{
      const dbName = String(name || "").trim();
      if (!dbName || typeof indexedDB === "undefined" || !indexedDB || typeof indexedDB.deleteDatabase !== "function") {{
        return false;
      }}
      return await new Promise((resolve) => {{
        let settled = false;
        const finish = (value) => {{
          if (settled) return;
          settled = true;
          resolve(!!value);
        }};
        try {{
          const request = indexedDB.deleteDatabase(dbName);
          request.onsuccess = () => finish(true);
          request.onerror = () => finish(false);
          request.onblocked = () => finish(false);
        }} catch (_err) {{
          finish(false);
        }}
      }});
    }}

    async function clearOriginIndexedDbStorage() {{
      if (typeof indexedDB === "undefined" || !indexedDB) {{
        return {{ attempted: 0, cleared: 0, supported: false }};
      }}
      if (typeof indexedDB.databases !== "function") {{
        return {{ attempted: 0, cleared: 0, supported: false }};
      }}

      let databases = [];
      try {{
        databases = await indexedDB.databases();
      }} catch (_err) {{
        return {{ attempted: 0, cleared: 0, supported: true }};
      }}

      let attempted = 0;
      let cleared = 0;
      for (const entry of (Array.isArray(databases) ? databases : [])) {{
        const name = String(entry && entry.name ? entry.name : "").trim();
        if (!name) continue;
        attempted += 1;
        if (await deleteIndexedDbDatabaseByName(name)) {{
          cleared += 1;
        }}
      }}
      return {{ attempted, cleared, supported: true }};
    }}

    async function resetAllLocalSettings() {{
      if (settingsApplyInFlight) return;
      const confirmed = window.confirm(
        "Reset all browser-local dashboard data for this origin? This clears saved settings, location caches, session state, cache storage, and IndexedDB databases for the dashboard UI only."
      );
      if (!confirmed) return;

      const typed = window.prompt(
        "Type RESET LOCAL to clear browser-local dashboard settings and reload:"
      );
      if (String(typed || "").trim().toUpperCase() !== "RESET LOCAL") {{
        setSettingsStatusText("Canceled: confirmation token did not match.");
        return;
      }}

      settingsApplyInFlight = true;
      if (typeof setSettingsButtonsDisabled === "function") {{
        setSettingsButtonsDisabled(true);
      }}
      setSettingsAndChannelsStatusText("Clearing browser-local dashboard settings, caches, and databases…");

      try {{
        try {{
          if (window.sessionStorage && typeof window.sessionStorage.clear === "function") {{
            window.sessionStorage.clear();
          }}
        }} catch (_err) {{
        }}
        try {{
          if (window.localStorage && typeof window.localStorage.clear === "function") {{
            window.localStorage.clear();
          }}
        }} catch (_err) {{
        }}
        await clearOriginCacheStorage();
        await clearOriginIndexedDbStorage();
      }} catch (err) {{
        settingsApplyInFlight = false;
        if (typeof setSettingsButtonsDisabled === "function") {{
          setSettingsButtonsDisabled(false);
        }}
        const msg = err instanceof Error ? err.message : String(err || "unknown error");
        setSettingsAndChannelsStatusText(`Local reset failed: ${{msg}}`);
        return;
      }}

      setSettingsAndChannelsStatusText("Browser-local dashboard data cleared. Reloading…");
      window.setTimeout(() => {{
        window.location.reload();
      }}, 120);
    }}

    async function regenerateNodeId() {{
      if (settingsApplyInFlight) return;
      const localNodeId = normalizeNodeId(resolveLocalNodeId(latestState));
      const idSuffix = isCanonicalNodeId(localNodeId) ? ` (current: ${{localNodeId}})` : "";

      const confirmed = window.confirm(
        `Regenerate radio node ID${{idSuffix}}? This sends FULL FACTORY RESET to the radio, erases config/channels/keys, and reboots.`
      );
      if (!confirmed) return;

      const typed = window.prompt("Type REGEN to confirm full factory reset and node ID regeneration:");
      if (String(typed || "").trim().toUpperCase() !== "REGEN") {{
        setText("settings-apply-status", "Canceled: confirmation token did not match.");
        return;
      }}

      const ok = await postRadioSettingsPayload(
        {{ actions: {{ regenerate_node_id: true }} }},
        "Regenerating node ID (full factory reset)… radio will reboot.",
        "node ID regeneration requested"
      );
      if (ok) {{
        setTimeout(() => {{
          void fetchSettingsFromRadio();
        }}, 3000);
      }}
    }}

    async function setRadioTime() {{
      if (settingsApplyInFlight) return;

      const timeSyncSelection = readSettingsTimeSyncSelection();
      settingsTimeSyncEnabledPref = !!(timeSyncSelection && timeSyncSelection.enabled);
      settingsTimeSyncTimezonePref = normalizeSettingsTimeSyncTimezone(
        timeSyncSelection && timeSyncSelection.timezone
      );
      persistSettingsTimeSyncPreferences();

      const requestedServer = String(readTextValue("settings-network-ntp-server") || "").trim() || "pool.ntp.org";
      const payload = {{
        actions: {{ set_time: true }},
        time_sync: {{
          enabled: settingsTimeSyncEnabledPref,
          timezone: settingsTimeSyncTimezonePref,
        }},
      }};
      if (settingsTimeSyncEnabledPref) {{
        payload.time_sync.server = requestedServer;
      }}

      const ok = await postRadioSettingsPayload(
        payload,
        settingsTimeSyncEnabledPref
          ? `Setting radio time from ${{requestedServer}}…`
          : "Setting radio time from dashboard host clock…",
        settingsTimeSyncEnabledPref
          ? `radio time synced from ${{requestedServer}}`
          : "radio time synced from dashboard host clock"
      );
      if (ok) {{
        setTimeout(() => {{
          void fetchSettingsFromRadio();
        }}, 600);
      }}
    }}

    async function setFixedPosition() {{
      if (settingsApplyInFlight) return;
      if (normalizeSettingsPositionSource(readSettingsPositionSourceSelection()) !== "fixed") {{
        setText("settings-apply-status", "Select Fixed position source before setting a fixed location.");
        return;
      }}

      const lat = readNumberValue("settings-fixed-latitude", true);
      const lon = readNumberValue("settings-fixed-longitude", true);
      const alt = readNumberValue("settings-fixed-altitude");
      if (lat == null || lon == null) {{
        setText("settings-apply-status", "Fixed position requires latitude and longitude.");
        return;
      }}
      if (lat < -90 || lat > 90) {{
        setText("settings-apply-status", "Latitude must be between -90 and 90.");
        return;
      }}
      if (lon < -180 || lon > 180) {{
        setText("settings-apply-status", "Longitude must be between -180 and 180.");
        return;
      }}

      const payload = {{
        actions: {{ set_fixed_position: true }},
        fixed_position: {{
          lat,
          lon,
        }},
      }};
      if (alt != null) {{
        payload.fixed_position.alt = alt;
      }}

      const ok = await postRadioSettingsPayload(
        payload,
        "Setting fixed GPS position on radio…",
        "fixed GPS position saved"
      );
      if (ok) {{
        persistSettingsFixedPositionCache({{ lat, lon, alt }});
        setTimeout(() => {{
          void fetchSettingsFromRadio();
        }}, 600);
      }}
    }}

    async function clearFixedPosition(positionSource = null) {{
      if (settingsApplyInFlight) return;

      const mode = normalizeSettingsPositionSource(
        positionSource == null ? readSettingsPositionSourceSelection() : positionSource
      );
      const modeLabel = mode === "none" ? "None" : (mode === "gps" ? "GPS" : "Fixed");

      const confirmed = window.confirm(
        mode === "fixed"
          ? "Clear fixed GPS position on the radio? The node will stop using a pinned location."
          : `Apply ${modeLabel} mode by clearing fixed GPS position override on the radio?`
      );
      if (!confirmed) return;

      const ok = await postRadioSettingsPayload(
        {{ actions: {{ clear_fixed_position: true }} }},
        mode === "fixed" ? "Clearing fixed GPS position…" : `Applying ${modeLabel} mode…`,
        mode === "fixed" ? "fixed GPS position cleared" : `${modeLabel} mode applied (fixed override cleared)`
      );
      if (ok) {{
        clearSettingsFixedPositionCache();
        setTimeout(() => {{
          void fetchSettingsFromRadio();
        }}, 600);
      }}
    }}
