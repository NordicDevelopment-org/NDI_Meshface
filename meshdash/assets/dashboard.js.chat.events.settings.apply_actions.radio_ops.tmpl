    async function applySectionSettings(scope) {{
      const isLocal = scope === "local";
      const sectionId = isLocal ? "settings-local-section" : "settings-module-section";
      const editorId = isLocal ? "settings-local-json" : "settings-module-json";
      const section = readSelectValue(sectionId);
      if (!section) {{
        setText("settings-apply-status", `Select a ${{scope}} section first.`);
        return;
      }}
      const parsed = parseSectionJsonTextarea(editorId);
      if (!parsed.ok) {{
        setText("settings-apply-status", parsed.error || "Invalid JSON");
        return;
      }}

      const payload = isLocal
        ? {{ local: {{ [section]: parsed.value }} }}
        : {{ module: {{ [section]: parsed.value }} }};

      const ok = await postRadioSettingsPayload(
        payload,
        `Applying ${{scope}}.${{section}} settings…`,
        `${{scope}}.${{section}} saved`
      );
      if (ok) {{
        setTimeout(() => {{
          void fetchSettingsFromRadio();
        }}, 600);
      }}
    }}

