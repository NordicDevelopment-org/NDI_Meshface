    function collectFileTransferFrames(state = latestState, options = null) {{
      const respectActiveChannel = !(options && options.respectActiveChannel === false);
      const safeState = (state && typeof state === "object") ? state : {{}};
      const traffic = (safeState.traffic && typeof safeState.traffic === "object")
        ? safeState.traffic
        : {{}};
      const recentChat = Array.isArray(traffic.recent_chat) ? traffic.recent_chat : [];
      const recentPackets = Array.isArray(traffic.recent_packets) ? traffic.recent_packets : [];
      const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
      const nodesById = new Map(
        nodes.map((node) => [normalizeNodeId(node && node.id), node])
      );
      const localNodeId = normalizeNodeId(resolveLocalNodeId(safeState) || "");
      const transfers = new Map();
      const ackByTransferKey = new Map();
      const fileTransferMessages = [];

      for (const msg of recentChat) {{
        if (!msg || typeof msg !== "object") continue;
        fileTransferMessages.push(msg);
      }}
      for (const entry of recentPackets) {{
        if (!entry || typeof entry !== "object") continue;
        const summary = (entry.summary && typeof entry.summary === "object")
          ? entry.summary
          : {{}};
        const packet = (entry.packet && typeof entry.packet === "object")
          ? entry.packet
          : {{}};
        const decoded = (packet.decoded && typeof packet.decoded === "object")
          ? packet.decoded
          : {{}};
        const text = String(summary.decoded_text ?? decoded.text ?? "").trim();
        if (!text) continue;
        const endpoints = packetEndpointIds(entry);
        const packetChannelIndex = explicitPacketChannelIndex(entry);
        fileTransferMessages.push({{
          text,
          from: endpoints.fromId || "",
          to: endpoints.toId || "",
          rx_time: summary.rx_time ?? entry.rx_time ?? "",
          captured_at: summary.captured_at ?? entry.captured_at ?? "",
          channel: Number.isInteger(packetChannelIndex) && packetChannelIndex >= 0 ? packetChannelIndex : null,
        }});
      }}

      for (const msg of fileTransferMessages) {{
        if (!msg || typeof msg !== "object") continue;
        const activeIdx = activeMeshChannelFilterIndex();
        const msgChannelIndex = explicitMessageMeshChannelIndex(msg);
        if (respectActiveChannel && activeIdx !== meshChannelAllIndex) {{
          if (!Number.isInteger(msgChannelIndex) || msgChannelIndex < 0 || msgChannelIndex !== activeIdx) {{
            continue;
          }}
        }}
        const frame = parseFileTransferFrameText(msg.text);
        if (!frame) continue;
        const fromId = normalizeNodeId(msg.from || "");
        const toId = normalizeNodeId(msg.to || msg.destination || "");
        const msgUnix = latestUnixTimestamp(msg.rx_time, msg.captured_at);
        const explicitChannelIndex = Number.isInteger(msgChannelIndex) && msgChannelIndex >= 0
          ? Math.trunc(msgChannelIndex)
          : null;

        if (frame.kind === "ack") {{
          const transferKey = fileTransferKeyOf(toId, fromId, frame.transferId);
          const receivedSet = decodeFileTransferChunkBitmap(frame.bitmap, frame.totalChunks);
          const receivedCount = Math.max(
            Math.min(frame.totalChunks, frame.receivedCount),
            Math.min(frame.totalChunks, receivedSet.size)
          );
          const ack = {{
            transferKey,
            transferId: frame.transferId,
            originalSenderId: toId,
            originalReceiverId: fromId,
            channelIndex: explicitChannelIndex,
            receivedCount,
            totalChunks: Math.max(1, Math.trunc(Number(frame.totalChunks) || 1)),
            bitmap: frame.bitmap,
            receivedSet,
            complete: receivedCount >= Math.max(1, Math.trunc(Number(frame.totalChunks) || 1)),
            latestUnix: msgUnix || 0,
          }};
          const prev = ackByTransferKey.get(transferKey);
          if (!prev || Number(ack.latestUnix || 0) >= Number(prev.latestUnix || 0)) {{
            ackByTransferKey.set(transferKey, ack);
          }}
          continue;
        }}

        const key = fileTransferKeyOf(fromId, toId, frame.transferId);
        let transfer = transfers.get(key);
        if (!transfer) {{
          transfer = {{
            key,
            transferId: frame.transferId,
            fromId,
            toId,
            channelIndex: explicitChannelIndex,
            firstUnix: null,
            latestUnix: null,
            fileName: "",
            fileSize: null,
            totalChunks: null,
            chunks: new Map(),
            hasDecodeError: false,
          }};
          transfers.set(key, transfer);
        }}

        if (!transfer.fromId && fromId) transfer.fromId = fromId;
        if (!transfer.toId && toId) transfer.toId = toId;
        if (msgUnix && (!transfer.firstUnix || msgUnix < transfer.firstUnix)) {{
          transfer.firstUnix = msgUnix;
        }}
        transfer.latestUnix = latestUnixTimestamp(transfer.latestUnix, msgUnix);
        if (Number.isInteger(explicitChannelIndex) && explicitChannelIndex >= 0) {{
          transfer.channelIndex = explicitChannelIndex;
        }}

        if (frame.kind === "meta") {{
          transfer.fileName = normalizeFileTransferName(frame.fileName || transfer.fileName || "mesh-file.bin");
          transfer.fileSize = Math.max(0, Math.trunc(Number(frame.fileSize) || 0));
          transfer.totalChunks = Math.max(1, Math.trunc(Number(frame.totalChunks) || 1));
          continue;
        }}

        if (frame.kind === "chunk") {{
          if (transfer.chunks.has(frame.chunkIndex)) {{
            continue;
          }}
          const bytes = decodeBase64ToBytes(frame.chunkData);
          if (!(bytes instanceof Uint8Array)) {{
            transfer.hasDecodeError = true;
            continue;
          }}
          transfer.chunks.set(frame.chunkIndex, bytes);
        }}
      }}

      const nowMs = Date.now();
      const activeTransferKeys = new Set();
      for (const [key, transfer] of transfers.entries()) {{
        if (!transfer || typeof transfer !== "object") continue;
        activeTransferKeys.add(key);
        const cacheRaw = fileTransferChunkCacheByKey.get(key);
        let cacheChunks = new Map();
        let cacheTotalChunks = null;
        let cacheFileName = "";
        let cacheFileSize = null;
        let cacheChannelIndex = null;
        let cacheLatestUnix = 0;
        if (cacheRaw && typeof cacheRaw === "object") {{
          const rawTotalChunks = Math.trunc(Number(cacheRaw.totalChunks));
          if (Number.isFinite(rawTotalChunks) && rawTotalChunks > 0) {{
            cacheTotalChunks = rawTotalChunks;
          }}
          cacheFileName = normalizeFileTransferName(cacheRaw.fileName || "");
          const rawFileSize = Number(cacheRaw.fileSize);
          if (Number.isFinite(rawFileSize) && rawFileSize >= 0) {{
            cacheFileSize = Math.max(0, Math.trunc(rawFileSize));
          }}
          cacheChannelIndex = fileTransferExplicitChannelIndex(cacheRaw.channelIndex);
          cacheLatestUnix = Math.max(0, Math.trunc(Number(cacheRaw.latestUnix) || 0));
          if (cacheRaw.chunks instanceof Map) {{
            for (const [idxRaw, bytes] of cacheRaw.chunks.entries()) {{
              const idx = Math.trunc(Number(idxRaw));
              if (!Number.isFinite(idx) || idx < 0) continue;
              if (!(bytes instanceof Uint8Array)) continue;
              cacheChunks.set(idx, bytes);
            }}
          }}
        }}
        const transferTotalChunksRaw = Math.trunc(Number(transfer.totalChunks));
        const transferTotalChunks = Number.isFinite(transferTotalChunksRaw) && transferTotalChunksRaw > 0
          ? transferTotalChunksRaw
          : null;
        if (cacheTotalChunks != null && transferTotalChunks != null && cacheTotalChunks !== transferTotalChunks) {{
          cacheChunks = new Map();
          cacheTotalChunks = transferTotalChunks;
        }}
        for (const [idxRaw, bytes] of transfer.chunks.entries()) {{
          const idx = Math.trunc(Number(idxRaw));
          if (!Number.isFinite(idx) || idx < 0) continue;
          if (!(bytes instanceof Uint8Array)) continue;
          cacheChunks.set(idx, bytes);
        }}
        const effectiveTotalChunks = transferTotalChunks != null ? transferTotalChunks : cacheTotalChunks;
        if (effectiveTotalChunks != null) {{
          for (const idx of Array.from(cacheChunks.keys())) {{
            if (idx >= effectiveTotalChunks) {{
              cacheChunks.delete(idx);
            }}
          }}
        }}
        transfer.chunks = cacheChunks;
        if (transferTotalChunks == null && effectiveTotalChunks != null) {{
          transfer.totalChunks = effectiveTotalChunks;
        }}
        if (!transfer.fileName && cacheFileName) {{
          transfer.fileName = cacheFileName;
        }}
        const transferFileSize = Number(transfer.fileSize);
        const hasTransferFileSize = Number.isFinite(transferFileSize) && transferFileSize >= 0;
        if (!hasTransferFileSize && cacheFileSize != null) {{
          transfer.fileSize = cacheFileSize;
        }}
        if (fileTransferExplicitChannelIndex(transfer.channelIndex) == null && cacheChannelIndex != null) {{
          transfer.channelIndex = cacheChannelIndex;
        }}
        transfer.latestUnix = latestUnixTimestamp(transfer.latestUnix, cacheLatestUnix);
        fileTransferChunkCacheByKey.set(key, {{
          chunks: cacheChunks,
          totalChunks: effectiveTotalChunks,
          fileName: normalizeFileTransferName(transfer.fileName || cacheFileName || "mesh-file.bin"),
          fileSize: Number.isFinite(Number(transfer.fileSize)) ? Math.max(0, Math.trunc(Number(transfer.fileSize) || 0)) : null,
          channelIndex: fileTransferExplicitChannelIndex(transfer.channelIndex),
          latestUnix: Number(transfer.latestUnix || transfer.firstUnix || 0),
          lastSeenAtMs: nowMs,
        }});
      }}
      const staleChunkCutoffMs = nowMs - (45 * 60 * 1000);
      for (const [key, cacheRaw] of fileTransferChunkCacheByKey.entries()) {{
        if (activeTransferKeys.has(key)) continue;
        const lastSeenAtMs = Number(cacheRaw && cacheRaw.lastSeenAtMs) || 0;
        if (lastSeenAtMs <= 0 || lastSeenAtMs < staleChunkCutoffMs) {{
          fileTransferChunkCacheByKey.delete(key);
        }}
      }}

      return {{
        transfers,
        ackByTransferKey,
        nodesById,
        localNodeId,
      }};
    }}

    function buildFileTransferRows(state = latestState) {{
      const frameState = collectFileTransferFrames(state, {{ respectActiveChannel: true }});
      const transfers = frameState.transfers;
      const ackByTransferKey = frameState.ackByTransferKey;
      const nodesById = frameState.nodesById;
      const localNodeId = frameState.localNodeId;
      const rows = [];
      for (const transfer of transfers.values()) {{
        const direction = fileTransferDirectionMeta(transfer.fromId, transfer.toId, localNodeId);
        const peerMeta = fileTransferPeerMeta(direction.peerId, nodesById, localNodeId);
        const expectedChunks = Number.isInteger(transfer.totalChunks) && transfer.totalChunks > 0
          ? transfer.totalChunks
          : Math.max(transfer.chunks.size, 1);
        const receivedChunks = transfer.chunks.size;
        let contiguous = receivedChunks >= expectedChunks;
        if (contiguous) {{
          for (let idx = 0; idx < expectedChunks; idx += 1) {{
            if (!(transfer.chunks.get(idx) instanceof Uint8Array)) {{
              contiguous = false;
              break;
            }}
          }}
        }}

        let observedBytes = 0;
        for (const bytes of transfer.chunks.values()) {{
          observedBytes += Number(bytes && bytes.length) || 0;
        }}

        const declaredBytes = Number.isFinite(transfer.fileSize) ? Math.max(0, Math.trunc(Number(transfer.fileSize) || 0)) : null;
        let assembled = null;
        let complete = false;
        let assembleError = "";
        if (contiguous && expectedChunks > 0) {{
          let totalLen = 0;
          for (let idx = 0; idx < expectedChunks; idx += 1) {{
            const part = transfer.chunks.get(idx);
            totalLen += Number(part && part.length) || 0;
          }}
          const merged = new Uint8Array(totalLen);
          let cursor = 0;
          for (let idx = 0; idx < expectedChunks; idx += 1) {{
            const part = transfer.chunks.get(idx);
            if (!(part instanceof Uint8Array)) {{
              assembleError = "Missing chunk data";
              break;
            }}
            merged.set(part, cursor);
            cursor += part.length;
          }}
          if (!assembleError) {{
            let mergedView = merged;
            if (declaredBytes != null) {{
              if (declaredBytes < merged.length) {{
                mergedView = merged.slice(0, declaredBytes);
              }} else if (declaredBytes > merged.length) {{
                assembleError = `Missing ${{declaredBytes - merged.length}} byte${{declaredBytes - merged.length === 1 ? "" : "s"}}`;
              }}
            }}
            if (!assembleError) {{
              assembled = new Uint8Array(mergedView);
              complete = true;
            }}
          }}
        }}

        const percent = Math.max(
          0,
          Math.min(100, Math.round((receivedChunks / Math.max(expectedChunks, 1)) * 100))
        );
        const outgoing = direction.className === "outbound";
        const ack = outgoing ? (ackByTransferKey.get(transfer.key) || null) : null;
        const ackedChunks = ack
          ? Math.max(
            0,
            Math.min(
              expectedChunks,
              Math.max(
                Number(ack.receivedCount || 0),
                (ack.receivedSet instanceof Set ? ack.receivedSet.size : 0)
              )
            )
          )
          : 0;
        const deliveryPct = Math.max(0, Math.min(100, Math.round((ackedChunks / Math.max(expectedChunks, 1)) * 100)));
        const outgoingSession = outgoing
          ? findOutgoingFileTransferSession(transfer.transferId, transfer.toId, transfer.channelIndex)
          : null;
        const transferChannelIndex = fileTransferExplicitChannelIndex(transfer.channelIndex);
        const sessionChannelIndex = fileTransferExplicitChannelIndex(outgoingSession && outgoingSession.channelIndex);
        const resolvedChannelIndex = transferChannelIndex != null ? transferChannelIndex : sessionChannelIndex;
        let delivered = outgoing
          ? !!(ack && ack.complete && ackedChunks >= expectedChunks)
          : complete;
        if (outgoingSession && outgoingSession.delivered) {{
          delivered = true;
        }}

        let progressLabel = "";
        let progressSort = 0;
        let outgoingRetrying = false;
        if (outgoing) {{
          if (outgoingSession && outgoingSession.failed && !delivered) {{
            progressLabel = `Delivery failed (${{ackedChunks}}/${{expectedChunks}} acked)`;
            progressSort = deliveryPct;
          }} else if (delivered) {{
            progressLabel = `Delivered (${{Math.max(ackedChunks, expectedChunks)}}/${{expectedChunks}} acked)`;
            progressSort = 220;
          }} else if (ack) {{
            progressLabel = `${{deliveryPct}}% delivered (${{ackedChunks}}/${{expectedChunks}} acked)`;
            progressSort = 100 + deliveryPct;
          }} else {{
            progressLabel = `Awaiting ACK (0/${{expectedChunks}} acked)`;
            progressSort = 25;
          }}
          const activeRetries = Math.max(
            0,
            Math.trunc(Number(outgoingSession && outgoingSession.retriesSinceProgress) || Number(outgoingSession && outgoingSession.retryAttempts) || 0)
          );
          if (outgoingSession && !outgoingSession.delivered && !outgoingSession.failed && activeRetries > 0) {{
            outgoingRetrying = true;
            progressLabel = `${{progressLabel}} • retry ${{activeRetries}}/${{outgoingSession.maxRetries}}`;
          }}
        }} else {{
          progressLabel = complete
            ? "Complete"
            : `${{percent}}% (${{receivedChunks}}/${{expectedChunks}} chunks)`;
          progressSort = complete ? 100 : percent;
          if (!complete && transfer.hasDecodeError) {{
            progressLabel = "Error (invalid chunk)";
          }} else if (!complete && assembleError) {{
            progressLabel = `Error (${{assembleError}})`;
          }}
        }}

        const sizeLabel = (() => {{
          if (declaredBytes == null) {{
            return formatFileTransferSize(observedBytes);
          }}
          if (complete || observedBytes <= 0) {{
            return formatFileTransferSize(declaredBytes);
          }}
          if (observedBytes === declaredBytes) {{
            return formatFileTransferSize(declaredBytes);
          }}
          return `${{formatFileTransferSize(observedBytes)}} / ${{formatFileTransferSize(declaredBytes)}}`;
        }})();
        const fileName = normalizeFileTransferName(transfer.fileName || `file-${{transfer.transferId}}.bin`);
        const channelLabel = resolvedChannelIndex == null
          ? "Unknown"
          : meshChannelLabelForIndex(resolvedChannelIndex, {{ allowAll: false }});
        const sortUnix = Number(transfer.latestUnix || transfer.firstUnix || 0);
        rows.push({{
          key: transfer.key,
          transferId: transfer.transferId,
          unix: sortUnix > 0 ? sortUnix : null,
          sortUnix,
          directionClass: direction.className,
          directionLabel: direction.label,
          peerId: direction.peerId,
          peerLabel: peerMeta.label,
          peerTitle: peerMeta.title,
          fileName,
          downloadName: safeFileTransferDownloadName(fileName),
          progressLabel,
          progressSort,
          sizeLabel,
          sizeSort: declaredBytes != null ? declaredBytes : observedBytes,
          channelIndex: resolvedChannelIndex,
          channelLabel,
          delivered,
          outgoingRetrying,
          canDownload: complete && assembled instanceof Uint8Array,
          bytes: assembled,
        }});
      }}

      rows.sort((a, b) => {{
        const unixDiff = Number(b.sortUnix || 0) - Number(a.sortUnix || 0);
        if (unixDiff !== 0) return unixDiff;
        const nameDiff = String(a.fileName || "").localeCompare(String(b.fileName || ""));
        if (nameDiff !== 0) return nameDiff;
        return String(a.key || "").localeCompare(String(b.key || ""));
      }});
      return rows;
    }}

    function fileTransferMissingChunkIndexes(totalChunks, receivedSet) {{
      const total = Math.max(1, Math.trunc(Number(totalChunks) || 1));
      const seen = receivedSet instanceof Set ? receivedSet : new Set();
      const missing = [];
      for (let idx = 0; idx < total; idx += 1) {{
        if (!seen.has(idx)) {{
          missing.push(idx);
        }}
      }}
      return missing;
    }}

    function findAckForOutgoingSession(session, ackByTransferKey, localNodeId) {{
      if (!session || !(ackByTransferKey instanceof Map)) return null;
      const senderId = normalizeNodeId(localNodeId || session.senderId || "");
      const expectedReceiver = normalizeNodeId(session.destination || "");
      const expectedChannel = fileTransferExplicitChannelIndex(session.channelIndex);
      if (!isCanonicalNodeId(expectedReceiver)) return null;
      const directKey = isCanonicalNodeId(senderId)
        ? fileTransferKeyOf(senderId, expectedReceiver, session.transferId)
        : "";
      if (directKey && ackByTransferKey.has(directKey)) {{
        return ackByTransferKey.get(directKey) || null;
      }}
      function ackChannelMatchScore(ack) {{
        if (!ack || typeof ack !== "object") return 0;
        const ackChannel = fileTransferExplicitChannelIndex(ack.channelIndex);
        if (expectedChannel == null || ackChannel == null) return 1;
        return ackChannel === expectedChannel ? 2 : 0;
      }}
      let fallback = null;
      let fallbackScore = -1;
      for (const ack of ackByTransferKey.values()) {{
        if (!ack || typeof ack !== "object") continue;
        if (String(ack.transferId || "") !== String(session.transferId || "")) continue;
        const ackOriginalReceiver = normalizeNodeId(ack.originalReceiverId || "");
        const ackOriginalSender = normalizeNodeId(ack.originalSenderId || "");
        if (isCanonicalNodeId(ackOriginalReceiver) && ackOriginalReceiver !== expectedReceiver) continue;
        if (isCanonicalNodeId(senderId) && isCanonicalNodeId(ackOriginalSender) && ackOriginalSender !== senderId) continue;
        const endpointConfidence = (
          (isCanonicalNodeId(ackOriginalReceiver) && ackOriginalReceiver === expectedReceiver)
          || (isCanonicalNodeId(senderId) && isCanonicalNodeId(ackOriginalSender) && ackOriginalSender === senderId)
        );
        if (!endpointConfidence) {{
          const endpointsUnknown = !isCanonicalNodeId(ackOriginalReceiver) && !isCanonicalNodeId(ackOriginalSender);
          if (!endpointsUnknown) {{
            continue;
          }}
        }}
        const score = ackChannelMatchScore(ack);
        if (
          !fallback
          || score > fallbackScore
          || (score === fallbackScore && Number(ack.latestUnix || 0) > Number(fallback.latestUnix || 0))
        ) {{
          fallback = ack;
          fallbackScore = score;
        }}
      }}
      if (fallback) {{
        return fallback;
      }}
      // Final escape hatch: if endpoints are missing or inconsistent in packet metadata,
      // a transferId-only match is still safe because transfer IDs are random per send.
      let transferIdOnlyFallback = null;
      let transferIdOnlyScore = -1;
      for (const ack of ackByTransferKey.values()) {{
        if (!ack || typeof ack !== "object") continue;
        if (String(ack.transferId || "") !== String(session.transferId || "")) continue;
        const score = ackChannelMatchScore(ack);
        if (
          !transferIdOnlyFallback
          || score > transferIdOnlyScore
          || (score === transferIdOnlyScore
            && Number(ack.latestUnix || 0) > Number(transferIdOnlyFallback.latestUnix || 0))
        ) {{
          transferIdOnlyFallback = ack;
          transferIdOnlyScore = score;
        }}
      }}
      if (transferIdOnlyFallback) {{
        return transferIdOnlyFallback;
      }}
      return fallback;
    }}

