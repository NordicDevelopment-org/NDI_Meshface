    function parseConsoleFilterExpression(rawFilterText) {{
      let raw = String(rawFilterText == null ? "" : rawFilterText).trim();
      if (!raw) {{
        return {{
          needle: "",
          before: 0,
          after: 0,
        }};
      }}
      let before = 0;
      let after = 0;
      const clamp = (value) => Math.max(0, Math.min(50, Math.trunc(Number(value) || 0)));
      raw = raw.replace(/(^|\s)-([cCabB])\s*(\d+)\b/g, (_match, prefix, flag, countText) => {{
        const count = clamp(countText);
        const mode = String(flag || "").toLowerCase();
        if (mode === "c") {{
          before = Math.max(before, count);
          after = Math.max(after, count);
        }} else if (mode === "a") {{
          after = Math.max(after, count);
        }} else if (mode === "b") {{
          before = Math.max(before, count);
        }}
        return String(prefix || " ");
      }});
      raw = raw.replace(/(^|\s)--(context|after-context|before-context)\s*=?\s*(\d+)\b/gi, (_match, prefix, flag, countText) => {{
        const count = clamp(countText);
        const mode = String(flag || "").toLowerCase();
        if (mode === "context") {{
          before = Math.max(before, count);
          after = Math.max(after, count);
        }} else if (mode === "after-context") {{
          after = Math.max(after, count);
        }} else if (mode === "before-context") {{
          before = Math.max(before, count);
        }}
        return String(prefix || " ");
      }});
      return {{
        needle: raw.trim(),
        before,
        after,
      }};
    }}

    function filterConsoleLinesWithContext(lines, filterExpr) {{
      const source = Array.isArray(lines) ? lines : [];
      const parsed = (filterExpr && typeof filterExpr === "object") ? filterExpr : {{
        needle: "",
        before: 0,
        after: 0,
      }};
      const needle = String(parsed.needle == null ? "" : parsed.needle).trim().toLowerCase();
      const before = Math.max(0, Math.trunc(Number(parsed.before) || 0));
      const after = Math.max(0, Math.trunc(Number(parsed.after) || 0));
      if (!needle) {{
        return {{
          lines: source.slice(),
          active: false,
          needle: "",
        }};
      }}
      const matchIndexes = [];
      for (let i = 0; i < source.length; i += 1) {{
        const lineText = String(source[i] == null ? "" : source[i]).toLowerCase();
        if (lineText.includes(needle)) {{
          matchIndexes.push(i);
        }}
      }}
      if (!matchIndexes.length) {{
        return {{
          lines: [],
          active: true,
          needle,
        }};
      }}
      if (before < 1 && after < 1) {{
        return {{
          lines: matchIndexes.map((index) => source[index]),
          active: true,
          needle,
        }};
      }}
      const ranges = [];
      for (const idx of matchIndexes) {{
        const start = Math.max(0, idx - before);
        const end = Math.min(source.length - 1, idx + after);
        if (!ranges.length || start > ranges[ranges.length - 1].end + 1) {{
          ranges.push({{ start, end }});
        }} else {{
          ranges[ranges.length - 1].end = Math.max(ranges[ranges.length - 1].end, end);
        }}
      }}
      const out = [];
      for (let r = 0; r < ranges.length; r += 1) {{
        if (r > 0) {{
          out.push("[filter] --");
        }}
        const range = ranges[r];
        for (let i = range.start; i <= range.end; i += 1) {{
          out.push(source[i]);
        }}
      }}
      return {{
        lines: out,
        active: true,
        needle,
      }};
    }}

    function renderConsoleBuffer(forceScroll = false) {{
      const pre = document.getElementById("live-console");
      if (!(pre instanceof HTMLElement)) return;
      if (!forceScroll && hasConsoleSelectionWithin(pre)) {{
        consoleRenderDeferred = true;
        return;
      }}
      consoleRenderDeferred = false;
      const filterExpr = parseConsoleFilterExpression(consoleFilterText);
      const filtered = filterConsoleLinesWithContext(consoleLines, filterExpr);
      const visibleLines = filtered.lines;
      const rendered = visibleLines.map((line) => escAttr(String(line == null ? "" : line)));
      if (filtered.active && visibleLines.length < 1) {{
        rendered.push(escAttr(`[filter] no matches for "${{filtered.needle}}"`));
      }}
      rendered.push(formatConsolePromptInputLine(consolePromptLabel, consoleCommandInputValue()));
      pre.innerHTML = rendered.join("\n");
      if (consoleAutoscroll || forceScroll) {{
        pre.scrollLeft = 0;
        pre.scrollTop = pre.scrollHeight;
      }}
    }}

