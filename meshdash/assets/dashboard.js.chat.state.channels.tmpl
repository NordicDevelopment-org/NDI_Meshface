    function normalizeMeshChannelIndex(value, options = {{}}) {{
      const allowAll = !!(options && options.allowAll);
      const text = String(value == null ? "" : value).trim().toLowerCase();
      if (allowAll && (text === "all" || text === "*")) {{
        return meshChannelAllIndex;
      }}
      const num = Number(value);
      if (!Number.isFinite(num)) return 0;
      const idx = Math.trunc(num);
      if (allowAll && idx === meshChannelAllIndex) {{
        return meshChannelAllIndex;
      }}
      if (!Number.isInteger(idx) || idx < 0) return 0;
      return idx;
    }}

    function meshChannelOptionLabel(opt) {{
      if (!opt || typeof opt !== "object") return "";
      const idx = Number(opt.index);
      if (!Number.isInteger(idx) || idx < 0) return "";
      const name = typeof opt.name === "string" ? opt.name.trim() : "";
      if (name) return name;
      return `Ch ${{idx}}`;
    }}

    function meshChannelOptionByIndex(rawIndex, sourceOptions = null) {{
      const idx = normalizeMeshChannelIndex(rawIndex);
      if (!Number.isInteger(idx) || idx < 0) return null;
      const candidateLists = [];
      if (Array.isArray(sourceOptions)) candidateLists.push(sourceOptions);
      if (Array.isArray(meshChannelOptions) && sourceOptions !== meshChannelOptions) candidateLists.push(meshChannelOptions);
      if (Array.isArray(meshChannelSendOptions) && sourceOptions !== meshChannelSendOptions) candidateLists.push(meshChannelSendOptions);
      for (const list of candidateLists) {{
        const match = list.find((opt) => Number(opt && opt.index) === idx);
        if (match && typeof match === "object") {{
          return {{ ...match, index: idx }};
        }}
      }}
      return null;
    }}

    function meshChannelConfiguredName(rawIndex, sourceOptions = null) {{
      const match = meshChannelOptionByIndex(rawIndex, sourceOptions);
      const name = match && typeof match.name === "string" ? match.name.trim() : "";
      return name || "";
    }}

    function meshChannelViewOptionLabel(opt) {{
      if (!opt || typeof opt !== "object") return "";
      const idx = Number(opt.index);
      if (!Number.isInteger(idx) || idx < 0) return "";
      const name = typeof opt.name === "string" ? opt.name.trim() : "";
      if (name) return name;
      return `Ch ${{idx}}`;
    }}

    function meshChannelIsPrimary(rawIndex) {{
      return normalizeMeshChannelIndex(rawIndex) === 0;
    }}

    function meshChannelPrimaryBadgeHtml(rawIndex) {{
      if (!meshChannelIsPrimary(rawIndex)) return "";
      return '<span class="mesh-channel-primary-badge" aria-hidden="true">P</span>';
    }}

    function meshChannelSendOptionLabel(opt) {{
      if (!opt || typeof opt !== "object") return "";
      const idx = Number(opt.index);
      if (!Number.isInteger(idx) || idx < 0) return "";
      const name = typeof opt.name === "string" ? opt.name.trim() : "";
      if (name) return name;
      return `Ch ${{idx}}`;
    }}

    function meshChannelColorMeta(rawIndex, {{ allowAll = true, sourceOptions = null }} = {{}}) {{
      const idx = normalizeMeshChannelIndex(rawIndex, {{ allowAll }});
      if (idx === meshChannelAllIndex) {{
        return {{
          key: "all",
          name: "all",
          fill: "#FFFFFF",
          title: "All channels view",
        }};
      }}
      const configuredName = meshChannelConfiguredName(idx, sourceOptions);
      if (!configuredName) {{
        const neutral = meshChannelNeutralPalette[idx % meshChannelNeutralPalette.length] || meshChannelNeutralPalette[0];
        const neutralName = String(neutral && neutral.name || "gray").trim() || "gray";
        const fill = String(neutral && neutral.fill || "#BBBBBB").trim() || "#BBBBBB";
        return {{
          key: `public-${{idx}}`,
          name: neutralName,
          fill,
          title: idx === 0 ? "Ch 0 • Primary channel" : `Ch ${{idx}}`,
        }};
      }}
      const palette = meshChannelColorPalette[idx % meshChannelColorPalette.length] || meshChannelColorPalette[0];
      const colorName = String(palette && palette.name || "channel").trim() || "channel";
      const fill = String(palette && palette.fill || "#8DA3B1").trim() || "#8DA3B1";
      const channelBaseLabel = configuredName || `Ch ${{idx}}`;
      const colorTitle = `${{channelBaseLabel}} • ${{colorName.charAt(0).toUpperCase()}}${{colorName.slice(1)}} channel`;
      return {{
        key: colorName,
        name: colorName,
        fill,
        title: colorTitle,
      }};
    }}

    function hexColorRgbTriplet(fill) {{
      const text = String(fill || "").trim();
      const match = /^#?([0-9a-f]{6})$/i.exec(text);
      if (!match) return "141, 163, 177";
      const hex = match[1];
      const r = Number.parseInt(hex.slice(0, 2), 16);
      const g = Number.parseInt(hex.slice(2, 4), 16);
      const b = Number.parseInt(hex.slice(4, 6), 16);
      return `${{r}}, ${{g}}, ${{b}}`;
    }}

    function meshChannelBadgeStyle(rawIndex, {{ allowAll = false }} = {{}}) {{
      const meta = meshChannelColorMeta(rawIndex, {{ allowAll }});
      return `--mesh-channel-badge-fill: ${{meta.fill}}; --mesh-channel-badge-rgb: ${{hexColorRgbTriplet(meta.fill)}};`;
    }}

    function meshChannelBadgeHtml(rawIndex, label, {{ allowAll = false, extraClass = "", title = "" }} = {{}}) {{
      const classNames = ["mesh-channel-badge"];
      if (extraClass) classNames.push(String(extraClass).trim());
      const text = String(label || "").trim() || meshChannelLabelForIndex(rawIndex, {{ compact: true, allowAll }});
      const titleText = String(title || "").trim();
      const styleAttr = escAttr(meshChannelBadgeStyle(rawIndex, {{ allowAll }}));
      const titleAttr = titleText ? ` title="${{escAttr(titleText)}}"` : "";
      return `<span class="${{escAttr(classNames.join(" "))}}" style="${{styleAttr}}"${{titleAttr}}>${{escAttr(text)}}</span>`;
    }}

    function meshChannelTintStyle(rawIndex, {{ allowAll = false }} = {{}}) {{
      const idx = normalizeMeshChannelIndex(rawIndex, {{ allowAll }});
      const meta = meshChannelColorMeta(idx, {{ allowAll }});
      return `--chat-feed-channel-fill: ${{meta.fill}}; --chat-feed-channel-rgb: ${{hexColorRgbTriplet(meta.fill)}};`;
    }}

    function meshChannelViewMenuLabel(rawIndex) {{
      const idx = normalizeMeshChannelIndex(rawIndex, {{ allowAll: true }});
      if (idx === meshChannelAllIndex) {{
        return "All channels";
      }}
      const match = meshChannelOptionByIndex(idx, meshChannelOptions);
      return meshChannelViewOptionLabel(match ? {{ ...match, index: idx }} : {{ index: idx }});
    }}

    function syncMeshChannelViewControl() {{
      renderMeshChannelPills(meshChannelOptions);
      syncMeshChannelMismatchWarning();
    }}

    function renderMeshChannelPills(options) {{
      const panel = document.getElementById("mesh-channel-pill-strip");
      if (!(panel instanceof HTMLElement)) return;
      const normalized = Array.isArray(options) ? options : [];
      const activeScope = normalizeChatChannel(activeChatChannel);
      const rows = [];
      rows.push({{
        index: meshChannelAllIndex,
        label: meshChannelViewMenuLabel(meshChannelAllIndex),
        meta: meshChannelColorMeta(meshChannelAllIndex, {{ allowAll: true }}),
        all: true,
        unread: Math.max(0, Number(chatUnreadByChannel[activeScope] || 0)),
      }});
      for (const opt of normalized) {{
        const idx = normalizeMeshChannelIndex(opt && opt.index);
        rows.push({{
          index: idx,
          label: meshChannelViewOptionLabel({{ ...opt, index: idx }}) || `Ch ${{idx}}`,
          meta: meshChannelColorMeta(idx, {{ allowAll: false }}),
          all: false,
          unread: getChatMeshChannelUnread(activeScope, idx),
        }});
      }}
      panel.innerHTML = rows.map((row) => {{
        const active = normalizeMeshChannelIndex(activeMeshChannelIndex, {{ allowAll: true }}) === row.index;
        const dotClass = row.all ? "channel-color-dot is-all" : "channel-color-dot";
        const unreadLabel = row.unread > 99 ? "99+" : String(row.unread || "");
        const primaryBadge = row.all ? "" : meshChannelPrimaryBadgeHtml(row.index);
        return `<button
          type="button"
          class="mesh-channel-pill${{active ? " active" : ""}}"
          role="tab"
          aria-selected="${{active ? "true" : "false"}}"
          data-mesh-channel-index="${{escAttr(row.index)}}"
          title="${{escAttr(row.meta.title === row.label ? row.meta.title : `${{row.meta.title}} • ${{row.label}}`)}}"
        >
          <span class="${{dotClass}}" style="${{row.all ? "" : `--channel-dot-fill: ${{row.meta.fill}};`}}" aria-hidden="true"></span>
          <span class="mesh-channel-pill-label">${{escAttr(row.label)}}</span>
          ${{primaryBadge}}
          ${{
            row.unread > 0
              ? `<span class="mesh-channel-pill-unread" aria-label="${{escAttr(`${{row.unread}} unread`)}}">(${{escAttr(unreadLabel)}})</span>`
              : ""
          }}
        </button>`;
      }}).join("");
    }}

    function meshChannelLabelForIndex(rawIndex, {{ verbose = false, compact = false, allowAll = true }} = {{}}) {{
      const idx = normalizeMeshChannelIndex(rawIndex, {{ allowAll }});
      if (idx === meshChannelAllIndex) {{
        return compact ? "All" : "All channels";
      }}
      const name = meshChannelConfiguredName(idx, meshChannelOptions);
      if (name) return compact ? name : verbose ? `Ch ${{idx}} (${{name}})` : name;
      return `Ch ${{idx}}`;
    }}

    function activeMeshChannelFilterIndex() {{
      return normalizeMeshChannelIndex(activeMeshChannelIndex, {{ allowAll: true }});
    }}

    function activeMeshChannelSendIndex() {{
      return normalizeMeshChannelIndex(activeMeshSendChannelIndex);
    }}

    function currentMeshChannelViewLabel() {{
      return meshChannelViewMenuLabel(activeMeshChannelIndex);
    }}

    function currentMeshChannelSendLabel() {{
      const idx = normalizeMeshChannelIndex(activeMeshSendChannelIndex);
      const match = meshChannelOptionByIndex(idx, meshChannelSendOptions);
      return meshChannelSendOptionLabel(match ? {{ ...match, index: idx }} : {{ index: idx }});
    }}

    function syncMeshChannelMismatchWarning() {{
      const wrap = document.querySelector(".chat-send-channel-wrap");
      const warningEl = document.getElementById("chat-channel-mismatch-warning");
      if (!(wrap instanceof HTMLElement)) return;

      const viewIdx = activeMeshChannelFilterIndex();
      const sendIdx = activeMeshChannelSendIndex();
      const mismatched = viewIdx !== meshChannelAllIndex && sendIdx !== viewIdx;
      const warningText = mismatched
        ? `Sending on ${{currentMeshChannelSendLabel()}} while viewing ${{currentMeshChannelViewLabel()}}. You may send something you cannot see here.`
        : "";

      wrap.classList.toggle("mismatch", mismatched);
      wrap.title = mismatched
        ? warningText
        : "Choose which configured message channel to use for outgoing chat. This sets the encryption group used for sends and does NOT change your LoRa frequency slot.";
      wrap.setAttribute("aria-label", mismatched ? warningText : "Outgoing chat channel");

      if (warningEl instanceof HTMLElement) {{
        warningEl.hidden = !mismatched;
        warningEl.textContent = warningText;
      }}
    }}

    function meshChannelSendContext() {{
      const sendIndex = activeMeshChannelSendIndex();
      return {{
        sendIndex,
        sendLabel: currentMeshChannelSendLabel(),
      }};
    }}

    function meshChannelSendSelectElements() {{
      const ids = ["chat-send-channel-select", "files-send-channel-select"];
      const out = [];
      for (const id of ids) {{
        const el = document.getElementById(id);
        if (el instanceof HTMLSelectElement) {{
          out.push(el);
        }}
      }}
      return out;
    }}

    function syncMeshChannelSendControl() {{
      const dot = document.getElementById("chat-send-channel-dot");
      const wrap = document.querySelector(".chat-send-channel-wrap");
      const composeShell = document.querySelector(".chat-compose-shell");
      const input = document.getElementById("chat-input");
      const filesDot = document.getElementById("files-send-channel-dot");
      const filesSelect = document.getElementById("files-send-channel-select");
      const filesHint = document.getElementById("files-send-channel-hint");
      const meta = meshChannelColorMeta(activeMeshSendChannelIndex, {{ allowAll: false }});
      const rgb = hexColorRgbTriplet(meta.fill);
      const sendLabel = currentMeshChannelSendLabel();
      if (wrap instanceof HTMLElement) {{
        wrap.style.setProperty("--chat-send-channel-fill", meta.fill);
        wrap.style.setProperty("--chat-send-channel-rgb", rgb);
      }}
      if (composeShell instanceof HTMLElement) {{
        composeShell.style.setProperty("--chat-send-channel-fill", meta.fill);
        composeShell.style.setProperty("--chat-send-channel-rgb", rgb);
      }}
      if (input instanceof HTMLElement) {{
        input.style.setProperty("--chat-send-channel-fill", meta.fill);
        input.style.setProperty("--chat-send-channel-rgb", rgb);
      }}
      if (dot instanceof HTMLElement) {{
        dot.classList.remove("is-all");
        dot.style.setProperty("--channel-dot-fill", meta.fill);
        dot.title = meta.title;
        dot.setAttribute("aria-label", meta.title);
      }}
      if (filesDot instanceof HTMLElement) {{
        filesDot.classList.remove("is-all");
        filesDot.style.setProperty("--channel-dot-fill", meta.fill);
        filesDot.title = meta.title;
        filesDot.setAttribute("aria-label", meta.title);
      }}
      if (filesSelect instanceof HTMLSelectElement) {{
        filesSelect.value = String(activeMeshSendChannelIndex);
        filesSelect.title = `Outgoing file transfer channel: ${{sendLabel}}`;
      }}
      if (filesHint instanceof HTMLElement) {{
        filesHint.textContent = `Files send on ${{sendLabel}}. Message channels are encryption groups, not frequency slots.`;
      }}
      const btn = document.getElementById("chat-send-channel-menu-btn");
      if (btn instanceof HTMLButtonElement) {{
        btn.innerHTML = `${{meshChannelPrimaryBadgeHtml(activeMeshSendChannelIndex)}}<span class="mesh-channel-menu-btn-label">${{escAttr(sendLabel)}}</span>`;
        btn.title = meta.title === sendLabel ? meta.title : `${{meta.title}} • ${{sendLabel}}`;
        const select = document.getElementById("chat-send-channel-select");
        const disabled = select instanceof HTMLSelectElement ? !!select.disabled : false;
        btn.disabled = disabled;
        btn.setAttribute("aria-disabled", disabled ? "true" : "false");
      }}
      syncMeshChannelMismatchWarning();
    }}

    function setMeshChannelSendMenuOpen(open) {{
      meshChannelSendMenuOpen = !!open;
      const panel = document.getElementById("chat-send-channel-menu");
      if (panel instanceof HTMLElement) {{
        panel.hidden = !meshChannelSendMenuOpen;
      }}
      const btn = document.getElementById("chat-send-channel-menu-btn");
      if (btn instanceof HTMLButtonElement) {{
        btn.setAttribute("aria-expanded", meshChannelSendMenuOpen ? "true" : "false");
      }}
    }}

    function collectMeshChannelOptionsFromLocalState(localState, options = {{}}) {{
      const root = (localState && typeof localState === "object") ? localState : {{}};
      const rawChannels = Array.isArray(root.channels) ? root.channels : [];
      const byIndex = new Map();
      const includeFallback = options.includeFallback !== false;
      const fallbackCount = Math.max(1, Math.trunc(Number(options.fallbackCount) || 0));

      for (let i = 0; i < rawChannels.length; i++) {{
        const ch = rawChannels[i];
        if (!ch || typeof ch !== "object") continue;

        const idxRaw = ch.index ?? ch.channel_index ?? ch.channelIndex ?? i;
        const idxNum = Math.trunc(Number(idxRaw));
        const index = Number.isInteger(idxNum) && idxNum >= 0 ? idxNum : i;

        const roleRaw = ch.role ?? ch.channel_role ?? ch.channelRole;
        const role = typeof roleRaw === "string" ? roleRaw.trim() : (roleRaw != null ? String(roleRaw) : "");
        const roleUpper = role.toUpperCase();
        const roleNum = Number(role);
        const disabled = (
          roleUpper === "DISABLED"
          || roleUpper === "CHANNEL_ROLE_DISABLED"
          || (Number.isInteger(roleNum) && roleNum === 0)
        );

        const settings = (ch.settings && typeof ch.settings === "object") ? ch.settings
          : (ch.channel_settings && typeof ch.channel_settings === "object") ? ch.channel_settings
          : (ch.channelSettings && typeof ch.channelSettings === "object") ? ch.channelSettings
          : null;
        const nameRaw = (
          settings && typeof settings.name === "string" ? settings.name
          : settings && typeof settings.channel_name === "string" ? settings.channel_name
          : settings && typeof settings.short_name === "string" ? settings.short_name
          : typeof ch.name === "string" ? ch.name
          : typeof ch.channel_name === "string" ? ch.channel_name
          : ""
        );
        const name = typeof nameRaw === "string" ? nameRaw.trim() : "";
        const pskRaw = (
          settings && settings.psk != null ? settings.psk
          : settings && settings.channel_psk != null ? settings.channel_psk
          : ch.psk != null ? ch.psk
          : ch.channel_psk != null ? ch.channel_psk
          : null
        );
        const hasPsk = Array.isArray(pskRaw)
          ? pskRaw.length > 0
          : (pskRaw != null && String(pskRaw).trim() !== "");

        const opt = {{ index, name, role, disabled, hasPsk }};
        if (!byIndex.has(index)) {{
          byIndex.set(index, opt);
        }} else {{
          const prev = byIndex.get(index);
          if (prev && typeof prev === "object") {{
            if (!prev.name && name) prev.name = name;
            if (!prev.role && role) prev.role = role;
            prev.hasPsk = prev.hasPsk === true || hasPsk === true;
            prev.disabled = prev.disabled && disabled;
          }}
        }}
      }}

      if (includeFallback) {{
        const fillCount = Math.max(fallbackCount, rawChannels.length || 0);
        for (let i = 0; i < fillCount; i++) {{
          if (!byIndex.has(i)) {{
            byIndex.set(i, {{ index: i, name: "", role: "", disabled: false, hasPsk: false }});
          }}
        }}
      }}

      const collectedOptions = Array.from(byIndex.values())
        .filter((opt) => opt && Number.isInteger(Number(opt.index)) && Number(opt.index) >= 0)
        .sort((a, b) => Number(a.index) - Number(b.index));

      if (collectedOptions.length) return collectedOptions;
      if (!includeFallback) return [];
      return [{{ index: 0, name: "", role: "", disabled: false, hasPsk: false }}];
    }}

    function buildMeshChannelOptionsFromLocalState(localState) {{
      const hasLocalChannels = !!(localState && Array.isArray(localState.channels) && localState.channels.length);
      const collected = collectMeshChannelOptionsFromLocalState(localState, {{
        includeFallback: !hasLocalChannels,
        fallbackCount: Math.max(8, (localState && Array.isArray(localState.channels)) ? localState.channels.length : 0),
      }}).filter((opt) => !(opt && opt.disabled));
      if (collected.length) return collected;
      return [{{ index: 0, name: "", role: "", disabled: false, hasPsk: false }}];
    }}

    function buildMeshChannelSendOptionsFromLocalState(localState) {{
      const hasLocalChannels = !!(localState && Array.isArray(localState.channels) && localState.channels.length);
      const collected = collectMeshChannelOptionsFromLocalState(localState, {{
        includeFallback: !hasLocalChannels,
        fallbackCount: Math.max(8, (localState && Array.isArray(localState.channels)) ? localState.channels.length : 0),
      }}).filter((opt) => !(opt && opt.disabled));
      if (collected.length) return collected;
      return [{{ index: 0, name: "", role: "", disabled: false, hasPsk: false }}];
    }}

    function renderMeshChannelSelect(options) {{
      const select = document.getElementById("mesh-channel-select");
      if (!(select instanceof HTMLSelectElement)) return;

      const normalized = Array.isArray(options) ? options : [];
      select.innerHTML = "";
      const allOption = document.createElement("option");
      allOption.value = String(meshChannelAllIndex);
      allOption.textContent = "All channels (view)";
      allOption.title = "All channels view";
      select.appendChild(allOption);
      for (const opt of normalized) {{
        const idx = normalizeMeshChannelIndex(opt && opt.index);
        const plainLabel = meshChannelViewOptionLabel({{ ...opt, index: idx }}) || `Ch ${{idx}}`;
        const optionEl = document.createElement("option");
        optionEl.value = String(idx);
        optionEl.textContent = plainLabel;
        optionEl.disabled = !!(opt && opt.disabled);
        if (opt && opt.role) {{
          optionEl.title = String(opt.role);
        }}
        select.appendChild(optionEl);
      }}

      // Pick an enabled value.
      const desired = String(normalizeMeshChannelIndex(activeMeshChannelIndex, {{ allowAll: true }}));
      const desiredOpt = Array.from(select.options).find((o) => o.value === desired && !o.disabled);
      if (desiredOpt) {{
        select.value = desired;
        return;
      }}
      const firstEnabled = Array.from(select.options).find((o) => !o.disabled);
      const nextValue = firstEnabled ? firstEnabled.value : "0";
      select.value = nextValue;
      activeMeshChannelIndex = normalizeMeshChannelIndex(nextValue, {{ allowAll: true }});
      syncMeshChannelViewControl();
      try {{
        window.localStorage.setItem(meshChannelIndexStorageKey, String(activeMeshChannelIndex));
      }} catch (_err) {{}}
    }}

    function renderMeshChannelSendSelect(options, {{ preserveCurrent = false }} = {{}}) {{
      const selects = meshChannelSendSelectElements();
      if (!selects.length) return;

      const normalized = Array.isArray(options) ? options.slice() : [];
      const desiredIndex = normalizeMeshChannelIndex(activeMeshSendChannelIndex);
      if (preserveCurrent && !normalized.some((opt) => normalizeMeshChannelIndex(opt && opt.index) === desiredIndex)) {{
        normalized.unshift({{ index: desiredIndex, name: "", role: "", disabled: false, hasPsk: false }});
      }}
      const fillSelect = (select) => {{
        select.innerHTML = "";
        for (const opt of normalized) {{
          const idx = normalizeMeshChannelIndex(opt && opt.index);
          const label = meshChannelSendOptionLabel({{ ...opt, index: idx }}) || `Ch ${{idx}}`;
          const optionEl = document.createElement("option");
          optionEl.value = String(idx);
          optionEl.textContent = label;
          optionEl.disabled = !!(opt && opt.disabled);
          optionEl.title = `${{label}} • Ch ${{idx}}`;
          select.appendChild(optionEl);
        }}
      }};
      for (const select of selects) {{
        fillSelect(select);
      }}

      const pickEnabledValue = (select, desiredValue) => {{
        const desiredOpt = Array.from(select.options).find((o) => o.value === desiredValue && !o.disabled);
        if (desiredOpt) return desiredValue;
        const firstEnabled = Array.from(select.options).find((o) => !o.disabled);
        return firstEnabled ? firstEnabled.value : "0";
      }};

      const desired = String(desiredIndex);
      const resolvedValue = pickEnabledValue(selects[0], desired);
      if (resolvedValue !== desired) {{
        activeMeshSendChannelIndex = normalizeMeshChannelIndex(resolvedValue);
        try {{
          window.localStorage.setItem(meshChannelSendIndexStorageKey, String(activeMeshSendChannelIndex));
        }} catch (_err) {{}}
      }}
      for (const select of selects) {{
        select.value = pickEnabledValue(select, resolvedValue);
      }}
    }}

    function renderMeshChannelSendMenu(options, {{ preserveCurrent = false }} = {{}}) {{
      const panel = document.getElementById("chat-send-channel-menu");
      if (!(panel instanceof HTMLElement)) return;

      const normalized = Array.isArray(options) ? options.slice() : [];
      const desiredIndex = normalizeMeshChannelIndex(activeMeshSendChannelIndex);
      if (preserveCurrent && !normalized.some((opt) => normalizeMeshChannelIndex(opt && opt.index) === desiredIndex)) {{
        normalized.unshift({{ index: desiredIndex, name: "", role: "", disabled: false, hasPsk: false }});
      }}

      panel.innerHTML = normalized.map((opt) => {{
        const idx = normalizeMeshChannelIndex(opt && opt.index);
        const label = meshChannelSendOptionLabel({{ ...opt, index: idx }}) || `Ch ${{idx}}`;
        const active = desiredIndex === idx;
        const meta = meshChannelColorMeta(idx, {{ allowAll: false }});
        const primaryBadge = meshChannelPrimaryBadgeHtml(idx);
        return `<button
          type="button"
          class="mesh-channel-menu-item${{active ? " active" : ""}}"
          role="option"
          aria-selected="${{active ? "true" : "false"}}"
          data-mesh-send-channel-index="${{escAttr(idx)}}"
          title="${{escAttr(meta.title === label ? meta.title : `${{meta.title}} • ${{label}}`)}}"
        >
          <span class="channel-color-dot" style="--channel-dot-fill: ${{meta.fill}};" aria-hidden="true"></span>
          <span class="mesh-channel-menu-item-main">
            <span class="mesh-channel-menu-item-title">${{primaryBadge}}<span>${{escAttr(label)}}</span></span>
          </span>
        </button>`;
      }}).join("");
    }}

    async function hydrateMeshChannelOptions(force = false) {{
      const nowMs = Date.now();
      const ttlMs = 60000;

      let localState = (settingsLocalStateCache && typeof settingsLocalStateCache === "object")
        ? settingsLocalStateCache
        : null;
      const stale = !settingsLocalStateFetchedAt || (nowMs - settingsLocalStateFetchedAt) > ttlMs;
      if (force || !localState || stale || !Array.isArray(localState.channels)) {{
        try {{
          const data = await fetchRawJson("/api/raw/local_state", rawDataCache.localState, ttlMs);
          const obj = (data && typeof data === "object") ? data : null;
          if (obj) {{
            settingsLocalStateCache = obj;
            settingsLocalStateFetchedAt = nowMs;
            localState = obj;
          }}
        }} catch (_err) {{}}
      }}

      const options = buildMeshChannelOptionsFromLocalState(localState);
      const sendOptions = buildMeshChannelSendOptionsFromLocalState(localState);
      meshChannelOptions = options;
      meshChannelSendOptions = sendOptions;
      renderMeshChannelSelect(options);
      renderMeshChannelPills(options);
      renderMeshChannelSendSelect(sendOptions);
      renderMeshChannelSendMenu(sendOptions, {{ preserveCurrent: true }});
      syncMeshChannelSendControl();
      return options;
    }}

    function ensureChannelsViewLocalStateHydrated(force = false) {{
      if (channelsViewHydrateInFlight) {{
        return channelsViewHydrateInFlight;
      }}
      const cached = settingsLocalStateCache && typeof settingsLocalStateCache === "object"
        ? settingsLocalStateCache
        : null;
      const stale = !settingsLocalStateFetchedAt || (Date.now() - settingsLocalStateFetchedAt) > 60000;
      const missingChannels = !(cached && Array.isArray(cached.channels));
      if (!force && !missingChannels && !stale) {{
        return Promise.resolve(cached);
      }}
      channelsViewHydrateInFlight = hydrateMeshChannelOptions(force)
        .catch(() => null)
        .then(() => {{
          if (activeLayoutView === "channels") {{
            renderChannelsView(latestState);
          }}
          return settingsLocalStateCache;
        }})
        .finally(() => {{
          channelsViewHydrateInFlight = null;
        }});
      return channelsViewHydrateInFlight;
    }}

    function applyMeshChannelIndex(rawIndex, persist = true) {{
      const idx = normalizeMeshChannelIndex(rawIndex, {{ allowAll: true }});
      const changed = idx !== activeMeshChannelIndex;
      const shouldFollowForSend = idx !== meshChannelAllIndex;
      activeMeshChannelIndex = idx;
      syncMeshChannelViewControl();

      const select = document.getElementById("mesh-channel-select");
      if (select instanceof HTMLSelectElement) {{
        select.value = String(activeMeshChannelIndex);
      }}
      renderMeshChannelPills(meshChannelOptions);

      if (persist) {{
        try {{
          window.localStorage.setItem(meshChannelIndexStorageKey, String(activeMeshChannelIndex));
        }} catch (_err) {{}}
      }}

      if (shouldFollowForSend) {{
        applyMeshSendChannelIndex(idx, persist, false);
      }}

      if (activeLayoutView === "chat" && !document.hidden && tabHasFocus) {{
        clearVisibleChatUnread(activeChatChannel);
      }}

      if ((changed || shouldFollowForSend) && latestState) {{
        if (activeLayoutView === "chat") {{
          renderChat(latestState);
        }} else if (activeLayoutView === "files") {{
          renderFilesView(latestState);
        }}
      }}
    }}

    function applyMeshSendChannelIndex(rawIndex, persist = true, rerenderChat = true) {{
      const idx = normalizeMeshChannelIndex(rawIndex);
      const changed = idx !== activeMeshSendChannelIndex;
      activeMeshSendChannelIndex = idx;

      for (const select of meshChannelSendSelectElements()) {{
        select.value = String(activeMeshSendChannelIndex);
      }}
      syncMeshChannelSendControl();
      renderMeshChannelSendMenu(meshChannelSendOptions, {{ preserveCurrent: true }});

      if (persist) {{
        try {{
          window.localStorage.setItem(meshChannelSendIndexStorageKey, String(activeMeshSendChannelIndex));
        }} catch (_err) {{}}
      }}

      if (rerenderChat && changed && latestState && activeLayoutView === "chat") {{
        renderChat(latestState);
      }}
    }}

    function loadMeshChannelIndex() {{
      let preferred = 0;
      let preferredSend = null;
      try {{
        preferred = normalizeMeshChannelIndex(
          window.localStorage.getItem(meshChannelIndexStorageKey) || "0",
          {{ allowAll: true }}
        );
        const storedSend = window.localStorage.getItem(meshChannelSendIndexStorageKey);
        if (storedSend != null && String(storedSend).trim() !== "") {{
          preferredSend = normalizeMeshChannelIndex(storedSend);
        }}
      }} catch (_err) {{}}
      activeMeshChannelIndex = preferred;
      activeMeshSendChannelIndex = preferredSend == null
        ? normalizeMeshChannelIndex(preferred)
        : normalizeMeshChannelIndex(preferredSend);
    }}

    function bindMeshChannelControl() {{
      const select = document.getElementById("mesh-channel-select");
      if (!(select instanceof HTMLSelectElement) || select.dataset.bound === "1") return;
      select.dataset.bound = "1";

      select.addEventListener("change", () => {{
        applyMeshChannelIndex(select.value, true);
      }});

      // Seed fast fallback so the control is usable before the radio query returns.
      const fallback = buildMeshChannelOptionsFromLocalState({{ channels: [] }});
      const sendFallback = buildMeshChannelSendOptionsFromLocalState(null);
      meshChannelOptions = fallback;
      meshChannelSendOptions = sendFallback;
      renderMeshChannelSelect(fallback);
      renderMeshChannelPills(fallback);
      renderMeshChannelSendSelect(sendFallback, {{ preserveCurrent: true }});
      renderMeshChannelSendMenu(sendFallback, {{ preserveCurrent: true }});
      select.value = String(activeMeshChannelIndex);
      syncMeshChannelViewControl();
      syncMeshChannelSendControl();

      void hydrateMeshChannelOptions(false);
    }}

    function bindMeshChannelMenuControl() {{
      const panel = document.getElementById("mesh-channel-pill-strip");
      if (!(panel instanceof HTMLElement) || panel.dataset.bound === "1") return;
      panel.dataset.bound = "1";

      panel.addEventListener("pointerdown", (ev) => {{
        const target = ev.target;
        if (!(target instanceof Element)) return;
        const item = target.closest(".mesh-channel-pill");
        if (!(item instanceof HTMLButtonElement)) return;
        ev.preventDefault();
        ev.stopPropagation();
        applyMeshChannelIndex(item.dataset.meshChannelIndex || meshChannelAllIndex, true);
      }});

      syncMeshChannelViewControl();
      renderMeshChannelPills(meshChannelOptions);
    }}

    function bindMeshChannelSendMenuControl() {{
      const btn = document.getElementById("chat-send-channel-menu-btn");
      const panel = document.getElementById("chat-send-channel-menu");
      if (!(btn instanceof HTMLButtonElement) || !(panel instanceof HTMLElement) || btn.dataset.bound === "1") return;
      btn.dataset.bound = "1";

      btn.addEventListener("click", (ev) => {{
        ev.preventDefault();
        if (btn.disabled) return;
        setMeshChannelSendMenuOpen(!meshChannelSendMenuOpen);
      }});

      panel.addEventListener("pointerdown", (ev) => {{
        const target = ev.target;
        if (!(target instanceof Element)) return;
        const item = target.closest(".mesh-channel-menu-item");
        if (!(item instanceof HTMLButtonElement)) return;
        ev.preventDefault();
        ev.stopPropagation();
        applyMeshSendChannelIndex(item.dataset.meshSendChannelIndex || 0, true);
        setMeshChannelSendMenuOpen(false);
      }});

      if (document.body.dataset.meshChannelSendMenuBound !== "1") {{
        document.body.dataset.meshChannelSendMenuBound = "1";
        document.addEventListener("pointerdown", (ev) => {{
          const target = ev.target;
          if (!(target instanceof Element)) return;
          if (target.closest("#chat-send-channel-menu-btn") || target.closest("#chat-send-channel-menu")) return;
          setMeshChannelSendMenuOpen(false);
        }});
        document.addEventListener("keydown", (ev) => {{
          if (ev.key === "Escape") {{
            setMeshChannelSendMenuOpen(false);
          }}
        }});
      }}

      syncMeshChannelSendControl();
      renderMeshChannelSendMenu(meshChannelSendOptions, {{ preserveCurrent: true }});
    }}

    function bindMeshChannelSendControl() {{
      const selects = meshChannelSendSelectElements();
      if (!selects.length) return;
      for (const select of selects) {{
        if (!(select instanceof HTMLSelectElement) || select.dataset.bound === "1") continue;
        select.dataset.bound = "1";
        select.addEventListener("change", () => {{
          applyMeshSendChannelIndex(select.value, true);
        }});
      }}

      renderMeshChannelSendSelect(
        meshChannelSendOptions.length ? meshChannelSendOptions : buildMeshChannelSendOptionsFromLocalState(null),
        {{ preserveCurrent: true }},
      );
      renderMeshChannelSendMenu(
        meshChannelSendOptions.length ? meshChannelSendOptions : buildMeshChannelSendOptionsFromLocalState(null),
        {{ preserveCurrent: true }},
      );
      syncMeshChannelSendControl();
    }}


    function normalizeChannelsUiMode(raw) {{
      const text = String(raw == null ? "" : raw).trim().toLowerCase();
      if (text === "advanced" || text === "1" || text === "true" || text === "on") return "advanced";
      return "simple";
    }}

    function applyChannelsUiMode() {{
      const root = document.body;
      if (root) {{
        root.classList.toggle("channels-advanced-ui", !!channelsUiAdvanced);
      }}
      const addOnlyBtn = document.getElementById("settings-channels-import-url-add-btn");
      if (addOnlyBtn instanceof HTMLButtonElement) {{
        addOnlyBtn.hidden = !channelsUiAdvanced;
      }}
    }}

    function setChannelsUiAdvanced(enabled, persist = true) {{
      channelsUiAdvanced = !!enabled;
      if (persist) {{
        try {{
          window.localStorage.setItem(
            channelsUiModeStorageKey,
            channelsUiAdvanced ? "advanced" : "simple"
          );
        }} catch (_err) {{}}
      }}
      applyChannelsUiMode();
    }}

    function setChannelsExperimentalEnabled(enabled, persist = true) {{
      channelsExperimentalEnabled = !!enabled;
      if (persist) {{
        try {{
          window.localStorage.setItem(
            channelsExperimentalStorageKey,
            channelsExperimentalEnabled ? "1" : "0"
          );
        }} catch (_err) {{}}
      }}
    }}

    function loadChannelsUiMode() {{
      let stored = "simple";
      try {{
        stored = normalizeChannelsUiMode(window.localStorage.getItem(channelsUiModeStorageKey) || "simple");
      }} catch (_err) {{}}
      channelsUiAdvanced = stored === "advanced";
    }}

    function loadChannelsExperimentalPreference() {{
      let stored = false;
      try {{
        stored = parseBoolToken(window.localStorage.getItem(channelsExperimentalStorageKey), false);
      }} catch (_err) {{}}
      channelsExperimentalEnabled = !!stored;
    }}


