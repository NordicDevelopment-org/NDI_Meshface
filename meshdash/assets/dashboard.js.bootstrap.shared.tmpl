    function getChatScroller() {{
      const feed = document.getElementById("chat-feed");
      if (!(feed instanceof HTMLElement)) return null;
      const scroller = feed.closest(".scroll");
      return scroller instanceof HTMLElement ? scroller : null;
    }}

    function isNearBottom(scroller, thresholdPx = chatBottomStickThresholdPx) {{
      if (!(scroller instanceof HTMLElement)) return false;
      const remaining = scroller.scrollHeight - scroller.scrollTop - scroller.clientHeight;
      return remaining <= thresholdPx;
    }}

    function bindChatAutoScroll() {{
      const scroller = getChatScroller();
      if (!(scroller instanceof HTMLElement) || scroller.dataset.chatScrollBound === "1") return;
      scroller.dataset.chatScrollBound = "1";
      chatStickToBottom = true;
      scroller.addEventListener("scroll", () => {{
        chatStickToBottom = isNearBottom(scroller);
        syncChatChangeAutoDismiss();
      }});
      scroller.addEventListener("mouseup", () => {{
        void copyChatSelectionToClipboard();
      }});
    }}

    function bytesToGiB(value) {{
      const num = Number(value);
      if (!Number.isFinite(num) || num < 0) return null;
      return num / (1024 ** 3);
    }}

    function formatModemPresetLabel(value, fallback = "unknown") {{
      const raw = String(value == null ? "" : value).trim();
      if (!raw) return fallback;
      const enumMap = new Map([
        ["0", "LONG_FAST"],
        ["1", "LONG_SLOW"],
        ["2", "VERY_LONG_SLOW"],
        ["3", "MEDIUM_SLOW"],
        ["4", "MEDIUM_FAST"],
        ["5", "SHORT_SLOW"],
        ["6", "SHORT_FAST"],
        ["7", "LONG_MODERATE"],
        ["8", "SHORT_TURBO"],
        ["9", "LONG_TURBO"],
      ]);
      const canonicalRaw = enumMap.get(raw) || raw;
      return canonicalRaw
        .split(/[_\\s]+/)
        .filter((token) => !!token)
        .map((token) => `${{token.slice(0, 1).toUpperCase()}}${{token.slice(1).toLowerCase()}}`)
        .join(" ");
    }}

    function parseDashboardTimeToMs(value) {{
      const numericRaw = Number(value);
      if (Number.isFinite(numericRaw) && numericRaw > 0) {{
        // Accept either Unix seconds or milliseconds.
        return Math.floor(numericRaw > 1e12 ? numericRaw : (numericRaw * 1000));
      }}
      const text = String(value == null ? "" : value).trim();
      if (!text) return null;
      const iso = text.includes("T") ? text : text.replace(" ", "T");
      const parsed = Date.parse(iso);
      if (!Number.isFinite(parsed)) return null;
      return Math.floor(parsed);
    }}

    function parseDashboardTimeToUnix(value) {{
      const parsedMs = parseDashboardTimeToMs(value);
      if (!parsedMs) return null;
      return Math.floor(parsedMs / 1000);
    }}

    function parsePositiveMessageId(value) {{
      const num = Number(value);
      if (!Number.isFinite(num) || num <= 0) return null;
      return Math.trunc(num);
    }}

    function messageIdOfChatPacket(msg) {{
      if (!msg || typeof msg !== "object") return null;
      return parsePositiveMessageId(msg.message_id ?? msg.messageId ?? msg.packet_id ?? msg.packetId);
    }}

    function replyIdOfChatPacket(msg) {{
      if (!msg || typeof msg !== "object") return null;
      return parsePositiveMessageId(msg.reply_id ?? msg.replyId);
    }}

    function hopCountOfChatPacket(msg) {{
      if (!msg || typeof msg !== "object") return null;
      const direct = Number(msg.hops);
      if (Number.isFinite(direct) && direct >= 0) {{
        return Math.trunc(direct);
      }}
      const hopStart = Number(msg.hop_start ?? msg.hopStart);
      const hopLimit = Number(msg.hop_limit ?? msg.hopLimit);
      if (Number.isFinite(hopStart) && Number.isFinite(hopLimit)) {{
        const derived = Math.trunc(hopStart) - Math.trunc(hopLimit);
        if (derived >= 0) return derived;
      }}
      return null;
    }}

    function latestUnixTimestamp(...values) {{
      let latest = 0;
      for (const value of values) {{
        const ts = parseDashboardTimeToUnix(value);
        if (ts && ts > latest) latest = ts;
      }}
      return latest > 0 ? latest : null;
    }}

    function latestTimestampMs(...values) {{
      let latest = 0;
      for (const value of values) {{
        const ts = parseDashboardTimeToMs(value);
        if (ts && ts > latest) latest = ts;
      }}
      return latest > 0 ? latest : null;
    }}

    function nestedPathValue(root, path) {{
      if (!root || typeof root !== "object") return null;
      let current = root;
      const parts = String(path || "").split(".");
      for (const rawPart of parts) {{
        const part = String(rawPart || "").trim();
        if (!part || !current || typeof current !== "object" || !(part in current)) {{
          return null;
        }}
        current = current[part];
      }}
      return current;
    }}

    function firstNestedValue(roots, paths) {{
      const rootList = Array.isArray(roots) ? roots : [roots];
      for (const root of rootList) {{
        for (const path of (Array.isArray(paths) ? paths : [])) {{
          const value = nestedPathValue(root, path);
          if (value == null) continue;
          if (typeof value === "string" && !value.trim()) continue;
          return value;
        }}
      }}
      return null;
    }}

    function firstFiniteNestedNumber(roots, paths) {{
      const raw = firstNestedValue(roots, paths);
      const num = Number(raw);
      return Number.isFinite(num) ? num : null;
    }}

    function formatLocalChatTime(unixTs, fallback = "n/a", nowUnix = Math.floor(Date.now() / 1000)) {{
      const ts = Number(unixTs);
      if (!Number.isFinite(ts) || ts <= 0) {{
        const fallbackText = String(fallback == null ? "" : fallback).trim();
        return fallbackText || "n/a";
      }}
      const valueDate = new Date(Math.floor(ts) * 1000);
      if (Number.isNaN(valueDate.getTime())) {{
        const fallbackText = String(fallback == null ? "" : fallback).trim();
        return fallbackText || "n/a";
      }}
      const nowDate = new Date(Math.floor(Number.isFinite(nowUnix) ? nowUnix : (Date.now() / 1000)) * 1000);
      const sameLocalDay = (
        valueDate.getFullYear() === nowDate.getFullYear()
        && valueDate.getMonth() === nowDate.getMonth()
        && valueDate.getDate() === nowDate.getDate()
      );
      const hh = String(valueDate.getHours()).padStart(2, "0");
      const mm = String(valueDate.getMinutes()).padStart(2, "0");
      const ss = String(valueDate.getSeconds()).padStart(2, "0");
      if (sameLocalDay) {{
        return `${{hh}}:${{mm}}:${{ss}}`;
      }}
      const mon = String(valueDate.getMonth() + 1).padStart(2, "0");
      const day = String(valueDate.getDate()).padStart(2, "0");
      return `${{mon}}/${{day}} ${{hh}}:${{mm}}:${{ss}}`;
    }}

    function nodeLastHeardUnix(node) {{
      if (!node || typeof node !== "object") return null;
      const raw = Number(node.last_heard_unix);
      if (Number.isFinite(raw) && raw > 0) {{
        return Math.floor(raw);
      }}
      return parseDashboardTimeToUnix(node.last_heard);
    }}

    function freshnessStatus(lastSeenUnix, nowUnix = Math.floor(Date.now() / 1000)) {{
      const ts = Number(lastSeenUnix);
      if (!Number.isFinite(ts) || ts <= 0) return "unknown";
      const age = Math.max(0, nowUnix - ts);
      if (age <= chatWarnWindowSeconds) return "online";
      if (age <= chatStaleWindowSeconds) return "warn";
      return "stale";
    }}

    function statusRank(status) {{
      const key = String(status || "unknown");
      if (key === "online") return 0;
      if (key === "warn") return 1;
      if (key === "stale") return 2;
      return 3;
    }}

    function normalizeFreshnessKey(status) {{
      const key = String(status || "").trim().toLowerCase();
      if (key === "online" || key === "warn" || key === "stale") return key;
      return "unknown";
    }}

    function applyFreshnessClass(el, status) {{
      if (!(el instanceof HTMLElement)) return;
      const key = normalizeFreshnessKey(status);
      if (el.dataset.freshness === key) return;
      el.dataset.freshness = key;
      el.classList.remove("status-online", "status-warn", "status-stale", "status-unknown");
      el.classList.add(`status-${{key}}`);
    }}

    function trimInlineError(value, maxLen = 120) {{
      const text = String(value == null ? "" : value).replace(/\\s+/g, " ").trim();
      if (!text) return "";
      const limit = Math.max(24, Math.floor(Number(maxLen) || 120));
      if (text.length <= limit) return text;
      return `${{text.slice(0, limit - 1)}}…`;
    }}

    function coerceOptionalBool(value) {{
      if (typeof value === "boolean") return value;
      if (typeof value === "number" && Number.isFinite(value)) {{
        return value !== 0;
      }}
      if (typeof value === "string") {{
        const clean = value.trim().toLowerCase();
        if (!clean) return null;
        if (["1", "true", "yes", "on", "y"].includes(clean)) return true;
        if (["0", "false", "no", "off", "n"].includes(clean)) return false;
      }}
      return null;
    }}

    function buildTargetWifiSummary(state = latestState) {{
      const safeState = (state && typeof state === "object") ? state : {{}};
      const summary = (safeState.summary && typeof safeState.summary === "object") ? safeState.summary : {{}};
      const radioConnection = (summary.radio_connection && typeof summary.radio_connection === "object")
        ? summary.radio_connection
        : null;
      const wifi = (radioConnection && typeof radioConnection.wifi === "object") ? radioConnection.wifi : null;
      if (!wifi) return null;

      const connected = coerceOptionalBool(wifi.is_connected ?? wifi.isConnected);
      const rssiRaw = Number(wifi.rssi_dbm ?? wifi.rssiDbm ?? wifi.rssi);
      const rssi = Number.isFinite(rssiRaw) ? Math.trunc(rssiRaw) : null;
      const ssid = String(wifi.ssid == null ? "" : wifi.ssid).trim();
      const ip = String(wifi.ip_address ?? wifi.ipAddress ?? "").trim();
      const ageRaw = Number(radioConnection && (radioConnection.age_seconds ?? radioConnection.ageSeconds));
      const ageSeconds = Number.isFinite(ageRaw) && ageRaw >= 0 ? Math.trunc(ageRaw) : null;

      let compact = "";
      if (connected === false) {{
        compact = "WiFi off";
      }} else if (Number.isFinite(rssi)) {{
        compact = `WiFi ${{rssi}}dBm`;
      }} else if (connected === true) {{
        compact = "WiFi on";
      }} else if (ssid || ip) {{
        compact = "WiFi ?";
      }} else {{
        return null;
      }}

      const detailParts = [];
      if (connected === true) detailParts.push("wifi connected");
      else if (connected === false) detailParts.push("wifi disconnected");
      else detailParts.push("wifi status unknown");
      if (Number.isFinite(rssi)) detailParts.push(`signal ${{rssi}} dBm`);
      if (ssid) detailParts.push(`ssid "${{ssid}}"`);
      if (ip) detailParts.push(`ip ${{ip}}`);
      if (Number.isFinite(ageSeconds)) detailParts.push(`age ${{ageSeconds}}s`);

      return {{
        compact,
        detail: detailParts.join(", "),
        connected,
        rssi,
        ssid,
        ip,
        age_seconds: ageSeconds,
      }};
    }}

    function resolveLocalNodeTelemetry(state = latestState) {{
      const safeState = (state && typeof state === "object") ? state : {{}};
      const summary = (safeState.summary && typeof safeState.summary === "object") ? safeState.summary : {{}};
      const localId = normalizeNodeId(resolveLocalNodeId(safeState) || "");
      const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
      const localNode = nodes.find((node) => normalizeNodeId(node && node.id) === localId) || null;
      const historyCapsById = new Map(
        Object.entries((safeState.history_caps && typeof safeState.history_caps === "object") ? safeState.history_caps : {{}})
          .map(([rawNodeId, caps]) => [normalizeNodeId(rawNodeId), caps])
          .filter(([nodeId, caps]) => isSelectableNodeId(nodeId) && caps && typeof caps === "object")
      );
      const caps = historyCapsById.get(localId) || null;
      const wifiSummary = buildTargetWifiSummary(safeState);

      const batteryRaw = Number(
        (localNode && localNode.battery_level != null)
          ? localNode.battery_level
          : (caps && caps.battery_level)
      );
      const batteryPct = Number.isFinite(batteryRaw)
        ? Math.max(0, Math.min(100, Math.round(batteryRaw * 10) / 10))
        : null;
      const voltageRaw = Number(localNode && localNode.voltage);
      const voltage = Number.isFinite(voltageRaw) ? voltageRaw : null;
      const hopsRaw = Number(
        (localNode && localNode.hops_away != null)
          ? localNode.hops_away
          : (caps && caps.last_hops)
      );
      const hops = Number.isFinite(hopsRaw) && hopsRaw >= 0 ? Math.trunc(hopsRaw) : null;
      const channelUtilRaw = Number(
        (localNode && localNode.channel_utilization != null)
          ? localNode.channel_utilization
          : (caps && (caps.channel_utilization ?? caps.channelUtilization))
      );
      const channelUtil = Number.isFinite(channelUtilRaw) ? Math.max(0, channelUtilRaw) : null;
      const airUtilTxRaw = Number(
        (localNode && localNode.air_util_tx != null)
          ? localNode.air_util_tx
          : (caps && (caps.air_util_tx ?? caps.airUtilTx))
      );
      const airUtilTx = Number.isFinite(airUtilTxRaw) ? Math.max(0, airUtilTxRaw) : null;
      const snrRaw = Number(
        (localNode && localNode.snr != null)
          ? localNode.snr
          : (caps && (caps.last_snr ?? caps.snr))
      );
      const snrDb = Number.isFinite(snrRaw) ? snrRaw : null;
      const rssiRaw = Number(
        (localNode && localNode.rssi != null)
          ? localNode.rssi
          : (caps && (caps.last_rssi ?? caps.rssi))
      );
      const rssiDbm = Number.isFinite(rssiRaw) ? Math.trunc(rssiRaw) : null;

      const lat = Number(localNode && localNode.lat);
      const lon = Number(localNode && localNode.lon);
      const gpsFix = isValidMapCoord(lat, lon);
      const gpsCapable = (caps && caps.has_position === true) || gpsFix;
      const nowUnix = Math.floor(Date.now() / 1000);
      const lastSeenUnix = nodeLastHeardUnix(localNode);
      const lastSeenText = Number.isFinite(lastSeenUnix)
        ? savedDetailAge(lastSeenUnix, nowUnix)
        : "n/a";
      const presetText = formatModemPresetLabel(summary.modem_preset, "n/a");
      const nodeName = preferredNodeName(localNode) || nodeNameCache.get(localId) || "Local node";
      return {{
        localId,
        localNode,
        caps,
        wifiSummary,
        batteryPct,
        voltage,
        hops,
        channelUtil,
        airUtilTx,
        snrDb,
        rssiDbm,
        lat,
        lon,
        gpsFix,
        gpsCapable,
        lastSeenUnix,
        lastSeenText,
        presetText,
        nodeName,
      }};
    }}

    function resolveLatestRadioSignalSnapshot(state = latestState) {{
      const safeState = (state && typeof state === "object") ? state : {{}};
      const traffic = safeState.traffic && typeof safeState.traffic === "object"
        ? safeState.traffic
        : {{}};
      const packets = Array.isArray(traffic.recent_packets) ? traffic.recent_packets : [];
      let latest = null;
      for (const packet of packets) {{
        const summary = (packet && typeof packet.summary === "object") ? packet.summary : packet;
        const snrRaw = Number(
          (summary && (summary.rx_snr ?? summary.rxSnr)) ?? (packet && (packet.rx_snr ?? packet.rxSnr))
        );
        const rssiRaw = Number(
          (summary && (summary.rx_rssi ?? summary.rxRssi)) ?? (packet && (packet.rx_rssi ?? packet.rxRssi))
        );
        const snrDb = Number.isFinite(snrRaw) ? snrRaw : null;
        const rssiDbm = Number.isFinite(rssiRaw) ? Math.trunc(rssiRaw) : null;
        if (!Number.isFinite(snrDb) && !Number.isFinite(rssiDbm)) continue;

        const seenUnix = latestUnixTimestamp(
          summary && summary.captured_at,
          summary && summary.rx_time,
          summary && summary.time,
          packet && packet.captured_at,
          packet && packet.rx_time,
          packet && packet.time,
        );
        if (!latest) {{
          latest = {{ snrDb, rssiDbm, seenUnix }};
          continue;
        }}
        const currentSeen = Number(latest.seenUnix);
        const nextSeen = Number(seenUnix);
        if (!Number.isFinite(nextSeen) || nextSeen <= 0) continue;
        if (!Number.isFinite(currentSeen) || nextSeen >= currentSeen) {{
          latest = {{ snrDb, rssiDbm, seenUnix: nextSeen }};
        }}
      }}
      return latest || {{ snrDb: null, rssiDbm: null, seenUnix: null }};
    }}

    function buildChannelUtilTickerSummary(state = latestState) {{
      const telemetry = resolveLocalNodeTelemetry(state);
      const localId = telemetry.localId;
      const channelUtilRaw = Number(telemetry && telemetry.channelUtil);
      const channelUtil = Number.isFinite(channelUtilRaw) ? Math.max(0, channelUtilRaw) : null;
      const airUtilTxRaw = Number(telemetry && telemetry.airUtilTx);
      const airUtilTx = Number.isFinite(airUtilTxRaw) ? Math.max(0, airUtilTxRaw) : null;
      const channelText = Number.isFinite(channelUtil)
        ? `${{formatTickerNumber(channelUtil, 1)}}%`
        : "n/a";
      const airText = Number.isFinite(airUtilTx)
        ? `TX ${{formatTickerNumber(airUtilTx, 1)}}%`
        : null;
      const text = [channelText, airText].filter(Boolean).join(" · ") || "n/a";
      const titleParts = [];
      if (isCanonicalNodeId(localId)) {{
        titleParts.push(`node ${{telemetry.nodeName}} (${{localId}})`);
      }} else {{
        titleParts.push(`node ${{telemetry.nodeName}}`);
      }}
      titleParts.push(Number.isFinite(channelUtil) ? `channel utilization ${{channelText}}` : "channel utilization n/a");
      titleParts.push(Number.isFinite(airUtilTx) ? `air util tx ${{formatTickerNumber(airUtilTx, 1)}}%` : "air util tx n/a");
      titleParts.push(`last seen ${{telemetry.lastSeenText}}`);
      return {{
        text,
        title: titleParts.join(" | "),
        channel_util: channelUtil,
        air_util_tx: airUtilTx,
      }};
    }}

    function buildWifiTickerSummary(state = latestState) {{
      const telemetry = resolveLocalNodeTelemetry(state);
      const localId = telemetry.localId;
      const wifiSummary = telemetry.wifiSummary;
      const compactRaw = String((wifiSummary && wifiSummary.compact) || "").trim();
      const compact = compactRaw.replace(/^WiFi\\s*/i, "").trim() || compactRaw || "n/a";
      const connected = coerceOptionalBool(wifiSummary && wifiSummary.connected);
      const rssiRaw = Number(wifiSummary && wifiSummary.rssi);
      const rssi = Number.isFinite(rssiRaw) ? Math.trunc(rssiRaw) : null;
      const rssiText = Number.isFinite(rssi)
        ? `${{rssi}}dBm`
        : (connected === false ? "off" : "n/a");
      const ip = String((wifiSummary && wifiSummary.ip) || "").trim() || "n/a";
      const ssid = String((wifiSummary && wifiSummary.ssid) || "").trim() || "n/a";
      const detail = String((wifiSummary && wifiSummary.detail) || "").trim();
      const rows = [
        {{ key: "RSSI", value: rssiText }},
      ];
      const rowsHtml = rows
        .map((row) => `<div class="wifi-ticker-row"><span class="wifi-ticker-key">${{escAttr(row.key)}}:</span><span class="wifi-ticker-val">${{escAttr(row.value)}}</span></div>`)
        .join("");
      const titleParts = [];
      if (isCanonicalNodeId(localId)) {{
        titleParts.push(`node ${{telemetry.nodeName}} (${{localId}})`);
      }} else {{
        titleParts.push(`node ${{telemetry.nodeName}}`);
      }}
      titleParts.push(`ssid "${{ssid}}"`);
      titleParts.push(detail || "wifi status unavailable");
      return {{
        text: compact,
        rows,
        rows_html: rowsHtml,
        title: titleParts.join(" | "),
        rssi_dbm: rssi,
      }};
    }}

    function buildGpsTickerSummary(state = latestState) {{
      const safeState = (state && typeof state === "object") ? state : {{}};
      const telemetry = resolveLocalNodeTelemetry(safeState);
      const localId = telemetry.localId;
      const localState = settingsLocalStateFrom(safeState);
      const localInfo = localState && typeof localState === "object" && localState.local_node_info && typeof localState.local_node_info === "object"
        ? localState.local_node_info
        : null;
      const nodePosition = telemetry && telemetry.localNode && typeof telemetry.localNode.position === "object"
        ? telemetry.localNode.position
        : null;
      const positionCandidates = [
        localState && localState.local_position,
        localState && localState.localPosition,
        localState && localState.local_node_position,
        localState && localState.localNodePosition,
        localState && localState.position,
        localInfo && localInfo.position,
        nodePosition,
      ].filter((candidate) => candidate && typeof candidate === "object" && !Array.isArray(candidate));

      const firstValue = (paths) => firstNestedValue(positionCandidates, paths);
      const firstFiniteNumber = (paths) => firstFiniteNestedNumber(positionCandidates, paths);

      let lat = Number(telemetry && telemetry.lat);
      let lon = Number(telemetry && telemetry.lon);
      if (!isValidMapCoord(lat, lon)) {{
        for (const candidate of positionCandidates) {{
          const candLat = coordinateValueFromSpecs(candidate, [
            {{ key: "lat" }},
            {{ key: "latitude" }},
            {{ key: "latitude_i", scale: 1e-7 }},
            {{ key: "latitudeI", scale: 1e-7 }},
          ]);
          const candLon = coordinateValueFromSpecs(candidate, [
            {{ key: "lon" }},
            {{ key: "lng" }},
            {{ key: "longitude" }},
            {{ key: "longitude_i", scale: 1e-7 }},
            {{ key: "longitudeI", scale: 1e-7 }},
          ]);
          if (isValidMapCoord(candLat, candLon)) {{
            lat = Number(candLat);
            lon = Number(candLon);
            break;
          }}
        }}
      }}
      const gpsFix = isValidMapCoord(lat, lon);
      const fixValue = gpsFix
        ? "fix"
        : (telemetry.gpsCapable ? "ready" : "n/a");
      const posText = gpsFix ? `${{lat.toFixed(5)}}, ${{lon.toFixed(5)}}` : "n/a";

      const altitude = firstFiniteNumber([
        "altitude",
        "altitude_m",
        "altitudeM",
        "alt",
      ]);
      const sats = firstFiniteNumber([
        "sats_in_view",
        "satsInView",
        "satellites",
        "num_satellites",
        "numSatellites",
      ]);
      const hdop = firstFiniteNumber(["hdop", "h_dop"]);
      const pdop = firstFiniteNumber(["pdop", "p_dop"]);
      const precisionBits = firstFiniteNumber(["precision_bits", "precisionBits"]);
      const accuracyMeters = firstFiniteNumber(["accuracy", "gps_accuracy", "horizontal_accuracy", "horizontalAccuracy"]);
      const speedMps = firstFiniteNumber([
        "ground_speed",
        "groundSpeed",
        "ground_speed_mps",
        "speed",
        "speed_mps",
      ]);
      const trackDegrees = firstFiniteNumber([
        "ground_track",
        "groundTrack",
        "heading",
        "bearing",
      ]);

      const precisionText = Number.isFinite(hdop) && hdop > 0
        ? `HDOP ${{formatTickerNumber(hdop, 1)}}`
        : (Number.isFinite(pdop) && pdop > 0
          ? `PDOP ${{formatTickerNumber(pdop, 1)}}`
          : (Number.isFinite(accuracyMeters) && accuracyMeters > 0
            ? `${{formatTickerNumber(accuracyMeters, 1)}}m`
            : (Number.isFinite(precisionBits) && precisionBits > 0
              ? `${{Math.round(precisionBits)}} bits`
              : null)));
      const speedText = Number.isFinite(speedMps) && speedMps >= 0
        ? `${{formatTickerNumber(speedMps, 1)}} m/s`
        : null;
      const trackText = Number.isFinite(trackDegrees)
        ? `${{Math.round(trackDegrees)}}°`
        : null;
      const fixUnix = latestUnixTimestamp(
        firstValue([
          "time",
          "timestamp",
          "timestamp_unix",
          "timestampUnix",
          "time_unix",
          "timeUnix",
          "position_time",
          "positionTime",
        ]),
        telemetry && telemetry.lastSeenUnix
      );
      const seenText = Number.isFinite(fixUnix)
        ? savedDetailAge(fixUnix, Math.floor(Date.now() / 1000))
        : telemetry.lastSeenText;

      const rows = [
        {{ key: "Fix", value: fixValue }},
        {{ key: "Pos", value: posText }},
      ];
      if (Number.isFinite(altitude)) rows.push({{ key: "Alt", value: `${{Math.round(altitude)}}m` }});
      if (Number.isFinite(sats) && sats >= 0) rows.push({{ key: "Sats", value: String(Math.round(sats)) }});
      if (precisionText) rows.push({{ key: "Prec", value: precisionText }});
      if (speedText) rows.push({{ key: "Speed", value: speedText }});
      if (trackText) rows.push({{ key: "Track", value: trackText }});
      rows.push({{ key: "Seen", value: seenText || "n/a" }});

      const rowsHtml = rows
        .map((row) => `<div class="node-ticker-row"><span class="node-ticker-key">${{escAttr(row.key)}}:</span><span class="node-ticker-val">${{escAttr(row.value)}}</span></div>`)
        .join("");
      const titleParts = [];
      if (isCanonicalNodeId(localId)) {{
        titleParts.push(`node ${{telemetry.nodeName}} (${{localId}})`);
      }} else {{
        titleParts.push(`node ${{telemetry.nodeName}}`);
      }}
      titleParts.push(gpsFix ? `position ${{posText}}` : "position unavailable");
      if (Number.isFinite(altitude)) titleParts.push(`alt ${{Math.round(altitude)}}m`);
      if (Number.isFinite(sats) && sats >= 0) titleParts.push(`sats ${{Math.round(sats)}}`);
      if (precisionText) titleParts.push(`precision ${{precisionText}}`);
      if (speedText) titleParts.push(`speed ${{speedText}}`);
      if (trackText) titleParts.push(`track ${{trackText}}`);
      titleParts.push(`last seen ${{seenText || "n/a"}}`);

      return {{
        text: rows.map((row) => `${{row.key}} ${{row.value}}`).join(" · "),
        rows,
        rows_html: rowsHtml,
        title: titleParts.join(" | "),
      }};
    }}

    function buildNodeTickerSummary(state = latestState) {{
      const telemetry = resolveLocalNodeTelemetry(state);
      const localId = telemetry.localId;
      const latestSignal = resolveLatestRadioSignalSnapshot(state);
      const snrDbRaw = Number(
        (latestSignal && latestSignal.snrDb != null)
          ? latestSignal.snrDb
          : telemetry.snrDb
      );
      const snrDb = Number.isFinite(snrDbRaw)
        ? Math.round(snrDbRaw * 10) / 10
        : null;
      const rssiDbmRaw = Number(
        (latestSignal && latestSignal.rssiDbm != null)
          ? latestSignal.rssiDbm
          : telemetry.rssiDbm
      );
      const rssiDbm = Number.isFinite(rssiDbmRaw) ? Math.trunc(rssiDbmRaw) : null;
      const hopsText = Number.isFinite(telemetry.hops) ? String(telemetry.hops) : "n/a";
      const routeText = Number.isFinite(telemetry.hops)
        ? (telemetry.hops <= 0 ? "direct" : `${{telemetry.hops}}-hop`)
        : "n/a";
      const snrText = Number.isFinite(snrDb)
        ? `${{formatTickerNumber(snrDb, 1)}}dB`
        : "n/a";
      const rssiText = Number.isFinite(rssiDbm)
        ? `${{rssiDbm}}dBm`
        : "n/a";
      const rowPrefs = nodeTickerRowPreferences();
      const rows = [
      ];
      if (rowPrefs.snr) rows.push({{ key: "SNR", value: snrText }});
      if (rowPrefs.rssi) rows.push({{ key: "RSSI", value: rssiText }});
      if (rowPrefs.route) rows.push({{ key: "Route", value: routeText }});
      if (rowPrefs.hops) rows.push({{ key: "Hops", value: hopsText }});
      const rowsHtml = rows
        .map((row) => `<div class="node-ticker-row"><span class="node-ticker-key">${{escAttr(row.key)}}:</span><span class="node-ticker-val">${{escAttr(row.value)}}</span></div>`)
        .join("");

      const compactParts = [];
      if (rssiText !== "n/a") compactParts.push(rssiText);
      if (snrText !== "n/a") compactParts.push(snrText);
      const text = compactParts.join(" · ") || "Signal n/a";

      const titleParts = [];
      if (isCanonicalNodeId(localId)) {{
        titleParts.push(`node ${{telemetry.nodeName}} (${{localId}})`);
      }} else {{
        titleParts.push(`node ${{telemetry.nodeName}}`);
      }}
      titleParts.push(`rssi ${{rssiText}}`);
      titleParts.push(`snr ${{snrText}}`);
      if (Number.isFinite(telemetry.hops)) {{
        titleParts.push(`hops ${{telemetry.hops}}`);
      }}
      titleParts.push(`route ${{routeText}}`);
      titleParts.push(`LoRa preset ${{telemetry.presetText}}`);

      return {{
        text: text || "n/a",
        rows,
        rows_html: rowsHtml,
        title: titleParts.join(" | "),
        has_rows: rows.length > 0,
        snr_db: snrDb,
        rssi_dbm: rssiDbm,
      }};
    }}

    function buildSystemTickerSummary(state = latestState) {{
      const safeState = (state && typeof state === "object") ? state : {{}};
      const localState = settingsLocalStateFrom(safeState);
      const localInfo = localState && typeof localState === "object" && localState.local_node_info && typeof localState.local_node_info === "object"
        ? localState.local_node_info
        : null;
      const myInfo = safeState.my_info && typeof safeState.my_info === "object"
        ? safeState.my_info
        : null;
      const metadata = safeState.metadata && typeof safeState.metadata === "object"
        ? safeState.metadata
        : null;

      const firstValue = (roots, paths) => firstNestedValue(roots, paths);
      const firstFiniteNumber = (roots, paths) => firstFiniteNestedNumber(roots, paths);

      const localStatsCandidate = firstValue([localState, localInfo], [
        "local_stats",
        "localStats",
      ]);
      const localStats = localStatsCandidate && typeof localStatsCandidate === "object"
        ? localStatsCandidate
        : null;
      const localMetrics = localInfo
        ? (localInfo.deviceMetrics || localInfo.device_metrics || localInfo.metrics || null)
        : null;
      const memoryInfo = firstValue([localStats, localMetrics, localInfo], [
        "memory",
        "memory_info",
        "system",
        "system_metrics",
      ]);

      const normalizePercent = (rawValue) => {{
        const num = Number(rawValue);
        if (!Number.isFinite(num)) return null;
        let percent = null;
        if (num > 0 && num <= 1) {{
          percent = num * 100;
        }} else if (num > 1 && num <= 100) {{
          percent = num;
        }}
        if (!Number.isFinite(percent) || percent <= 0) return null;
        return Math.max(0, Math.min(100, percent));
      }};
      const percentText = (rawValue) => {{
        const percent = normalizePercent(rawValue);
        if (!Number.isFinite(percent)) return "n/a";
        const digits = percent < 10 && !Number.isInteger(percent) ? 1 : 0;
        return `${{formatTickerNumber(percent, digits)}}%`;
      }};

      const heapValue = firstValue([memoryInfo, localStats, localMetrics, localInfo], [
        "heap",
        "heap_percent",
        "heapPercent",
        "heap_usage",
        "heapUsage",
        "heap_usage_percent",
        "heapUsagePercent",
      ]);
      const heapTotalBytes = firstFiniteNumber([localStats, localInfo], [
        "heap_total_bytes",
        "heapTotalBytes",
        "localStats.heap_total_bytes",
        "localStats.heapTotalBytes",
        "local_stats.heap_total_bytes",
        "local_stats.heapTotalBytes",
      ]);
      const heapFreeBytes = firstFiniteNumber([localStats, localInfo], [
        "heap_free_bytes",
        "heapFreeBytes",
        "localStats.heap_free_bytes",
        "localStats.heapFreeBytes",
        "local_stats.heap_free_bytes",
        "local_stats.heapFreeBytes",
      ]);
      const heapDerivedPercent = (
        Number.isFinite(heapTotalBytes)
        && Number.isFinite(heapFreeBytes)
        && heapTotalBytes > 0
        && heapFreeBytes >= 0
        && heapFreeBytes <= heapTotalBytes
      )
        ? ((heapTotalBytes - heapFreeBytes) / heapTotalBytes) * 100
        : null;
      const psramValue = firstValue([memoryInfo, localStats, localMetrics, localInfo], [
        "psram",
        "psram_percent",
        "psramPercent",
        "psram_usage",
        "psramUsage",
        "psram_usage_percent",
        "psramUsagePercent",
      ]);
      const flashValue = firstValue([memoryInfo, localStats, localMetrics, localInfo], [
        "flash",
        "flash_percent",
        "flashPercent",
        "flash_usage",
        "flashUsage",
        "flash_usage_percent",
        "flashUsagePercent",
      ]);

      const firmwareValue = firstValue([localInfo, myInfo], [
        "firmware_version",
        "firmwareVersion",
        "user.firmware_version",
        "user.firmwareVersion",
        "version",
        "hw_version",
        "hwVersion",
      ]);
      const firmwareText = String(firmwareValue == null ? "" : firmwareValue).trim() || "n/a";
      const metadataVersionValue = firstValue([metadata], [
        "firmware_version",
        "firmwareVersion",
        "version",
      ]);
      const metadataVersionText = String(metadataVersionValue == null ? "" : metadataVersionValue).trim();
      const resolvedVersionText = firmwareText !== "n/a"
        ? firmwareText
        : (metadataVersionText || "n/a");
      const hwModelValue = firstValue([localInfo, myInfo, metadata], [
        "user.hwModel",
        "user.hw_model",
        "hwModel",
        "hw_model",
        "hardware_model",
        "device_model",
        "deviceModel",
        "board",
      ]);
      const hwModelText = String(hwModelValue == null ? "" : hwModelValue).trim() || "n/a";
      const resolvedHeapValue = heapValue != null ? heapValue : heapDerivedPercent;
      const heapText = percentText(resolvedHeapValue);
      const psramText = percentText(psramValue);
      const flashText = percentText(flashValue);
      const rows = [];
      if (heapText !== "n/a") {{
        rows.push({{ key: "Heap", value: heapText }});
      }}
      if (psramText !== "n/a") {{
        rows.push({{ key: "PSRAM", value: psramText }});
      }}
      if (flashText !== "n/a") {{
        rows.push({{ key: "Flash", value: flashText }});
      }}
      if (resolvedVersionText !== "n/a") {{
        rows.push({{ key: "Ver", value: resolvedVersionText }});
      }}
      if (hwModelText !== "n/a") {{
        rows.push({{ key: "HW", value: hwModelText }});
      }}
      const rowsHtml = rows
        .map((row) => `<div class="node-ticker-row"><span class="node-ticker-key">${{escAttr(row.key)}}:</span><span class="node-ticker-val">${{escAttr(row.value)}}</span></div>`)
        .join("");
      const titleParts = rows.map((row) => `${{row.key}}=${{row.value}}`);
      return {{
        rows,
        rows_html: rowsHtml,
        text: rows.length
          ? rows.map((row) => `${{row.key}} ${{row.value}}`).join(" · ")
          : "n/a",
        title: rows.length
          ? titleParts.join(" | ")
          : "System metrics not exposed by this radio/feed",
      }};
    }}

    function buildRadioTrafficSnapshot(traffic, localNodeId, nowUnix = Math.floor(Date.now() / 1000), windowSec = 120) {{
      const packets = Array.isArray(traffic && traffic.recent_packets) ? traffic.recent_packets : [];
      let rxRecent = 0;
      let txRecent = 0;
      let lastPacketUnix = null;
      const windowSeconds = Math.max(30, Math.floor(Number(windowSec) || 120));
      for (const packet of packets) {{
        const summary = (packet && typeof packet.summary === "object") ? packet.summary : packet;
        const packetUnix = latestUnixTimestamp(
          summary && summary.captured_at,
          summary && summary.rx_time,
          summary && summary.time,
          packet && packet.captured_at,
          packet && packet.rx_time,
          packet && packet.time,
        );
        if (Number.isFinite(packetUnix) && packetUnix > 0) {{
          if (!Number.isFinite(lastPacketUnix) || packetUnix > lastPacketUnix) {{
            lastPacketUnix = packetUnix;
          }}
        }}
        if (!Number.isFinite(packetUnix) || packetUnix <= 0) continue;
        if ((nowUnix - packetUnix) > windowSeconds) continue;

        const fromId = normalizeNodeId(
          summary && (summary.from_id ?? summary.fromId ?? summary.from)
        );
        const toId = normalizeNodeId(
          summary && (summary.to_id ?? summary.toId ?? summary.to)
        );
        const isLocalTx = isCanonicalNodeId(localNodeId) && fromId === localNodeId;
        const isDirectToLocal = isCanonicalNodeId(localNodeId) && toId === localNodeId;
        const heardFromPeer = isCanonicalNodeId(fromId) && (!isCanonicalNodeId(localNodeId) || fromId !== localNodeId);
        if (isLocalTx) {{
          txRecent += 1;
        }} else if (isDirectToLocal || heardFromPeer) {{
          rxRecent += 1;
        }}
      }}
      return {{
        rxRecent,
        txRecent,
        lastPacketUnix,
        windowSeconds,
      }};
    }}

    function buildTargetRadioStatus(state = latestState) {{
      const safeState = (state && typeof state === "object") ? state : {{}};
      const nowUnix = Math.floor(Date.now() / 1000);
      const localStateError = trimInlineError(safeState.local_state_error || "");
      const trackerError = trimInlineError(safeState.tracker_error || "");
      const pollError = trimInlineError(lastPollError || "");
      const pollErrorActive = !!pollError
        && Number.isFinite(lastPollErrorUnix)
        && lastPollErrorUnix > 0
        && (nowUnix - lastPollErrorUnix) <= Math.max(120, Math.round((refreshMs / 1000) * 6));
      const pollSuccessAge = Number.isFinite(lastPollSuccessUnix) && lastPollSuccessUnix > 0
        ? Math.max(0, nowUnix - lastPollSuccessUnix)
        : null;
      const pollLikelyLost = pollErrorActive
        && (!Number.isFinite(pollSuccessAge) || pollSuccessAge > Math.max(20, Math.round((refreshMs / 1000) * 4)));

      const localId = resolveLocalNodeId(safeState);
      const traffic = (safeState.traffic && typeof safeState.traffic === "object") ? safeState.traffic : {{}};
      const trafficSnap = buildRadioTrafficSnapshot(traffic, localId, nowUnix, 120);
      const trafficText = `RX ${{trafficSnap.rxRecent}} / TX ${{trafficSnap.txRecent}} (2m)`;
      const trafficCompactText = `RX ${{trafficSnap.rxRecent}} TX ${{trafficSnap.txRecent}}`;
      const lastActivityText = Number.isFinite(trafficSnap.lastPacketUnix)
        ? savedDetailAge(trafficSnap.lastPacketUnix, nowUnix)
        : "n/a";
      const lastActivityCompact = String(lastActivityText).replace(/\s+ago$/, "");
      const activityText = `last activity ${{lastActivityText}}`;

      const errors = [];
      if (localStateError) errors.push(`local state: ${{localStateError}}`);
      if (trackerError) errors.push(`tracker: ${{trackerError}}`);
      if (pollErrorActive) errors.push(`poll: ${{pollError}}`);
      const errorSummary = errors.join(" | ");
      const trackerReportsLost = /radio link lost/i.test(trackerError);

      if (!isCanonicalNodeId(localId)) {{
        const detail = errorSummary || "local radio id unavailable";
        return {{
          key: "lost",
          text: `Lost · ${{lastActivityCompact}} · ${{trafficCompactText}}`,
          title: `Local radio unavailable. ${{detail}}`,
        }};
      }}

      const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
      const selfNode = nodes.find((node) => normalizeNodeId(node && node.id) === localId) || null;
      const historyCapsById = new Map(
        Object.entries((safeState.history_caps && typeof safeState.history_caps === "object") ? safeState.history_caps : {{}})
          .map(([rawNodeId, caps]) => [normalizeNodeId(rawNodeId), caps])
          .filter(([nodeId, caps]) => isSelectableNodeId(nodeId) && caps && typeof caps === "object")
      );
      const caps = historyCapsById.get(localId) || null;
      const chatMessages = Array.isArray(traffic.recent_chat) ? traffic.recent_chat : [];
      const latestChatTouchByNode = mapLatestChatTouchInfo(chatMessages);
      const freshness = resolveNodeFreshness(selfNode, caps, null, latestChatTouchByNode.get(localId) || null);
      const liveFreshnessUnix = Number(freshness.unix);
      const trafficFreshnessUnix = Number(trafficSnap.lastPacketUnix);
      const statusFreshnessCandidates = [];
      if (Number.isFinite(liveFreshnessUnix) && liveFreshnessUnix > 0) {{
        statusFreshnessCandidates.push(Math.trunc(liveFreshnessUnix));
      }}
      if (Number.isFinite(trafficFreshnessUnix) && trafficFreshnessUnix > 0) {{
        statusFreshnessCandidates.push(Math.trunc(trafficFreshnessUnix));
      }}
      const statusFreshnessUnix = statusFreshnessCandidates.length > 0
        ? Math.max(...statusFreshnessCandidates)
        : null;
      const freshnessKey = normalizeFreshnessKey(freshnessStatus(statusFreshnessUnix, nowUnix));
      if (pollLikelyLost) {{
        const detail = errorSummary || "state polling failed";
        return {{
          key: "lost",
          text: `Lost · ${{lastActivityCompact}} · ${{trafficCompactText}}`,
          title: `Dashboard polling is stale (${{
            Number.isFinite(pollSuccessAge) ? `${{pollSuccessAge}}s since last success` : "no successful poll yet"
          }}). ${{detail}} | ${{trafficText}} | ${{activityText}}`,
        }};
      }}
      if (trackerReportsLost) {{
        const detail = errorSummary || trackerError;
        return {{
          key: "lost",
          text: `Lost · ${{lastActivityCompact}} · ${{trafficCompactText}}`,
          title: `Meshtastic interface reported radio disconnect. ${{detail || "radio link lost"}} | ${{trafficText}} | ${{activityText}}`,
        }};
      }}

      let key = freshnessKey;
      let label = "Unknown";
      if (freshnessKey === "online") label = "Active";
      else if (freshnessKey === "warn") label = "Aging";
      else if (freshnessKey === "stale") label = "Stale";

      const text = `${{label}} · ${{lastActivityCompact}} · ${{trafficCompactText}}`;
      const statusUsesTraffic = Number.isFinite(statusFreshnessUnix)
        && Number.isFinite(trafficFreshnessUnix)
        && Math.trunc(statusFreshnessUnix) === Math.trunc(trafficFreshnessUnix)
        && (!Number.isFinite(liveFreshnessUnix) || trafficFreshnessUnix >= liveFreshnessUnix);
      const lastSeenTitle = Number.isFinite(statusFreshnessUnix)
        ? `last seen ${{savedDetailAge(statusFreshnessUnix, nowUnix)}}${{statusUsesTraffic ? " (packet activity)" : ""}}`
        : "last seen n/a";
      return {{
        key,
        text,
        title: `${{localId}} | ${{label}} | ${{activityText}} | ${{trafficText}} | ${{lastSeenTitle}}${{errorSummary ? ` | ${{errorSummary}}` : ""}}`,
      }};
    }}

    function renderTargetRadioStatus(state = latestState) {{
      const el = document.getElementById("m-target-radio-status");
      if (!(el instanceof HTMLElement)) return;
      const status = buildTargetRadioStatus(state);
      const cleanKey = String(status && status.key ? status.key : "unknown").toLowerCase();
      const allowed = new Set(["online", "warn", "stale", "lost", "unknown"]);
      const key = allowed.has(cleanKey) ? cleanKey : "unknown";
      let toneKey = "warn";
      if (key === "online") toneKey = "online";
      else if (key === "lost") toneKey = "lost";
      el.classList.remove("status-online", "status-warn", "status-stale", "status-lost", "status-unknown");
      el.classList.add(`status-${{toneKey}}`);
      el.textContent = status && status.text ? String(status.text) : "n/a";
      el.title = status && status.title ? String(status.title) : "Radio status unavailable";
    }}

    function computeNodeFreshnessUnix(node, caps = null, chatTouch = null) {{
      const candidates = [];
      const live = nodeLastHeardUnix(node);
      if (Number.isFinite(live) && live > 0) {{
        candidates.push(Math.trunc(live));
      }}
      const capsUnix = Number(caps && caps.last_seen_unix);
      if (Number.isFinite(capsUnix) && capsUnix > 0) {{
        candidates.push(Math.trunc(capsUnix));
      }}
      const chatUnix = Number(chatTouch && chatTouch.unix);
      if (Number.isFinite(chatUnix) && chatUnix > 0) {{
        candidates.push(Math.trunc(chatUnix));
      }}
      if (candidates.length === 0) return null;
      return Math.max(...candidates);
    }}

    function syncFavoriteOnlineNotices(
      state = latestState,
      nodesById = null,
      capsById = null,
      latestChatTouchByNode = null,
      nowUnix = Math.floor(Date.now() / 1000)
    ) {{
      const safeState = state && typeof state === "object" ? state : {{}};
      const nodeMap = nodesById instanceof Map
        ? nodesById
        : new Map(
            (Array.isArray(safeState.nodes) ? safeState.nodes : [])
              .map((node) => [normalizeNodeId(node && node.id), node])
          );
      const capsMap = capsById instanceof Map
        ? capsById
        : new Map(
            Object.entries((safeState.history_caps && typeof safeState.history_caps === "object") ? safeState.history_caps : {{}})
              .map(([rawNodeId, caps]) => [normalizeNodeId(rawNodeId), caps])
              .filter(([nodeId, caps]) => isSelectableNodeId(nodeId) && caps && typeof caps === "object")
          );
      const chatTouchMap = latestChatTouchByNode instanceof Map
        ? latestChatTouchByNode
        : mapLatestChatTouchInfo(
            Array.isArray(safeState.traffic && safeState.traffic.recent_chat)
              ? safeState.traffic.recent_chat
              : []
          );

      for (const nodeId of Array.from(favoriteFreshnessByNodeId.keys())) {{
        if (!favoriteNodeIds.has(nodeId)) {{
          favoriteFreshnessByNodeId.delete(nodeId);
        }}
      }}

      const bootstrap = !favoriteFreshnessHydrated;
      for (const favoriteId of favoriteNodeIds) {{
        const nodeId = normalizeNodeId(favoriteId);
        if (!isSelectableNodeId(nodeId)) continue;
        const node = nodeMap.get(nodeId);
        const caps = capsMap.get(nodeId);
        const chatTouch = chatTouchMap.get(nodeId) || null;
        const lastSeenUnix = computeNodeFreshnessUnix(node, caps, chatTouch);
        const status = normalizeFreshnessKey(freshnessStatus(lastSeenUnix, nowUnix));
        const previousStatus = favoriteFreshnessByNodeId.has(nodeId)
          ? String(favoriteFreshnessByNodeId.get(nodeId) || "")
          : "";
        favoriteFreshnessByNodeId.set(nodeId, status);
        if (bootstrap || !previousStatus || previousStatus === "online" || status !== "online") {{
          continue;
        }}
        const displayName = preferredNodeName(node) || nodeNameCache.get(nodeId) || nodeId;
        const whenText = Number.isFinite(lastSeenUnix)
          ? savedDetailAge(lastSeenUnix, nowUnix)
          : "just now";
        const noticeKeyUnix = Number.isFinite(lastSeenUnix) ? Math.trunc(lastSeenUnix) : Math.trunc(nowUnix);
        trackChatChangeNotice({{
          key: `favorite-online:${{nodeId}}:${{noticeKeyUnix}}`,
          focusKey: nodeId,
          channel: "all",
          targetView: "saved",
          sender: displayName,
          preview: `starred node is online (${{nodeId}}, seen ${{whenText}})`,
          kind: "status",
          // Keep these visible even in "Self" notification scope.
          selfRelevant: true,
          unix: noticeKeyUnix,
        }});
      }}
      favoriteFreshnessHydrated = true;
    }}

    function tickFreshnessUI(state = latestState) {{
      if (!state || typeof state !== "object") return;
      const nodes = Array.isArray(state.nodes) ? state.nodes : [];
      const nodesById = new Map(
        nodes.map((node) => [normalizeNodeId(node && node.id), node])
      );
      const capsById = new Map(
        Object.entries((state.history_caps && typeof state.history_caps === "object") ? state.history_caps : {{}})
          .map(([rawNodeId, caps]) => [normalizeNodeId(rawNodeId), caps])
          .filter(([nodeId, caps]) => isSelectableNodeId(nodeId) && caps && typeof caps === "object")
      );
      const traffic = (state.traffic && typeof state.traffic === "object") ? state.traffic : {{}};
      const chatMessages = Array.isArray(traffic.recent_chat) ? traffic.recent_chat : [];
      const latestChatTouchByNode = mapLatestChatTouchInfo(chatMessages);

      const nowUnix = Math.floor(Date.now() / 1000);
      syncFavoriteOnlineNotices(state, nodesById, capsById, latestChatTouchByNode, nowUnix);

      // Network explorer table freshness dots.
      const table = document.getElementById("nodes-table");
      if (table) {{
        for (const row of table.querySelectorAll("tbody tr[data-node-id]")) {{
          if (!(row instanceof HTMLElement)) continue;
          const nodeId = normalizeNodeId(row.dataset.nodeId || "");
          if (!isSelectableNodeId(nodeId)) continue;
          const node = nodesById.get(nodeId);
          const caps = capsById.get(nodeId);
          const chatTouch = latestChatTouchByNode.get(nodeId) || null;
          const lastSeenUnix = computeNodeFreshnessUnix(node, caps, chatTouch);
          const status = freshnessStatus(lastSeenUnix, nowUnix);
          applyFreshnessClass(row, status);
          const dot = row.querySelector(".node-status-dot");
          if (dot instanceof HTMLElement) {{
            applyFreshnessClass(dot, status);
          }}
        }}
      }}

      // Chat roster freshness + counts.
      const rosterList = document.getElementById("chat-room-list");
      let chatOnlineCount = 0;
      let chatWarnCount = 0;
      let chatStaleCount = 0;
      const rosterModel = Array.isArray(chatRosterModel) ? chatRosterModel : [];
      if (rosterModel.length > 0) {{
        for (const entry of rosterModel) {{
          const nodeId = normalizeNodeId(entry && entry.id);
          if (!isSelectableNodeId(nodeId)) continue;
          const node = nodesById.get(nodeId);
          const caps = capsById.get(nodeId);
          const chatTouch = latestChatTouchByNode.get(nodeId) || null;
          const lastSeenUnix = computeNodeFreshnessUnix(node, caps, chatTouch);
          const status = freshnessStatus(lastSeenUnix, nowUnix);
          const key = normalizeFreshnessKey(status);
          if (key === "online") chatOnlineCount += 1;
          else if (key === "warn") chatWarnCount += 1;
          else if (key === "stale") chatStaleCount += 1;
        }}
      }}

      if (rosterList) {{
        // Refresh the visible DOM list's status chips, but compute the counts from the
        // canonical roster model (so search filters don't skew the totals).
        let fallbackOnline = 0;
        let fallbackWarn = 0;
        let fallbackStale = 0;
        const useFallbackCounts = rosterModel.length === 0;
        for (const item of rosterList.querySelectorAll(".chat-member-item[data-node-id]")) {{
