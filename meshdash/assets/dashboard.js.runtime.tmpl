    let pollInFlight = false;
    let pollQueued = false;
    async function pollOnce() {{
      if (pollInFlight) {{
        pollQueued = true;
        return;
      }}
      pollInFlight = true;
      try {{
        await poll();
      }} finally {{
        pollInFlight = false;
        if (pollQueued) {{
          pollQueued = false;
          void pollOnce();
        }}
      }}
    }}

