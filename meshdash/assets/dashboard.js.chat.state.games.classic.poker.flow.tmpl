    function pokerTurnOrderFromDealer(playerCountRaw, dealerIndexRaw, activeSeatIndexesRaw = null) {{
      const playerCount = normalizePokerPlayerCount(playerCountRaw, pokerDefaultPlayers);
      const preferredSeats = Array.isArray(activeSeatIndexesRaw)
        ? Array.from(new Set(
          activeSeatIndexesRaw
            .map((value) => normalizePokerIndex(value, -1))
            .filter((value) => value >= 0 && value < playerCount)
        )).sort((a, b) => a - b)
        : [];
      const seats = preferredSeats.length > 0
        ? preferredSeats
        : Array.from({{ length: playerCount }}, (_unused, index) => index);
      if (seats.length < 1) return [];
      const dealerIndex = Math.max(-1, Math.min(playerCount - 1, normalizePokerIndex(dealerIndexRaw, -1)));
      let startPos = seats.findIndex((seatIndex) => seatIndex > dealerIndex);
      if (startPos < 0) startPos = 0;
      return Array.from({{ length: seats.length }}, (_unused, offset) => seats[(startPos + offset) % seats.length]);
    }}

    function pokerActiveSeatOrder(state) {{
      if (!state || typeof state !== "object" || !Array.isArray(state.seats)) return [];
      return state.seats
        .filter((seat) => Number(seat && seat.stack) > 0)
        .map((seat) => normalizePokerIndex(seat.seat, -1))
        .filter((seatIndex) => seatIndex >= 0)
        .sort((a, b) => a - b);
    }}

    function pokerNextActiveDealer(activeSeatOrderRaw, previousDealerRaw) {{
      const seats = Array.isArray(activeSeatOrderRaw) ? activeSeatOrderRaw : [];
      if (seats.length < 1) return -1;
      const previousDealer = normalizePokerIndex(previousDealerRaw, -1);
      for (const seatIndex of seats) {{
        if (seatIndex > previousDealer) return seatIndex;
      }}
      return seats[0];
    }}

    function pokerPostForcedChips(state, seatIndexRaw, amountRaw, label = "") {{
      if (!state || typeof state !== "object" || !Array.isArray(state.seats)) return 0;
      const seatIndex = normalizePokerIndex(seatIndexRaw, -1);
      if (seatIndex < 0) return 0;
      const seat = state.seats.find((row) => Number(row.seat) === seatIndex);
      if (!seat) return 0;
      const target = normalizePokerChipAmount(amountRaw, 0, 0, Number.MAX_SAFE_INTEGER);
      const stack = normalizePokerChipAmount(seat.stack, 0, 0, Number.MAX_SAFE_INTEGER);
      const posted = Math.min(stack, target);
      seat.stack = stack - posted;
      seat.contributed = normalizePokerChipAmount(seat.contributed, 0, 0, Number.MAX_SAFE_INTEGER) + posted;
      if (label) {{
        seat.blind_posted = posted > 0 ? `${{label}} ${{posted}}` : label;
      }}
      state.pot_total = normalizePokerChipAmount(state.pot_total, 0, 0, Number.MAX_SAFE_INTEGER) + posted;
      return posted;
    }}

    function pokerSeatByIndex(state, seatIndexRaw) {{
      if (!state || typeof state !== "object" || !Array.isArray(state.seats)) return null;
      const seatIndex = normalizePokerIndex(seatIndexRaw, -1);
      if (seatIndex < 0) return null;
      return state.seats.find((row) => Number(row.seat) === seatIndex) || null;
    }}

    function pokerLiveSeatIndexes(state) {{
      if (!state || typeof state !== "object" || !Array.isArray(state.seats)) return [];
      return state.seats
        .filter((seat) => !!seat && !!seat.in_hand && !seat.folded)
        .map((seat) => normalizePokerIndex(seat.seat, -1))
        .filter((seatIndex) => seatIndex >= 0)
        .sort((a, b) => a - b);
    }}

    function pokerBettingSeatOrder(state) {{
      if (!state || typeof state !== "object") return [];
      const liveSeats = pokerLiveSeatIndexes(state);
      const liveSet = new Set(liveSeats);
      if (liveSet.size < 1) return [];
      const sourceOrder = Array.isArray(state.betting_order) && state.betting_order.length > 0
        ? state.betting_order
        : pokerTurnOrderFromDealer(state.player_count, state.dealer_index, liveSeats);
      const order = sourceOrder.filter((seatIndex) => liveSet.has(Number(seatIndex)));
      return Array.from(new Set(order.map((seatIndex) => normalizePokerIndex(seatIndex, -1)).filter((seatIndex) => seatIndex >= 0)));
    }}

    function pokerActionableSeatOrder(state) {{
      return pokerBettingSeatOrder(state).filter((seatIndex) => {{
        const seat = pokerSeatByIndex(state, seatIndex);
        return !!(seat && seat.in_hand && !seat.folded && Number(seat.stack) > 0);
      }});
    }}

    function pokerCurrentCallAmount(state, seatRaw = null) {{
      const seat = seatRaw && typeof seatRaw === "object"
        ? seatRaw
        : pokerSeatByIndex(state, state && state.current_player);
      if (!seat) return 0;
      const currentBet = normalizePokerChipAmount(state && state.current_bet, 0, 0, Number.MAX_SAFE_INTEGER);
      const roundBet = normalizePokerChipAmount(seat.round_bet, 0, 0, Number.MAX_SAFE_INTEGER);
      return Math.max(0, currentBet - roundBet);
    }}

    function pokerResolveUncontestedWin(state) {{
      const liveSeats = pokerLiveSeatIndexes(state);
      if (liveSeats.length !== 1) return false;
      const winnerSeat = pokerSeatByIndex(state, liveSeats[0]);
      if (!winnerSeat) return false;
      const payout = normalizePokerChipAmount(state.pot_total, 0, 0, Number.MAX_SAFE_INTEGER);
      if (payout > 0) {{
        winnerSeat.stack = normalizePokerChipAmount(winnerSeat.stack, 0, 0, Number.MAX_SAFE_INTEGER) + payout;
      }}
      winnerSeat.last_payout = payout;
      state.pot_total = 0;
      state.winners = [Number(winnerSeat.seat)];
      state.phase = "showdown";
      state.current_player = -1;
      state.draw_order = [];
      state.draw_index = 0;
      state.betting_order = [];
      state.betting_index = 0;
      state.current_bet = 0;
      state.notice = payout > 0
        ? `${{winnerSeat.name}} wins ${{payout}} chips (all others folded).`
        : `${{winnerSeat.name}} wins (all others folded).`;
      return true;
    }}

    function pokerStartDrawPhase(state) {{
      if (!state || typeof state !== "object" || !Array.isArray(state.seats)) return;
      const liveSeats = pokerLiveSeatIndexes(state);
      for (const seat of state.seats) {{
        if (!seat || typeof seat !== "object") continue;
        seat.selected_discards = [];
        seat.draw_count = 0;
        seat.draw_done = !seat.in_hand || !!seat.folded;
        seat.round_acted = false;
      }}
      state.phase = "draw";
      state.current_bet = 0;
      state.betting_order = [];
      state.betting_index = 0;
      state.draw_order = pokerTurnOrderFromDealer(state.player_count, state.dealer_index, liveSeats);
      state.draw_index = 0;
      state.current_player = Number(state.draw_order[0] ?? -1);
      const currentSeat = pokerCurrentSeat();
      state.notice = currentSeat
        ? `Betting complete. ${{currentSeat.name}}: select cards, then Draw/Stand.`
        : "Betting complete.";
    }}

    function pokerAdvanceBettingTurn(state) {{
      if (!state || typeof state !== "object") return;
      const actionable = pokerActionableSeatOrder(state);
      if (actionable.length < 1) {{
        pokerStartDrawPhase(state);
        return;
      }}
      const allActed = actionable.every((seatIndex) => {{
        const seat = pokerSeatByIndex(state, seatIndex);
        return !!(seat && seat.round_acted);
      }});
      if (allActed) {{
        pokerStartDrawPhase(state);
        return;
      }}
      const order = pokerBettingSeatOrder(state);
      if (order.length < 1) {{
        pokerStartDrawPhase(state);
        return;
      }}
      let startIndex = Math.max(0, Math.trunc(Number(state.betting_index) || 0));
      if (startIndex >= order.length) startIndex = 0;
      for (let offset = 1; offset <= order.length; offset += 1) {{
        const orderIndex = (startIndex + offset) % order.length;
        const seatIndex = normalizePokerIndex(order[orderIndex], -1);
        const seat = pokerSeatByIndex(state, seatIndex);
        if (!seat || !seat.in_hand || seat.folded || Number(seat.stack) <= 0 || seat.round_acted) continue;
        state.betting_index = orderIndex;
        state.current_player = seatIndex;
        const callAmount = pokerCurrentCallAmount(state, seat);
        const cue = callAmount > 0
          ? `call ${{callAmount}}, raise, or fold.`
          : "check, bet, or fold.";
        state.notice = state.last_action
          ? `${{state.last_action}} ${{seat.name}} to act: ${{cue}}`
          : `${{seat.name}} to act: ${{cue}}`;
        return;
      }}
      pokerStartDrawPhase(state);
    }}

    function pokerDrawCard(state) {{
      if (!state || typeof state !== "object") return "";
      if (!Array.isArray(state.deck)) state.deck = [];
      if (!Array.isArray(state.discard_pile)) state.discard_pile = [];
      if (state.deck.length < 1 && state.discard_pile.length > 0) {{
        state.deck = shuffleCardDeck(state.discard_pile);
        state.discard_pile = [];
      }}
      const card = String(state.deck.pop() || "").trim().toUpperCase();
      return parseStandardCard(card) ? card : "";
    }}

    function dealPokerHand() {{
      const state = ensurePokerState();
      const playerCount = normalizePokerPlayerCount(state.player_count, pokerDefaultPlayers);
      const rules = normalizePokerRules(state, state);
      state.player_count = playerCount;
      state.starting_stack = rules.starting_stack;
      state.ante = rules.ante;
      state.small_blind = rules.small_blind;
      state.big_blind = rules.big_blind;
      state.seats = Array.from({{ length: playerCount }}, (_unused, index) => {{
        const seatRaw = state.seats[index];
        const seat = seatRaw && typeof seatRaw === "object" ? seatRaw : createPokerSeat(index, rules.starting_stack);
        return {{
          seat: index,
          name: String(seat.name || `Player ${{index + 1}}`).trim() || `Player ${{index + 1}}`,
          hand: [],
          selected_discards: [],
          draw_count: 0,
          draw_done: false,
          hand_eval: null,
          stack: normalizePokerChipAmount(seat.stack, rules.starting_stack, 0, Number.MAX_SAFE_INTEGER),
          contributed: 0,
          round_bet: 0,
          round_acted: false,
          folded: false,
          blind_posted: "",
          last_payout: 0,
          in_hand: false,
        }};
      }});
      const activeSeats = pokerActiveSeatOrder(state);
      state.winners = [];
      state.last_action = "";
      state.pot_total = 0;
      state.current_bet = 0;
      state.betting_order = [];
      state.betting_index = 0;
      state.draw_order = [];
      state.draw_index = 0;
      state.current_player = -1;
      if (activeSeats.length < pokerMinPlayers) {{
        state.deck = [];
        state.discard_pile = [];
        state.phase = "deal";
        state.notice = "Need at least 2 players with chips to deal a hand. Start a new table to reset busted seats.";
        if (activeLayoutView === "games") renderGamesView(latestState);
        return;
      }}
      state.deck = shuffleCardDeck(createStandardCardDeck());
      state.discard_pile = [];
      state.phase = "betting";
      state.hand_number = Math.max(0, Math.trunc(Number(state.hand_number) || 0)) + 1;
      state.dealer_index = pokerNextActiveDealer(activeSeats, state.dealer_index);

      if (rules.ante > 0) {{
        for (const seatIndex of activeSeats) {{
          pokerPostForcedChips(state, seatIndex, rules.ante);
        }}
      }}

      let smallBlindSeat = -1;
      let bigBlindSeat = -1;
      if (activeSeats.length === 2) {{
        smallBlindSeat = state.dealer_index;
        const headsUpOrder = pokerTurnOrderFromDealer(playerCount, state.dealer_index, activeSeats);
        bigBlindSeat = normalizePokerIndex(headsUpOrder[0], -1);
      }} else {{
        const blindOrder = pokerTurnOrderFromDealer(playerCount, state.dealer_index, activeSeats);
        smallBlindSeat = normalizePokerIndex(blindOrder[0], -1);
        bigBlindSeat = normalizePokerIndex(blindOrder[1], -1);
      }}
      let smallBlindPosted = 0;
      let bigBlindPosted = 0;
      if (smallBlindSeat >= 0 && rules.small_blind > 0) {{
        smallBlindPosted = pokerPostForcedChips(state, smallBlindSeat, rules.small_blind, "SB");
        const sbSeat = pokerSeatByIndex(state, smallBlindSeat);
        if (sbSeat) sbSeat.round_bet = normalizePokerChipAmount(sbSeat.round_bet, 0, 0, Number.MAX_SAFE_INTEGER) + smallBlindPosted;
      }}
      if (bigBlindSeat >= 0 && rules.big_blind > 0) {{
        bigBlindPosted = pokerPostForcedChips(state, bigBlindSeat, rules.big_blind, "BB");
        const bbSeat = pokerSeatByIndex(state, bigBlindSeat);
        if (bbSeat) bbSeat.round_bet = normalizePokerChipAmount(bbSeat.round_bet, 0, 0, Number.MAX_SAFE_INTEGER) + bigBlindPosted;
      }}
      state.current_bet = Math.max(smallBlindPosted, bigBlindPosted);

      for (let cardSlot = 0; cardSlot < pokerHandSize; cardSlot += 1) {{
        for (const seatIndex of activeSeats) {{
          const seat = state.seats.find((row) => Number(row.seat) === Number(seatIndex));
          if (!seat) continue;
          const card = pokerDrawCard(state);
          if (!card) continue;
          seat.hand.push(card);
          seat.in_hand = true;
        }}
      }}
      state.betting_order = pokerTurnOrderFromDealer(
        playerCount,
        rules.big_blind > 0 ? (bigBlindSeat >= 0 ? bigBlindSeat : state.dealer_index) : state.dealer_index,
        activeSeats
      );
      state.betting_index = 0;
      state.current_player = Number(state.betting_order[0] ?? -1);
      if (pokerActionableSeatOrder(state).length < 1) {{
        pokerStartDrawPhase(state);
        if (activeLayoutView === "games") renderGamesView(latestState);
        return;
      }}
      const currentSeat = state.seats.find((seat) => Number(seat.seat) === Number(state.current_player));
      const forcedBits = [];
      if (rules.ante > 0) forcedBits.push(`ante ${{rules.ante}}`);
      if (rules.small_blind > 0 || rules.big_blind > 0) forcedBits.push(`blinds ${{rules.small_blind}}/${{rules.big_blind}}`);
      const potSummary = state.pot_total > 0
        ? ` Pot ${{state.pot_total}}${{forcedBits.length > 0 ? ` after ${{forcedBits.join(" + ")}}` : ""}}.`
        : "";
      const callAmount = currentSeat ? pokerCurrentCallAmount(state, currentSeat) : 0;
      const actionPrompt = callAmount > 0 ? `call ${{callAmount}}, raise, or fold` : "check, bet, or fold";
      state.notice = currentSeat
        ? `Hand #${{state.hand_number}} dealt.${{potSummary}} ${{currentSeat.name}} to act: ${{actionPrompt}}.`
        : `Hand #${{state.hand_number}} dealt.${{potSummary}}`;
      if (activeLayoutView === "games") renderGamesView(latestState);
    }}

    function pokerCurrentSeat() {{
      const state = ensurePokerState();
      return state.seats.find((seat) => Number(seat.seat) === Number(state.current_player)) || null;
    }}

    function evaluateFiveCardHand(cardsRaw) {{
      const cards = Array.isArray(cardsRaw) ? cardsRaw.map((card) => parseStandardCard(card)).filter((card) => !!card) : [];
      if (cards.length !== pokerHandSize) {{
        return {{
          score: [0, 0, 0, 0, 0, 0],
          name: "Incomplete hand",
        }};
      }}
      const rankCounts = new Map();
      const suitCounts = new Map();
      for (const card of cards) {{
        rankCounts.set(card.rank_value, (rankCounts.get(card.rank_value) || 0) + 1);
        suitCounts.set(card.suit, (suitCounts.get(card.suit) || 0) + 1);
      }}
      const groups = Array.from(rankCounts.entries())
        .map(([rank, count]) => [Number(rank), Number(count)])
        .sort((a, b) => {{
          if (b[1] !== a[1]) return b[1] - a[1];
          return b[0] - a[0];
        }});
      const valuesDesc = cards
        .map((card) => Number(card.rank_value))
        .sort((a, b) => b - a);
      const uniqueDesc = Array.from(new Set(valuesDesc));
      const flush = suitCounts.size === 1;
      let straight = false;
      let straightHigh = 0;
      if (uniqueDesc.length === pokerHandSize) {{
        if (uniqueDesc[0] - uniqueDesc[uniqueDesc.length - 1] === (pokerHandSize - 1)) {{
          straight = true;
          straightHigh = uniqueDesc[0];
        }} else if (
          uniqueDesc[0] === 14
          && uniqueDesc[1] === 5
          && uniqueDesc[2] === 4
          && uniqueDesc[3] === 3
          && uniqueDesc[4] === 2
        ) {{
          straight = true;
          straightHigh = 5;
        }}
      }}

      if (straight && flush) {{
        return {{
          score: [8, straightHigh],
          name: `Straight flush (${pokerRankWord(straightHigh)} high)`,
        }};
      }}
      if (groups[0] && groups[0][1] === 4) {{
        const quad = groups[0][0];
        const kicker = groups[1] ? groups[1][0] : 0;
        return {{
          score: [7, quad, kicker],
          name: `Four of a kind (${{pokerRankWord(quad)}}s)`,
        }};
      }}
      if (groups[0] && groups[0][1] === 3 && groups[1] && groups[1][1] === 2) {{
        const trips = groups[0][0];
        const pair = groups[1][0];
        return {{
          score: [6, trips, pair],
          name: `Full house (${{pokerRankWord(trips)}}s over ${{pokerRankWord(pair)}}s)`,
        }};
      }}
      if (flush) {{
        return {{
          score: [5, ...valuesDesc],
          name: "Flush",
        }};
      }}
      if (straight) {{
        return {{
          score: [4, straightHigh],
          name: `Straight (${pokerRankWord(straightHigh)} high)`,
        }};
      }}
      if (groups[0] && groups[0][1] === 3) {{
        const trips = groups[0][0];
        const kickers = groups.slice(1).map((entry) => entry[0]).sort((a, b) => b - a);
        return {{
          score: [3, trips, ...kickers],
          name: `Three of a kind (${{pokerRankWord(trips)}}s)`,
        }};
      }}
      if (groups[0] && groups[0][1] === 2 && groups[1] && groups[1][1] === 2) {{
        const pairHigh = Math.max(groups[0][0], groups[1][0]);
        const pairLow = Math.min(groups[0][0], groups[1][0]);
        const kicker = groups[2] ? groups[2][0] : 0;
        return {{
          score: [2, pairHigh, pairLow, kicker],
          name: `Two pair (${{pokerRankWord(pairHigh)}}s and ${{pokerRankWord(pairLow)}}s)`,
        }};
      }}
      if (groups[0] && groups[0][1] === 2) {{
        const pair = groups[0][0];
        const kickers = groups.slice(1).map((entry) => entry[0]).sort((a, b) => b - a);
        return {{
          score: [1, pair, ...kickers],
          name: `One pair (${{pokerRankWord(pair)}}s)`,
        }};
      }}
      return {{
        score: [0, ...valuesDesc],
        name: `High card (${{pokerRankWord(valuesDesc[0])}})`,
      }};
    }}

    function comparePokerEvaluations(aEval, bEval) {{
      const aScore = Array.isArray(aEval && aEval.score) ? aEval.score : [];
      const bScore = Array.isArray(bEval && bEval.score) ? bEval.score : [];
      const count = Math.max(aScore.length, bScore.length);
      for (let index = 0; index < count; index += 1) {{
        const aValue = Number(aScore[index] || 0);
        const bValue = Number(bScore[index] || 0);
        if (aValue > bValue) return 1;
        if (aValue < bValue) return -1;
      }}
      return 0;
    }}

    function resolvePokerShowdown() {{
      const state = ensurePokerState();
      const evaluations = [];
      for (const seat of state.seats) {{
        seat.last_payout = 0;
        const inHand = !!seat.in_hand && Array.isArray(seat.hand) && seat.hand.length === pokerHandSize;
        if (!inHand) {{
          seat.hand_eval = null;
          continue;
        }}
        const handEval = evaluateFiveCardHand(seat.hand);
        seat.hand_eval = handEval;
        evaluations.push({{
          seat_index: seat.seat,
          name: seat.name,
          eval: handEval,
        }});
      }}
      if (evaluations.length < 1) {{
        state.winners = [];
        state.phase = "showdown";
        state.current_player = -1;
        state.draw_index = state.draw_order.length;
        state.pot_total = 0;
        state.notice = "Showdown complete.";
        return;
      }}
      evaluations.sort((a, b) => comparePokerEvaluations(b.eval, a.eval));
      const bestEval = evaluations[0] ? evaluations[0].eval : null;
      const winners = evaluations
        .filter((row) => comparePokerEvaluations(row.eval, bestEval) === 0)
        .map((row) => Number(row.seat_index))
        .sort((a, b) => a - b);
      const totalPot = normalizePokerChipAmount(state.pot_total, 0, 0, Number.MAX_SAFE_INTEGER);
      if (winners.length > 0 && totalPot > 0) {{
        const basePayout = Math.floor(totalPot / winners.length);
        let remainder = totalPot - (basePayout * winners.length);
        for (const seatIndex of winners) {{
          const seat = state.seats.find((row) => Number(row.seat) === seatIndex);
          if (!seat) continue;
          const extra = remainder > 0 ? 1 : 0;
          if (remainder > 0) remainder -= 1;
          const payout = basePayout + extra;
          seat.stack = normalizePokerChipAmount(seat.stack, 0, 0, Number.MAX_SAFE_INTEGER) + payout;
          seat.last_payout = payout;
        }}
      }}
      state.pot_total = 0;
      state.winners = winners;
      state.phase = "showdown";
      state.current_player = -1;
      state.draw_index = state.draw_order.length;
      if (winners.length === 1) {{
        const winnerSeat = state.seats.find((seat) => Number(seat.seat) === Number(winners[0]));
        const winnerLabel = winnerSeat ? winnerSeat.name : "Winner";
        const winnerEval = winnerSeat && winnerSeat.hand_eval ? winnerSeat.hand_eval.name : "best hand";
        const payout = winnerSeat ? normalizePokerChipAmount(winnerSeat.last_payout, 0, 0, Number.MAX_SAFE_INTEGER) : 0;
        state.notice = payout > 0
          ? `Showdown: ${{winnerLabel}} wins ${{payout}} chips with ${{winnerEval}}.`
          : `Showdown: ${{winnerLabel}} wins with ${{winnerEval}}.`;
      }} else if (winners.length > 1) {{
        const names = state.seats
          .filter((seat) => winners.includes(Number(seat.seat)))
          .map((seat) => seat.name);
        const sharedEval = bestEval && bestEval.name ? bestEval.name : "matching hands";
        const payoutSummary = state.seats
          .filter((seat) => winners.includes(Number(seat.seat)))
          .map((seat) => {{
            const payout = normalizePokerChipAmount(seat.last_payout, 0, 0, Number.MAX_SAFE_INTEGER);
            return payout > 0 ? `${{seat.name}} +${{payout}}` : "";
          }})
          .filter((value) => !!value)
          .join(", ");
        state.notice = payoutSummary
          ? `Showdown: tie between ${{names.join(", ")}} with ${{sharedEval}}. Split: ${{payoutSummary}}.`
          : `Showdown: tie between ${{names.join(", ")}} with ${{sharedEval}}.`;
      }} else {{
        state.notice = "Showdown complete.";
      }}
    }}

    function applyPokerBettingAction(actionRaw, amountRaw = null) {{
      const state = ensurePokerState();
      if (state.phase !== "betting") return;
      const action = String(actionRaw || "").trim().toLowerCase();
      if (!["check", "call", "bet", "raise", "fold"].includes(action)) return;
      const seat = pokerCurrentSeat();
      if (!seat || !seat.in_hand || seat.folded) return;
      const callAmount = pokerCurrentCallAmount(state, seat);
      const stackAmount = normalizePokerChipAmount(seat.stack, 0, 0, Number.MAX_SAFE_INTEGER);
      let summary = "";

      if (action === "fold") {{
        seat.folded = true;
        seat.in_hand = false;
        seat.draw_done = true;
        seat.selected_discards = [];
        seat.round_acted = true;
        summary = `${{seat.name}} folds.`;
      }} else if (action === "check") {{
        if (callAmount > 0) {{
          state.notice = `${{seat.name}} must call ${{callAmount}}, raise, or fold.`;
          if (activeLayoutView === "games") renderGamesView(latestState);
          return;
        }}
        seat.round_acted = true;
        summary = `${{seat.name}} checks.`;
      }} else if (action === "call") {{
        if (callAmount <= 0) {{
          seat.round_acted = true;
          summary = `${{seat.name}} checks.`;
        }} else {{
          const posted = pokerPostForcedChips(state, seat.seat, callAmount);
          seat.round_bet = normalizePokerChipAmount(seat.round_bet, 0, 0, Number.MAX_SAFE_INTEGER) + posted;
          seat.round_acted = true;
          summary = posted < callAmount
            ? `${{seat.name}} calls all-in for ${{posted}}.`
            : `${{seat.name}} calls ${{posted}}.`;
        }}
      }} else {{
        if (stackAmount <= 0) {{
          state.notice = `${{seat.name}} has no chips left.`;
          if (activeLayoutView === "games") renderGamesView(latestState);
          return;
        }}
        const fallbackRaise = Math.max(1, normalizePokerChipAmount(state.big_blind, 1, 1, Number.MAX_SAFE_INTEGER));
        const raiseBy = normalizePokerChipAmount(amountRaw, fallbackRaise, 1, Number.MAX_SAFE_INTEGER);
        const totalTarget = callAmount + raiseBy;
        const posted = pokerPostForcedChips(state, seat.seat, totalTarget);
        seat.round_bet = normalizePokerChipAmount(seat.round_bet, 0, 0, Number.MAX_SAFE_INTEGER) + posted;
        if (posted <= callAmount) {{
          seat.round_acted = true;
          summary = callAmount > 0
            ? `${{seat.name}} calls all-in for ${{posted}}.`
            : `${{seat.name}} is all-in for ${{posted}}.`;
        }} else {{
          const newBet = normalizePokerChipAmount(seat.round_bet, 0, 0, Number.MAX_SAFE_INTEGER);
          state.current_bet = Math.max(normalizePokerChipAmount(state.current_bet, 0, 0, Number.MAX_SAFE_INTEGER), newBet);
          for (const otherSeatIndex of pokerLiveSeatIndexes(state)) {{
            const otherSeat = pokerSeatByIndex(state, otherSeatIndex);
            if (!otherSeat || Number(otherSeat.seat) === Number(seat.seat)) continue;
            if (Number(otherSeat.stack) > 0) otherSeat.round_acted = false;
          }}
          seat.round_acted = true;
          const raisePortion = posted - callAmount;
          summary = callAmount > 0
            ? `${{seat.name}} raises by ${{raisePortion}} to ${{newBet}}.`
            : `${{seat.name}} bets ${{newBet}}.`;
        }}
      }}

      state.last_action = summary;
      if (pokerResolveUncontestedWin(state)) {{
        if (activeLayoutView === "games") renderGamesView(latestState);
        return;
      }}
      pokerAdvanceBettingTurn(state);
      if (activeLayoutView === "games") renderGamesView(latestState);
    }}

    function togglePokerDiscard(seatIndexRaw, cardIndexRaw) {{
      const state = ensurePokerState();
      if (state.phase !== "draw") return;
      const seatIndex = Math.trunc(Number(seatIndexRaw) || 0);
      const cardIndex = Math.trunc(Number(cardIndexRaw) || 0);
      if (seatIndex !== Number(state.current_player)) return;
      if (cardIndex < 0 || cardIndex >= pokerHandSize) return;
      const seat = state.seats.find((row) => Number(row.seat) === seatIndex);
      if (!seat) return;
      const clean = Array.from(new Set(
        (Array.isArray(seat.selected_discards) ? seat.selected_discards : [])
          .map((value) => normalizePokerIndex(value, -1))
          .filter((value) => value >= 0 && value < pokerHandSize)
      ));
      const currentSet = new Set(clean);
      if (currentSet.has(cardIndex)) {{
        currentSet.delete(cardIndex);
      }} else {{
        currentSet.add(cardIndex);
      }}
      seat.selected_discards = Array.from(currentSet).sort((a, b) => a - b);
      const selectedCount = seat.selected_discards.length;
      state.notice = selectedCount > 0
        ? `${{seat.name}} selected ${{selectedCount}} card${{selectedCount === 1 ? "" : "s"}} to replace.`
        : `${{seat.name}} is standing pat.`;
      if (activeLayoutView === "games") renderGamesView(latestState);
    }}

    function commitPokerDrawTurn() {{
      const state = ensurePokerState();
      if (state.phase !== "draw") {{
        dealPokerHand();
        return;
      }}
      const seat = pokerCurrentSeat();
      if (!seat) {{
        resolvePokerShowdown();
        if (activeLayoutView === "games") renderGamesView(latestState);
        return;
      }}
      const selected = Array.from(new Set(
        (Array.isArray(seat.selected_discards) ? seat.selected_discards : [])
          .map((value) => normalizePokerIndex(value, -1))
          .filter((value) => value >= 0 && value < pokerHandSize)
      )).sort((a, b) => a - b);
      let drewCount = 0;
      for (const handIndex of selected) {{
        const oldCard = String(seat.hand[handIndex] || "").trim().toUpperCase();
        if (parseStandardCard(oldCard)) {{
          state.discard_pile.push(oldCard);
        }}
        const nextCard = pokerDrawCard(state);
        if (nextCard) {{
          seat.hand[handIndex] = nextCard;
          drewCount += 1;
        }}
      }}
      seat.selected_discards = [];
      seat.draw_count = drewCount;
      seat.draw_done = true;
      state.last_action = drewCount > 0
        ? `${{seat.name}} drew ${{drewCount}} card${{drewCount === 1 ? "" : "s"}}.`
        : `${{seat.name}} stood pat.`;
      let nextDrawIndex = Math.max(0, Math.trunc(Number(state.draw_index) || 0)) + 1;
      while (nextDrawIndex < state.draw_order.length) {{
        const nextSeatIndex = normalizePokerIndex(state.draw_order[nextDrawIndex], -1);
        const nextSeat = state.seats.find((row) => Number(row.seat) === nextSeatIndex);
        if (nextSeat && !nextSeat.draw_done) {{
          break;
        }}
        nextDrawIndex += 1;
      }}
      if (nextDrawIndex < state.draw_order.length) {{
        state.draw_index = nextDrawIndex;
        state.current_player = normalizePokerIndex(state.draw_order[nextDrawIndex], -1);
        const nextSeat = pokerCurrentSeat();
        state.notice = nextSeat
          ? `${{state.last_action}} ${{nextSeat.name}}: select cards, then Draw/Stand.`
          : state.last_action;
      }} else {{
        resolvePokerShowdown();
      }}
      if (activeLayoutView === "games") renderGamesView(latestState);
    }}

    function startNewPokerGame(options = {{}}) {{
      const preferredCount = normalizePokerPlayerCount(
        options.player_count ?? options.playerCount ?? getPokerPlayerCountFromControl(),
        pokerDefaultPlayers
      );
      const controlRules = getPokerRulesFromControls();
      const preferredRules = normalizePokerRules({{
        starting_stack: options.starting_stack ?? options.startingStack,
        ante: options.ante,
        small_blind: options.small_blind ?? options.smallBlind,
        big_blind: options.big_blind ?? options.bigBlind,
      }}, controlRules);
      pokerState = createNewPokerState(preferredCount, preferredRules);
      const selectEl = document.getElementById("poker-player-count-select");
      if (selectEl instanceof HTMLSelectElement) {{
        selectEl.value = String(preferredCount);
      }}
      syncPokerRuleControls(preferredRules);
      const autoDeal = !(
        options
        && (options.auto_deal === false || options.autoDeal === false)
      );
      if (autoDeal) {{
        dealPokerHand();
      }} else if (activeLayoutView === "games") {{
        renderGamesView(latestState);
      }}
    }}

    function advancePokerPhase() {{
      const state = ensurePokerState();
      if (state.phase === "betting") {{
        const seat = pokerCurrentSeat();
        if (!seat) {{
          pokerAdvanceBettingTurn(state);
          if (activeLayoutView === "games") renderGamesView(latestState);
          return;
        }}
        const callAmount = seat ? pokerCurrentCallAmount(state, seat) : 0;
        applyPokerBettingAction(callAmount > 0 ? "call" : "check");
        return;
      }}
      if (state.phase === "draw") {{
        commitPokerDrawTurn();
        return;
      }}
      dealPokerHand();
    }}

