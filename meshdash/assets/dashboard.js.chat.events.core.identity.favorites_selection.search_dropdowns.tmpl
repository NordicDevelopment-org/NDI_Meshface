    function normalizeSearchQuery(value) {{
      return String(value == null ? "" : value).trim().toLowerCase();
    }}

    function nodeSearchKeywordText(nodeId, nodeName) {{
      const idKey = normalizeSearchQuery(nodeId);
      const nameKey = normalizeSearchQuery(nodeName);
      const noteEntry = (typeof nodeNoteEntry === "function")
        ? nodeNoteEntry(nodeId)
        : null;
      const noteKey = normalizeSearchQuery(
        noteEntry && noteEntry.note != null
          ? String(noteEntry.note).replace(/\s+/g, " ")
          : ""
      );
      return [idKey, nameKey, noteKey].filter(Boolean).join(" ");
    }}

    function matchesIdOrNameQuery(nodeId, nodeName, query) {{
      if (!query) return true;
      return nodeSearchKeywordText(nodeId, nodeName).includes(query);
    }}

    function closeSavedNodeSearchDropdown() {{
      if (savedNodeSearchBlurTimer !== null) {{
        clearTimeout(savedNodeSearchBlurTimer);
        savedNodeSearchBlurTimer = null;
      }}
      savedNodeSearchOpen = false;
      const dropdown = document.getElementById("saved-node-search-dropdown");
      if (dropdown instanceof HTMLElement) {{
        dropdown.hidden = true;
      }}
    }}

    function closeFavoriteMenuNodeSearchDropdown() {{
      if (favoriteMenuNodeSearchBlurTimer !== null) {{
        clearTimeout(favoriteMenuNodeSearchBlurTimer);
        favoriteMenuNodeSearchBlurTimer = null;
      }}
      favoriteMenuNodeSearchOpen = false;
      const dropdown = document.getElementById("favorite-menu-node-search-dropdown");
      if (dropdown instanceof HTMLElement) {{
        dropdown.hidden = true;
      }}
    }}

    function buildNodeSearchResults(state, query, limit = 250) {{
      const safeState = state && typeof state === "object" ? state : {{}};
      const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
      const nodeById = new Map();
      for (const node of nodes) {{
        const nodeId = normalizeNodeId(node && node.id);
        if (!isSelectableNodeId(nodeId)) continue;
        nodeById.set(nodeId, node);
      }}

      const orderedNodeIds = [];
      const seenNodeIds = new Set();
      const pushNodeId = (nodeId) => {{
        const cleanNodeId = normalizeNodeId(nodeId);
        if (!isSelectableNodeId(cleanNodeId) || seenNodeIds.has(cleanNodeId)) return;
        seenNodeIds.add(cleanNodeId);
        orderedNodeIds.push(cleanNodeId);
      }};

      for (const node of nodes) {{
        pushNodeId(node && node.id);
      }}
      if (typeof favoriteNodeIds !== "undefined" && favoriteNodeIds && typeof favoriteNodeIds.forEach === "function") {{
        favoriteNodeIds.forEach((nodeId) => {{
          pushNodeId(nodeId);
        }});
      }}
      if (typeof nodeNotesById !== "undefined" && nodeNotesById && typeof nodeNotesById.forEach === "function") {{
        nodeNotesById.forEach((_entry, nodeId) => {{
          pushNodeId(nodeId);
        }});
      }}
      pushNodeId(selectedNodeId || "");

      const maxRows = Math.max(1, Number(limit) || 250);
      const results = [];
      for (const nodeId of orderedNodeIds) {{
        const node = nodeById.get(nodeId);
        const name = preferredNodeName(node) || nodeNameCache.get(nodeId) || `Node ${{nodeId}}`;
        if (!matchesIdOrNameQuery(nodeId, name, query)) continue;
        results.push({{
          nodeId,
          name: String(name || nodeId),
        }});
        if (results.length >= maxRows) break;
      }}
      return results;
    }}

    function renderSavedNodeSearchDropdown(state = latestState) {{
      const input = document.getElementById("saved-node-search-input");
      const dropdown = document.getElementById("saved-node-search-dropdown");
      if (!(input instanceof HTMLInputElement) || !(dropdown instanceof HTMLElement)) return;

      if (activeLayoutView !== "saved") {{
        dropdown.hidden = true;
        return;
      }}

      const hasFocus = document.activeElement === input || dropdown.contains(document.activeElement);
      if (!savedNodeSearchOpen || !hasFocus) {{
        dropdown.hidden = true;
        return;
      }}

      const query = normalizeSearchQuery(savedNodeSearchQuery);
      const rows = buildNodeSearchResults(state, query, 250);
      if (!rows.length) {{
        dropdown.innerHTML = '<div class="node-search-empty">No nodes match this search.</div>';
        dropdown.hidden = false;
        return;
      }}

      const selectedId = normalizeNodeId(selectedNodeId || "");
      dropdown.innerHTML = rows.map((row) => {{
        const selectedClass = row.nodeId === selectedId ? " selected-node" : "";
        return `<button type="button" class="node-search-item${{selectedClass}}" data-node-id="${{escAttr(row.nodeId)}}" role="option" aria-selected="${{row.nodeId === selectedId ? "true" : "false"}}"><span class="node-search-name">${{escAttr(row.name)}}</span><span class="node-search-id">${{escAttr(row.nodeId)}}</span></button>`;
      }}).join("");
      dropdown.hidden = false;
    }}

