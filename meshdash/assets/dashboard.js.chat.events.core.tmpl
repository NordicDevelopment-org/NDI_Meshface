    function nodeLabel(node) {{
      return node.long_name || node.short_name || node.id || "unknown";
    }}

    function preferredNodeName(node) {{
      if (!node || typeof node !== "object") return "";
      const longName = String(node.long_name || "").trim();
      if (longName) return longName;
      const shortName = String(node.short_name || "").trim();
      if (shortName) return shortName;
      return "";
    }}

    function markerStyle(isSelected) {{
      if (isSelected) {{
        return {{
          radius: 8,
          color: "#7a0f20",
          fillColor: "#ffd24a",
          fillOpacity: 0.95,
          weight: 2,
          bubblingMouseEvents: false
        }};
      }}
      return {{
        radius: 6,
        color: "#143d2a",
        fillColor: "#34c27f",
        fillOpacity: 0.85,
        weight: 1,
        bubblingMouseEvents: false
      }};
    }}

    function normalizeNodeId(nodeId) {{
      const raw = String(nodeId == null ? "" : nodeId).trim();
      if (!raw) return "";
      const lower = raw.toLowerCase();
      if (
        lower === "^all"
        || lower === "all"
        || lower === "broadcast"
        || lower === "!ffffffff"
        || lower === "ffffffff"
        || lower === "0xffffffff"
        || lower === "4294967295"
      ) return "^all";
      if (lower === "unknown") return "Unknown";
      if (lower === "n/a" || lower === "na") return "n/a";
      if (lower === "local") return "local";

      const hex = raw.startsWith("!") ? raw.slice(1) : raw;
      if (/^[0-9a-f]{8}$/i.test(hex)) {{
        return `!${{hex.toLowerCase()}}`;
      }}
      return raw;
    }}

    function isCanonicalNodeId(nodeId) {{
      return /^![0-9a-f]{{8}}$/.test(normalizeNodeId(nodeId));
    }}

    function isSelectableNodeId(nodeId) {{
      const normalized = normalizeNodeId(nodeId);
      return !!normalized && normalized !== "^all" && normalized !== "Unknown" && normalized !== "n/a";
    }}

    function parseNodeNum(value) {{
      const numeric = Number(value);
      if (!Number.isFinite(numeric) || numeric < 0) return null;
      return Math.trunc(numeric);
    }}

    function findNodeIdByNum(nodeNum, state = latestState) {{
      const targetNum = parseNodeNum(nodeNum);
      if (!Number.isInteger(targetNum) || targetNum < 0) return "";
      const safeState = (state && typeof state === "object") ? state : {{}};
      const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
      for (const node of nodes) {{
        const candidateNum = parseNodeNum(node && node.num);
        if (candidateNum !== targetNum) continue;
        const nodeId = normalizeNodeId(node && node.id);
        if (isCanonicalNodeId(nodeId)) {{
          return nodeId;
        }}
      }}
      return "";
    }}

    function nodeNumFromMapping(value) {{
      if (!value || typeof value !== "object") return null;
      for (const key of ["my_node_num", "myNodeNum", "node_num", "nodeNum", "num"]) {{
        const parsed = parseNodeNum(value[key]);
        if (Number.isInteger(parsed) && parsed >= 0) {{
          return parsed;
        }}
      }}
      return null;
    }}

    function resolveLocalNodeId(state = latestState) {{
      const safeState = (state && typeof state === "object") ? state : {{}};
      const direct = normalizeNodeId(safeState.local_node_id || safeState.localNodeId || "");
      if (isCanonicalNodeId(direct)) {{
        return direct;
      }}

      const infoNum = nodeNumFromMapping(safeState.my_info);
      if (Number.isInteger(infoNum) && infoNum >= 0) {{
        const fromInfo = findNodeIdByNum(infoNum, safeState);
        if (isCanonicalNodeId(fromInfo)) {{
          return fromInfo;
        }}
      }}

      const localStateNum = nodeNumFromMapping(safeState.local_state);
      if (Number.isInteger(localStateNum) && localStateNum >= 0) {{
        const fromLocal = findNodeIdByNum(localStateNum, safeState);
        if (isCanonicalNodeId(fromLocal)) {{
          return fromLocal;
        }}
      }}

      return isCanonicalNodeId(resolvedLocalNodeId) ? resolvedLocalNodeId : "";
    }}

    function resolveSavedViewNodeId(state = latestState) {{
      const explicitId = normalizeNodeId(selectedNodeId || "");
      if (isSelectableNodeId(explicitId)) {{
        return explicitId;
      }}
      const localId = normalizeNodeId(resolveLocalNodeId(state) || "");
      if (isSelectableNodeId(localId)) {{
        return localId;
      }}
      return "";
    }}

    function resolveSavedViewNodeName(state = latestState, nodeId = resolveSavedViewNodeId(state)) {{
      const clean = normalizeNodeId(nodeId || "");
      if (!isSelectableNodeId(clean)) {{
        return "";
      }}
      const safeState = (state && typeof state === "object") ? state : {{}};
      const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
      const node = nodes.find((entry) => normalizeNodeId(entry && entry.id) === clean) || null;
      const nodeName = preferredNodeName(node);
      if (nodeName) {{
        return nodeName;
      }}
      const localId = normalizeNodeId(resolveLocalNodeId(safeState) || "");
      if (clean === localId) {{
        const owner = localNodeUserFromState(safeState);
        const longName = String((owner && owner.long_name) || "").trim();
        const shortName = String((owner && owner.short_name) || "").trim();
        if (longName && shortName && shortName !== longName) {{
          return `${{longName}} (${{shortName}})`;
        }}
        if (longName) {{
          return longName;
        }}
        if (shortName) {{
          return shortName;
        }}
      }}
      return nodeNameCache.get(clean) || clean;
    }}

    function savedViewNodeFrom(nodes, state = latestState) {{
      const nodeId = resolveSavedViewNodeId(state);
      if (!isSelectableNodeId(nodeId)) {{
        return null;
      }}
      for (const node of (nodes || [])) {{
        if (normalizeNodeId(node && node.id) === nodeId) {{
          return node;
        }}
      }}
      return null;
    }}

    function isSelfNodeId(nodeId, state = latestState) {{
      const clean = normalizeNodeId(nodeId);
      if (!isCanonicalNodeId(clean)) return false;
      const selfId = resolveLocalNodeId(state);
      return isCanonicalNodeId(selfId) && clean === selfId;
    }}

    function pruneSelfFromManualDirectPeers(state = latestState) {{
      const selfId = resolveLocalNodeId(state);
      if (!isCanonicalNodeId(selfId) || !manualDirectPeerIds.has(selfId)) {{
        return false;
      }}
      manualDirectPeerIds.delete(selfId);
      persistManualDirectPeers();
      return true;
    }}

    function selfRadioProfileShortLabel(nodeId) {{
      const cleanId = String(nodeId || "").replace(/[^A-Za-z0-9]/g, "");
      if (cleanId) return cleanId.slice(-4).toLowerCase();
      return "na";
    }}

    function renderSelfRadioPill(state = latestState) {{
      const pill = document.getElementById("self-radio-pill");
      const hasPill = pill instanceof HTMLElement;
      const profile = document.getElementById("self-radio-profile");
      const profileShort = document.getElementById("self-radio-profile-short");
      const copyBtn = document.getElementById("self-radio-copy-id-btn");
      const setProfile = (shortText, titleText) => {{
        if (profileShort instanceof HTMLElement) {{
          profileShort.textContent = String(shortText || "na");
        }}
        if (profile instanceof HTMLElement) {{
          profile.title = String(titleText || "Connected local radio: unavailable");
          profile.setAttribute("aria-label", profile.title);
        }}
      }};
      const setProfileFullId = (nodeId) => {{
        const cleanId = normalizeNodeId(nodeId || "");
        const hasFullId = isCanonicalNodeId(cleanId);
        if (profile instanceof HTMLElement) {{
          if (hasFullId) {{
            profile.dataset.fullRadioId = cleanId;
          }} else {{
            delete profile.dataset.fullRadioId;
          }}
        }}
        if (copyBtn instanceof HTMLButtonElement) {{
          copyBtn.disabled = !hasFullId;
          copyBtn.title = hasFullId
            ? `Copy ${{cleanId}} to clipboard`
            : "Full radio ID unavailable";
        }}
      }};
      const setProfileFreshness = (status, lastSeenUnix = null) => {{
        const key = normalizeFreshnessKey(status);
        if (profile instanceof HTMLElement) {{
          applyFreshnessClass(profile, key);
          const lastSeen = Number(lastSeenUnix);
          if (Number.isFinite(lastSeen) && lastSeen > 0) {{
            profile.dataset.lastSeenUnix = String(Math.trunc(lastSeen));
          }} else {{
            delete profile.dataset.lastSeenUnix;
          }}
        }}
        if (hasPill) {{
          applyFreshnessClass(pill, key);
        }}
      }};
      const freshnessLabel = (status) => {{
        const key = normalizeFreshnessKey(status);
        if (key === "online") return "Online";
        if (key === "warn") return "Aging";
        if (key === "stale") return "Stale";
        return "Unknown";
      }};

      const safeState = (state && typeof state === "object") ? state : {{}};
      const selfId = resolveLocalNodeId(safeState);
      if (!isCanonicalNodeId(selfId)) {{
        if (hasPill) {{
          pill.textContent = "n/a";
          pill.title = "Connected local radio: unavailable";
        }}
        setProfile("na", "Connected local radio: unavailable");
        setProfileFullId("");
        setProfileFreshness("unknown");
        syncConsoleCommandInputState(safeState);
        return;
      }}

      const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
      const selfNode = nodes.find((node) => normalizeNodeId(node && node.id) === selfId) || null;
      const historyCapsById = new Map(
        Object.entries((safeState.history_caps && typeof safeState.history_caps === "object") ? safeState.history_caps : {{}})
          .map(([rawNodeId, caps]) => [normalizeNodeId(rawNodeId), caps])
          .filter(([nodeId, caps]) => isSelectableNodeId(nodeId) && caps && typeof caps === "object")
      );
      const caps = historyCapsById.get(selfId) || null;
      const traffic = (safeState.traffic && typeof safeState.traffic === "object") ? safeState.traffic : {{}};
      const chatMessages = Array.isArray(traffic.recent_chat) ? traffic.recent_chat : [];
      const latestChatTouchByNode = mapLatestChatTouchInfo(chatMessages);
      const chatTouch = latestChatTouchByNode.get(selfId) || null;
      const nowUnix = Math.floor(Date.now() / 1000);
      const lastSeenUnix = computeNodeFreshnessUnix(selfNode, caps, chatTouch);
      const status = normalizeFreshnessKey(freshnessStatus(lastSeenUnix, nowUnix));
      setProfileFullId(selfId);
      const statusDetail = Number.isFinite(lastSeenUnix)
        ? `${{freshnessLabel(status)}} (seen ${{savedDetailAge(lastSeenUnix, nowUnix)}})`
        : freshnessLabel(status);
      const selfName = preferredNodeName(selfNode) || nodeNameCache.get(selfId) || "";
      if (selfName) {{
        const profileTitle = `Connected local radio: ${{selfName}} (${{selfId}}) • Status: ${{statusDetail}}`;
        if (hasPill) {{
          pill.textContent = `${{selfName}} (${{selfId}})`;
          pill.title = profileTitle;
        }}
        setProfile(
          selfRadioProfileShortLabel(selfId),
          profileTitle
        );
      }} else {{
        const profileTitle = `Connected local radio: ${{selfId}} • Status: ${{statusDetail}}`;
        if (hasPill) {{
          pill.textContent = `${{selfId}}`;
          pill.title = profileTitle;
        }}
        setProfile(
          selfRadioProfileShortLabel(selfId),
          profileTitle
        );
      }}
      setProfileFreshness(status, lastSeenUnix);
      syncConsoleCommandInputState(safeState);
    }}

    function normalizeSearchQuery(value) {{
      return String(value == null ? "" : value).trim().toLowerCase();
    }}

    function matchesIdOrNameQuery(nodeId, nodeName, query) {{
      if (!query) return true;
      const idKey = normalizeSearchQuery(nodeId);
      const nameKey = normalizeSearchQuery(nodeName);
      return idKey.includes(query) || nameKey.includes(query);
    }}

    function closeSavedNodeSearchDropdown() {{
      if (savedNodeSearchBlurTimer !== null) {{
        clearTimeout(savedNodeSearchBlurTimer);
        savedNodeSearchBlurTimer = null;
      }}
      savedNodeSearchOpen = false;
      const dropdown = document.getElementById("saved-node-search-dropdown");
      if (dropdown instanceof HTMLElement) {{
        dropdown.hidden = true;
      }}
    }}

    function closeFavoriteMenuNodeSearchDropdown() {{
      if (favoriteMenuNodeSearchBlurTimer !== null) {{
        clearTimeout(favoriteMenuNodeSearchBlurTimer);
        favoriteMenuNodeSearchBlurTimer = null;
      }}
      favoriteMenuNodeSearchOpen = false;
      const dropdown = document.getElementById("favorite-menu-node-search-dropdown");
      if (dropdown instanceof HTMLElement) {{
        dropdown.hidden = true;
      }}
    }}

    function buildNodeSearchResults(state, query, limit = 250) {{
      const safeState = state && typeof state === "object" ? state : {{}};
      const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
      const results = [];
      for (const node of nodes) {{
        const nodeId = normalizeNodeId(node && node.id);
        if (!isSelectableNodeId(nodeId)) continue;
        const name = nodeLabel(node);
        if (!matchesIdOrNameQuery(nodeId, name, query)) continue;
        results.push({{
          nodeId,
          name: String(name || nodeId),
        }});
        if (results.length >= Math.max(1, Number(limit) || 250)) break;
      }}
      return results;
    }}

    function renderSavedNodeSearchDropdown(state = latestState) {{
      const input = document.getElementById("saved-node-search-input");
      const dropdown = document.getElementById("saved-node-search-dropdown");
      if (!(input instanceof HTMLInputElement) || !(dropdown instanceof HTMLElement)) return;

      if (activeLayoutView !== "saved") {{
        dropdown.hidden = true;
        return;
      }}

      const hasFocus = document.activeElement === input || dropdown.contains(document.activeElement);
      if (!savedNodeSearchOpen || !hasFocus) {{
        dropdown.hidden = true;
        return;
      }}

      const query = normalizeSearchQuery(savedNodeSearchQuery);
      const rows = buildNodeSearchResults(state, query, 250);
      if (!rows.length) {{
        dropdown.innerHTML = '<div class="node-search-empty">No nodes match this search.</div>';
        dropdown.hidden = false;
        return;
      }}

      const selectedId = normalizeNodeId(selectedNodeId || "");
      dropdown.innerHTML = rows.map((row) => {{
        const selectedClass = row.nodeId === selectedId ? " selected-node" : "";
        return `<button type="button" class="node-search-item${{selectedClass}}" data-node-id="${{escAttr(row.nodeId)}}" role="option" aria-selected="${{row.nodeId === selectedId ? "true" : "false"}}"><span class="node-search-name">${{escAttr(row.name)}}</span><span class="node-search-id">${{escAttr(row.nodeId)}}</span></button>`;
      }}).join("");
      dropdown.hidden = false;
    }}

    function renderFavoriteMenuNodeSearchDropdown(state = latestState) {{
      const input = document.getElementById("favorite-menu-node-search-input");
      const dropdown = document.getElementById("favorite-menu-node-search-dropdown");
      const selectedHost = document.getElementById("favorite-menu-selected-list");
      if (
        !(input instanceof HTMLInputElement)
        || !(dropdown instanceof HTMLElement)
        || !(selectedHost instanceof HTMLElement)
      ) {{
        return;
      }}

      if (!favoriteMenuOpen) {{
        dropdown.hidden = true;
        return;
      }}

      const hasFocus = document.activeElement === input || dropdown.contains(document.activeElement);
      if (!favoriteMenuNodeSearchOpen || !hasFocus) {{
        dropdown.hidden = true;
        return;
      }}

      const query = normalizeSearchQuery(favoriteMenuNodeSearchQuery);
      const rows = buildNodeSearchResults(state, query, 250);
      if (!rows.length) {{
        dropdown.innerHTML = '<div class="node-search-empty">No nodes match this search.</div>';
        dropdown.hidden = false;
        return;
      }}

      const selectedId = normalizeNodeId(selectedNodeId || "");
      dropdown.innerHTML = rows.map((row) => {{
        const selectedClass = row.nodeId === selectedId ? " selected-node" : "";
        return `<button type="button" class="node-search-item${{selectedClass}}" data-node-id="${{escAttr(row.nodeId)}}" role="option" aria-selected="${{row.nodeId === selectedId ? "true" : "false"}}"><span class="node-search-name">${{escAttr(row.name)}}</span><span class="node-search-id">${{escAttr(row.nodeId)}}</span></button>`;
      }}).join("");
      dropdown.hidden = false;
    }}

    function loadFavoriteNodes() {{
      favoriteNodeIds.clear();
      try {{
        const raw = window.localStorage.getItem(favoritesStorageKey);
        if (!raw) return;
        const parsed = JSON.parse(raw);
        if (!Array.isArray(parsed)) return;
        for (const entry of parsed) {{
          const nodeId = normalizeNodeId(entry);
          if (isSelectableNodeId(nodeId)) {{
            favoriteNodeIds.add(nodeId);
          }}
        }}
      }} catch (_err) {{
      }}
    }}

    function persistFavoriteNodes() {{
      try {{
        const ids = Array.from(favoriteNodeIds).slice(0, 2000);
        window.localStorage.setItem(favoritesStorageKey, JSON.stringify(ids));
      }} catch (_err) {{
      }}
    }}

    function isFavoriteNode(nodeId) {{
      const normalized = normalizeNodeId(nodeId);
      return isSelectableNodeId(normalized) && favoriteNodeIds.has(normalized);
    }}

    function favoriteToggleButtonHtml(nodeId, extraClass = "") {{
      const normalized = normalizeNodeId(nodeId);
      if (!isSelectableNodeId(normalized)) return "";
      const active = favoriteNodeIds.has(normalized);
      const title = active ? "Remove from saved nodes" : "Save node";
      return `<button type="button" class="favorite-toggle-btn ${{extraClass}}${{active ? " active" : ""}}" data-node-id="${{escAttr(normalized)}}" title="${{title}}" aria-label="${{title}}" aria-pressed="${{active ? "true" : "false"}}"><span class="favorite-toggle-icon">${{active ? "★" : "☆"}}</span></button>`;
    }}

    function renderSavedRailStatus() {{
      const count = Math.max(0, favoriteNodeIds.size);
      const explicitSelectedId = isSelectableNodeId(selectedNodeId) ? normalizeNodeId(selectedNodeId) : "";
      const selectedId = activeLayoutView === "saved"
        ? resolveSavedViewNodeId(latestState)
        : explicitSelectedId;
      const usingLocalFallback = activeLayoutView === "saved" && !explicitSelectedId && !!selectedId;
      const selectedName = selectedId
        ? (
            usingLocalFallback
              ? (resolveSavedViewNodeName(latestState, selectedId) || selectedId)
              : (resolveSelectedNodeName() || selectedId)
          )
        : "";
      const btn = document.querySelector('.teams-rail .rail-btn[data-view="saved"]');
      if (btn instanceof HTMLButtonElement) {{
        if (!btn.dataset.baseTitle) {{
          btn.dataset.baseTitle = btn.getAttribute("title") || "Node details and saved nodes";
        }}
        btn.textContent = "Node";
        const baseTitle = btn.dataset.baseTitle || "Node details and saved nodes";
        if (selectedId) {{
          btn.title = usingLocalFallback
            ? `${{baseTitle}}. Showing local node: ${{selectedName}}.`
            : `${{baseTitle}}. Selected: ${{selectedName}}.`;
        }} else {{
          btn.title = count > 0
            ? `${{baseTitle}}. ${{count}} saved node${{count === 1 ? "" : "s"}}.`
            : `${{baseTitle}}. No saved nodes yet.`;
        }}
        btn.setAttribute("aria-label", btn.title);
      }}

      const favMenuBtn = document.getElementById("favorite-menu-toggle-btn");
      if (favMenuBtn instanceof HTMLButtonElement) {{
        favMenuBtn.classList.toggle("has-saved", count > 0);
        favMenuBtn.classList.toggle("has-selected", !!selectedId);
        const title = selectedId
          ? (
              usingLocalFallback
                ? `Showing local node: ${{selectedName}}. Open node menu.`
                : `Selected node: ${{selectedName}}. Open node menu.`
            )
          : (count > 0
            ? `${{count}} saved node${{count === 1 ? "" : "s"}}. Open node menu.`
            : "No node selected. Open node menu.");
        favMenuBtn.title = title;
        favMenuBtn.setAttribute("aria-label", title);
      }}
    }}

    function renderStarredNodeSelect(state) {{
      const selectedList = document.getElementById("favorite-menu-selected-list");
      const list = document.getElementById("favorite-menu-saved-list");
      if (!(list instanceof HTMLElement)) return;

      const safeState = (state && typeof state === "object") ? state : {{}};
      const nodes = Array.isArray(safeState.nodes) ? safeState.nodes : [];
      const nodesById = new Map(nodes.map((node) => [normalizeNodeId(node.id || ""), node]));
      const resolveEntryName = (nodeId) => {{
        const normalized = normalizeNodeId(nodeId);
        const node = nodesById.get(normalized);
        return preferredNodeName(node) || nodeNameCache.get(normalized) || `Node ${{normalized}}`;
      }};
      const entries = Array.from(favoriteNodeIds)
        .map((nodeId) => {{
          const name = resolveEntryName(nodeId);
          return {{ id: nodeId, name }};
        }})
        .sort((a, b) => {{
          const nameDiff = String(a.name || "").localeCompare(String(b.name || ""));
          if (nameDiff !== 0) return nameDiff;
          return String(a.id || "").localeCompare(String(b.id || ""));
        }});
      const selectedNodeValue = isSelectableNodeId(selectedNodeId) ? normalizeNodeId(selectedNodeId) : "";
      const showSelectedTopRow = !!selectedNodeValue;

      if (selectedList instanceof HTMLElement) {{
        if (showSelectedTopRow) {{
          closeFavoriteMenuNodeSearchDropdown();
          const selectedName = resolveEntryName(selectedNodeValue);
          const title = `Selected: ${{selectedName}} (${{selectedNodeValue}}). Click to clear selection.`;
          selectedList.innerHTML = `<button type="button" role="listitem" class="favorite-menu-saved-item favorite-menu-selected-item active" data-node-id="${{escAttr(selectedNodeValue)}}" title="${{escAttr(title)}}" aria-label="${{escAttr(title)}}">
            <span class="favorite-menu-saved-main">
              <span class="favorite-menu-selected-prefix">Selected</span>
              <span class="favorite-menu-saved-name">${{escAttr(selectedName)}}</span>
            </span>
            <span class="favorite-menu-saved-id">${{escAttr(selectedNodeValue)}}</span>
          </button>`;
        }} else {{
          let searchInput = document.getElementById("favorite-menu-node-search-input");
          let searchDropdown = document.getElementById("favorite-menu-node-search-dropdown");
          const hasSearchControls = (
            searchInput instanceof HTMLInputElement
            && searchDropdown instanceof HTMLElement
            && selectedList.contains(searchInput)
            && selectedList.contains(searchDropdown)
          );
          if (!hasSearchControls) {{
            selectedList.innerHTML = `<div class="favorite-menu-node-search-wrap">
              <input
                id="favorite-menu-node-search-input"
                class="list-search-input"
                type="search"
                placeholder="Search by ID or name"
                autocomplete="off"
              />
              <div id="favorite-menu-node-search-dropdown" class="node-search-dropdown favorite-menu-node-search-dropdown" hidden></div>
            </div>`;
            searchInput = document.getElementById("favorite-menu-node-search-input");
            searchDropdown = document.getElementById("favorite-menu-node-search-dropdown");
          }}
          if (searchInput instanceof HTMLInputElement) {{
            searchInput.value = favoriteMenuNodeSearchQuery;
          }}
          bindFavoriteMenuNodeSearchControls();
          renderFavoriteMenuNodeSearchDropdown(safeState);
        }}
      }}
      if (!entries.length) {{
        list.innerHTML = '<div class="favorite-menu-saved-empty">No saved nodes yet.</div>';
        return;
      }}
      list.innerHTML = entries.map((entry) => {{
        const title = `${{entry.name}} (${{entry.id}})`;
        return `<button type="button" role="listitem" class="favorite-menu-saved-item" data-node-id="${{escAttr(entry.id)}}" title="${{escAttr(title)}}" aria-label="${{escAttr(title)}}">
          <span class="favorite-menu-saved-name">${{escAttr(entry.name)}}</span>
          <span class="favorite-menu-saved-id">${{escAttr(entry.id)}}</span>
        </button>`;
      }}).join("");
    }}

    function refreshFavoriteToggleButtons() {{
      for (const btn of document.querySelectorAll(".favorite-toggle-btn")) {{
        if (!(btn instanceof HTMLButtonElement)) continue;
        const nodeId = normalizeNodeId(btn.dataset.nodeId || "");
        const active = isFavoriteNode(nodeId);
        btn.classList.toggle("active", active);
        btn.setAttribute("aria-pressed", active ? "true" : "false");
        const title = active ? "Remove from saved nodes" : "Save node";
        btn.title = title;
        btn.setAttribute("aria-label", title);
        const icon = btn.querySelector(".favorite-toggle-icon");
        if (icon) {{
          icon.textContent = active ? "★" : "☆";
        }}
        const cell = btn.closest && btn.closest("td");
        if (cell instanceof HTMLElement) {{
          cell.setAttribute("data-sort", active ? "1" : "0");
        }}
      }}
