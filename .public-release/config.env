# Default publish target for curated public releases.
# Override any of these with CLI flags when needed.

PUBLIC_RELEASE_REMOTE=meshyface
PUBLIC_RELEASE_BRANCH=release-candidate
PUBLIC_RELEASE_PROFILE=core-ui

# Optional drift-guard defaults for release/public-v0 preflight:
# PUBLIC_DRIFT_BRANCH=release/public-v0
# PUBLIC_DRIFT_BASE_BRANCH=main
# PUBLIC_DRIFT_ALLOWLIST=.public-release/allowlists/public-v0-drift.allowlist
